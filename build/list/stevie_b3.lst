0118      A016     parm9             equ  core1.top + 22  ; Function parameter 9
0119      A018     outparm1          equ  core1.top + 24  ; Function output parameter 1
0120      A01A     outparm2          equ  core1.top + 26  ; Function output parameter 2
0121      A01C     outparm3          equ  core1.top + 28  ; Function output parameter 3
0122      A01E     outparm4          equ  core1.top + 30  ; Function output parameter 4
