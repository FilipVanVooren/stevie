0077 6D65   20                   byte 32               ; / i  p3LSB = Padding character
0078               
0079 6D66 06A0  32         bl    @trimnum              ; Trim number to the left
     6D68 2AAE     
0080 6D6A A102                   data rambuf+2,ram.msg1+6,32
     6D6C F756     
     6D6E 0020     
0081               
