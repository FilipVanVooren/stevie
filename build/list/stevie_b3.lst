0025 363E 0649  14         dect  stack
0026 3640 C645  30         mov   tmp1,*stack           ; Push tmp1
0027 3642 0649  14         dect  stack
0028 3644 C646  30         mov   tmp2,*stack           ; Push tmp2
0029                       ;------------------------------------------------------
0030                       ; Get slot entry
0031                       ;------------------------------------------------------
0032 3646 C120  34         mov   @parm1,tmp0           ; Line number in editor buffer
     3648 A006     
0033               
0034 364A 06A0  32         bl    @_idx.samspage.get    ; Get SAMS page with index slot
     364C 3304     
0035                                                   ; \ i  tmp0     = Line number
0036                                                   ; / o  outparm1 = Slot offset in SAMS page
0037               
0038 364E C120  34         mov   @outparm1,tmp0        ; \ Get slot entry
     3650 A018     
0039 3652 C164  34         mov   @idx.top(tmp0),tmp1   ; /
     3654 B000     
0040               
0041 3656 130C  14         jeq   idx.pointer.get.parm.null
0042                                                   ; Skip if index slot empty
0043                       ;------------------------------------------------------
0044                       ; Calculate MSB (SAMS page)
0045                       ;------------------------------------------------------
0046 3658 C185  18         mov   tmp1,tmp2             ; \
0047 365A 0986  32         srl   tmp2,8                ; / Right align SAMS page
0048                       ;------------------------------------------------------
0049                       ; Calculate LSB (pointer address)
0050                       ;------------------------------------------------------
0051 365C 0245  22         andi  tmp1,>00ff            ; Get rid of MSB (SAMS page)
     365E 00FF     
0052 3660 0A45  24         sla   tmp1,4                ; Multiply with 16
0053 3662 0225  22         ai    tmp1,edb.top          ; Add editor buffer base address
     3664 C000     
0054                       ;------------------------------------------------------
0055                       ; Return parameters
0056                       ;------------------------------------------------------
0057               idx.pointer.get.parm:
0058 3666 C805  38         mov   tmp1,@outparm1        ; Index slot -> Pointer
     3668 A018     
0059 366A C806  38         mov   tmp2,@outparm2        ; Index slot -> SAMS page
     366C A01A     
0060 366E 1004  14         jmp   idx.pointer.get.exit
0061                       ;------------------------------------------------------
0062                       ; Special handling for "null"-pointer
0063                       ;------------------------------------------------------
0064               idx.pointer.get.parm.null:
0065 3670 04E0  34         clr   @outparm1
     3672 A018     
0066 3674 04E0  34         clr   @outparm2
     3676 A01A     
