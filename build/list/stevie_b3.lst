0039 3710 0A17  18         sla   tmp3,1                ; adjust to slot size
0040 3712 0507  14         neg   tmp3                  ; tmp3 = -tmp3
0041 3714 A1C4  18         a     tmp0,tmp3             ; tmp3 = tmp3 + tmp0
0042 3716 0287  22         ci    tmp3,idx.top - 4      ; Address before top of index ?
     3718 AFFC     
0043 371A 1504  14         jgt   _idx.entry.insert.reorg.loop
0044                                                   ; No, jump to loop start
0045                       ;------------------------------------------------------
