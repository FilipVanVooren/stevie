0247                       copy  "rom_fg99.asm"             ; FinalGROM 99 support
     **** ****     > rom_fg99.asm
0001               * FILE......: rom_fg99.asm
0002               * Purpose...: FinalGROM 99 reload code
0003               
0004               *//////////////////////////////////////////////////////////////
0005               *               FinalGROM 99 reload cartridge code
0006               *//////////////////////////////////////////////////////////////
0007               
0008               ***************************************************************
0009               * fg99 - Load cartridge from flash card into FinalGROM99
0010               ***************************************************************
0011               *  bl   @fg99
0012               *       data p0
0013               *
0014               *  p0 = Pointer to FG99 cartridge table entry
0015               *--------------------------------------------------------------
0016               *  bl   @xfg99
0017               *
0018               *  tmp0 = Pointer to FG99 cartridge table entry
0019               *--------------------------------------------------------------
0020               * Remark
0021               * https://github.com/endlos99/finalgrom99/blob/master/lib/reload_example.a99
0022               *
0023               * NOTE: You must use shortened 8.3 upper-case filenames here.
0024               *       For example, to reload "mylongfile.bin", use "MYLONG~1.BIN".
0025               *       If there are multiple files with prefix "MYLONG" in the
0026               *       folder, you may have to replace the suffix "~1" by "~2",
0027               *       "~3", ... to select the correct file.
0028               *
0029               *       PAD filename with >00 bytes so that it's always 8 bytes.
0030               *       Code is expected to run from RAM, not from the cartridge space.
0031               ********|*****|*********************|**************************
0032 2ED8 C13B  46 fg99    mov   *r11+,tmp0            ; Get p0
0033               *--------------------------------------------------------------
0034               * Register version
0035               *--------------------------------------------------------------
0036               xfg99:
0037 2EDA 0649  22         dect  stack
0038 2EDC C64B  38         mov   r11,*stack            ; Save return address
0039 2EDE 0649  22         dect  stack
0040 2EE0 C644  38         mov   tmp0,*stack           ; Push tmp0
0041               *--------------------------------------------------------------
0042               * (1) Send prefix and filename to FinalGROM
0043               *--------------------------------------------------------------
0044 2EE2 C004  30         mov   tmp0,r0               ; Get Pointer
0045 2EE4 0202  24         li    r2,20                 ; Len = prefix (8) + fname (8) + suffix (4)
     2EE6 0014     
0046               fg99.send.loop:
0047 2EE8 04E0  34         clr   @>6000                ; Signal new byte
     2EEA 6000     
0048 2EEC 0201  24         li    r1,>0038              ; >7000 >> 9
     2EEE 0038     
0049 2EF0 D070  44         movb  *r0+,r1
0050 2EF2 0B71  38         src   r1,7                  ; >7000 + (byte << 1)
0051               
0052 2EF4 04D1  30         clr   *r1                   ; Send byte
0053 2EF6 0602  22         dec   r2                    ; Prepare for next iteration
0054 2EF8 16F7  14         jne   fg99.send.loop        ; Next byte
0055               
0056 2EFA 04E0  34         clr   @>6000                ; Done sending filename
     2EFC 6000     
0057 2EFE 0B80  40         src   r0,8                  ; Burn at least 21 cycles
0058               *--------------------------------------------------------------
0059               * (3) Wait for image to be loaded by FinalGROM
0060               *--------------------------------------------------------------
0061               fg99.wait:
0062 2F00 0200  24         li    r0,>6000              ; check >6000->6200
     2F02 6000     
0063 2F04 0202  24         li    r2,>100
     2F06 0100     
0064 2F08 C070  46 !       mov   *r0+, r1
0065 2F0A 1603  14         jne   fg99.exit             ; Done loading, exit
0066 2F0C 0602  22         dec   r2
0067 2F0E 16FC  14         jne   -!
0068 2F10 10F7  14         jmp   fg99.wait
0069               *--------------------------------------------------------------
0070               * (4) Image finished loading
0071               *--------------------------------------------------------------
0072               fg99.exit:
0073 2F12 C139  46         mov   *stack+,tmp0          ; Pop tmp0
0074 2F14 C2F9  46         mov   *stack+,r11           ; Pop R11
0075 2F16 045B  24         b     *r11                  ; Return to caller
                   < runlib.asm
