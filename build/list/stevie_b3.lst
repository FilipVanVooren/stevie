     **** ****     > timers_alloc.asm
0001               * FILE......: timer_alloc.asm
0002               * Purpose...: Timers / Timer allocation
0003               
0004               
0005               ***************************************************************
0006               * MKSLOT - Allocate timer slot(s)
0007               ***************************************************************
0008               *  BL    @MKSLOT
0009               *  BYTE  P0HB,P0LB
0010               *  DATA  P1
0011               *  ....
0012               *  DATA  EOL                        ; End-of-list
0013               *--------------------------------------------------------------
0014               *  P0 = Slot number, target count
0015               *  P1 = Subroutine to call via BL @xxxx if slot is fired
0016               ********|*****|*********************|**************************
0017 2FE0 C13B  46 mkslot  mov   *r11+,tmp0
0018 2FE2 C17B  46         mov   *r11+,tmp1
0019               *--------------------------------------------------------------
0020               *  Calculate address of slot
0021               *--------------------------------------------------------------
0022 2FE4 C184  30         mov   tmp0,tmp2
0023 2FE6 0966  36         srl   tmp2,6                ; Right align & TMP2 = TMP2 * 4
0024 2FE8 A1A0  38         a     @wtitab,tmp2          ; Add table base
     2FEA 832C     
0025               *--------------------------------------------------------------
0026               *  Add slot to table
0027               *--------------------------------------------------------------
0028 2FEC CD85  46         mov   tmp1,*tmp2+           ; Store address of subroutine
0029 2FEE 0A84  40         sla   tmp0,8                ; Get rid of slot number
0030 2FF0 C584  38         mov   tmp0,*tmp2            ; Store target count and reset tick count
0031               *--------------------------------------------------------------
0032               *  Check for end of list
0033               *--------------------------------------------------------------
0034 2FF2 881B  46         c     *r11,@w$ffff          ; End of list ?
     2FF4 2022     
0035 2FF6 1301  14         jeq   mkslo1                ; Yes, exit
0036 2FF8 10F3  14         jmp   mkslot                ; Process next entry
0037               *--------------------------------------------------------------
0038               *  Exit
0039               *--------------------------------------------------------------
0040 2FFA 05CB  22 mkslo1  inct  r11
0041 2FFC 045B  24         b     *r11                  ; Exit
0042               
0043               
0044               ***************************************************************
0045               * CLSLOT - Clear single timer slot
0046               ***************************************************************
0047               *  BL    @CLSLOT
0048               *  DATA  P0
0049               *--------------------------------------------------------------
0050               *  P0 = Slot number
0051               ********|*****|*********************|**************************
0052 2FFE C13B  46 clslot  mov   *r11+,tmp0
0053 3000 0A24  28 xlslot  sla   tmp0,2                ; TMP0 = TMP0*4
0054 3002 A120  38         a     @wtitab,tmp0          ; Add table base
     3004 832C     
0055 3006 04F4  38         clr   *tmp0+                ; Clear 1st word of slot
0056 3008 04D4  30         clr   *tmp0                 ; Clear 2nd word of slot
0057 300A 045B  24         b     *r11                  ; Exit
0058               
0059               
0060               ***************************************************************
0061               * RSSLOT - Reset single timer slot loop counter
0062               ***************************************************************
0063               *  BL    @RSSLOT
0064               *  DATA  P0
0065               *--------------------------------------------------------------
0066               *  P0 = Slot number
0067               ********|*****|*********************|**************************
0068 300C C13B  46 rsslot  mov   *r11+,tmp0
0069 300E 0A24  28         sla   tmp0,2                ; TMP0 = TMP0*4
0070 3010 A120  38         a     @wtitab,tmp0          ; Add table base
     3012 832C     
0071 3014 05C4  22         inct  tmp0                  ; Skip 1st word of slot
0072 3016 C154  38         mov   *tmp0,tmp1
0073 3018 0245  30         andi  tmp1,>ff00            ; Clear LSB (loop counter)
     301A FF00     
0074 301C C505  38         mov   tmp1,*tmp0
0075 301E 045B  24         b     *r11                  ; Exit
