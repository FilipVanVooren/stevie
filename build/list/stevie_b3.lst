0128                                                   ; / i  tmp2 = Num. of index entries to move
0129               
0130 376A 06A0  32         bl    @_idx.sams.mapcolumn.off
     376C 32CA     
0131                                                   ; Restore memory window layout
0132               
0133 376E 1008  14         jmp   idx.entry.insert.exit
