     **** ****     > edb.line.mappage.asm
0001               * FILE......: edb.line.mappage.asm
0002               * Purpose...: Editor buffer SAMS setup
0003               
0004               
0005               ***************************************************************
0006               * edb.line.mappage
0007               * Activate editor buffer SAMS page for line
0008               ***************************************************************
0009               * bl  @edb.line.mappage
0010               *
0011               * tmp0 = Line number in editor buffer (base 1)
0012               *--------------------------------------------------------------
0013               * OUTPUT
0014               * outparm1 = Pointer to line in editor buffer
0015               * outparm2 = SAMS page
0016               *--------------------------------------------------------------
0017               * Register usage
0018               * tmp0,tmp1
0019               ***************************************************************
0020               edb.line.mappage:
0021                       .pushregs 1                 ; Push registers and return address on stack
     **** ****     > PUSHREGS
0001 378C 0229  22         ai    stack,-(1 * 2 + 4)    ; Make room on stack for registers
     378E FFFA     
0012 3790 CE45  34         mov   tmp1,*stack+          ; Push tmp1
0015 3792 CE44  34         mov   tmp0,*stack+          ; Push tmp0
0017 3794 C64B  30         mov   r11,*stack            ; Push return address
0018 3796 0229  22         ai    stack,-(1 * 2 + 2)    ; Set stack pointer back to original position
     3798 FFFC     
                   < edb.line.mappage.asm
0022                       ;------------------------------------------------------
0023                       ; Assert
0024                       ;------------------------------------------------------
0025 379A 8804  34         c     tmp0,@edb.lines       ; Non-existing line?
     379C A504     
0026 379E 1204  14         jle   edb.line.mappage.lookup
0027                                                   ; All checks passed, continue
0028                                                   ;--------------------------
0029                                                   ; Assert failed
0030                                                   ;--------------------------
0031 37A0 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     37A2 FFCE     
0032 37A4 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     37A6 2026     
0033                       ;------------------------------------------------------
0034                       ; Lookup SAMS page for line in parm1
0035                       ;------------------------------------------------------
0036               edb.line.mappage.lookup:
0037 37A8 C804  38         mov   tmp0,@parm1           ; Set line number in editor buffer
     37AA A006     
0038               
0039 37AC 06A0  32         bl    @idx.pointer.get      ; Get pointer to line
     37AE 3636     
0040                                                   ; \ i  parm1    = Line number
0041                                                   ; | o  outparm1 = Pointer to line
0042                                                   ; / o  outparm2 = SAMS page
0043               
0044 37B0 C120  34         mov   @outparm2,tmp0        ; SAMS page
     37B2 A01A     
0045 37B4 C160  34         mov   @outparm1,tmp1        ; Pointer to line
     37B6 A018     
0046 37B8 130B  14         jeq   edb.line.mappage.exit ; Nothing to page-in if NULL pointer
0047                                                   ; (=empty line)
0048                       ;------------------------------------------------------
0049                       ; Determine if requested SAMS page is already active
0050                       ;------------------------------------------------------
0051 37BA 8120  34         c     @tv.sams.c000,tmp0    ; Compare with active page editor buffer
     37BC A208     
0052 37BE 1308  14         jeq   edb.line.mappage.exit ; Request page already active, so exit
0053                       ;------------------------------------------------------
0054                       ; Activate requested SAMS page
0055                       ;-----------------------------------------------------
0056 37C0 06A0  32         bl    @xsams.page.set       ; Switch SAMS memory page
     37C2 25D6     
0057                                                   ; \ i  tmp0 = SAMS page
0058                                                   ; / i  tmp1 = Memory address
0059               
0060 37C4 C820  54         mov   @outparm2,@tv.sams.c000
     37C6 A01A     
     37C8 A208     
0061                                                   ; Set page in shadow registers
0062               
0063 37CA C820  54         mov   @outparm2,@edb.sams.page
     37CC A01A     
     37CE A518     
0064                                                   ; Set current SAMS page
0065                       ;------------------------------------------------------
0066                       ; Exit
0067                       ;------------------------------------------------------
0068               edb.line.mappage.exit:
0069                       .popregs 1                  ; Pop registers and return to caller
