0146 32CE 0649  14         dect  stack
0147 32D0 C644  30         mov   tmp0,*stack           ; Push tmp0
0148 32D2 0649  14         dect  stack
0149 32D4 C645  30         mov   tmp1,*stack           ; Push tmp1
0150 32D6 0649  14         dect  stack
0151 32D8 C646  30         mov   tmp2,*stack           ; Push tmp2
0152 32DA 0649  14         dect  stack
