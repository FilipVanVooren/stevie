0038                       copy  "edb.hipage.alloc.asm"    ; Check/increase highest SAMS page
     **** ****     > edb.hipage.alloc.asm
0001               * FILE......: edb.hipage.alloc.asm
0002               * Purpose...: Editor buffer utilities
0003               
0004               
0005               ***************************************************************
0006               * edb.hipage.alloc
0007               * Check and increase highest SAMS page of editor buffer
0008               ***************************************************************
0009               *  bl   @edb.hipage.alloc
0010               *--------------------------------------------------------------
0011               * INPUT
0012               * @edb.next_free.ptr = Pointer to next free line
0013               *--------------------------------------------------------------
0014               * OUTPUT
0015               *--------------------------------------------------------------
0016               * Register usage
0017               * tmp0,tmp1
0018               ********|*****|*********************|**************************
0019               edb.hipage.alloc:
0020                       .pushregs 1                 ; Push registers and return address on stack
     **** ****     > PUSHREGS
0001 3846 0229  22         ai    stack,-(1 * 2 + 4)    ; Make room on stack for registers
     3848 FFFA     
0012 384A CE45  34         mov   tmp1,*stack+          ; Push tmp1
0015 384C CE44  34         mov   tmp0,*stack+          ; Push tmp0
0017 384E C64B  30         mov   r11,*stack            ; Push return address
0018 3850 0229  22         ai    stack,-(1 * 2 + 2)    ; Set stack pointer back to original position
     3852 FFFC     
                   < edb.hipage.alloc.asm
0021                       ;------------------------------------------------------
0022                       ; 1a. Check if highest SAMS page needs to be increased
0023                       ;------------------------------------------------------
0024               edb.hipage.alloc.check_setpage:
0025 3854 C120  34         mov   @edb.next_free.ptr,tmp0
     3856 A508     
0026                                                   ;--------------------------
0027                                                   ; Check for page overflow
0028                                                   ;--------------------------
0029 3858 0244  22         andi  tmp0,>0fff            ; Get rid of highest nibble
     385A 0FFF     
0030 385C 0224  22         ai    tmp0,82               ; Assume line of 80 chars (+2 bytes prefix)
     385E 0052     
0031 3860 0284  22         ci    tmp0,>1000 - 16       ; 4K boundary reached?
     3862 0FF0     
0032 3864 1105  14         jlt   edb.hipage.alloc.setpage
0033                                                   ; Not yet, don't increase SAMS page
0034                       ;------------------------------------------------------
0035                       ; 1b. Increase highest SAMS page (copy-on-write!)
0036                       ;------------------------------------------------------
0037 3866 05A0  34         inc   @edb.sams.hipage      ; Set highest SAMS page
     3868 A51C     
0038 386A C820  54         mov   @edb.top.ptr,@edb.next_free.ptr
     386C A500     
     386E A508     
0039                                                   ; Start at top of SAMS page again
0040                       ;------------------------------------------------------
0041                       ; 1c. Switch to SAMS page and exit
0042                       ;------------------------------------------------------
0043               edb.hipage.alloc.setpage:
0044 3870 C120  34         mov   @edb.sams.hipage,tmp0
     3872 A51C     
0045 3874 C160  34         mov   @edb.top.ptr,tmp1
     3876 A500     
0046 3878 06A0  32         bl    @xsams.page.set       ; Set SAMS page
     387A 25D6     
0047                                                   ; \ i  tmp0 = SAMS page number
0048                                                   ; / i  tmp1 = Memory address
0049               
0050 387C 1004  14         jmp   edb.hipage.alloc.exit
0051                       ;------------------------------------------------------
0052                       ; Check failed, crash CPU!
0053                       ;------------------------------------------------------
0054               edb.hipage.alloc.crash:
0055 387E C80B  38         mov   r11,@>ffce            ; \ Save caller address
     3880 FFCE     
0056 3882 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     3884 2026     
0057                       ;------------------------------------------------------
0058                       ; Exit
0059                       ;------------------------------------------------------
0060               edb.hipage.alloc.exit:
0061                       .popregs 1                  ; Pop registers and return to caller
     **** ****     > POPREGS
0011 3886 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 3888 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 388A C2F9  30         mov   *stack+,r11           ; Pop r11
0017 388C 045B  20         b     *r11                  ; Return
                   < edb.hipage.alloc.asm
