0030 354E A100                   data rambuf           ; | i p1  = Pointer to 5 byte string buffer
0031 3550 30                     byte 48               ; | i p2H = Offset for ASCII digit 0
0032 3551   20                   byte 32               ; / i p2L = Char for replacing leading 0's
0033               
0034 3552 0204  20         li    tmp0,uint16.unpacked
     3554 A02C     
0035 3556 04F4  30         clr   *tmp0+                ; Clear string 01
0036 3558 04F4  30         clr   *tmp0+                ; Clear string 23
0037 355A 04F4  30         clr   *tmp0+                ; Clear string 34
0038               
0039 355C 06A0  32         bl    @trimnum              ; Trim unsigned number string
     355E 2AAE     
0040 3560 A100                   data rambuf           ; \ i p0  = Pointer to 5 byte string buffer
0041 3562 A02C                   data uint16.unpacked  ; | i p1  = Pointer to output buffer
0042 3564 0020                   data 32               ; / i p2  = Padding char to match against
0043                       ;-------------------------------------------------------
0044                       ; Exit
0045                       ;-------------------------------------------------------
0046               tv.uint16.unpack.exit:
0047                       .popregs 0                  ; Pop registers and return to caller
     **** ****     > POPREGS
0014 3566 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 3568 C2F9  30         mov   *stack+,r11           ; Pop r11
