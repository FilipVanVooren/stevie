0131      A034     trmpvector        equ  core1.top + 52  ; Vector trampoline (if p1|tmp1 = >ffff)
0132      A036     core1.free1       equ  core1.top + 54  ; 54-99 **free**
0133      A064     timers            equ  core1.top + 100 ; Timers (80 bytes)
