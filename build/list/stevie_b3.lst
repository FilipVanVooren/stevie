0264               *//////////////////////////////////////////////////////////////
0265               *                    RUNLIB INITIALISATION
0266               *//////////////////////////////////////////////////////////////
0267               
0268               ***************************************************************
0269               *  RUNLIB - Runtime library initalisation
0270               ***************************************************************
0271               *  B  @RUNLIB
0272               *--------------------------------------------------------------
0273               *  REMARKS
0274               *  if R0 in WS1 equals >4a4a we were called from the system
0275               *  crash handler so we return there after initialisation.
0276               
0277               *  If R1 in WS1 equals >FFFF we return to the TI title screen
0278               *  after clearing scratchpad memory. This has higher priority
0279               *  as crash handler flag R0.
0280               ********|*****|*********************|**************************
0287 3020 04E0  26 runlib  clr   @>8302                ; Reset exit flag (R1 in workspace WS1!)
     3022 8302     
0289               *--------------------------------------------------------------
0290               * Alternative entry point
0291               *--------------------------------------------------------------
0292 3024 0300  22 runli1  limi  0                     ; Turn off interrupts
     3026 0000     
0293 3028 02E0  18         lwpi  ws1                   ; Activate workspace 1
     302A 8300     
0294 302C C0E0  30         mov   @>83c0,r3             ; Get random seed from OS monitor
     302E 83C0     
0295               *--------------------------------------------------------------
0296               * Clear scratch-pad memory from R4 upwards
0297               *--------------------------------------------------------------
0298 3030 0202  20 runli2  li    r2,>8308
     3032 8308     
0299 3034 04F2  30 runli3  clr   *r2+                  ; Clear scratchpad >8306->83FF
0300 3036 0282  22         ci    r2,>8400
     3038 8400     
0301 303A 16FC  14         jne   runli3
0302               *--------------------------------------------------------------
0303               * Exit to TI-99/4A title screen ?
0304               *--------------------------------------------------------------
0305 303C 0281  22 runli3a ci    r1,>ffff              ; Exit flag set ?
     303E FFFF     
0306 3040 1602  14         jne   runli4                ; No, continue
0307 3042 0420  42         blwp  @0                    ; Yes, bye bye
     3044 0000     
0308               *--------------------------------------------------------------
0309               * Determine if VDP is PAL or NTSC
0310               *--------------------------------------------------------------
0311 3046 C803  30 runli4  mov   r3,@waux1             ; Store random seed
     3048 833C     
0312 304A 04C1  14         clr   r1                    ; Reset counter
0313 304C 0202  20         li    r2,10                 ; We test 10 times
     304E 000A     
0314 3050 C0E0  30 runli5  mov   @vdps,r3
     3052 8802     
0315 3054 20E0  34         coc   @wbit0,r3             ; Interupt flag set ?
     3056 2020     
0316 3058 1302  14         jeq   runli6
0317 305A 0581  14         inc   r1                    ; Increase counter
0318 305C 10F9  14         jmp   runli5
0319 305E 0602  14 runli6  dec   r2                    ; Next test
0320 3060 16F7  14         jne   runli5
0321 3062 0281  22         ci    r1,>1250              ; Max for NTSC reached ?
     3064 1250     
0322 3066 1202  14         jle   runli7                ; No, so it must be NTSC
0323 3068 0262  22         ori   config,palon          ; Yes, it must be PAL, set flag
     306A 201C     
