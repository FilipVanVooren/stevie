0239                       ; Check if new highest SAMS index page
0240                       ;------------------------------------------------------
0241 3340 8804  34         c     tmp0,@idx.sams.hipage ; New highest page?
     3342 A604     
0242 3344 1202  14         jle   _idx.samspage.get.exit
0243                                                   ; No, exit
0244 3346 C804  38         mov   tmp0,@idx.sams.hipage ; Yes, set highest SAMS index page
     3348 A604     
0245                       ;------------------------------------------------------
0246                       ; Exit
0247                       ;------------------------------------------------------
