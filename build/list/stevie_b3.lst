     37DA FFFA     
0012 37DC CE45  34         mov   tmp1,*stack+          ; Push tmp1
0015 37DE CE44  34         mov   tmp0,*stack+          ; Push tmp0
0017 37E0 C64B  30         mov   r11,*stack            ; Push return address
0018 37E2 0229  22         ai    stack,-(1 * 2 + 2)    ; Set stack pointer back to original position
     37E4 FFFC     
                   < edb.line.getlength.asm
0022                       ;------------------------------------------------------
0023                       ; Initialisation
0024                       ;------------------------------------------------------
0025 37E6 04E0  34         clr   @outparm1             ; Reset length
     37E8 A018     
0026 37EA 04E0  34         clr   @outparm2             ; Reset SAMS bank
     37EC A01A     
0027                       ;------------------------------------------------------
0028                       ; Exit if requested line beyond editor buffer
0029                       ;------------------------------------------------------
0030 37EE C120  34         mov   @parm1,tmp0           ; \
     37F0 A006     
0031 37F2 0584  14         inc   tmp0                  ; /  base 1
0032               
0033 37F4 8804  34         c     tmp0,@edb.lines       ; Requested line at BOT?
     37F6 A504     
0034 37F8 1201  14         jle   !                     ; No, continue processing
0035 37FA 100B  14         jmp   edb.line.getlength.null
0036                                                   ; Set length 0 and exit early
0037                       ;------------------------------------------------------
0038                       ; Map SAMS page
0039                       ;------------------------------------------------------
0040 37FC C120  34 !       mov   @parm1,tmp0           ; Get line
     37FE A006     
0041               
0042 3800 06A0  32         bl    @edb.line.mappage     ; Activate editor buffer SAMS page for line
     3802 378C     
0043                                                   ; \ i  tmp0     = Line number
0044                                                   ; | o  outparm1 = Pointer to line
0045                                                   ; / o  outparm2 = SAMS page
0046               
0047 3804 C120  34         mov   @outparm1,tmp0        ; Store pointer in tmp0
     3806 A018     
0048 3808 1304  14         jeq   edb.line.getlength.null
0049                                                   ; Set length to 0 if null-pointer
0050                       ;------------------------------------------------------
0051                       ; Process line prefix and exit
0052                       ;------------------------------------------------------
0053 380A C154  26         mov   *tmp0,tmp1            ; Get length into tmp1
0054 380C C805  38         mov   tmp1,@outparm1        ; Save length
     380E A018     
0055 3810 1002  14         jmp   edb.line.getlength.exit
0056                       ;------------------------------------------------------
0057                       ; Set length to 0 if null-pointer
0058                       ;------------------------------------------------------
0059               edb.line.getlength.null:
0060 3812 04E0  34         clr   @outparm1             ; Set length to 0, was a null-pointer
     3814 A018     
0061                       ;------------------------------------------------------
0062                       ; Exit
0063                       ;------------------------------------------------------
0064               edb.line.getlength.exit:
0065                       .popregs 1                  ; Pop registers and return to caller
     **** ****     > POPREGS
