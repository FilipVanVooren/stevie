0089               ***************************************************************
0090               * bl @_idx.sams.mapcolumn.on
0091               *--------------------------------------------------------------
0092               * Register usage
0093               * tmp0,tmp1,tmp2
0094               *--------------------------------------------------------------
0095               *  Remarks
0096               *  Private, only to be called from inside idx module
0097               ********|*****|*********************|**************************
0098               _idx.sams.mapcolumn.on:
0099 3296 0649  14         dect  stack
0100 3298 C64B  30         mov   r11,*stack            ; Push return address
0101 329A 0649  14         dect  stack
0102 329C C644  30         mov   tmp0,*stack           ; Push tmp0
0103 329E 0649  14         dect  stack
0104 32A0 C645  30         mov   tmp1,*stack           ; Push tmp1
0105 32A2 0649  14         dect  stack
0106 32A4 C646  30         mov   tmp2,*stack           ; Push tmp2
0107               *--------------------------------------------------------------
0108               * Map index pages into memory window  (b000-ffff)
0109               *--------------------------------------------------------------
0110 32A6 C120  34         mov   @idx.sams.lopage,tmp0 ; Get lowest index page
     32A8 A602     
0111 32AA 0205  20         li    tmp1,idx.top
     32AC B000     
0112 32AE 0206  20         li    tmp2,5                ; Set loop counter. all pages of index
     32B0 0005     
0113                       ;-------------------------------------------------------
0114                       ; Loop over banks
0115                       ;-------------------------------------------------------
0116 32B2 06A0  32 !       bl    @xsams.page.set       ; Set SAMS page
     32B4 25D6     
0117                                                   ; \ i  tmp0  = SAMS page number
0118                                                   ; / i  tmp1  = Memory address
0119               
0120 32B6 0584  14         inc   tmp0                  ; Next SAMS index page
0121 32B8 0225  22         ai    tmp1,>1000            ; Next memory region
     32BA 1000     
0122 32BC 0606  14         dec   tmp2                  ; Update loop counter
0123 32BE 15F9  14         jgt   -!                    ; Next iteration
0124               *--------------------------------------------------------------
0125               * Exit
0126               *--------------------------------------------------------------
