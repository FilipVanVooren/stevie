0038 3210 A160  34         a     @fb.column,tmp1       ; tmp1 = tmp1 + column
     3212 A30C     
0039 3214 A160  34         a     @fb.top.ptr,tmp1      ; tmp1 = tmp1 + base
     3216 A300     
