     6D36 2832     
0055 6D38 0000                   byte 0,0,32,80
     6D3A 2050     
0056 6D3C FFFF                   data eol              ; Remove leftover junk from previous dialog
0057               
0058 6D3E C839  42         mov   *stack+,@wyx          ; Restore cursor position
     6D40 832A     
0059                       ;-------------------------------------------------------
0060                       ; Print SAMS pages free
0061                       ;-------------------------------------------------------
0062 6D42 0204  20         li    tmp0,tv.sams.maxpage  ; Calculate number of free pages
     6D44 0100     
0063 6D46 6120  34         s     @edb.sams.hipage,tmp0 ;
     6D48 A51C     
0064               
0065 6D4A C804  38         mov   tmp0,@rambuf          ; Number of pages free
     6D4C A100     
0066               
