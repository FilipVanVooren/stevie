0027 6CF4 0649  14         dect  stack
0028 6CF6 C645  30         mov   tmp1,*stack           ; Push tmp1
0029 6CF8 0649  14         dect  stack
0030 6CFA C646  30         mov   tmp2,*stack           ; Push tmp2
0031                       ;-------------------------------------------------------
0032                       ; Initialsiation
0033                       ;-------------------------------------------------------
0034 6CFC 06A0  32         bl    @film
     6CFE 2236     
0035 6D00 F750                   data ram.msg1,0,160   ; Clear both status lines
     6D02 0000     
     6D04 00A0     
0036               
0037 6D06 0204  20         li    tmp0,>4c00            ; MSB = 76
     6D08 4C00     
0038 6D0A D804  38         movb  tmp0,@ram.msg1        ; Set line 1 length
     6D0C F750     
0039 6D0E D804  38         movb  tmp0,@ram.msg2        ; Set line 2 length
     6D10 F7A0     
0040               
0041 6D12 0204  20         li    tmp0,ram.msg1
     6D14 F750     
0042 6D16 C804  38         mov   tmp0,@cmdb.panhint    ; Show status line 1
     6D18 A728     
0043 6D1A 0204  20         li    tmp0,ram.msg2
     6D1C F7A0     
0044 6D1E C804  38         mov   tmp0,@cmdb.panhint2   ; Show status line 2
     6D20 A72A     
0045               
0046 6D22 0204  20         li    tmp0,txt.keys.menu
     6D24 7914     
0047 6D26 C804  38         mov   tmp0,@cmdb.pankeys    ; Keylist in status line
     6D28 A72E     
