0004               ***************************************************************
0005               * idx.entry.update
0006               * Update index entry - Each entry corresponds to a line
0007               ***************************************************************
0008               * bl @idx.entry.update
0009               *--------------------------------------------------------------
0010               * INPUT
0011               * @parm1    = Line number in editor buffer
0012               * @parm2    = Pointer to line in editor buffer
0013               * @parm3    = SAMS page
0014               *--------------------------------------------------------------
0015               * OUTPUT
0016               * @outparm1 = Pointer to updated index entry
0017               *--------------------------------------------------------------
0018               * Register usage
0019               * tmp0,tmp1,tmp2
0020               ********|*****|*********************|**************************
0021               idx.entry.update:
0022 35E4 0649  14         dect  stack
0023 35E6 C64B  30         mov   r11,*stack            ; Save return address
0024 35E8 0649  14         dect  stack
0025 35EA C644  30         mov   tmp0,*stack           ; Push tmp0
0026 35EC 0649  14         dect  stack
0027 35EE C645  30         mov   tmp1,*stack           ; Push tmp1
0028                       ;------------------------------------------------------
0029                       ; Get parameters
0030                       ;------------------------------------------------------
0031 35F0 C120  34         mov   @parm1,tmp0           ; Get line number
     35F2 A006     
0032 35F4 C160  34         mov   @parm2,tmp1           ; Get pointer
     35F6 A008     
0033 35F8 1312  14         jeq   idx.entry.update.clear
0034                                                   ; Special handling for "null"-pointer
0035                       ;------------------------------------------------------
0036                       ; Calculate LSB value index slot (pointer offset)
0037                       ;------------------------------------------------------
0038 35FA 0245  22         andi  tmp1,>0fff            ; Remove high-nibble from pointer
     35FC 0FFF     
0039 35FE 0945  24         srl   tmp1,4                ; Get offset (divide by 16)
0040                       ;------------------------------------------------------
0041                       ; Calculate MSB value index slot (SAMS page editor buffer)
0042                       ;------------------------------------------------------
0043 3600 06E0  34         swpb  @parm3
     3602 A00A     
0044 3604 D160  34         movb  @parm3,tmp1           ; Put SAMS page in MSB
     3606 A00A     
0045 3608 06E0  34         swpb  @parm3                ; \ Restore original order again,
     360A A00A     
0046                                                   ; / important for messing up caller parm3!
0047                       ;------------------------------------------------------
0048                       ; Update index slot
0049                       ;------------------------------------------------------
0050               idx.entry.update.save:
0051 360C 06A0  32         bl    @_idx.samspage.get    ; Get SAMS page for index
     360E 3304     
0052                                                   ; \ i  tmp0     = Line number
0053                                                   ; / o  outparm1 = Slot offset in SAMS page
0054               
0055 3610 C120  34         mov   @outparm1,tmp0        ; \ Update index slot
     3612 A018     
0056 3614 C905  38         mov   tmp1,@idx.top(tmp0)   ; /
     3616 B000     
0057 3618 C804  38         mov   tmp0,@outparm1        ; Pointer to updated index entry
     361A A018     
0058 361C 1008  14         jmp   idx.entry.update.exit
0059                       ;------------------------------------------------------
0060                       ; Special handling for "null"-pointer
0061                       ;------------------------------------------------------
0062               idx.entry.update.clear:
0063 361E 06A0  32         bl    @_idx.samspage.get    ; Get SAMS page for index
     3620 3304     
0064                                                   ; \ i  tmp0     = Line number
0065                                                   ; / o  outparm1 = Slot offset in SAMS page
0066               
0067 3622 C120  34         mov   @outparm1,tmp0        ; \ Clear index slot
     3624 A018     
0068 3626 04E4  34         clr   @idx.top(tmp0)        ; /
     3628 B000     
0069 362A C804  38         mov   tmp0,@outparm1        ; Pointer to updated index entry
     362C A018     
0070                       ;------------------------------------------------------
0071                       ; Exit
0072                       ;------------------------------------------------------
0073               idx.entry.update.exit:
0074                       .popregs 1                  ; Pop registers and return to caller
