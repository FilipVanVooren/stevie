0112      A00A     parm3             equ  core1.top + 10  ; Function parameter 3
0113      A00C     parm4             equ  core1.top + 12  ; Function parameter 4
0114      A00E     parm5             equ  core1.top + 14  ; Function parameter 5
0115      A010     parm6             equ  core1.top + 16  ; Function parameter 6
0116      A012     parm7             equ  core1.top + 18  ; Function parameter 7
