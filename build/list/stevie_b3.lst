0179               ***************************************************************
0180               * _idx.samspage.get
0181               * Get SAMS page for index
0182               ***************************************************************
0183               * bl @_idx.samspage.get
0184               *--------------------------------------------------------------
0185               * INPUT
0186               * tmp0 = Line number
0187               *--------------------------------------------------------------
0188               * OUTPUT
0189               * @outparm1 = Offset for index entry in index SAMS page
0190               *--------------------------------------------------------------
0191               * Register usage
0192               * tmp0,tmp1,tmp2
0193               *--------------------------------------------------------------
0194               *  Remarks
0195               *  Private, only to be called from inside idx module.
0196               *  Activates SAMS page containing required index slot entry.
0197               ********|*****|*********************|**************************
0198               _idx.samspage.get:
0199 3304 0649  14         dect  stack
0200 3306 C64B  30         mov   r11,*stack            ; Save return address
0201 3308 0649  14         dect  stack
0202 330A C644  30         mov   tmp0,*stack           ; Push tmp0
0203 330C 0649  14         dect  stack
0204 330E C645  30         mov   tmp1,*stack           ; Push tmp1
0205 3310 0649  14         dect  stack
0206 3312 C646  30         mov   tmp2,*stack           ; Push tmp2
0207                       ;------------------------------------------------------
0208                       ; Determine SAMS index page
0209                       ;------------------------------------------------------
0210 3314 C184  18         mov   tmp0,tmp2             ; Line number
0211 3316 04C5  14         clr   tmp1                  ; MSW (tmp1) = 0 / LSW (tmp2) = Line number
0212 3318 0204  20         li    tmp0,2048             ; Index entries in 4K SAMS page
     331A 0800     
0213               
0214 331C 3D44 128         div   tmp0,tmp1             ; \ Divide 32 bit value by 2048
0215                                                   ; | tmp1 = quotient  (SAMS page offset)
0216                                                   ; / tmp2 = remainder
0217               
0218 331E 0A16  18         sla   tmp2,1                ; line number * 2
0219 3320 C806  38         mov   tmp2,@outparm1        ; Offset index entry
     3322 A018     
0220               
0221 3324 A160  34         a     @idx.sams.lopage,tmp1 ; Add SAMS page base
     3326 A602     
0222 3328 8805  34         c     tmp1,@idx.sams.page   ; Page already active?
     332A A600     
0223               
0224 332C 130E  14         jeq   _idx.samspage.get.exit
0225                                                   ; Yes, so exit
0226                       ;------------------------------------------------------
0227                       ; Activate SAMS index page
0228                       ;------------------------------------------------------
0229 332E C805  38         mov   tmp1,@idx.sams.page   ; Set current SAMS page
     3330 A600     
0230 3332 C805  38         mov   tmp1,@tv.sams.b000    ; Also keep SAMS window synced in Stevie
     3334 A206     
0231 3336 C105  18         mov   tmp1,tmp0             ; Destination SAMS page
0232               
0233 3338 0205  20         li    tmp1,>b000            ; Memory window for index page
     333A B000     
0234               
0235 333C 06A0  32         bl    @xsams.page.set       ; Switch to SAMS page
     333E 25D6     
0236                                                   ; \ i  tmp0 = SAMS page
0237                                                   ; / i  tmp1 = Memory address
