     6D50 253A     
0068 6D52 73A5                   data txt.hint.sams+1,ram.msg1+1,14
     6D54 F751     
     6D56 000E     
0069               
0070 6D58 0242  22         andi  config,>7fff          ; Do not print number
     6D5A 7FFF     
0071                                                   ; (Reset bit 0 in config register)
0072               
0073 6D5C 06A0  32         bl    @mknum                ; Convert unsigned number to string
     6D5E 2A56     
