2834               
2835               * Video Single Byte Write
2836               * In: R0=VDP address, R1=data
2837 7B0A 0260  22 VSBW   ORI  R0,>4000   ; set memory flag
     7B0C 4000     
2838 7B0E 06C0  14        SWPB R0
2839 7B10 D800  30        MOVB R0,@VDPWA  ; write low address byte
     7B12 8C02     
2840 7B14 06C0  14        SWPB R0
2841 7B16 D800  30        MOVB R0,@VDPWA  ; write high address byte
     7B18 8C02     
2842 7B1A 0240  22        ANDI R0,>3FFF   ; undo changes to R0
     7B1C 3FFF     
2843 7B1E D801  30        MOVB R1,@VDPWD  ; write data
     7B20 8C00     
2844 7B22 045B  20        B *R11
2845               
2846               * Video Multiple Byte Read
2847               * In: R0=VDP base address, R1=CPU base address, R2=length; modified R1, R2
2848 7B24 06C0  14 VMBR   SWPB R0
2849 7B26 D800  30        MOVB R0,@VDPWA  ; write low address byte
     7B28 8C02     
2850 7B2A 06C0  14        SWPB R0
2851 7B2C D800  30        MOVB R0,@VDPWA  ; write high address byte
     7B2E 8C02     
2852 7B30 1000  14        NOP             ; delay
2853 7B32 DC60  44 VMBR2  MOVB @VDPRD,*R1+  ; write data to CPU and advance source pointer
     7B34 8800     
2854 7B36 0602  14        DEC  R2         ; count down
2855 7B38 16FC  14        JNE  VMBR2      ; repeat until no bytes to copy
2856 7B3A 045B  20        B *R11
2857               
2858               * Video Multiple Byte Write (write different bytes)
2859               * In: R0=VDP base address, R1=CPU base address, R2=length; modified R1, R2
2860 7B3C 0260  22 VMBW   ORI  R0,>4000   ; set memory flag
     7B3E 4000     
2861 7B40 06C0  14        SWPB R0
2862 7B42 D800  30        MOVB R0,@VDPWA  ; write low address byte
     7B44 8C02     
2863 7B46 06C0  14        SWPB R0
2864 7B48 D800  30        MOVB R0,@VDPWA  ; write high address byte
     7B4A 8C02     
2865 7B4C 0240  22        ANDI R0,>3FFF   ; undo changes to R0
     7B4E 3FFF     
2866 7B50 D831  40 VMBW2  MOVB *R1+,@VDPWD  ; write data to VDP and advance source pointer
     7B52 8C00     
2867 7B54 0602  14        DEC  R2         ; count down
2868 7B56 16FC  14        JNE  VMBW2      ; repeat until no bytes to copy
2869 7B58 045B  20        B *R11
2870               
2871               * Video Multiple Byte Stream (write same byte multiple times)
2872               * In: R0=VDP base address, R1=data, R2=length; modified R2
2873 7B5A 0260  22 VMBS   ORI  R0,>4000   ; set memory flag
     7B5C 4000     
2874 7B5E 06C0  14        SWPB R0
2875 7B60 D800  30        MOVB R0,@VDPWA  ; write low address byte
     7B62 8C02     
