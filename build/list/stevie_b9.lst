2985               * end VIDEO -----------------------------------------
2986               
2987               * GROM addresses >0000 - >1FFF
2988      02B2     SCAN   EQU >02B2  ; >000E is an indirect that just consumes time
2989      04B2     CHKCLR EQU >04B2  ; uses R12 only
2990               
2991               * CPU scratchpad RAM >8300 - >83FF
2992      8300     BASWP  EQU >8300      ; workspace for BASIC interpretter
2993      8320     CURLIN EQU BASWP+32   ; Save pointer into current line pointer table entry when reading each line (for skipping false IFs)
2994      8322     LINTOP EQU CURLIN+2   ; Pointer to end of line pointers in low memory (word where -1 is found)
2995      8324     MEMTOP EQU LINTOP+2   ; Pointer to end of line strings in high memory (above this usable for strings)
2996      8326     CURSOR EQU MEMTOP+2   ; Cursor position in VDP RAM
2997      8328     RAND1  EQU CURSOR+2   ; Random number
2998      832A     RAND2  EQU RAND1+2    ; Used to generate random number
2999      832C     CHRGET EQU RAND2+2    ; CHRGET routine (for speed)
3000      000C     CHRSIZ EQU INIT-INITAT  ; number of bytes in CHRGET routine
3001      8338     TEMPF1 EQU CHRGET+CHRSIZ  ; fast temp #1 (used in CHROUT and CHKEND and TOKEND and SLOAD/SSAVE)
3002      833A     TEMPF2 EQU TEMPF1+2   ; fast temp #2 (used in CHROUT and TOKARG and SLOAD/SSAVE)
3003      833C     TEMPF3 EQU TEMPF2+2   ; fast temp #3 (used in CHROUT and TOKIZE and SLOAD/SSAVE)
3004      833E     TEMPF4 EQU TEMPF3+2   ; fast temp #4 (used in TOKIZE and SLIST and LSOPT)
3005      8340     TEMPF5 EQU TEMPF4+2   ; fast temp #5 (used in SLIST)
3006      8342     ENDLIN EQU TEMPF5+2   ; End of line flag for SPRINT
3007      8343     NXTPAD EQU ENDLIN+1   ; next scratchpad address (for adding more high speed storage locations)
3008               * 43-53 available (8.5 words/17 bytes)
3009      8374     KEYDEV EQU >8374      ; keyboard device to check (byte)
3010      8375     KEYKEY EQU >8375      ; key pressed (byte)
3011      837C     GPLSTS EQU >837C      ; keyboard and DSR status (byte)
3012               * 80-BF GPL stack not available because of SCAN
3013      83E0     GPLWS  EQU >83E0      ; GPL workspace registers
3014               
3015               * Low expansion RAM >2000 - >3FFF
3016      0100     STKSIZ EQU >0100      ; size of BASIC stack
3017      0006     GSBSIZ EQU 6          ; size of a GOSUB entry on the stack
3018      000C     FORSIZ EQU 12         ; size of a FOR entry on the stack
3019      0100     LINSIZ EQU >0100      ; size of line input buffer
3020      02E0     VDPSIZ EQU >02E0      ; Size of screen minus 1 line (768-32)
3021      2000     STACK  EQU >2000      ; BASIC stack for FOR/NEXT and GOSUB/RETURN statements
3022      2100     LINBUF EQU STACK+STKSIZ  ; Line input buffer (overlap middle of VDPBUF)
3023      2200     VDPBUF EQU LINBUF+LINSIZ  ; Room to save screen minus 1 line, also used for tokenization of input line
3024                      EVEN           ; any workspace register set must be aligned
3025      24E0     SYSWS  EQU VDPBUF+VDPSIZ  ; workspace for SYS statement
3026      2500     VARS   EQU SYSWS+32   ; 26 words for variables A-Z
3027      2534     SCROLL EQU VARS+52    ; indicator that last CHROUT resulted in screen scrolling (0=no, -1=yes)
3028      2535     OPENED EQU SCROLL+1   ; indicator that a file is open (0=no, -1=yes)
3029                      EVEN           ; any workspace register set must be aligned
3030      2536     UTILWS EQU OPENED+1   ; workspace for utility routines (only for KSCAN, DSRLNK)
3031      2556     DSRWRK EQU UTILWS+32  ; DSR workspace array (80 bytes)
3032      001A     PABSIZ EQU 26         ; size of PAB
3033      25A6     CPUPAB EQU DSRWRK+80  ; File handle assembly point for LOAD/SAVE in CPU RAM
3034      25A8     PABADR EQU CPUPAB+2   ; Buffer address in VDP RAM for LOAD/SAVE
3035      25AC     PABLEN EQU CPUPAB+6   ; Data length for LOAD/SAVE
3036      25AF     PABFNL EQU CPUPAB+9   ; Filename length
3037      25B0     PABNAM EQU CPUPAB+10  ; Filename
3038      373E     VDPPAB EQU 14142      ; Actual file handle for LOAD/SAVE in VDP RAM
3039      3758     FILBUF EQU VDPPAB+PABSIZ  ; File buffer for LOAD/SAVE in VDP RAM (just below floppy drive controller reserved space)
3040      25C0     NXTLBL EQU CPUPAB+PABSIZ  ; Placeholder for next available address in low memory
3041      0006     LTESIZ EQU 6          ; Line table entry size (6 bytes/3 words)
3042      25C0     LINBOT EQU >25C0      ; Equate to start of line pointers in low memory
3043               * Line pointer table entry = WORD line number (-1 is end), WORD pointer (next free byte at end), WORD length (0 at end)
3044               * Starting at >25C0 leaves room for 1120 lines
3045               
3046               * High expansion RAM >A000 - >FFFF
3047      A000     TXTBOT EQU >A000      ; Equate to start of lines in high memory
3048               
3049               * Hardware bridge register addresses
3050      8C02     VDPWA  EQU >8C02      ; VDP RAM write address
3051      8800     VDPRD  EQU >8800      ; VDP RAM read data
3052      8C00     VDPWD  EQU >8C00      ; VDP RAM write data
3053      8802     VDPSTA EQU >8802      ; VDP RAM status
3054      83D4     SHDWR1 EQU >83D4      ; VDP register 1 shadow (always update)
3055      8400     SOUND  EQU >8400      ; Sound chip register bridge address
3056               * GROM registers
3057      9C02     GRMWA  EQU >9C02      ; GROM/GRAM write address
3058      9802     GRMRA  EQU >9802      ; GROM/GRAM read address
3059      9800     GRMRD  EQU >9800      ; GROM/GRAM read data
3060      9C00     GRMWD  EQU >9C00      ; GROM/GRAM write data
3061               * Utility constants
3062      8354     DSRSIZ EQU >8354      ; Name length
3063      8356     DSRNAM EQU >8356      ; DSR address
3064      83D0     CRULST EQU >83D0      ; CRU list
3065      83D2     SAVADD EQU >83D2      ; Save address
3066      2540     DSRWS5 EQU UTILWS+10  ; DSR register 5
3067      2537     DSRWS0 EQU UTILWS+1   ; DSR register 0 low byte
3068      0000     DSROPN EQU >0000      ; OPEN
3069      0100     DSRCLS EQU >0100      ; CLOSE
3070      0200     DSRRD  EQU >0200      ; READ
3071      0300     DSRWR  EQU >0300      ; WRITE
3072               
3073               * character codes/joystick
3074      0200     CCLEAR EQU >0200      ; clear (FN+4) [break]
3075      0800     CLEFT  EQU >0800      ; left arrow [delete]
3076      0900     CRIGHT EQU >0900      ; right arrow [tab]
3077      0D00     CENTER EQU >0D00      ; enter
3078      2000     CSPACE EQU >2000      ; space
3079      7F00     CCURSR EQU >7F00      ; cursor
3080               *JOYB   EQU >0100      ; joystick button
3081               *JOYL   EQU >0200      ; joystick left
3082               *JOYR   EQU >0400      ; joystick right
3083               *JOYD   EQU >0800      ; joystick down
3084               *JOYU   EQU >1000      ; joystick up
