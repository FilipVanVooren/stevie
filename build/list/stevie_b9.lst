0024                       aorg  >6000
0025                       save  >6000,>8000           ; Save bank
0026               
0027                       aorg  >600a
0028 600A 0460  28         b     @INIT                 ; Start Jackalope Basic
     600C 795A     
0029                       aorg  >600e
0030 600E 04E0  34         clr   @bank8.rom            ; Return to Jackalope integration layer
     6010 6010     
