0298               * start EXECUTION --------------------------------------
0299 61E8 028E  22 GETSTT CI R14,TSYS*>0100
     61EA 7100     
0300 61EC 1A1B  14        JL GETSTE          ; 00-70: unassigned (error)
0301 61EE 028E  22        CI R14,TDEC*>0100
     61F0 E600     
0302 61F2 1A03  14        JL GETST1
0303 61F4 020B  20        LI R11,SDECRE      ; E6-FF -> E6: decrement
     61F6 7034     
0304 61F8 1014  14        JMP DOSTMT
0305 61FA 028E  22 GETST1 CI R14,TINC*>0100
     61FC CC00     
0306 61FE 1A03  14        JL GETST2
0307 6200 020B  20        LI R11,SINCRE      ; CC-E5 -> CC: increment
     6202 702C     
0308 6204 100E  14        JMP DOSTMT
0309 6206 028E  22 GETST2 CI R14,TLET*>0100
     6208 B100     
0310 620A 1A03  14        JL GETST3
0311 620C 020B  20        LI R11,SLET        ; B2-CB -> B2: let
     620E 6E78     
0312 6210 1008  14        JMP DOSTMT
0313               *      fall through       ; 71-B1: literal statements
0314               * look up statement address from table
0315 6212 020F  20 GETST3 LI R15,TSYS*>0100
     6214 7100     
0316 6216 C30E  18        MOV R14,R12        ; never operate on R14 since the low byte must remain 00 at all times
0317 6218 730F  18        SB R15,R12         ; R14=R14-R15 (current token minus first token)
0318 621A 06CC  14        SWPB R12           ; put result in lower byte
0319 621C A30C  18        A R12,R12          ; double result (2 bytes per table entry)
