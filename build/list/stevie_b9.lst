2877 7B66 D800  30        MOVB R0,@VDPWA  ; write high address byte
     7B68 8C02     
2878 7B6A 0240  22        ANDI R0,>3FFF   ; undo changes to R0
     7B6C 3FFF     
2879 7B6E D801  30 VMBS2  MOVB R1,@VDPWD  ; write data
     7B70 8C00     
2880 7B72 0602  14        DEC  R2         ; count down
2881 7B74 16FC  14        JNE  VMBS2      ; repeat until no bytes to copy
2882 7B76 045B  20        B *R11
