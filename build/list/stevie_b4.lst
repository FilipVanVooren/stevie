0090               * bl @_idx.sams.mapcolumn.on
0091               *--------------------------------------------------------------
0092               * Register usage
0093               * tmp0,tmp1,tmp2
0094               *--------------------------------------------------------------
0095               *  Remarks
0096               *  Private, only to be called from inside idx module
0097               ********|*****|*********************|**************************
0098               _idx.sams.mapcolumn.on:
0099 3296 0649  14         dect  stack
0100 3298 C64B  30         mov   r11,*stack            ; Push return address
0101 329A 0649  14         dect  stack
0102 329C C644  30         mov   tmp0,*stack           ; Push tmp0
0103 329E 0649  14         dect  stack
0104 32A0 C645  30         mov   tmp1,*stack           ; Push tmp1
0105 32A2 0649  14         dect  stack
0106 32A4 C646  30         mov   tmp2,*stack           ; Push tmp2
0107               *--------------------------------------------------------------
