0125      A024     outparm7          equ  core1.top + 36  ; Function output parameter 7
0126      A026     kbflags           equ  core1.top + 38  ; Keyboard control flags
0127      A028     keycode1          equ  core1.top + 40  ; Current key scanned
0128      A02A     keycode2          equ  core1.top + 42  ; Previous key scanned
