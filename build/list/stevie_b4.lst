0065                                                   ; / o  outparm1 = Slot offset in SAMS page
0066               
0067 3622 C120  34         mov   @outparm1,tmp0        ; \ Clear index slot
     3624 A018     
0068 3626 04E4  34         clr   @idx.top(tmp0)        ; /
     3628 B000     
0069 362A C804  38         mov   tmp0,@outparm1        ; Pointer to updated index entry
     362C A018     
