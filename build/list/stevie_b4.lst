0042                       ;------------------------------------------------------
0043 3580 C120  34         mov   @parm1,tmp0           ; \ Get string prefix (length-byte)
     3582 A006     
0044 3584 D194  26         movb  *tmp0,tmp2            ; /
0045 3586 0986  32         srl   tmp2,8                ; Right align
0046 3588 C1C6  18         mov   tmp2,tmp3             ; Make copy of length-byte for later use
0047               
0048 358A 8806  34         c     tmp2,@parm2           ; String length > requested length?
     358C A008     
0049 358E 1520  14         jgt   tv.pad.string.panic   ; Yes, crash
0050                       ;------------------------------------------------------
0051                       ; Copy string to buffer
0052                       ;------------------------------------------------------
0053 3590 C120  34         mov   @parm1,tmp0           ; Get source address
     3592 A006     
0054 3594 C160  34         mov   @parm4,tmp1           ; Get destination address
     3596 A00C     
0055 3598 0586  14         inc   tmp2                  ; Also include length-byte in copy
0056               
0057 359A 0649  14         dect  stack
0058 359C C647  30         mov   tmp3,*stack           ; Push tmp3 (get overwritten by xpym2m)
0059               
0060 359E 06A0  32         bl    @xpym2m               ; Copy length-prefix string to buffer
     35A0 2540     
0061                                                   ; \ i  tmp0 = Source CPU memory address
0062                                                   ; | i  tmp1 = Target CPU memory address
0063                                                   ; / i  tmp2 = Number of bytes to copy
0064               
0065 35A2 C1F9  30         mov   *stack+,tmp3          ; Pop tmp3
0066                       ;------------------------------------------------------
0067                       ; Set length of new string
0068                       ;------------------------------------------------------
0069 35A4 C120  34         mov   @parm2,tmp0           ; Get requested length
     35A6 A008     
0070 35A8 0A84  32         sla   tmp0,8                ; Left align
0071 35AA C160  34         mov   @parm4,tmp1           ; Get pointer to buffer
     35AC A00C     
0072 35AE D544  30         movb  tmp0,*tmp1            ; Set new length of string
0073 35B0 A147  18         a     tmp3,tmp1             ; \ Skip to end of string
0074 35B2 0585  14         inc   tmp1                  ; /
0075                       ;------------------------------------------------------
0076                       ; Prepare for padding string
