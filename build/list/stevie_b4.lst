     7520 833C     
0062 7522 0224  22         ai    tmp0,24               ; End marker
     7524 0018     
0063 7526 C147  18         mov   tmp3,tmp1             ; Restore color combination
0064 7528 06A0  32         bl    @xvputb               ; Write single byte to VDP
     752A 22CC     
