0013                       aorg  bankx.vectab
0014 7F70 64E0     vec.1   data  fb.goto.toprow        ; Refresh FB with top-row and row offset
0015 7F72 6608     vec.2   data  fb.ruler.init         ; Setup ruler with tab positions in memory
0016 7F74 66B0     vec.3   data  fb.colorlines         ; Colorize frame buffer content
0017 7F76 6746     vec.4   data  fb.vdpdump            ; Dump frame buffer to VDP SIT
0018 7F78 6796     vec.5   data  fb.scan.fname         ; Scan current line for possible filename
0019 7F7A 6850     vec.6   data  fb.hscroll            ; Horizontal scroll frame buffer window
0020 7F7C 6882     vec.7   data  fb.restore            ; Restore frame buffer to normal operations
0021 7F7E 68BE     vec.8   data  fb.refresh            ; Refresh frame buffer
0022 7F80 6934     vec.9   data  fb.get.nonblank       ; Get column of first non-blank character
0023 7F82 63F4     vec.10  data  fb.tab.prev           ; Move cursor to previous tab position
0024 7F84 6456     vec.11  data  fb.tab.next           ; Move cursor to nexttab position
0025 7F86 60DE     vec.12  data  fb.cursor.up          ; Move cursor up 1 line
0026 7F88 6146     vec.13  data  fb.cursor.down        ; Move cursor down 1 line
0027 7F8A 61C2     vec.14  data  fb.cursor.home        ; Move cursor home
0028 7F8C 61F0     vec.15  data  fb.insert.line        ; Insert a new line
0029 7F8E 6004     vec.16  data  fb.cursor.top         ; Move cursor to top of file
0030 7F90 602C     vec.17  data  fb.cursor.topscr      ; Move cursor to top of screen
0031 7F92 6052     vec.18  data  fb.cursor.bot         ; Move cursor to bottom of file
0032 7F94 608E     vec.19  data  fb.cursor.botscr      ; Move cursor to bottom of screen
0033 7F96 628A     vec.20  data  fb.insert.char        ; Insert character
0034 7F98 634E     vec.21  data  fb.replace.char       ; Replace character
