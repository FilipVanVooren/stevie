     676E A210     
0046                                                   ; Is ruler visible on screen?
0047 6770 1302  14         jeq   fb.vdpdump.calc       ; No, continue with calculation
0048 6772 A120  34         a     @fb.colsline,tmp0     ; Yes, add 2nd line offset
     6774 A30E     
0049                       ;------------------------------------------------------
0050                       ; Refresh VDP content with framebuffer
0051                       ;------------------------------------------------------
0052               fb.vdpdump.calc:
0053 6776 3960  74         mpy   @fb.colsline,tmp1     ; columns per line * number of rows in parm1
     6778 A30E     
0054                                                   ; 16 bit part is in tmp2!
0055 677A C160  34         mov   @fb.top.ptr,tmp1      ; RAM Source address
     677C A300     
0056               
0057 677E 0286  22         ci    tmp2,0                ; \ Exit early if nothing to copy
     6780 0000     
0058 6782 1304  14         jeq   fb.vdpdump.exit       ; /
0059               
0060 6784 06A0  32         bl    @xpym2v               ; Copy to VDP
     6786 24EC     
0061                                                   ; \ i  tmp0 = VDP target address
0062                                                   ; | i  tmp1 = RAM source address
0063                                                   ; / i  tmp2 = Bytes to copy
0064               
0065 6788 04E0  34         clr   @fb.dirty             ; Reset frame buffer dirty flag
     678A A31A     
0066                       ;------------------------------------------------------
0067                       ; Exit
0068                       ;------------------------------------------------------
0069               fb.vdpdump.exit:
0070                       .popregs 2                  ; Pop registers and return to caller
