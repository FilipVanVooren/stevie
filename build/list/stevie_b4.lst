0008 352C C1B9  30         mov   *stack+,tmp2          ; Pop tmp2
0011 352E C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 3530 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 3532 C2F9  30         mov   *stack+,r11           ; Pop r11
0017 3534 045B  20         b     *r11                  ; Return
