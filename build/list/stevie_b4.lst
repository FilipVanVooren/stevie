0093               fb.colorlines.fill:
0094 6722 0206  20         li    tmp2,80               ; 80 characters to fill
     6724 0050     
0095               
0096 6726 06A0  32         bl    @xfilv                ; Fill VDP VRAM
     6728 2294     
0097                                                   ; \ i  tmp0 = VDP start address
0098                                                   ; | i  tmp1 = Byte to fill
0099                                                   ; / i  tmp2 = count
0100               
0101 672A 0224  22         ai    tmp0,80               ; Next line
     672C 0050     
0102 672E 0588  14         inc   tmp4
0103 6730 0607  14         dec   tmp3                  ; Update loop counter
0104 6732 15E9  14         jgt   fb.colorlines.loop    ; Back to (1)
0105                       ;------------------------------------------------------
0106                       ; Exit
0107                       ;------------------------------------------------------
0108               fb.colorlines.exit
0109 6734 04E0  34         clr   @fb.colorize          ; Reset colorize flag
     6736 A312     
