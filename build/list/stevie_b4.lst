0017 36F6 0286  22         ci    tmp2,2048*5           ; Crash if loop counter value is unrealistic
     36F8 2800     
0018                                                   ; Max. 5 SAMS pages, each with 2048 index
0019                                                   ; entries.
0020               
0021 36FA 1204  14         jle   !                     ; Continue if ok
0022                       ;------------------------------------------------------
0023                       ; Crash and burn
