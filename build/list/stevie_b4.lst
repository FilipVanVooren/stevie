0025               _idx.entry.insert.reorg.crash:
0026 36FC C80B  38         mov   r11,@>ffce            ; \ Save caller address
     36FE FFCE     
0027 3700 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     3702 2026     
0028                       ;------------------------------------------------------
0029                       ; Reorganize index entries
0030                       ;------------------------------------------------------
0031 3704 0224  22 !       ai    tmp0,idx.top          ; Add index base to offset
     3706 B000     
0032 3708 C144  18         mov   tmp0,tmp1             ; a = current slot
0033 370A 05C5  14         inct  tmp1                  ; b = current slot + 2
0034 370C 0586  14         inc   tmp2                  ; One time adjustment for current line
0035                       ;------------------------------------------------------
0036                       ; Assert 2
0037                       ;------------------------------------------------------
0038 370E C1C6  18         mov   tmp2,tmp3             ; Number of slots to reorganize
0039 3710 0A17  18         sla   tmp3,1                ; adjust to slot size
0040 3712 0507  14         neg   tmp3                  ; tmp3 = -tmp3
0041 3714 A1C4  18         a     tmp0,tmp3             ; tmp3 = tmp3 + tmp0
0042 3716 0287  22         ci    tmp3,idx.top - 4      ; Address before top of index ?
     3718 AFFC     
0043 371A 1504  14         jgt   _idx.entry.insert.reorg.loop
0044                                                   ; No, jump to loop start
0045                       ;------------------------------------------------------
0046                       ; Crash and burn
0047                       ;------------------------------------------------------
0048 371C C80B  38         mov   r11,@>ffce            ; \ Save caller address
     371E FFCE     
0049 3720 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     3722 2026     
0050                       ;------------------------------------------------------
0051                       ; Loop backwards from end of index up to insert point
0052                       ;------------------------------------------------------
0053               _idx.entry.insert.reorg.loop:
0054 3724 C554  38         mov   *tmp0,*tmp1           ; Copy a -> b
0055 3726 0644  14         dect  tmp0                  ; Move pointer up
0056 3728 0645  14         dect  tmp1                  ; Move pointer up
0057 372A 0606  14         dec   tmp2                  ; Next index entry
0058 372C 15FB  14         jgt   _idx.entry.insert.reorg.loop
0059                                                   ; Repeat until done
0060                       ;------------------------------------------------------
0061                       ; Clear index entry at insert point
0062                       ;------------------------------------------------------
0063 372E 05C4  14         inct  tmp0                  ; \ Clear index entry for line
0064 3730 04D4  26         clr   *tmp0                 ; / following insert point
0065               
0066 3732 045B  20         b     *r11                  ; Return to caller
