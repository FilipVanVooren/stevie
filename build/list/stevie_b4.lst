0110      A006     parm1             equ  core1.top + 6   ; Function parameter 1
0111      A008     parm2             equ  core1.top + 8   ; Function parameter 2
0112      A00A     parm3             equ  core1.top + 10  ; Function parameter 3
0113      A00C     parm4             equ  core1.top + 12  ; Function parameter 4
0114      A00E     parm5             equ  core1.top + 14  ; Function parameter 5
0115      A010     parm6             equ  core1.top + 16  ; Function parameter 6
0116      A012     parm7             equ  core1.top + 18  ; Function parameter 7
0117      A014     parm8             equ  core1.top + 20  ; Function parameter 8
0118      A016     parm9             equ  core1.top + 22  ; Function parameter 9
0119      A018     outparm1          equ  core1.top + 24  ; Function output parameter 1
0120      A01A     outparm2          equ  core1.top + 26  ; Function output parameter 2
0121      A01C     outparm3          equ  core1.top + 28  ; Function output parameter 3
0122      A01E     outparm4          equ  core1.top + 30  ; Function output parameter 4
