0019               ********|*****|*********************|**************************
0020               fb.vdpdump:
0021 6746 0649  14         dect  stack
0022 6748 C64B  30         mov   r11,*stack            ; Save return address
0023 674A 0649  14         dect  stack
0024 674C C644  30         mov   tmp0,*stack           ; Push tmp0
0025 674E 0649  14         dect  stack
0026 6750 C645  30         mov   tmp1,*stack           ; Push tmp1
0027 6752 0649  14         dect  stack
0028 6754 C646  30         mov   tmp2,*stack           ; Push tmp2
0029                       ;------------------------------------------------------
0030                       ; Assert
0031                       ;------------------------------------------------------
0032 6756 C160  34         mov   @parm1,tmp1
     6758 A006     
0033 675A 0285  22         ci    tmp1,80*30
     675C 0960     
0034 675E 1204  14         jle   !
0035                       ;------------------------------------------------------
0036                       ; Crash the system
0037                       ;------------------------------------------------------
0038 6760 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     6762 FFCE     
0039 6764 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     6766 2026     
0040                       ;------------------------------------------------------
0041                       ; Setup start position in VDP memory
0042                       ;------------------------------------------------------
0043 6768 0204  20 !       li    tmp0,vdp.fb.toprow.sit
     676A 0050     
