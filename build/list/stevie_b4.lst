0001               * FILE......: equ.asm
0002               * Purpose...: The main equates file for Stevie editor
0003               
0004               
0005               *===============================================================================
0006               * Memory map
0007               * ==========
0008               *
0009               * CARTRIDGE SPACE (6000-7fff)
0010               *
0011               *     Mem range   Bytes    BANK   Purpose
0012               *     =========   =====    ====   ==================================
0013               *     6000-603f      64       0   Cartridge header
0014               *     6040-7fff    8128       0   SP2 library + Stevie library
0015               *                                 relocated to RAM space
0016               *     ..............................................................
0017               *     6000-603f      64     1-7   Cartridge header
0018               *     6040-7fef    7744     1-7   Stevie program code
0019               *     7f00-7fff     384     1-7   Vector table (32 vectors)
0020               *===============================================================================
0021               
0022               ;-------------------------------------------------------------------------------
0023               ; Stevie specific equates
0024               ;-------------------------------------------------------------------------------
0025      0000     fh.fopmode.none           equ  0        ; No file operation in progress
0026      0001     fh.fopmode.readfile       equ  1        ; Read file from disk to memory
0027      0002     fh.fopmode.writefile      equ  2        ; Save file from memory to disk
0028      0003     fh.fopmode.others         equ  3        ; Other file operation (delete,dir,...)
0029      0000     fh.ea5.vdpbuf             equ  >0000    ; VRAM address for storing EA5 chunk
0030      9900     tv.colorize.reset         equ  >9900    ; Colorization off
0031      00FE     tv.1timeonly              equ  254      ; One-time only flag indicator
0032      0100     tv.sams.maxpage           equ  256      ; Max SAMS pages supported
0033               ;-------------------------------------------------------------------------------
0034               ; Stevie Dialog / Pane specific equates
0035               ;-------------------------------------------------------------------------------
0036      0000     pane.focus.fb             equ  0       ; Editor pane has focus
0037      0001     pane.focus.cmdb           equ  1       ; Command buffer pane has focus
0038      000C     tv.colorscheme.entries    equ 12       ; Entries in colorscheme table
0039               ;-------------------------------------------------------------------------------
0040               ;   Dialog ID's
0041               ;-------------------------------------------------------------------------------
0042      000A     id.dialog.open            equ  10      ; "Open file"
0043      000B     id.dialog.insert          equ  11      ; "Insert file"
0044      000C     id.dialog.append          equ  12      ; "Append file"
0045      000D     id.dialog.save            equ  13      ; "Save file"
0046      000E     id.dialog.saveblock       equ  14      ; "Save block to file"
0047      000F     id.dialog.delete          equ  15      ; "Delete file"
0048      0014     id.dialog.opt.clip        equ  20      ; "Configure clipboard"
0049      0019     id.dialog.cat             equ  25      ; "Catalog"
0050      001E     id.dialog.run             equ  30      ; "Run program file"
0051               ;-------------------------------------------------------------------------------
0052               ;   Dialog ID's > 30 means file catalog is unsupported
0053               ;-------------------------------------------------------------------------------
0054      0028     id.dialog.print           equ  40      ; "Print file"
0055      0032     id.dialog.printblock      equ  50      ; "Print block"
0056      003C     id.dialog.goto            equ  60      ; "Goto"
0057      0046     id.dialog.find            equ  70      ; "Find"
0058      0050     id.dialog.cart.fg99       equ  80      ; "FinalGROM 99 Cartridge"
0059               ;-------------------------------------------------------------------------------
0060               ;   Dialog ID's >= 100 indicate that command prompt should be
0061               ;   hidden and no characters added to CMDB keyboard buffer.
0062               ;-------------------------------------------------------------------------------
0063      0064     id.dialog.main            equ  100     ; "Main Menu"
0064      0065     id.dialog.unsaved         equ  101     ; "Unsaved changes"
0065      0066     id.dialog.block           equ  102     ; "Block move/copy/delete/print/..."
0066      0067     id.dialog.clipboard       equ  103     ; "Copy clipboard to line ..."
0067      0068     id.dialog.help            equ  104     ; "About"
0068      0069     id.dialog.file            equ  105     ; "File"
0069      006A     id.dialog.cart.type       equ  106     ; "Cartridge Type"
0070      006B     id.dialog.basic           equ  107     ; "TI Basic"
0071      006C     id.dialog.opt             equ  108     ; "Options"
0072      006E     id.dialog.font            equ  110     ; "Configure font"
0073      006F     id.dialog.shortcuts       equ  111     ; "Shortcuts"
0074               ;-------------------------------------------------------------------------------
0075               ; Suffix characters for clipboards
0076               ;-------------------------------------------------------------------------------
0077      3100     clip1                     equ  >3100   ; '1'
0078      3200     clip2                     equ  >3200   ; '2'
0079      3300     clip3                     equ  >3300   ; '3's
0080               ;-------------------------------------------------------------------------------
0081               ; Keyboard flags in Stevie
0082               ;-------------------------------------------------------------------------------
0083      0001     kbf.kbclear               equ  >0001   ;  Keyboard buffer cleared / @w$0001
0084               ;-------------------------------------------------------------------------------
0085               ; File work mode
0086               ;-------------------------------------------------------------------------------
0087      0001     id.file.loadfile          equ  1       ; Load file
0088      0002     id.file.insertfile        equ  2       ; Insert file
0089      0003     id.file.appendfile        equ  3       ; Append file
0090      0004     id.file.savefile          equ  4       ; Save file
0091      0005     id.file.saveblock         equ  5       ; Save block to file
0092      0006     id.file.clipblock         equ  6       ; Save block to clipboard
0093      0007     id.file.printfile         equ  7       ; Print file
0094      0008     id.file.printblock        equ  8       ; Print block
0095      0009     id.file.deletefile        equ  9       ; Delete file
0096      FFFF     id.file.interrupt         equ  >ffff   ; File operation interrupted
0097               ;-------------------------------------------------------------------------------
0098               ; Special file indicator
0099               ;-------------------------------------------------------------------------------
0100      0000     id.special.normal         equ  0       ; Normal file
0101      0002     id.special.readonly       equ  2       ; Read-only file
0102      0003     id.special.basic          equ  3       ; TI Basic program
