0144      A0C0     tib.autounpk      equ  core1.top + 192 ; TI-Basic AutoUnpack (uncrunch)
0145      A0C2     tib.stab.ptr      equ  core1.top + 194 ; Pointer to TI-Basic SAMS page table
0146      A0C4     tib.scrpad.ptr    equ  core1.top + 196 ; Pointer to TI-Basic scratchpad in SAMS
0147      A0C6     tib.lnt.top.ptr   equ  core1.top + 198 ; Pointer to top of line number table
0148      A0C8     tib.lnt.bot.ptr   equ  core1.top + 200 ; Pointer to bottom of line number table
0149      A0CA     tib.symt.top.ptr  equ  core1.top + 202 ; Pointer to top of symbol table
0150      A0CC     tib.symt.bot.ptr  equ  core1.top + 204 ; Pointer to bottom of symbol table
0151      A0CE     tib.strs.top.ptr  equ  core1.top + 206 ; Pointer to top of string space
0152      A0D0     tib.strs.bot.ptr  equ  core1.top + 208 ; Pointer to bottom of string space
0153      A0D2     tib.lines         equ  core1.top + 210 ; Number of lines in TI Basic program
0154      A0D4     tib.free3         equ  core1.top + 212 ; **free* up to 233
