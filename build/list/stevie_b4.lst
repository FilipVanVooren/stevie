0025 66B8 0649  14         dect  stack
0026 66BA C645  30         mov   tmp1,*stack           ; Push tmp1
0027 66BC 0649  14         dect  stack
0028 66BE C646  30         mov   tmp2,*stack           ; Push tmp2
0029 66C0 0649  14         dect  stack
0030 66C2 C647  30         mov   tmp3,*stack           ; Push tmp3
0031 66C4 0649  14         dect  stack
0032 66C6 C648  30         mov   tmp4,*stack           ; Push tmp4
0033                       ;------------------------------------------------------
0034                       ; Force refresh flag set
0035                       ;------------------------------------------------------
0036 66C8 C120  34         mov   @parm1,tmp0           ; \ Force refresh flag set?
     66CA A006     
0037 66CC 0284  22         ci    tmp0,>ffff            ; /
     66CE FFFF     
0038 66D0 130D  14         jeq   !                     ; Yes, so skip Asserts
0039                       ;------------------------------------------------------
0040                       ; Assert
0041                       ;------------------------------------------------------
0042 66D2 C120  34         mov   @fb.colorize,tmp0     ; Check if colorization necessary
     66D4 A312     
0043 66D6 132E  14         jeq   fb.colorlines.exit    ; Exit if nothing to do.
0044                       ;------------------------------------------------------
0045                       ; Speedup screen refresh dramatically
0046                       ;------------------------------------------------------
0047 66D8 C120  34         mov   @edb.block.m1,tmp0    ; \ M1 marker unset?
     66DA A50E     
0048 66DC 0288  22         ci    tmp4,>ffff            ; /
     66DE FFFF     
0049 66E0 1329  14         jeq   fb.colorlines.exit    ; Exit if marker M1 unset
0050 66E2 C120  34         mov   @edb.block.m2,tmp0    ; \ M2 marker unset?
     66E4 A510     
0051 66E6 0288  22         ci    tmp4,>ffff            ; /
     66E8 FFFF     
0052 66EA 1324  14         jeq   fb.colorlines.exit    ; Exit if marker M2 unset
0053                       ;------------------------------------------------------
0054                       ; Color the lines in the framebuffer (TAT)
0055                       ;------------------------------------------------------
0056 66EC 0204  20 !       li    tmp0,vdp.fb.toprow.tat
     66EE 1310     
0057                                                   ; VDP start address
0058 66F0 C1E0  34         mov   @fb.scrrows,tmp3      ; Set loop counter
     66F2 A31E     
0059               
0060 66F4 C220  34         mov   @tv.ruler.visible,tmp4
     66F6 A210     
0061 66F8 1303  14         jeq   fb.colorlines.noruler ; Skip row adjustment if no ruler visible
0062               
0063 66FA 0224  22         ai    tmp0,80               ; Skip ruler line
     66FC 0050     
0064 66FE 0607  14         dec   tmp3                  ; Skip ruler line
0065               fb.colorlines.noruler:
0066 6700 C220  34         mov   @fb.topline,tmp4      ; Position in editor buffer
     6702 A304     
0067 6704 0588  14         inc   tmp4                  ; M1/M2 use base 1 offset
0068                       ;------------------------------------------------------
0069                       ; 1. Set color for each line in framebuffer
0070                       ;------------------------------------------------------
0071               fb.colorlines.loop:
0072 6706 C1A0  34         mov   @edb.block.m1,tmp2
     6708 A50E     
0073 670A 8206  18         c     tmp2,tmp4             ; M1 > current line
0074 670C 1507  14         jgt   fb.colorlines.normal  ; Yes, skip marking color
0075               
0076 670E C1A0  34         mov   @edb.block.m2,tmp2
     6710 A510     
0077 6712 8206  18         c     tmp2,tmp4             ; M2 < current line
0078 6714 1103  14         jlt   fb.colorlines.normal  ; Yes, skip marking color
0079                       ;------------------------------------------------------
0080                       ; 1a. Set marking color
0081                       ;------------------------------------------------------
0082 6716 C160  34         mov   @tv.markcolor,tmp1
     6718 A21E     
0083 671A 1003  14         jmp   fb.colorlines.fill
0084                       ;------------------------------------------------------
0085                       ; 1b. Set normal text color
0086                       ;------------------------------------------------------
0087               fb.colorlines.normal:
0088 671C C160  34         mov   @tv.color,tmp1
     671E A218     
0089 6720 0985  32         srl   tmp1,8
