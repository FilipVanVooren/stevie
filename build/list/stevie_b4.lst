0001               * FILE......: fb.scan.fname.asm
0002               * Purpose...: Scan current line for possible filename
0003               
0004               ***************************************************************
0005               * fb.scan.fname
0006               * Scan current line for possible filename
0007               ***************************************************************
0008               *  bl   @fb.scan.fname
0009               *--------------------------------------------------------------
0010               * INPUT
0011               * none
0012               *--------------------------------------------------------------
0013               * OUTPUT
0014               * @cmdb.dflt.fname = Pointer to string with default filename
0015               *--------------------------------------------------------------
0016               * Register usage
0017               * tmp0,tmp1,tmp2,tmp3,tmp4,r2,r3
0018               ********|*****|*********************|**************************
0019               fb.scan.fname:
0020 6796 0649  14         dect  stack
0021 6798 C64B  30         mov   r11,*stack            ; Save return address
0022 679A 0649  14         dect  stack
0023 679C C644  30         mov   tmp0,*stack           ; Push tmp0
0024 679E 0649  14         dect  stack
0025 67A0 C645  30         mov   tmp1,*stack           ; Push tmp1
0026 67A2 0649  14         dect  stack
0027 67A4 C646  30         mov   tmp2,*stack           ; Push tmp2
0028 67A6 0649  14         dect  stack
0029 67A8 C647  30         mov   tmp3,*stack           ; Push tmp3
0030 67AA 0649  14         dect  stack
0031 67AC C648  30         mov   tmp4,*stack           ; Push tmp4
0032 67AE 0649  14         dect  stack
0033 67B0 C642  30         mov   r2,*stack             ; Push r2
0034 67B2 0649  14         dect  stack
0035 67B4 C643  30         mov   r3,*stack             ; Push r3
0036                       ;-------------------------------------------------------
0037                       ; Initialisation
0038                       ;-------------------------------------------------------
0039               fb.scan.fname.copy:
0040 67B6 06A0  32         bl    @film
     67B8 2236     
0041 67BA A7B6                   data cmdb.dflt.fname,>00,80
     67BC 0000     
     67BE 0050     
0042                                                   ; Clear filename in buffer
0043               
0044 67C0 06A0  32         bl    @fb.calc.pointer      ; Calculate position in frame buffer
     67C2 31FC     
0045                                                   ; \ i   @fb.top      = Address top row in FB
0046                                                   ; | i   @fb.topline  = Top line in FB
0047                                                   ; | i   @fb.row      = Current row in FB
0048                                                   ; |                  (offset 0..@fb.scrrows)
0049                                                   ; | i   @fb.column   = Current column in FB
0050                                                   ; | i   @fb.colsline = Columns per line FB
0051                                                   ; |
0052                                                   ; / o   @fb.current  = Updated pointer
0053               
0054                       ; Register usage in following code
0055                       ;
0056                       ; tmp0 = Pointer to first character in framebuffer line
0057                       ; tmp1 = Destination address for filename copy
0058                       ; tmp2 = Pointer to last character in framebuffer line
0059                       ; tmp3 = Pointer to first character in valid devices string
0060                       ; tmp4 = Pointer to last character in valid devices string
0061                       ; r3   = Temporary storage
0062               
0063                       ;-------------------------------------------------------
0064                       ; (1) Prepare for lookup
0065                       ;-------------------------------------------------------
0066 67C4 04C2  14         clr   r2                    ; Length counter
0067 67C6 0203  20         li    r3,>2c00              ; Delimiter is ASCII 44 (>2c) ","
     67C8 2C00     
0068               
0069 67CA C120  34         mov   @fb.current,tmp0      ; Start address in framebuffer
     67CC A302     
0070 67CE C184  18         mov   tmp0,tmp2             ; \ calculate end address of
0071 67D0 A1A0  34         a     @fb.row.length,tmp2   ; / source line in framebuffer
     67D2 A308     
0072               
0073 67D4 0205  20         li    tmp1,cmdb.dflt.fname  ; Destination for character copy
     67D6 A7B6     
0074 67D8 0585  14         inc   tmp1                  ; Skip length byte, will be set later
0075               
0076 67DA 0207  20         li    tmp3,def.devices      ; Get string with valid devices
     67DC 3DA0     
0077 67DE C217  26         mov   *tmp3,tmp4            ; \ Get length byte, skipping
0078 67E0 0988  32         srl   tmp4,8                ; / 1st following character
0079 67E2 A207  18         a     tmp3,tmp4             ; Calc end address of valid devices
0080 67E4 05C7  14         inct  tmp3                  ; Skip length byte and following char
0081                       ;-------------------------------------------------------
0082                       ; (2) Compare char in framebuffer with device lookup
0083                       ;-------------------------------------------------------
0084               fb.scan.fname.device.loop:
0085 67E6 95D4  34         cb    *tmp0,*tmp3           ; Does char match with lookup?
0086 67E8 160A  14         jne   fb.scan.fname.nextdev.loop
0087                                                   ; No, look for next device (3)
0088               
0089 67EA DD74  42         movb  *tmp0+,*tmp1+         ; Copy byte to destination
0090 67EC 0582  14         inc   r2                    ; Increase length
0091               
0092 67EE 0587  14         inc   tmp3                  ; Next char in lookup
0093 67F0 90D7  26         cb    *tmp3,r3              ; Did we find the delimiter?
0094 67F2 130A  14         jeq   fb.scan.fname.copy.rest
0095                                                   ; Yes, device match. Now copy rest (4)
0096               
0097 67F4 8207  18         c     tmp3,tmp4             ; At end in lookup string?
0098 67F6 1323  14         jeq   fb.scan.fname.exit    ; Yes, exit without match
0099               
0100 67F8 8184  18         c     tmp0,tmp2             ; End of line reached?
