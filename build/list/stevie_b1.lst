0035                                                   ; | o  @outparm1 = Length of line
0036                                                   ; / o  @outparm2 = SAMS page
0037               
0038 382C C820  54         mov   @outparm1,@fb.row.length
     382E A018     
     3830 A308     
0039                                                   ; Save row length
0040                       ;------------------------------------------------------
0041                       ; Exit
0042                       ;------------------------------------------------------
0043               edb.line.getlength2.exit:
0044                       .popregs 0                  ; Pop registers and return to caller
     **** ****     > POPREGS
0014 3832 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 3834 C2F9  30         mov   *stack+,r11           ; Pop r11
0017 3836 045B  20         b     *r11                  ; Return
                   < edb.line.getlength2.asm
