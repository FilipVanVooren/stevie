0215                                                   ; /
0216               
0217 6624 8820  50         c     @parm1,@edb.lines     ; Now at BOT in editor buffer after delete?
     6626 A006     
     6628 A504     
0218 662A 1302  14         jeq   edkey.action.del_line.refresh
