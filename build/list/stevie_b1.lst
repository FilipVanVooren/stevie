0192               edkey.key.process.crash:
0193 6244 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     6246 FFCE     
0194 6248 06A0  32         bl    @cpu.crash            ; / File error occured. Halt system.
     624A 2026     
0195                       ;-------------------------------------------------------
0196                       ; Check ENTER key if ID >= 100 and close pane if match
0197                       ;-------------------------------------------------------
0198               edkey.key.process.enter:
0199 624C C120  34         mov   @keycode1,tmp0        ; Get key
     624E A028     
0200 6250 0284  22         ci    tmp0,key.space        ; SPACE ?
     6252 0020     
0201 6254 1606  14         jne   edkey.key.process.exit
