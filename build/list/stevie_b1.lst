0001               * FILE......: edkey.fb.goto.asm
0002               * Purpose...: Goto specified line
0003               
0004               ***************************************************************
0005               * edkey.fb.goto.toprow
0006               *
0007               * Refresh frame buffer with specified top-row and row offset,
0008               * align variables in editor buffer to match with that position.
0009               *
0010               * Internal method that needs to be called via jmp or branch
0011               * instruction.
0012               ***************************************************************
0013               * b    @edkey.fb.goto.toprow
0014               *--------------------------------------------------------------
0015               * INPUT
0016               * @parm1  = Line in editor buffer to display as top row (goto)
0017               * @parm2  = Row offset in frame buffer
0018               *
0019               * Register usage
0020               * none
0021               ********|*****|*********************|**************************
0022               edkey.fb.goto.toprow:
0023 64B6 0649  14         dect  stack
0024 64B8 C644  30         mov   tmp0,*stack           ; Push tmp0
0025                       ;-------------------------------------------------------
0026                       ; Assert on line
0027                       ;-------------------------------------------------------
0028 64BA C120  34         mov   @parm1,tmp0           ; \ Line number 0?
     64BC A006     
0029 64BE 8120  34         c     @edb.lines,tmp0       ; | Line number beyond EOF ?
     64C0 A504     
0030 64C2 1B05  14         jh    edkey.fb.goto.offset  ; / No, keep on going
0031                       ;-------------------------------------------------------
0032                       ; Goto EOF
0033                       ;-------------------------------------------------------
0034 64C4 C820  54         mov   @edb.lines,@parm1     ; \ Goto EOF
     64C6 A504     
     64C8 A006     
0035 64CA 0620  34         dec   @parm1                ; / Base 0
     64CC A006     
0036                       ;-------------------------------------------------------
0037                       ; Assert on row offset in frame buffer
0038                       ;-------------------------------------------------------
0039               edkey.fb.goto.offset:
0040 64CE 8820  50         c     @parm2,@fb.scrrows    ; Row offset off page ?
     64D0 A008     
     64D2 A31E     
0041 64D4 1104  14         jlt   edkey.fb.goto.row     ; No, use row offset
0042 64D6 C820  54         mov   @fb.scrrows,@fb.row   ; Limit row offset
     64D8 A31E     
     64DA A306     
0043 64DC 1003  14         jmp   edkey.fb.goto.line    ; Goto line
0044               edkey.fb.goto.row:
0045 64DE C820  54         mov   @parm2,@fb.row        ; Set row offset
     64E0 A008     
     64E2 A306     
0046                       ;-------------------------------------------------------
0047                       ; Goto line
0048                       ;-------------------------------------------------------
0049               edkey.fb.goto.line:
0050 64E4 0720  34         seto  @fb.status.dirty      ; Trigger refresh of status lines
     64E6 A31C     
0051               
0052 64E8 06A0  32         bl    @fb.refresh           ; \ Refresh frame buffer
     64EA 7864     
0053                                                   ; | i  @parm1 = Line to start with
0054                                                   ; /             (becomes @fb.topline)
0055               
0056 64EC 04E0  34         clr   @fb.column            ; Frame buffer column 0
     64EE A30C     
0057               
0058 64F0 C120  34         mov   @fb.row,tmp0          ; \
     64F2 A306     
0059 64F4 0A84  32         sla   tmp0,8                ; | Position VDP cursor
0060 64F6 C804  30         mov   tmp0,@wyx             ; /
     64F8 832A     
0061               
0062 64FA 06A0  32         bl    @fb.calc.pointer      ; Calculate position in frame buffer
     64FC 31FC     
0063                                                   ; \ i   @fb.top      = Address top row in FB
0064                                                   ; | i   @fb.topline  = Top line in FB
0065                                                   ; | i   @fb.row      = Current row in FB
0066                                                   ; |                  (offset 0..@fb.scrrows)
0067                                                   ; | i   @fb.column   = Current column in FB
0068                                                   ; | i   @fb.colsline = Columns per line FB
0069                                                   ; |
0070                                                   ; / o   @fb.current  = Updated pointer
0071               
0072 64FE 06A0  32         bl    @edb.line.getlength2  ; \ Get length current line
     6500 3814     
0073                                                   ; | i  @fb.row        = Row in frame buffer
0074                                                   ; / o  @fb.row.length = Length of row
0075               
0076                       ;-------------------------------------------------------
0077                       ; Exit
0078                       ;-------------------------------------------------------
0079 6502 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0080 6504 0460  28         b     @edkey.keyscan.hook.debounce
     6506 2F1C     
0081                                                   ; Back to editor main
0082               
0083               
0084               *---------------------------------------------------------------
0085               * Goto specified line (@parm1) in editor buffer
0086               *---------------------------------------------------------------
0087               edkey.action.goto:
0088                       ;-------------------------------------------------------
0089                       ; Crunch current row if dirty
0090                       ;-------------------------------------------------------
0091 6508 8820  50         c     @fb.row.dirty,@w$ffff
     650A A30A     
     650C 2022     
0092 650E 1609  14         jne   edkey.action.goto.refresh
0093               
0094 6510 0649  14         dect  stack
0095 6512 C660  46         mov   @parm1,*stack         ; Push parm1
     6514 A006     
0096               
0097 6516 06A0  32         bl    @edb.line.pack.fb     ; Copy line to editor buffer
     6518 7300     
0098                                                   ; \ i   @fb.top      = Address top row in FB
0099                                                   ; | i   @fb.row      = Current row in FB
0100                                                   ; | i   @fb.column   = Current column in FB
0101                                                   ; / i   @fb.colsline = Cols per line in FB
0102               
0103 651A C839  50         mov   *stack+,@parm1        ; Pop parm1
     651C A006     
0104 651E 04E0  34         clr   @fb.row.dirty         ; Current row no longer dirty
     6520 A30A     
0105                       ;-------------------------------------------------------
0106                       ; Refresh page
0107                       ;-------------------------------------------------------
0108               edkey.action.goto.refresh:
0109 6522 0720  34         seto  @fb.colorize          ; Colorize M1/M2 marked lines (if present)
     6524 A312     
0110               
0111 6526 04E0  34         clr   @parm2                ; No row offset in frame buffer
     6528 A008     
0112               
0113 652A 0460  28         b     @edkey.fb.goto.toprow ; \ Position cursor and exit
     652C 64B6     
0114                                                   ; | i  @parm1 = Top line in editor buffer
0115                                                   ; / i  @parm2 = Row offset in frame buffer
