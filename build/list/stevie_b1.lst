0084               *--------------------------------------------------------------
0085 2F7E 05C4  22         inct  tmp0                  ; Second word of slot data
0086 2F80 0594  30         inc   *tmp0                 ; Update tick count in slot
0087 2F82 C194  38         mov   *tmp0,tmp2            ; Get second word of slot data
0088 2F84 9820  42         cb    @tmp2hb,@tmp2lb       ; Slot target count = Slot internal counter ?
     2F86 830C     
     2F88 830D     
0089 2F8A 1608  14         jne   tmgr10                ; No, get next slot
0090 2F8C 0246  30         andi  tmp2,>ff00            ; Clear internal counter
     2F8E FF00     
0091 2F90 C506  38         mov   tmp2,*tmp0            ; Update timer table
0092               *--------------------------------------------------------------
