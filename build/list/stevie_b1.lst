0001               * FILE......: rom.farjump.asm
0002               * Purpose...: Trampoline to routine in other ROM bank
0003               
0004               ***************************************************************
0005               * rom.farjump - Jump to routine in specified bank
0006               ***************************************************************
0007               *  bl   @rom.farjump
0008               *       data p0,p1,p2
0009               *--------------------------------------------------------------
0010               *  p0 = Write address of target ROM bank
0011               *  p1 = Vector address with target address to jump to
0012               *  p2 = Write address of source ROM bank
0013               *--------------------------------------------------------------
0014               *  bl   @xrom.farjump
0015               *
0016               *  tmp0 = Write address of target ROM bank
0017               *  tmp1 = Vector address with target address to jump to
0018               *  tmp2 = Write address of source ROM bank
0019               *--------------------------------------------------------------
0020               * Register usage
0021               * tmp0,tmp1,tmp2,tmp3
0022               *--------------------------------------------------------------
0023               *  Remarks
0024               *  r11 gets pushed/popped from farjump stack, not from normal
0025               *  value stack.
0026               ********|*****|*********************|**************************
0027               rom.farjump:
0028 30D8 0649  14         dect  stack
0029 30DA C644  30         mov   tmp0,*stack           ; Push tmp0
0030 30DC 0649  14         dect  stack
0031 30DE C645  30         mov   tmp1,*stack           ; Push tmp1
0032 30E0 0649  14         dect  stack
0033 30E2 C646  30         mov   tmp2,*stack           ; Push tmp2
0034 30E4 0649  14         dect  stack
0035 30E6 C647  30         mov   tmp3,*stack           ; Push tmp3
0036                       ;------------------------------------------------------
0037                       ; Parameters
0038                       ;------------------------------------------------------
0039 30E8 C13B  30         mov   *r11+,tmp0            ; P0
0040 30EA C17B  30         mov   *r11+,tmp1            ; P1
0041 30EC C1BB  30         mov   *r11+,tmp2            ; P2
0042 30EE 1008  14         jmp   xrom.farjump.push_return
0043                       ;------------------------------------------------------
0044                       ; Push registers to value stack (but not r11!)
0045                       ;------------------------------------------------------
0046               xrom.farjump:
0047 30F0 0649  14         dect  stack
0048 30F2 C644  30         mov   tmp0,*stack           ; Push tmp0
0049 30F4 0649  14         dect  stack
0050 30F6 C645  30         mov   tmp1,*stack           ; Push tmp1
0051 30F8 0649  14         dect  stack
0052 30FA C646  30         mov   tmp2,*stack           ; Push tmp2
0053 30FC 0649  14         dect  stack
0054 30FE C647  30         mov   tmp3,*stack           ; Push tmp3
0055                       ;------------------------------------------------------
0056                       ; Push to farjump return stack
0057                       ;------------------------------------------------------
0058               xrom.farjump.push_return:
0059 3100 0284  22         ci    tmp0,>6000            ; Invalid bank write address?
     3102 6000     
0060 3104 1116  14         jlt   rom.farjump.bankswitch.failed1
0061                                                   ; Crash if bogus value in bank write address
0062               
0063 3106 C1E0  34         mov   @tv.fj.stackpnt,tmp3  ; Get farjump stack pointer
     3108 A22E     
0064 310A 0647  14         dect  tmp3
0065 310C C5CB  30         mov   r11,*tmp3             ; Push return address to farjump stack
0066 310E 0647  14         dect  tmp3
0067 3110 C5C6  30         mov   tmp2,*tmp3            ; Push source ROM bank to farjump stack
0068 3112 C807  38         mov   tmp3,@tv.fj.stackpnt  ; Set farjump stack pointer
     3114 A22E     
0069               
0073               
0074                       ;------------------------------------------------------
0075                       ; Bankswitch to target 8K ROM bank
0076                       ;------------------------------------------------------
0077               rom.farjump.bankswitch.target.rom8k:
0078 3116 04D4  26         clr   *tmp0                 ; Switch to target ROM bank 8K >6000
0079 3118 1004  14         jmp   rom.farjump.bankswitch.tgt.done
0080                       ;------------------------------------------------------
0081                       ; Bankswitch to target 4K ROM / 4K RAM banks (FG99 advanced mode)
0082                       ;------------------------------------------------------
0083               rom.farjump.bankswitch.tgt.advfg99:
0084 311A 04D4  26         clr   *tmp0                 ; Switch to target ROM bank 4K >6000
0085 311C 0224  22         ai    tmp0,>0800
     311E 0800     
0086 3120 04D4  26         clr   *tmp0                 ; Switch to target RAM bank 4K >7000
0087                       ;------------------------------------------------------
0088                       ; Bankswitch to target bank(s) completed
0089                       ;------------------------------------------------------
0090               rom.farjump.bankswitch.tgt.done:
0091                       ;------------------------------------------------------
0092                       ; Deref vector from @trmpvector if >ffff
0093                       ;------------------------------------------------------
0094 3122 0285  22         ci    tmp1,>ffff
     3124 FFFF     
0095 3126 1602  14         jne   !
0096 3128 C160  34         mov   @trmpvector,tmp1
     312A A034     
0097                       ;------------------------------------------------------
0098                       ; Deref value in vector
0099                       ;------------------------------------------------------
0100 312C C115  26 !       mov   *tmp1,tmp0            ; Deref value in vector address
0101 312E 1301  14         jeq   rom.farjump.bankswitch.failed1
0102                                                   ; Crash if null-pointer in vector
0103               
0104 3130 1004  14         jmp   rom.farjump.bankswitch.call
0105                                                   ; Call function in target bank
0106                       ;------------------------------------------------------
0107                       ; Assert 1 failed before bank-switch
0108                       ;------------------------------------------------------
0109               rom.farjump.bankswitch.failed1:
0110 3132 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     3134 FFCE     
0111 3136 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     3138 2026     
0112                       ;------------------------------------------------------
0113                       ; Call function in target bank
0114                       ;------------------------------------------------------
0115               rom.farjump.bankswitch.call:
0116 313A 0694  24         bl    *tmp0                 ; Call function
0117                       ;------------------------------------------------------
0118                       ; Bankswitch back to source bank
0119                       ;------------------------------------------------------
0120               rom.farjump.return:
0121 313C C120  34         mov   @tv.fj.stackpnt,tmp0  ; Get farjump stack pointer
     313E A22E     
0122 3140 C154  26         mov   *tmp0,tmp1            ; Get bank write address of caller
0123 3142 1319  14         jeq   rom.farjump.bankswitch.failed2
0124                                                   ; Crash if null-pointer in address
0125               
0126 3144 04F4  30         clr   *tmp0+                ; Remove bank write address from
0127                                                   ; farjump stack
0128               
0129 3146 C2D4  26         mov   *tmp0,r11             ; Get return addr of caller for return
0130               
0131 3148 04F4  30         clr   *tmp0+                ; Remove return address of caller from
0132                                                   ; farjump stack
0133               
0134                       ;------------------------------------------------------
0135                       ; Assert on memory source address in cartridge space
0136                       ;------------------------------------------------------
0137               rom.farjump.assert.cart:
0138 314A 028B  22         ci    r11,>6000
     314C 6000     
0139 314E 1104  14         jlt   rom.farjump.assert.lowmem
0140 3150 028B  22         ci    r11,>7fff
     3152 7FFF     
0141 3154 1510  14         jgt   rom.farjump.bankswitch.failed2
0142 3156 1006  14         jmp   !
0143                       ;------------------------------------------------------
0144                       ; Assert on memory source address in low memory expansion
0145                       ;------------------------------------------------------
0146               rom.farjump.assert.lowmem:
0147 3158 028B  22         ci    r11,>2000
     315A 2000     
0148 315C 110C  14         jlt   rom.farjump.bankswitch.failed2
0149 315E 028B  22         ci    r11,>3fff
     3160 3FFF     
0150 3162 1509  14         jgt   rom.farjump.bankswitch.failed2
0151                       ;------------------------------------------------------
0152                       ; Update farjump return stack pointer
0153                       ;------------------------------------------------------
0154 3164 C804  38 !       mov   tmp0,@tv.fj.stackpnt  ; Update farjump return stack pointer
     3166 A22E     
0155               
0159                       ;------------------------------------------------------
0160                       ; Bankswitch to source 8K ROM bank
0161                       ;------------------------------------------------------
0162               rom.farjump.bankswitch.src.rom8k:
0163 3168 04D5  26         clr   *tmp1                 ; Switch to source ROM bank 8K >6000
0164 316A 1009  14         jmp   rom.farjump.exit
0165                       ;------------------------------------------------------
0166                       ; Bankswitch to source 4K ROM / 4K RAM banks (FG99 advanced mode)
0167                       ;------------------------------------------------------
0168               rom.farjump.bankswitch.src.advfg99:
0169 316C 04D5  26         clr   *tmp1                 ; Switch to source ROM bank 4K >6000
0170 316E 0225  22         ai    tmp1,>0800
     3170 0800     
0171 3172 04D5  26         clr   *tmp1                 ; Switch to source RAM bank 4K >7000
0172 3174 1004  14         jmp   rom.farjump.exit
0173                       ;------------------------------------------------------
0174                       ; Assert 2 failed after bank-switch
