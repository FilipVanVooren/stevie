0014 32C4 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 32C6 C2F9  30         mov   *stack+,r11           ; Pop r11
0017 32C8 045B  20         b     *r11                  ; Return
                   < idx.asm
