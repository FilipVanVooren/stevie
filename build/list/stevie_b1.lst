0027 7048 0284  22         ci    tmp0,>2000
     704A 2000     
0028 704C 1104  14         jlt   !                     ; Invalid address, crash
0029               
0030 704E 0284  22         ci    tmp0,>7fff
     7050 7FFF     
0031 7052 1501  14         jgt   !                     ; Invalid address, crash
