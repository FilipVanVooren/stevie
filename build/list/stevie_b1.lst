0035                       copy  "edb.line.mappage.asm"    ; Activate edbuf SAMS page for line
     **** ****     > edb.line.mappage.asm
0001               * FILE......: edb.line.mappage.asm
0002               * Purpose...: Editor buffer SAMS setup
0003               
0004               
0005               ***************************************************************
0006               * edb.line.mappage
0007               * Activate editor buffer SAMS page for line
0008               ***************************************************************
0009               * bl  @edb.line.mappage
0010               *
0011               * tmp0 = Line number in editor buffer (base 1)
0012               *--------------------------------------------------------------
0013               * OUTPUT
0014               * outparm1 = Pointer to line in editor buffer
0015               * outparm2 = SAMS page
0016               *--------------------------------------------------------------
0017               * Register usage
0018               * tmp0,tmp1
0019               ***************************************************************
0020               edb.line.mappage:
0021 3786 0649  14         dect  stack
0022 3788 C64B  30         mov   r11,*stack            ; Push return address
0023 378A 0649  14         dect  stack
0024 378C C644  30         mov   tmp0,*stack           ; Push tmp0
0025 378E 0649  14         dect  stack
0026 3790 C645  30         mov   tmp1,*stack           ; Push tmp1
0027                       ;------------------------------------------------------
0028                       ; Assert
0029                       ;------------------------------------------------------
0030 3792 8804  34         c     tmp0,@edb.lines       ; Non-existing line?
     3794 A504     
0031 3796 1204  14         jle   edb.line.mappage.lookup
0032                                                   ; All checks passed, continue
0033                                                   ;--------------------------
0034                                                   ; Assert failed
0035                                                   ;--------------------------
0036 3798 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     379A FFCE     
0037 379C 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     379E 2026     
0038                       ;------------------------------------------------------
0039                       ; Lookup SAMS page for line in parm1
0040                       ;------------------------------------------------------
0041               edb.line.mappage.lookup:
0042 37A0 C804  38         mov   tmp0,@parm1           ; Set line number in editor buffer
     37A2 A006     
0043               
0044 37A4 06A0  32         bl    @idx.pointer.get      ; Get pointer to line
     37A6 3630     
0045                                                   ; \ i  parm1    = Line number
0046                                                   ; | o  outparm1 = Pointer to line
0047                                                   ; / o  outparm2 = SAMS page
0048               
0049 37A8 C120  34         mov   @outparm2,tmp0        ; SAMS page
     37AA A01A     
0050 37AC C160  34         mov   @outparm1,tmp1        ; Pointer to line
     37AE A018     
0051 37B0 130B  14         jeq   edb.line.mappage.exit ; Nothing to page-in if NULL pointer
0052                                                   ; (=empty line)
0053                       ;------------------------------------------------------
0054                       ; Determine if requested SAMS page is already active
0055                       ;------------------------------------------------------
0056 37B2 8120  34         c     @tv.sams.c000,tmp0    ; Compare with active page editor buffer
     37B4 A208     
0057 37B6 1308  14         jeq   edb.line.mappage.exit ; Request page already active, so exit
0058                       ;------------------------------------------------------
0059                       ; Activate requested SAMS page
0060                       ;-----------------------------------------------------
0061 37B8 06A0  32         bl    @xsams.page.set       ; Switch SAMS memory page
     37BA 25D6     
0062                                                   ; \ i  tmp0 = SAMS page
0063                                                   ; / i  tmp1 = Memory address
0064               
0065 37BC C820  54         mov   @outparm2,@tv.sams.c000
     37BE A01A     
     37C0 A208     
0066                                                   ; Set page in shadow registers
0067               
0068 37C2 C820  54         mov   @outparm2,@edb.sams.page
     37C4 A01A     
     37C6 A518     
0069                                                   ; Set current SAMS page
0070                       ;------------------------------------------------------
0071                       ; Exit
0072                       ;------------------------------------------------------
0073               edb.line.mappage.exit:
0074                       .popregs 1                  ; Pop registers and return to caller
     **** ****     > POPREGS
0011 37C8 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 37CA C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 37CC C2F9  30         mov   *stack+,r11           ; Pop r11
0017 37CE 045B  20         b     *r11                  ; Return
