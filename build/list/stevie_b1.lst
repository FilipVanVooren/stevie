     **** ****     > tv.uint16.pack.asm
0001               * FILE......: tv.uint16.pack.asm
0002               * Purpose...: Pack string to 16bit unsigned integer
0003               
0004               ***************************************************************
0005               * tv.uint16.pack
0006               * Pack (number) string to 16bit unsigned integer
0007               ***************************************************************
0008               * bl @tv.uint16.pack
0009               *--------------------------------------------------------------
0010               * INPUT
0011               * @parm1 = Pointer to input string (no length-byte prefix!)
0012               *--------------------------------------------------------------
0013               * OUTPUT
0014               * @outparm1 = 16bit unsigned integer
0015               * @outparm2 = 0 conversion ok, >FFFF invalid input
0016               *--------------------------------------------------------------
0017               * REMARK
0018               * None
0019               *--------------------------------------------------------------
0020               * Register usage
0021               * tmp0,tmp1,tmp2,tmp3,r0,r1
0022               ***************************************************************
0023               tv.uint16.pack:
0024 34A2 0649  14         dect  stack
0025 34A4 C64B  30         mov   r11,*stack            ; Push return address
0026 34A6 0649  14         dect  stack
0027 34A8 C644  30         mov   tmp0,*stack           ; Push tmp0
0028 34AA 0649  14         dect  stack
0029 34AC C645  30         mov   tmp1,*stack           ; Push tmp1
0030 34AE 0649  14         dect  stack
0031 34B0 C646  30         mov   tmp2,*stack           ; Push tmp2
0032 34B2 0649  14         dect  stack
0033 34B4 C647  30         mov   tmp3,*stack           ; Push tmp3
0034 34B6 0649  14         dect  stack
0035 34B8 C640  30         mov   r0,*stack             ; Push r0
0036 34BA 0649  14         dect  stack
0037 34BC C641  30         mov   r1,*stack             ; Push r1
0038                       ;------------------------------------------------------
0039                       ; Initialisation
0040                       ;------------------------------------------------------
0041 34BE C120  34         mov   @parm1,tmp0           ; Pointer to input string
     34C0 A006     
0042 34C2 04C5  14         clr   tmp1                  ; Termination character >00
0043 34C4 04E0  34         clr   @outparm1             ; Reset output parameters
     34C6 A018     
0044 34C8 04E0  34         clr   @outparm2             ; Reset output parameters
     34CA A01A     
0045                       ;------------------------------------------------------
0046                       ; Get string length
0047                       ;------------------------------------------------------
0048 34CC 06A0  32         bl    @xstring.getlenc      ; Get length of C-style string
     34CE 2B64     
0049                                                   ; \ i  tmp0   = Pointer to C-style string
0050                                                   ; | i  tmp1   = Termination character
0051                                                   ; / o  @waux1 = Length of string
0052                       ;------------------------------------------------------
0053                       ; Assert
0054                       ;------------------------------------------------------
0055 34D0 C1A0  30         mov   @waux1,tmp2           ; Get string length
     34D2 833C     
0056 34D4 131F  14         jeq   tv.uint16.pack.error  ; No input string given
0057 34D6 0286  22         ci    tmp2,5                ; Maximum 5 digits ?
     34D8 0005     
0058 34DA 151C  14         jgt   tv.uint16.pack.error  ; Input string too long
0059                       ;------------------------------------------------------
0060                       ; Prepare register values
0061                       ;------------------------------------------------------
0062 34DC C120  34         mov   @parm1,tmp0           ; Pointer to input string
     34DE A006     
0063               
0064 34E0 A186  18         a     tmp2,tmp2             ; \ Starting offset in tv.uint16.mpy
0065 34E2 0226  22         ai    tmp2,-10              ; |    10 - (tmp2 * 2)
     34E4 FFF6     
0066 34E6 0746  18         abs   tmp2                  ; /
0067               
0068 34E8 04C7  14         clr   tmp3                  ; Clear final uint16
0069                       ;------------------------------------------------------
0070                       ; Get character
0071                       ;------------------------------------------------------
0072               tv.uint16.pack.loop:
0073 34EA D174  28         movb  *tmp0+,tmp1           ; Get character
0074 34EC 0985  32         srl   tmp1,8                ; MSB to LSB
0075                       ;------------------------------------------------------
0076                       ; Character is ASCII 0 or blank (ASCII 32) ?
0077                       ;------------------------------------------------------
0078 34EE 1318  14         jeq   tv.uint16.pack.exit   ; End of string reached
0079 34F0 0285  22         ci    tmp1,32               ; Blank ?
     34F2 0020     
0080 34F4 1315  14         jeq   tv.uint16.pack.exit   ; End of string reached
0081                       ;------------------------------------------------------
0082                       ; Character in range 0..9 ?
0083                       ;------------------------------------------------------
0084 34F6 0225  22         ai    tmp1,-48              ; Remove ASCII offset
     34F8 FFD0     
0085 34FA 110C  14         jlt   tv.uint16.pack.error  ; Invalid character, exit
0086 34FC 0285  22         ci    tmp1,9
     34FE 0009     
0087 3500 1509  14         jgt   tv.uint16.pack.error  ; Invalid character, exit
0088                       ;------------------------------------------------------
0089                       ; Get base 10 multiplier for digit
0090                       ;------------------------------------------------------
0091 3502 C026  34         mov   @tv.uint16.mpy(tmp2),r0
     3504 3530     
0092                       ;------------------------------------------------------
0093                       ; Convert number to decimal 10 (final result in tmp3)
0094                       ;------------------------------------------------------
0095 3506 3805  58         mpy   tmp1,r0               ; Multiply digit with r0, 32bit result is
0096                                                   ; in r0 and r1. We need r1 (LSW)
0097 3508 A1C1  18         a     r1,tmp3               ; Add base10 value to final uint16
0098                       ;------------------------------------------------------
0099                       ; Prepare for next digit
0100                       ;------------------------------------------------------
0101 350A 05C6  14         inct  tmp2                  ; Update loop counter
0102 350C 0286  22         ci    tmp2,8                ; Last digit done?
     350E 0008     
0103 3510 12EC  14         jle   tv.uint16.pack.loop   ; Next iteration
0104 3512 1004  14         jmp   tv.uint16.pack.done   ; Done packing uint16, exit
0105                       ;------------------------------------------------------
0106                       ; Invalid character, stop packing and exit
0107                       ;------------------------------------------------------
0108               tv.uint16.pack.error:
0109 3514 04E0  34         clr   @outparm1             ; Empty uint16
     3516 A018     
0110 3518 0720  34         seto  @outparm2             ; Invalid input string
     351A A01A     
0111                       ;-------------------------------------------------------
0112                       ; Save final uint16
0113                       ;-------------------------------------------------------
0114               tv.uint16.pack.done:
0115 351C C807  38         mov   tmp3,@outparm1
     351E A018     
0116                       ;-------------------------------------------------------
0117                       ; Exit
0118                       ;-------------------------------------------------------
0119               tv.uint16.pack.exit:
0120 3520 C079  30         mov   *stack+,r1            ; Pop r1
0121 3522 C039  30         mov   *stack+,r0            ; Pop r0
0122                       .popregs 3                  ; Pop registers and return to caller
     **** ****     > POPREGS
0005 3524 C1F9  30         mov   *stack+,tmp3          ; Pop tmp3
0008 3526 C1B9  30         mov   *stack+,tmp2          ; Pop tmp2
0011 3528 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 352A C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 352C C2F9  30         mov   *stack+,r11           ; Pop r11
0017 352E 045B  20         b     *r11                  ; Return
