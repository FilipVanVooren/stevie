0001               * FILE......: edkey.fb.del.asm
0002               * Purpose...: Delete related actions in frame buffer pane.
0003               
0004               *---------------------------------------------------------------
0005               * Delete character
0006               *---------------------------------------------------------------
0007               edkey.action.del_char:
0008                       ;-------------------------------------------------------
0009                       ; Skip if editor buffer is locked
0010                       ;-------------------------------------------------------
0011 652E C120  34         mov   @edb.locked,tmp0      ; Is editor buffer locked?
     6530 A5DA     
0012 6532 163D  14         jne   edkey.action.del_char.exit
0013                                                   ; Yes, exit
0014                       ;-------------------------------------------------------
0015                       ; Get current line in editor buffer
0016                       ;-------------------------------------------------------
0017 6534 0720  34         seto  @edb.dirty            ; Editor buffer dirty (text changed!)
     6536 A506     
0018 6538 06A0  32         bl    @fb.calc.pointer      ; Calculate position in frame buffer
     653A 31FC     
0019                                                   ; \ i   @fb.top      = Address top row in FB
0020                                                   ; | i   @fb.topline  = Top line in FB
0021                                                   ; | i   @fb.row      = Current row in FB
0022                                                   ; |                  (offset 0..@fb.scrrows)
0023                                                   ; | i   @fb.column   = Current column in FB
0024                                                   ; | i   @fb.colsline = Columns per line FB
0025                                                   ; |
0026                                                   ; / o   @fb.current  = Updated pointer
0027                       ;-------------------------------------------------------
0028                       ; Assert 1 - Empty line
0029                       ;-------------------------------------------------------
0030               edkey.action.del_char.sanity1:
0031 653C C1A0  34         mov   @fb.row.length,tmp2   ; Get line length
     653E A308     
0032 6540 1336  14         jeq   edkey.action.del_char.exit
0033                                                   ; Exit if empty line
0034 6542 C120  34         mov   @fb.current,tmp0      ; Get pointer
     6544 A302     
0035                       ;-------------------------------------------------------
0036                       ; Assert 2 - Already at EOL
0037                       ;-------------------------------------------------------
0038               edkey.action.del_char.sanity2:
0039 6546 C1C6  18         mov   tmp2,tmp3             ; \
0040 6548 0607  14         dec   tmp3                  ; / tmp3 = line length - 1
0041 654A 81E0  34         c     @fb.column,tmp3
     654C A30C     
0042 654E 110A  14         jlt   edkey.action.del_char.sanity3
0043                       ;------------------------------------------------------
0044                       ; At EOL - clear current character
0045                       ;------------------------------------------------------
0046 6550 04C5  14         clr   tmp1                  ; \ Overwrite with character >00
0047 6552 D505  30         movb  tmp1,*tmp0            ; /
0048 6554 C820  54         mov   @fb.column,@fb.row.length
     6556 A30C     
     6558 A308     
0049                                                   ; Row length - 1
0050 655A 0720  34         seto  @fb.row.dirty         ; Current row needs to be crunched/packed
     655C A30A     
0051 655E 0720  34         seto  @fb.dirty             ; Trigger screen refresh
     6560 A31A     
0052 6562 1025  14         jmp  edkey.action.del_char.exit
0053                       ;-------------------------------------------------------
0054                       ; Assert 3 - Abort if row length > 80
0055                       ;-------------------------------------------------------
0056               edkey.action.del_char.sanity3:
0057 6564 0286  22         ci    tmp2,colrow
     6566 0050     
0058 6568 1204  14         jle   edkey.action.del_char.prep
0059                                                   ; Continue if row length <= 80
0060                       ;-----------------------------------------------------------------------
0061                       ; CPU crash
0062                       ;-----------------------------------------------------------------------
0063 656A C80B  38         mov   r11,@>ffce            ; \ Save caller address
     656C FFCE     
0064 656E 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     6570 2026     
0065                       ;-------------------------------------------------------
0066                       ; Calculate number of characters to move
0067                       ;-------------------------------------------------------
0068               edkey.action.del_char.prep:
0069 6572 C1C6  18         mov   tmp2,tmp3             ; tmp3=line length
0070 6574 61E0  34         s     @fb.column,tmp3
     6576 A30C     
0071 6578 0607  14         dec   tmp3                  ; Remove base 1 offset
0072 657A A107  18         a     tmp3,tmp0             ; tmp0=Pointer to last char in line
0073 657C C144  18         mov   tmp0,tmp1
0074 657E 0585  14         inc   tmp1                  ; tmp1=tmp0+1
0075 6580 61A0  34         s     @fb.column,tmp2       ; tmp2=amount of characters to move
     6582 A30C     
0076                       ;-------------------------------------------------------
0077                       ; Setup pointers
0078                       ;-------------------------------------------------------
0079 6584 C120  34         mov   @fb.current,tmp0      ; Get pointer
     6586 A302     
0080 6588 C144  18         mov   tmp0,tmp1             ; \ tmp0 = Current character
0081 658A 0585  14         inc   tmp1                  ; / tmp1 = Next character
0082                       ;-------------------------------------------------------
0083                       ; Loop from current character until end of line
0084                       ;-------------------------------------------------------
0085               edkey.action.del_char.loop:
0086 658C DD35  42         movb  *tmp1+,*tmp0+         ; Overwrite current char with next char
0087 658E 0606  14         dec   tmp2
0088 6590 16FD  14         jne   edkey.action.del_char.loop
0089                       ;-------------------------------------------------------
0090                       ; Special treatment if line 80 characters long
0091                       ;-------------------------------------------------------
0092 6592 0206  20         li    tmp2,colrow
     6594 0050     
0093 6596 81A0  34         c     @fb.row.length,tmp2
     6598 A308     
0094 659A 1603  14         jne   edkey.action.del_char.save
0095 659C 0604  14         dec   tmp0                  ; One time adjustment
0096 659E 04C5  14         clr   tmp1
0097 65A0 D505  30         movb  tmp1,*tmp0            ; Write >00 character
0098                       ;-------------------------------------------------------
0099                       ; Save variables
0100                       ;-------------------------------------------------------
0101               edkey.action.del_char.save:
0102 65A2 0720  34         seto  @fb.row.dirty         ; Current row needs to be crunched/packed
     65A4 A30A     
0103 65A6 0720  34         seto  @fb.dirty             ; Trigger screen refresh
     65A8 A31A     
0104 65AA 0620  34         dec   @fb.row.length        ; @fb.row.length--
     65AC A308     
0105                       ;-------------------------------------------------------
0106                       ; Exit
0107                       ;-------------------------------------------------------
0108               edkey.action.del_char.exit:
0109 65AE 0460  28         b     @edkey.keyscan.hook.debounce ; Back to editor main
     65B0 2F1C     
0110               
0111               
0112               *---------------------------------------------------------------
0113               * Delete until end of line
0114               *---------------------------------------------------------------
0115               edkey.action.del_eol:
0116                       ;-------------------------------------------------------
0117                       ; Skip if editor buffer is locked
0118                       ;-------------------------------------------------------
0119 65B2 C120  34         mov   @edb.locked,tmp0      ; Is editor buffer locked?
     65B4 A5DA     
0120 65B6 1618  14         jne   edkey.action.del_eol.exit
0121                                                   ; Yes, exit
0122                       ;-------------------------------------------------------
0123                       ; Get current line in editor buffer
0124                       ;-------------------------------------------------------
0125 65B8 0720  34         seto  @edb.dirty            ; Editor buffer dirty (text changed!)
     65BA A506     
0126 65BC 06A0  32         bl    @fb.calc.pointer      ; Calculate position in frame buffer
     65BE 31FC     
0127                                                   ; \ i   @fb.top      = Address top row in FB
0128                                                   ; | i   @fb.topline  = Top line in FB
0129                                                   ; | i   @fb.row      = Current row in FB
0130                                                   ; |                  (offset 0..@fb.scrrows)
0131                                                   ; | i   @fb.column   = Current column in FB
0132                                                   ; | i   @fb.colsline = Columns per line FB
0133                                                   ; |
0134                                                   ; / o   @fb.current  = Updated pointer
0135               
0136 65C0 C1A0  34         mov   @fb.row.length,tmp2   ; Get line length
     65C2 A308     
0137 65C4 1311  14         jeq   edkey.action.del_eol.exit
0138                                                   ; Exit if empty line
0139                       ;-------------------------------------------------------
0140                       ; Prepare for erase operation
0141                       ;-------------------------------------------------------
0142 65C6 C120  34         mov   @fb.current,tmp0      ; Get pointer
     65C8 A302     
0143 65CA C1A0  34         mov   @fb.colsline,tmp2
     65CC A30E     
0144 65CE 61A0  34         s     @fb.column,tmp2
     65D0 A30C     
0145 65D2 04C5  14         clr   tmp1
0146                       ;-------------------------------------------------------
0147                       ; Loop until last column in frame buffer
0148                       ;-------------------------------------------------------
0149               edkey.action.del_eol_loop:
0150 65D4 DD05  32         movb  tmp1,*tmp0+           ; Overwrite current char with >00
0151 65D6 0606  14         dec   tmp2
0152 65D8 16FD  14         jne   edkey.action.del_eol_loop
0153                       ;-------------------------------------------------------
0154                       ; Save variables
0155                       ;-------------------------------------------------------
0156 65DA 0720  34         seto  @fb.row.dirty         ; Current row needs to be crunched/packed
     65DC A30A     
0157 65DE 0720  34         seto  @fb.dirty             ; Trigger screen refresh
     65E0 A31A     
0158               
0159 65E2 C820  54         mov   @fb.column,@fb.row.length
     65E4 A30C     
     65E6 A308     
0160                                                   ; Set new row length
0161                       ;-------------------------------------------------------
0162                       ; Exit
0163                       ;-------------------------------------------------------
0164               edkey.action.del_eol.exit:
0165 65E8 0460  28         b     @edkey.keyscan.hook.debounce ; Back to editor main
     65EA 2F1C     
