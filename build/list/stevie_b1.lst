0325               * Copy machine code to scratchpad (prepare tight loop)
0326               *--------------------------------------------------------------
0327 306C 06A0  32 runli7  bl    @loadmc
     306E 221A     
0328               *--------------------------------------------------------------
0329               * Initialize registers, memory, ...
0330               *--------------------------------------------------------------
0331 3070 04C1  14 runli9  clr   r1
0332 3072 04C2  14         clr   r2
0333 3074 04C3  14         clr   r3
0334 3076 0209  20         li    stack,sp2.stktop      ; Set top of stack (grows downwards!)
     3078 A900     
0335 307A 020F  20         li    r15,vdpw              ; Set VDP write address
     307C 8C00     
0337 307E 06A0  32         bl    @mute                 ; Mute sound generators
     3080 28AA     
0339               *--------------------------------------------------------------
0340               * Setup video memory
0341               *--------------------------------------------------------------
0348 3082 06A0  32         bl    @filv                 ; Clear 16K VDP memory
     3084 228E     
0349 3086 0000             data  >0000,>00,>3fff
     3088 0000     
     308A 3FFF     
0351 308C 06A0  32 runlia  bl    @filv
     308E 228E     
0352 3090 12C0             data  pctadr,spfclr,16      ; Load color table
     3092 00F4     
     3094 0010     
0353               *--------------------------------------------------------------
0354               * Check if there is a F18A present
0355               *--------------------------------------------------------------
0359 3096 06A0  32         bl    @f18unl               ; Unlock the F18A
     3098 278A     
0360 309A 06A0  32         bl    @f18chk               ; Check if F18A is there \
     309C 27B4     
0361 309E 06A0  32         bl    @f18chk               ; Check if F18A is there | js99er bug?
     30A0 27B4     
0362 30A2 06A0  32         bl    @f18chk               ; Check if F18A is there /
     30A4 27B4     
0363               
0364 30A6 06A0  32         bl    @putvr                ; Reset all F18a extended registers
     30A8 2332     
0365 30AA 3201                   data >3201            ; F18a VR50 (>32), bit
0366               
0367 30AC 06A0  32         bl    @f18lck               ; Lock the F18A again
     30AE 27A0     
