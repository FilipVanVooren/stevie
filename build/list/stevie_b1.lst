     **** ****     > idx.asm
0001               * FILE......: idx.asm
0002               * Purpose...: Index management
0003               
0004               ***************************************************************
0005               *  Size of index page is 4K and allows indexing of 2048 lines
0006               *  per page.
0007               *
0008               *  Each index slot (word) has the format:
0009               *    +-----+-----+
0010               *    | MSB | LSB |
0011               *    +-----|-----+   LSB = Pointer offset 00-ff.
0012               *
0013               *  MSB = SAMS Page 40-ff
0014               *        Allows addressing of up to 256 4K SAMS pages (1024 KB)
0015               *
0016               *  LSB = Pointer offset in range 00-ff
0017               *
0018               *        To calculate pointer to line in Editor buffer:
0019               *        Pointer address = edb.top + (LSB * 16)
0020               *
0021               *        Note that the editor buffer itself resides in own 4K memory range
0022               *        starting at edb.top
0023               *
0024               *        All support routines must assure that length-prefixed string in
0025               *        Editor buffer always start on a 16 byte boundary for being
0026               *        accessible via index.
0027               *
0028               *
0029               * The index starts at SAMS page >20 and can allocate up to page >3f
0030               * for a total of 32 pages (128 K). With that up to 65536 lines of text
0031               * can be addressed.
0032               ***************************************************************
0033               
0034               
0035               ***************************************************************
0036               * idx.init
0037               * Initialize index
0038               ***************************************************************
0039               * bl @idx.init
0040               *--------------------------------------------------------------
0041               * INPUT
0042               * none
0043               *--------------------------------------------------------------
0044               * OUTPUT
0045               * none
0046               *--------------------------------------------------------------
0047               * Register usage
0048               * tmp0
0049               ********|*****|*********************|**************************
0050               idx.init:
0051 3254 0649  14         dect  stack
0052 3256 C64B  30         mov   r11,*stack            ; Save return address
0053 3258 0649  14         dect  stack
0054 325A C644  30         mov   tmp0,*stack           ; Push tmp0
0055                       ;------------------------------------------------------
0056                       ; Initialize
0057                       ;------------------------------------------------------
0058 325C 0204  20         li    tmp0,idx.top
     325E B000     
0059 3260 C804  38         mov   tmp0,@edb.index.ptr   ; Set pointer to index in editor structure
     3262 A502     
0060               
0061 3264 C120  34         mov   @tv.sams.b000,tmp0
     3266 A206     
0062 3268 C804  38         mov   tmp0,@idx.sams.page   ; Set current SAMS page
     326A A600     
0063 326C C804  38         mov   tmp0,@idx.sams.lopage ; Set 1st SAMS page
     326E A602     
0064                       ;------------------------------------------------------
0065                       ; Clear all index pages
0066                       ;------------------------------------------------------
0067 3270 0224  22         ai    tmp0,4                ; \ Let's clear all index pages
     3272 0004     
0068 3274 C804  38         mov   tmp0,@idx.sams.hipage ; /
     3276 A604     
0069               
0070 3278 06A0  32         bl    @_idx.sams.mapcolumn.on
     327A 3296     
0071                                                   ; Index in continuous memory region
0072               
0073 327C 06A0  32         bl    @film
     327E 2236     
0074 3280 B000                   data idx.top,>00,idx.size * 5
     3282 0000     
     3284 5000     
0075                                                   ; Clear index
0076               
0077 3286 06A0  32         bl    @_idx.sams.mapcolumn.off
     3288 32CA     
0078                                                   ; Restore memory window layout
0079               
0080 328A C820  54         mov   @idx.sams.lopage,@idx.sams.hipage
     328C A602     
     328E A604     
0081                                                   ; Reset last SAMS page
0082                       ;------------------------------------------------------
0083                       ; Exit
0084                       ;------------------------------------------------------
0085               idx.init.exit:
0086                       .popregs 0                  ; Pop registers and return to caller
     **** ****     > POPREGS
0014 3290 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 3292 C2F9  30         mov   *stack+,r11           ; Pop r11
0017 3294 045B  20         b     *r11                  ; Return
                   < idx.asm
