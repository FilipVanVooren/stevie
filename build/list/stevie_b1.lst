0002               * Purpose...: Actions in Goto dialog
0003               
0004               *---------------------------------------------------------------
0005               * Goto line
0006               *---------------------------------------------------------------
0007               edkey.action.cmdb.goto:
0008                       ;-------------------------------------------------------
0009                       ; Exit on empty input string
0010                       ;-------------------------------------------------------
0011 70D6 06A0  32         bl    @cmdb.cmd.getlength   ; Get length of current command
     70D8 779E     
0012 70DA C120  34         mov   @outparm1,tmp0        ; Length == 0 ?
     70DC A018     
0013 70DE 1321  14         jeq   edkey.action.cmdb.goto.exit
0014                                                   ; Yes, exit
0015                       ;-------------------------------------------------------
0016                       ; Scan input line number and pack as uint16
0017                       ;-------------------------------------------------------
0018 70E0 0204  20         li    tmp0,cmdb.cmd         ; \ Pointer to command
     70E2 A733     
0019 70E4 C804  38         mov   tmp0,@parm1           ; / (no length-byte prefix)
     70E6 A006     
