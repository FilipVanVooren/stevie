0038                       copy  "edb.hipage.alloc.asm"    ; Check/increase highest SAMS page
     **** ****     > edb.hipage.alloc.asm
0001               * FILE......: edb.hipage.alloc.asm
0002               * Purpose...: Editor buffer utilities
0003               
0004               
0005               ***************************************************************
0006               * edb.hipage.alloc
0007               * Check and increase highest SAMS page of editor buffer
0008               ***************************************************************
0009               *  bl   @edb.hipage.alloc
0010               *--------------------------------------------------------------
0011               * INPUT
0012               * @edb.next_free.ptr = Pointer to next free line
0013               *--------------------------------------------------------------
0014               * OUTPUT
0015               *--------------------------------------------------------------
0016               * Register usage
0017               * tmp0,tmp1
0018               ********|*****|*********************|**************************
0019               edb.hipage.alloc:
0020 3838 0649  14         dect  stack
0021 383A C64B  30         mov   r11,*stack            ; Save return address
0022 383C 0649  14         dect  stack
0023 383E C644  30         mov   tmp0,*stack           ; Push tmp0
0024 3840 0649  14         dect  stack
0025 3842 C645  30         mov   tmp1,*stack           ; Push tmp1
0026                       ;------------------------------------------------------
0027                       ; 1a. Check if highest SAMS page needs to be increased
0028                       ;------------------------------------------------------
0029               edb.hipage.alloc.check_setpage:
0030 3844 C120  34         mov   @edb.next_free.ptr,tmp0
     3846 A508     
0031                                                   ;--------------------------
0032                                                   ; Check for page overflow
0033                                                   ;--------------------------
0034 3848 0244  22         andi  tmp0,>0fff            ; Get rid of highest nibble
     384A 0FFF     
0035 384C 0224  22         ai    tmp0,82               ; Assume line of 80 chars (+2 bytes prefix)
     384E 0052     
0036 3850 0284  22         ci    tmp0,>1000 - 16       ; 4K boundary reached?
     3852 0FF0     
0037 3854 1105  14         jlt   edb.hipage.alloc.setpage
0038                                                   ; Not yet, don't increase SAMS page
0039                       ;------------------------------------------------------
0040                       ; 1b. Increase highest SAMS page (copy-on-write!)
0041                       ;------------------------------------------------------
0042 3856 05A0  34         inc   @edb.sams.hipage      ; Set highest SAMS page
     3858 A51C     
0043 385A C820  54         mov   @edb.top.ptr,@edb.next_free.ptr
     385C A500     
     385E A508     
0044                                                   ; Start at top of SAMS page again
0045                       ;------------------------------------------------------
0046                       ; 1c. Switch to SAMS page and exit
0047                       ;------------------------------------------------------
0048               edb.hipage.alloc.setpage:
0049 3860 C120  34         mov   @edb.sams.hipage,tmp0
     3862 A51C     
0050 3864 C160  34         mov   @edb.top.ptr,tmp1
     3866 A500     
0051 3868 06A0  32         bl    @xsams.page.set       ; Set SAMS page
     386A 25D6     
0052                                                   ; \ i  tmp0 = SAMS page number
0053                                                   ; / i  tmp1 = Memory address
0054               
0055 386C 1004  14         jmp   edb.hipage.alloc.exit
0056                       ;------------------------------------------------------
0057                       ; Check failed, crash CPU!
0058                       ;------------------------------------------------------
0059               edb.hipage.alloc.crash:
0060 386E C80B  38         mov   r11,@>ffce            ; \ Save caller address
     3870 FFCE     
0061 3872 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     3874 2026     
0062                       ;------------------------------------------------------
0063                       ; Exit
0064                       ;------------------------------------------------------
0065               edb.hipage.alloc.exit:
0066                       .popregs 1                  ; Pop registers and return to caller
     **** ****     > POPREGS
0011 3876 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 3878 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 387A C2F9  30         mov   *stack+,r11           ; Pop r11
0017 387C 045B  20         b     *r11                  ; Return
                   < edb.hipage.alloc.asm
                   < ram.resident.asm
