0010               ********|*****|*********************|**************************
0011               tv.tabs.table.lr:
0012 38DE 0007             byte  0,7,12,25             ; \   Default tab positions as used
     38E0 0C19     
0013 38E2 1E2D             byte  30,45,59,79           ; |   in Editor/Assembler module.
     38E4 3B4F     
0014 38E6 FF00             byte  >ff,0,0,0             ; |   Up to 11 positions supported.
     38E8 0000     
0015                                                   ; /   >ff means end-of-list.
0016               
0017               tv.tabs.table.rl:
0018 38EA 4F3B             byte  79,59,45,30           ; \   Default tab positions as used
     38EC 2D1E     
0019 38EE 190C             byte  25,12,7,0             ; |   in Editor/Assembler module.
     38F0 0700     
0020 38F2 FF00             byte  >ff,0,0,0             ; |   Up to 11 positions supported.
     38F4 0000     
0021                                                   ; /   >ff means end-of-list.
0022               
0023               ***************************************************************
0024               * Constants for numbers 0-10
0025               ********|*****|*********************|**************************
0026      2000     const.0       equ   w$0000          ; 0
0027      2002     const.1       equ   w$0001          ; 1
0028      2004     const.2       equ   w$0002          ; 2
0029 38F6 0003     const.3       data  3               ; 3
0030      2006     const.4       equ   w$0004          ; 4
0031 38F8 0005     const.5       data  5               ; 5
0032 38FA 0006     const.6       data  6               ; 6
0033 38FC 0007     const.7       data  7               ; 7
0034      2008     const.8       equ   w$0008          ; 8
0035 38FE 0009     const.9       data  9               ; 9
0036 3900 000A     const.10      data  10              ; 10 ; A
0037 3902 000B     const.11      data  11              ; 11 ; B
0038 3904 000C     const.12      data  12              ; 12 ; C
0039 3906 000D     const.13      data  13              ; 13 ; D
