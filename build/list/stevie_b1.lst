0201 6610 1207  14         jle   edkey.action.del_line.doit
0202                                                   ; No, is real line. Continue with delete.
0203               
0204 6612 C820  54         mov   @fb.topline,@parm1    ; Line to start with (becomes @fb.topline)
     6614 A304     
     6616 A006     
0205 6618 06A0  32         bl    @fb.refresh           ; Refresh frame buffer with EB content
     661A 7864     
0206                                                   ; \ i  @parm1 = Line to start with
0207                                                   ; /
0208 661C 0460  28         b     @edkey.action.up      ; Move cursor one line up
     661E 64A6     
