0026                       ;------------------------------------------------------
0027 381C C120  34         mov   @fb.topline,tmp0      ; Get top line in frame buffer
     381E A304     
0028 3820 A120  34         a     @fb.row,tmp0          ; Get current row in frame buffer
     3822 A306     
0029 3824 C804  38         mov   tmp0,@parm1
     3826 A006     
0030                       ;------------------------------------------------------
0031                       ; Get length
0032                       ;------------------------------------------------------
0033 3828 06A0  32         bl    @edb.line.getlength   ; Get length of specified line
     382A 37D0     
