0094               *--------------------------------------------------------------
0095 2F92 C804  34         mov   tmp0,@wtitmp          ; Save TMP0
     2F94 8330     
0096 2F96 0697  32         bl    *tmp3                 ; Call routine in slot
0097 2F98 C120  38 slotok  mov   @wtitmp,tmp0          ; Restore TMP0
     2F9A 8330     
0098               *--------------------------------------------------------------
0099               *  Prepare for next slot
0100               *--------------------------------------------------------------
0101 2F9C 058A  22 tmgr10  inc   r10                   ; Next slot
0102 2F9E 9820  42         cb    @r10lb,@btihi         ; Last slot done ?
     2FA0 8315     
     2FA2 8314     
0103 2FA4 1504  14         jgt   tmgr12                ; yes, Wait for next VDP interrupt
0104 2FA6 05C4  22         inct  tmp0                  ; Offset for next slot
0105 2FA8 10E8  14         jmp   tmgr9                 ; Process next slot
0106 2FAA 05C4  22 tmgr11  inct  tmp0                  ; Skip 2nd word of slot data
0107 2FAC 10F7  14         jmp   tmgr10                ; Process next slot
0108 2FAE 024A  30 tmgr12  andi  r10,>ff00             ; Use R10LB as tick counter. Reset.
     2FB0 FF00     
0109 2FB2 10B4  14         jmp   tmgr1
0110 2FB4 0280     tmdat   data  >0280                 ; Bit 8 (kernel thread) and bit 6 (user hook)
