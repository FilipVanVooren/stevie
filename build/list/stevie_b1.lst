0003               
0004               ****************************************************************
0005               * Editor - Process action keys
0006               ****************************************************************
0007               edkey.key.process:
0008 6150 0649  14         dect  stack
0009 6152 C64B  30         mov   r11,*stack            ; Save return address
0010 6154 0649  14         dect  stack
0011 6156 C644  30         mov   tmp0,*stack           ; Push tmp0
0012 6158 0649  14         dect  stack
0013 615A C645  30         mov   tmp1,*stack           ; Push tmp1
0014               
0015 615C 06A0  32         bl    @rsslot               ; \ Reset loop counter slot 1
     615E 300C     
0016 6160 0001                   data 1                ; / Prevent reading clock
0017               
0018 6162 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0019 6164 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0020 6166 C2F9  30         mov   *stack+,r11           ; Pop R11
0021               
0022 6168 C160  34         mov   @keycode1,tmp1        ; Get key pressed
     616A A028     
0023 616C 0A85  32         sla   tmp1,8                ; Move to MSB
0024 616E 0707  14         seto  tmp3                  ; EOL marker
0025                       ;-------------------------------------------------------
0026                       ; (1) Process key depending on pane with focus
0027                       ;-------------------------------------------------------
0028 6170 C1A0  34         mov   @tv.pane.focus,tmp2
     6172 A22A     
0029 6174 0286  22         ci    tmp2,pane.focus.fb    ; Framebuffer has focus ?
     6176 0000     
0030 6178 1307  14         jeq   edkey.key.process.special
0031                                                   ; First check special key combinations
0032               
0033 617A 0286  22         ci    tmp2,pane.focus.cmdb  ; Command buffer has focus ?
     617C 0001     
0034 617E 1322  14         jeq   edkey.key.process.loadmap.cmdb
0035                                                   ; Yes, so load CMDB keymap
0036                       ;-------------------------------------------------------
0037                       ; Pane without focus, crash
0038                       ;-------------------------------------------------------
0039 6180 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     6182 FFCE     
0040 6184 06A0  32         bl    @cpu.crash            ; / File error occured. Halt system.
     6186 2026     
0041                       ;-------------------------------------------------------
0042                       ; (2) Check special key combination
0043                       ;-------------------------------------------------------
0044               edkey.key.process.special:
0045 6188 0285  22         ci    tmp1,>2000            ; Space key pressed?
     618A 2000     
0046 618C 1618  14         jne   edkey.key.process.loadmap.editor
0047                                                   ; No, continue with normal checks
0048                       ;-------------------------------------------------------
0049                       ; (2a) Look for <ctrl> key
0050                       ;-------------------------------------------------------
0051 618E 0649  14         dect  stack
0052 6190 C644  30         mov   tmp0,*stack           ; Push tmp0
0053 6192 0649  14         dect  stack
0054 6194 C645  30         mov   tmp1,*stack           ; Push tmp1
0055 6196 0649  14         dect  stack
0056 6198 C64C  30         mov   r12,*stack            ; Push r12
0057               
0058 619A 04C4  14         clr   tmp0                  ; Keyboard column 0
0059 619C 020C  20         li    r12,>0024             ; CRU address decoder
     619E 0024     
0060 61A0 30C4  30         ldcr  tmp0,3                ; Select column
0061 61A2 020C  20         li    r12,>0006             ; Address of the first row
     61A4 0006     
0062 61A6 3605  48         stcr  tmp1,8                ; Read 8 rows
0063 61A8 0245  22         andi  tmp1,>4000            ; Test ctrl key
     61AA 4000     
0064 61AC 1605  14         jne   edkey.key.process.special.postprocess
0065                                                   ; No ctrl key pressed
0066                       ;-------------------------------------------------------
0067                       ; <ctrl> + space key pressed
0068                       ;-------------------------------------------------------
0069 61AE C339  30         mov   *stack+,r12           ; Pop r12
0070 61B0 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0071 61B2 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0072 61B4 0460  28         b     @edkey.action.block.mark
     61B6 67F2     
0073                                                   ; Set block M1/M2 marker
0074                       ;-------------------------------------------------------
0075                       ; Postprocessing <ctrl> + space check
0076                       ;-------------------------------------------------------
0077               edkey.key.process.special.postprocess:
0078 61B8 C339  30         mov   *stack+,r12           ; Pop r12
0079 61BA C179  30         mov   *stack+,tmp1          ; Pop tmp1
0080 61BC C139  30         mov   *stack+,tmp0          ; Pop tmp0
0081                       ;-------------------------------------------------------
0082                       ; (3) Load Editor keyboard map
0083                       ;-------------------------------------------------------
0084               edkey.key.process.loadmap.editor:
0085 61BE 0206  20         li    tmp2,keymap_actions.editor
     61C0 7B08     
0086 61C2 1002  14         jmp   edkey.key.check.next
0087                       ;-------------------------------------------------------
0088                       ; (4) Load CMDB keyboard map
0089                       ;-------------------------------------------------------
0090               edkey.key.process.loadmap.cmdb:
0091 61C4 0206  20         li    tmp2,keymap_actions.cmdb
     61C6 7BEA     
0092                       ;-------------------------------------------------------
0093                       ; (5) Iterate over keyboard map for matching action key
0094                       ;-------------------------------------------------------
0095               edkey.key.check.next:
0096 61C8 91D6  26         cb    *tmp2,tmp3            ; EOL reached ?
0097 61CA 1328  14         jeq   edkey.key.process.addbuffer
0098                                                   ; Yes, means no action key pressed,
0099                                                   ; so add character to buffer
0100                       ;-------------------------------------------------------
0101                       ; (6) Check for action key match
0102                       ;-------------------------------------------------------
0103 61CC 9585  26         cb    tmp1,*tmp2            ; Action key matched?
0104 61CE 130F  14         jeq   edkey.key.check.scope
0105                                                   ; Yes, check scope
0106                       ;-------------------------------------------------------
0107                       ; If key in range 'a..z' then also check 'A..Z'
0108                       ;-------------------------------------------------------
0109 61D0 0285  22         ci    tmp1,>6100            ; ASCII 97 'a'
     61D2 6100     
0110 61D4 1109  14         jlt   edkey.key.check.next.entry
0111               
0112 61D6 0285  22         ci    tmp1,>7a00            ; ASCII 122 'z'
     61D8 7A00     
0113 61DA 1506  14         jgt   edkey.key.check.next.entry
0114               
0115 61DC 0225  22         ai    tmp1,->2000           ; Make uppercase
     61DE E000     
0116 61E0 9585  26         cb    tmp1,*tmp2            ; Action key matched?
0117 61E2 1305  14         jeq   edkey.key.check.scope
0118                                                   ; Yes, check scope
0119                       ;-------------------------------------------------------
0120                       ; Key is no action key, keep case for later (buffer)
0121                       ;-------------------------------------------------------
0122 61E4 0225  22         ai    tmp1,>2000            ; Make lowercase
     61E6 2000     
0123               
0124               edkey.key.check.next.entry:
0125 61E8 0226  22         ai    tmp2,4                ; Skip current entry
     61EA 0004     
0126 61EC 10ED  14         jmp   edkey.key.check.next  ; Check next entry
0127                       ;-------------------------------------------------------
0128                       ; (7) Check scope of key
0129                       ;-------------------------------------------------------
0130               edkey.key.check.scope:
0131 61EE 0586  14         inc   tmp2                  ; Move to scope
0132 61F0 9816  42         cb    *tmp2,@tv.pane.focus+1
     61F2 A22B     
0133                                                   ; (1) Process key if scope matches pane
0134 61F4 1309  14         jeq   edkey.key.process.action
0135               
0136 61F6 9816  42         cb    *tmp2,@cmdb.dialog+1  ; (2) Process key if scope matches dialog
     61F8 A721     
0137 61FA 1306  14         jeq   edkey.key.process.action
0138                       ;-------------------------------------------------------
0139                       ; (8) Key pressed outside valid scope, ignore action entry
0140                       ;-------------------------------------------------------
0141 61FC 0226  22         ai    tmp2,3                ; Skip current entry
     61FE 0003     
0142 6200 C160  34         mov   @keycode1,tmp1        ; Restore original case of key
     6202 A028     
0143 6204 0A85  32         sla   tmp1,8                ; Move to MSB
0144 6206 10E0  14         jmp   edkey.key.check.next  ; Process next action entry
0145                       ;-------------------------------------------------------
0146                       ; (9) Trigger keyboard action
0147                       ;-------------------------------------------------------
0148               edkey.key.process.action:
0149 6208 0586  14         inc   tmp2                  ; Move to action address
0150 620A C196  26         mov   *tmp2,tmp2            ; Get action address
0151               
0152 620C 0204  20         li    tmp0,id.dialog.unsaved
     620E 0065     
0153 6210 8120  34         c     @cmdb.dialog,tmp0
     6212 A720     
0154 6214 1302  14         jeq   !                     ; Skip store pointer if in "Unsaved changes"
0155               
0156 6216 C806  38         mov   tmp2,@cmdb.action.ptr ; Store action address as pointer
     6218 A730     
0157 621A 0456  20 !       b     *tmp2                 ; Process key action
0158                       ;-------------------------------------------------------
0159                       ; (10) Add character to editor or cmdb buffer
0160                       ;-------------------------------------------------------
0161               edkey.key.process.addbuffer:
0162 621C C120  34         mov   @tv.pane.focus,tmp0   ; Frame buffer has focus?
     621E A22A     
0163 6220 1607  14         jne   !                     ; No, skip frame buffer processing
0164 6222 C120  34         mov   @edb.locked,tmp0      ; Is editor locked?
     6224 A5DA     
0165 6226 1619  14         jne   edkey.key.process.flash
0166                                                   ; Yes, flash screen and exit
0167 6228 C105  18         mov   tmp1,tmp0             ; Get keycode
0168 622A 06A0  32         bl    @edk.fb.char          ; Add character to frame buffer
     622C 698A     
0169                                                   ; \ i  tmp0 = Keycode (MSB)
0170                                                   ; /
0171 622E 1019  14         jmp   edkey.key.process.exit
0172                       ;-------------------------------------------------------
0173                       ; (11) CMDB buffer
0174                       ;-------------------------------------------------------
0175 6230 0284  22 !       ci    tmp0,pane.focus.cmdb  ; CMDB has focus ?
     6232 0001     
0176 6234 1607  14         jne   edkey.key.process.crash
0177                                                   ; No, crash
0178                       ;-------------------------------------------------------
0179                       ; Don't add character if dialog has ID >= 100
0180                       ;-------------------------------------------------------
0181 6236 C120  34         mov   @cmdb.dialog,tmp0
     6238 A720     
0182 623A 0284  22         ci    tmp0,99
     623C 0063     
0183 623E 1506  14         jgt   edkey.key.process.enter
0184                       ;-------------------------------------------------------
0185                       ; Add character to CMDB
0186                       ;-------------------------------------------------------
