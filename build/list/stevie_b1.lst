0250               *//////////////////////////////////////////////////////////////
0251               *                            TIMERS
0252               *//////////////////////////////////////////////////////////////
0253               
0254                       copy  "timers_tmgr.asm"          ; Timers / Thread scheduler
     **** ****     > timers_tmgr.asm
0001               * FILE......: timers_tmgr.asm
0002               * Purpose...: Timers / Thread scheduler
0003               
0004               ***************************************************************
0005               * TMGR - X - Start Timers/Thread scheduler
0006               ***************************************************************
0007               *  B @TMGR
0008               *--------------------------------------------------------------
0009               *  REMARKS
0010               *  Timer/Thread scheduler. Normally called from MAIN.
0011               *  This is basically the kernel keeping everything together.
0012               *  Do not forget to set BTIHI to highest slot in use.
0013               *
0014               *  Register usage in TMGR8 - TMGR11
0015               *  TMP0  = Pointer to timer table
0016               *  R10LB = Use as slot counter
0017               *  TMP2  = 2nd word of slot data
0018               *  TMP3  = Address of routine to call
0019               ********|*****|*********************|**************************
0020 2F18 0300  22 tmgr    limi  0                     ; No interrupt processing
     2F1A 0000     
0021               *--------------------------------------------------------------
0022               * Read VDP status register
0023               *--------------------------------------------------------------
0024 2F1C D360  38 tmgr1   movb  @vdps,r13             ; Save copy of VDP status register in R13
     2F1E 8802     
0025               *--------------------------------------------------------------
0026               * Latch sprite collision flag
0027               *--------------------------------------------------------------
0028 2F20 2360  38         coc   @wbit2,r13            ; C flag on ?
     2F22 201C     
0029 2F24 1602  14         jne   tmgr1a                ; No, so move on
0030 2F26 E0A0  42         soc   @wbit12,config        ; Latch bit 12 in config register
     2F28 2008     
0031               *--------------------------------------------------------------
0032               * Interrupt flag
0033               *--------------------------------------------------------------
0034 2F2A 2360  38 tmgr1a  coc   @wbit0,r13            ; Interupt flag set ?
     2F2C 2020     
0035 2F2E 1311  14         jeq   tmgr4                 ; Yes, process slots 0..n
0036               *--------------------------------------------------------------
0037               * Run speech player
0038               *--------------------------------------------------------------
0044               *--------------------------------------------------------------
0045               * Run kernel thread
0046               *--------------------------------------------------------------
0047 2F30 20A0  38 tmgr2   coc   @wbit8,config         ; Kernel thread blocked ?
     2F32 2010     
0048 2F34 1305  14         jeq   tmgr3                 ; Yes, skip to user hook
0049 2F36 20A0  38         coc   @wbit9,config         ; Kernel thread enabled ?
     2F38 200E     
0050 2F3A 1602  14         jne   tmgr3                 ; No, skip to user hook
0051 2F3C 0460  28         b     @kthread              ; Run kernel thread
     2F3E 2FB6     
0052               *--------------------------------------------------------------
0053               * Run user hook
0054               *--------------------------------------------------------------
0055 2F40 20A0  38 tmgr3   coc   @wbit6,config         ; User hook blocked ?
     2F42 2014     
0056 2F44 13EB  14         jeq   tmgr1
0057 2F46 20A0  38         coc   @wbit7,config         ; User hook enabled ?
     2F48 2012     
0058 2F4A 16E8  14         jne   tmgr1
0059 2F4C C120  38         mov   @wtiusr,tmp0
     2F4E 832E     
0060 2F50 0454  24         b     *tmp0                 ; Run user hook
0061               *--------------------------------------------------------------
0062               * Do internal housekeeping
0063               *--------------------------------------------------------------
0064 2F52 40A0  42 tmgr4   szc   @tmdat,config         ; Unblock kernel thread and user hook
     2F54 2FB4     
0065 2F56 C10A  30         mov   r10,tmp0
0066 2F58 0244  30         andi  tmp0,>00ff            ; Clear HI byte
     2F5A 00FF     
0067 2F5C 20A0  38         coc   @wbit2,config         ; PAL flag set ?
     2F5E 201C     
0068 2F60 1303  14         jeq   tmgr5
0069 2F62 0284  26         ci    tmp0,60               ; 1 second reached ?
     2F64 003C     
0070 2F66 1002  14         jmp   tmgr6
0071 2F68 0284  26 tmgr5   ci    tmp0,50
     2F6A 0032     
0072 2F6C 1101  14 tmgr6   jlt   tmgr7                 ; No, continue
0073 2F6E 1001  14         jmp   tmgr8
0074 2F70 058A  22 tmgr7   inc   r10                   ; Increase tick counter
0075               *--------------------------------------------------------------
0076               * Loop over slots
0077               *--------------------------------------------------------------
0078 2F72 C120  38 tmgr8   mov   @wtitab,tmp0          ; Pointer to timer table
     2F74 832C     
0079 2F76 024A  30         andi  r10,>ff00             ; Use R10LB as slot counter. Reset.
     2F78 FF00     
0080 2F7A C1D4  38 tmgr9   mov   *tmp0,tmp3            ; Is slot empty ?
0081 2F7C 1316  14         jeq   tmgr11                ; Yes, get next slot
0082               *--------------------------------------------------------------
