0027                       ;------------------------------------------------------
0028 3542 06A0  32         bl    @mknum                ; Convert unsigned number to string
     3544 2A56     
0029 3546 A006                   data parm1            ; \ i p0  = Pointer to 16bit unsigned number
0030 3548 A100                   data rambuf           ; | i p1  = Pointer to 5 byte string buffer
0031 354A 30                     byte 48               ; | i p2H = Offset for ASCII digit 0
0032 354B   20                   byte 32               ; / i p2L = Char for replacing leading 0's
0033               
0034 354C 0204  20         li    tmp0,uint16.unpacked
     354E A02C     
0035 3550 04F4  30         clr   *tmp0+                ; Clear string 01
0036 3552 04F4  30         clr   *tmp0+                ; Clear string 23
0037 3554 04F4  30         clr   *tmp0+                ; Clear string 34
0038               
0039 3556 06A0  32         bl    @trimnum              ; Trim unsigned number string
     3558 2AAE     
0040 355A A100                   data rambuf           ; \ i p0  = Pointer to 5 byte string buffer
0041 355C A02C                   data uint16.unpacked  ; | i p1  = Pointer to output buffer
0042 355E 0020                   data 32               ; / i p2  = Padding char to match against
0043                       ;-------------------------------------------------------
0044                       ; Exit
0045                       ;-------------------------------------------------------
0046               tv.uint16.unpack.exit:
0047                       .popregs 0                  ; Pop registers and return to caller
     **** ****     > POPREGS
0014 3560 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 3562 C2F9  30         mov   *stack+,r11           ; Pop r11
0017 3564 045B  20         b     *r11                  ; Return
