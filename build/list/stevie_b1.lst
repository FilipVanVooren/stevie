0146      A0C4     tib.scrpad.ptr    equ  core1.top + 196 ; Pointer to TI-Basic scratchpad in SAMS
0147      A0C6     tib.lnt.top.ptr   equ  core1.top + 198 ; Pointer to top of line number table
0148      A0C8     tib.lnt.bot.ptr   equ  core1.top + 200 ; Pointer to bottom of line number table
