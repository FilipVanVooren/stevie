0182                       copy  "data.vdpmodes.asm"   ; Table for VDP modes
     **** ****     > data.vdpmodes.asm
0001               * FILE......: data.vdp.modes.asm
0002               * Purpose...: VDP modes tables
0003               
0004                           aorg bankx.vdptab
0005               
0006               ; ====================================================================
0007               ; Keep the tables in sequence, or change offsets in equ.vdp.*.asm
0008               ; ====================================================================
0009               
0010               ***************************************************************
0011               * Textmode (80 columns, 30 rows) - F18A
0012               *--------------------------------------------------------------
0013               *
0014               * ; VDP#0 Control bits
0015               * ;      bit 0=0: reserved
0016               * ;      bit 1=0: reserved
0017               * ;      bit 2=0: reserved
0018               * ;      bit 3=0: reserved
0019               * ;      bit 4=0: PICO9918 double rows mode (48, 60)
0020               * ;      bit 5=1: 80-columns mode F18A/PICO9918
0021               * ;      bit 6=0: M3 | Graphics 1 mode
0022               * ;      bit 7=0: Disable external VDP input
0023               * ; VDP#1 Control bits
0024               * ;      bit 0=1: 16K selection
0025               * ;      bit 1=1: Enable display
0026               * ;      bit 2=1: Enable VDP interrupt
0027               * ;      bit 3=1: M1 \ TEXT MODE
0028               * ;      bit 4=0: M2 /
0029               * ;      bit 5=0: reserved
0030               * ;      bit 6=0: 8x8 sprites
0031               * ;      bit 7=0: Sprite magnification (1x)
0032               * ; VDP#2 PNT (Pattern name table)       at >0000  (>00 * >960)
0033               * ; VDP#3 PCT (Pattern color table)      at >12c0  (>4b * >040)
0034               * ; VDP#4 PDT (Pattern descriptor table) at >2800  (>05 * >800)
0035               * ; VDP#5 SAT (sprite attribute table)   at >2580  (>4b * >080)
0036               * ; VDP#6 SPT (Sprite pattern table)     at >2800  (>05 * >800)
0037               * ; VDP#7 Set foreground/background color
0038               ***************************************************************
0039               stevie.80x30:
0040                      ; VDP#0
0051 7F50 0C              byte   >0c
0053                      ; VDP#1 - VDP#7
0054 7F51   F0            byte   >f0,>00,>4b,>05,>4b,>05,SPFCLR,0,80
     7F52 004B     
     7F54 054B     
     7F56 05F4     
     7F58 0050     
0055               
0056               
0057               ***************************************************************
0058               * TI Basic mode (32 columns/24 rows)
0059               *--------------------------------------------------------------
0060               tibasic.32x24:
0061 7F5A 00E2             byte  >00,>e2,>00,>0c,>00,>06,>00,>07,0,32
     7F5C 000C     
     7F5E 0006     
     7F60 0007     
     7F62 0020     
0062               *
0063               * ; VDP#0 Control bits
0064               * ;      bit 6=0: M3 | Graphics 1 mode
0065               * ;      bit 7=0: Disable external VDP input
0066               * ; VDP#1 Control bits
0067               * ;      bit 0=1: 16K selection
0068               * ;      bit 1=1: Enable display
0069               * ;      bit 2=1: Enable VDP interrupt
0070               * ;      bit 3=0: M1 \ Graphics 1 mode
0071               * ;      bit 4=0: M2 /
0072               * ;      bit 5=0: reserved
0073               * ;      bit 6=1: 16x16 sprites
0074               * ;      bit 7=0: Sprite magnification (1x)
0075               * ; VDP#2 PNT (Pattern name table)       at >0000  (>00 * >960)
0076               * ; VDP#3 PCT (Pattern color table)      at >0300  (>0C * >040)
0077               * ; VDP#4 PDT (Pattern descriptor table) at >0000  (>00 * >800)
0078               * ; VDP#5 SAT (sprite attribute list)    at >0300  (>06 * >080)
0079               * ; VDP#6 SPT (Sprite pattern table)     at >0000  (>00 * >800)
0080               * ; VDP#7 Set screen background color
0081               
0082               
0083               ***************************************************************
0084               * Editor/Assembler (32 columns/24 rows)
0085               *--------------------------------------------------------------
0086               edasm.32x24:
