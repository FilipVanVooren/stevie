0036                       copy  "edb.line.getlength.asm"  ; Get line length
     **** ****     > edb.line.getlength.asm
0001               * FILE......: edb.line.getlength.asm
0002               * Purpose...: Get length of specified line in editor buffer
0003               
0004               ***************************************************************
0005               * edb.line.getlength
0006               * Get length of specified line
0007               ***************************************************************
0008               *  bl   @edb.line.getlength
0009               *--------------------------------------------------------------
0010               * INPUT
0011               * @parm1 = Line number (base 0)
0012               *--------------------------------------------------------------
0013               * OUTPUT
0014               * @outparm1 = Length of line
0015               * @outparm2 = SAMS page
0016               *--------------------------------------------------------------
0017               * Register usage
0018               * tmp0,tmp1
0019               ********|*****|*********************|**************************
0020               edb.line.getlength:
0021 37D0 0649  14         dect  stack
0022 37D2 C64B  30         mov   r11,*stack            ; Push return address
0023 37D4 0649  14         dect  stack
0024 37D6 C644  30         mov   tmp0,*stack           ; Push tmp0
0025 37D8 0649  14         dect  stack
0026 37DA C645  30         mov   tmp1,*stack           ; Push tmp1
0027                       ;------------------------------------------------------
0028                       ; Initialisation
0029                       ;------------------------------------------------------
0030 37DC 04E0  34         clr   @outparm1             ; Reset length
     37DE A018     
0031 37E0 04E0  34         clr   @outparm2             ; Reset SAMS bank
     37E2 A01A     
0032                       ;------------------------------------------------------
0033                       ; Exit if requested line beyond editor buffer
0034                       ;------------------------------------------------------
0035 37E4 C120  34         mov   @parm1,tmp0           ; \
     37E6 A006     
0036 37E8 0584  14         inc   tmp0                  ; /  base 1
0037               
0038 37EA 8804  34         c     tmp0,@edb.lines       ; Requested line at BOT?
     37EC A504     
0039 37EE 1201  14         jle   !                     ; No, continue processing
0040 37F0 100B  14         jmp   edb.line.getlength.null
0041                                                   ; Set length 0 and exit early
0042                       ;------------------------------------------------------
0043                       ; Map SAMS page
0044                       ;------------------------------------------------------
0045 37F2 C120  34 !       mov   @parm1,tmp0           ; Get line
     37F4 A006     
0046               
0047 37F6 06A0  32         bl    @edb.line.mappage     ; Activate editor buffer SAMS page for line
     37F8 3786     
0048                                                   ; \ i  tmp0     = Line number
0049                                                   ; | o  outparm1 = Pointer to line
0050                                                   ; / o  outparm2 = SAMS page
0051               
0052 37FA C120  34         mov   @outparm1,tmp0        ; Store pointer in tmp0
     37FC A018     
0053 37FE 1304  14         jeq   edb.line.getlength.null
0054                                                   ; Set length to 0 if null-pointer
0055                       ;------------------------------------------------------
0056                       ; Process line prefix and exit
0057                       ;------------------------------------------------------
0058 3800 C154  26         mov   *tmp0,tmp1            ; Get length into tmp1
0059 3802 C805  38         mov   tmp1,@outparm1        ; Save length
     3804 A018     
0060 3806 1002  14         jmp   edb.line.getlength.exit
0061                       ;------------------------------------------------------
0062                       ; Set length to 0 if null-pointer
0063                       ;------------------------------------------------------
0064               edb.line.getlength.null:
0065 3808 04E0  34         clr   @outparm1             ; Set length to 0, was a null-pointer
     380A A018     
0066                       ;------------------------------------------------------
0067                       ; Exit
0068                       ;------------------------------------------------------
0069               edb.line.getlength.exit:
0070                       .popregs 1                  ; Pop registers and return to caller
     **** ****     > POPREGS
0011 380C C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 380E C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 3810 C2F9  30         mov   *stack+,r11           ; Pop r11
0017 3812 045B  20         b     *r11                  ; Return
                   < edb.line.getlength.asm
