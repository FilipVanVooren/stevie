     65F8 A30A     
0192               
0193 65FA C820  54         mov   @fb.topline,@parm1    ; \
     65FC A304     
     65FE A006     
0194 6600 A820  54         a     @fb.row,@parm1        ; | Line number to delete (base 1)
     6602 A306     
     6604 A006     
0195 6606 05A0  34         inc   @parm1                ; /
     6608 A006     
0196               
0197                       ;-------------------------------------------------------
0198                       ; Special handling if at BOT (no real line)
0199                       ;-------------------------------------------------------
0200 660A 8820  50         c     @parm1,@edb.lines     ; At BOT in editor buffer?
     660C A006     
