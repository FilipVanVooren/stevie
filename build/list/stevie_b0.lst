     **** ****     > timers_hooks.asm
0001               * FILE......: timers_kthread.asm
0002               * Purpose...: Timers / User hooks
0003               
0004               
0005               ***************************************************************
0006               * MKHOOK - Allocate user hook
0007               ***************************************************************
0008               *  BL    @MKHOOK
0009               *  DATA  P0
0010               *--------------------------------------------------------------
0011               *  P0 = Address of user hook
0012               *--------------------------------------------------------------
0013               *  REMARKS
0014               *  The user hook gets executed after the kernel thread.
0015               *  The user hook must always exit with "B @HOOKOK"
0016               ********|*****|*********************|**************************
0017 70AE C83B  50 mkhook  mov   *r11+,@wtiusr         ; Set user hook address
     70B0 832E     
0018 70B2 E0A0  42         soc   @wbit7,config         ; Enable user hook
     70B4 2012     
0019 70B6 045B  24 mkhoo1  b     *r11                  ; Return
0020      2F1C     hookok  equ   tmgr1                 ; Exit point for user hook
0021               
0022               
0023               ***************************************************************
0024               * CLHOOK - Clear user hook
0025               ***************************************************************
0026               *  BL    @CLHOOK
0027               ********|*****|*********************|**************************
0028 70B8 04E0  26 clhook  clr   @wtiusr               ; Unset user hook address
     70BA 832E     
0029 70BC 0242  30         andi  config,>feff          ; Disable user hook (bit 7=0)
     70BE FEFF     
0030 70C0 045B  24         b     *r11                  ; Return
