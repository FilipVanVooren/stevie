0354               * Check if there is a F18A present
0355               *--------------------------------------------------------------
0359 7178 06A0  32         bl    @f18unl               ; Unlock the F18A
     717A 278A     
0360 717C 06A0  32         bl    @f18chk               ; Check if F18A is there \
     717E 27B4     
0361 7180 06A0  32         bl    @f18chk               ; Check if F18A is there | js99er bug?
     7182 27B4     
0362 7184 06A0  32         bl    @f18chk               ; Check if F18A is there /
     7186 27B4     
0363               
