0032               ********|*****|*********************|**************************
0033 67E0 026E  22 inton   ori   r14,>0020             ; VDP#R1 bit 2=1 (Enable VDP interrupt)
     67E2 0020     
0034 67E4 0460  28         b     @putv01
     67E6 2346     
