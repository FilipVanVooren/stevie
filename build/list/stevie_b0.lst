0302               sams.layout.standard:
0303 6770 0200             data  >0200                 ; >2000-2fff, SAMS page >02
0304 6772 0300             data  >0300                 ; >3000-3fff, SAMS page >03
0305 6774 0A00             data  >0a00                 ; >a000-afff, SAMS page >0a
0306 6776 0B00             data  >0b00                 ; >b000-bfff, SAMS page >0b
0307 6778 0C00             data  >0c00                 ; >c000-cfff, SAMS page >0c
0308 677A 0D00             data  >0d00                 ; >d000-dfff, SAMS page >0d
0309 677C 0E00             data  >0e00                 ; >e000-efff, SAMS page >0e
0310 677E 0F00             data  >0f00                 ; >f000-ffff, SAMS page >0f
