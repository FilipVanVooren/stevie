0001               * FILE......: equ.vdp.2480.chr.asm
0002               * Purpose...: F18a/PICO9918 24x80 mode
0003               
0005               
0006               *--------------------------------------------------------------
0007               * Video mode configuration (stevie) - Graphics mode 24x80
0008               *--------------------------------------------------------------
0009      0000     vdp.sit.base              equ  >0000   ; VDP SIT base address
0010      0780     vdp.sit.size              equ  24*80   ; VDP SIT size 80 columns, 48 rows
0011      12C0     vdp.tat.base              equ  >12c0   ; VDP TAT base address
0012      0780     vdp.tat.size              equ  24*80   ; VDP TAT size 80 columns, 60 rows
0013      2800     vdp.pdt.base              equ  >2800   ; VDP PDT base address
0014               
0015      0050     vdp.fb.toprow.sit         equ  vdp.sit.base + >50   ; VDP SIT 1st Framebuf row
0016      1310     vdp.fb.toprow.tat         equ  vdp.tat.base + >50   ; VDP TAT 1st Framebuf row
0017               
0018               *--------------------------------------------------------------
0019               * Video mode configuration (stevie)
0020               *--------------------------------------------------------------
0021      0007     cmdb.rows                 equ  7       ; Number of rows in command buffer
0022      0017     pane.botrow               equ  23      ; Bottom row on screen
0023      0050     colrow                    equ  80      ; Columns per row
0024      0001     device.f18a               equ  1       ; F18a/PICO9918 on
0025               
0026               *--------------------------------------------------------------
0027               * VDP memory setup for file handling
0028               *--------------------------------------------------------------
0029      2580     fh.vpab                   equ  >2580   ; \ VDP address PAB
0030                                                      ; | Range >2580 - 261f
0031                                                      ; / Reserve max 160 bytes for 1 PAB
0032      2620     fh.vrecbuf                equ  >2620   ; \ VDP address record buffer
0033                                                      ; | Range >2620 - 27ff
0034                                                      ; / Reserve max 480 bytes for 1 record
0035      2000     fh.filebuf                equ  >2000   ; VDP address binary file buffer
0036               
0037               *--------------------------------------------------------------
0038               * Video mode configuration (spectra2)
0039               *--------------------------------------------------------------
0040      00F4     spfclr  equ   >f4                   ; Foreground/Background color for font.
0041      0004     spfbck  equ   >04                   ; Screen background color.
0042      7F50     spvmod  equ   bankx.vdptab          ; Video mode.   See VIDTAB for details.
0043      000C     spfont  equ   >0c                   ; Font to load. See LDFONT for details.
0044      12C0     pctadr  equ   >12c0                 ; VDP color table base
0045      2900     fntadr  equ   vdp.pdt.base + >100   ; VDP font start address (in PDT range)
0046      2580     sprsat  equ   >2580                 ; VDP sprite attribute table
0047      2800     sprpdt  equ   >2800                 ; VDP sprite pattern table
