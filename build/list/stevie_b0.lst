0128               ***************************************************************
0129               * PUTNUM - Put unsigned number on screen
0130               ***************************************************************
0131               *  BL   @PUTNUM
0132               *  DATA P0,P1,P2,P3
0133               *--------------------------------------------------------------
0134               *  P0   = YX position
0135               *  P1   = Pointer to 16 bit unsigned number
0136               *  P2   = Pointer to 5 byte string buffer
0137               *  P3HB = Offset for ASCII digit
0138               *  P3LB = Character for replacing leading 0's
0139               ********|*****|*********************|**************************
0140 6BB6 C83B  42 putnum  mov   *r11+,@wyx            ; Set cursor
     6BB8 832A     
0141 6BBA 0262  22         ori   config,>8000          ; CONFIG register bit 0=1
     6BBC 8000     
0142 6BBE 10BC  14         jmp   mknum                 ; Convert number and display
                   < runlib.asm
