0058                       ;------------------------------------------------------
0059               edb.hipage.alloc.crash:
0060 7950 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     7952 FFCE     
0061 7954 06A0  32         bl    @cpu.crash            ; / Crash and halt system
