     **** ****     > tv.pad.string.asm
0001               * FILE......: tv.pad.string.asm
0002               * Purpose...: pad string to specified length
0003               
0004               
0005               ***************************************************************
0006               * tv.pad.string
0007               * pad string to specified length
0008               ***************************************************************
0009               * bl @tv.pad.string
0010               *--------------------------------------------------------------
0011               * INPUT
0012               * @parm1 = Pointer to length-prefixed string
0013               * @parm2 = Requested length
0014               * @parm3 = Fill character
0015               * @parm4 = Pointer to string buffer
0016               *--------------------------------------------------------------
0017               * OUTPUT
0018               * @outparm1 = Pointer to padded string
0019               *--------------------------------------------------------------
0020               * Register usage
0021               * tmp0,tmp1,tmp2,tmp3
0022               *--------------------------------------------------------------
0023               * Remarks
0024               * Routine must reside in RAM when @parm1 refers to string in
0025               * ROM bank. If you store this routine in a ROM bank, it can
0026               * only reference strings in the same bank or strings in RAM.
0027               * It cannot reference strings in other ROM banks.
0028               ***************************************************************
0029               tv.pad.string:
0030 7648 0649  14         dect  stack
0031 764A C64B  30         mov   r11,*stack            ; Push return address
0032 764C 0649  14         dect  stack
0033 764E C644  30         mov   tmp0,*stack           ; Push tmp0
0034 7650 0649  14         dect  stack
0035 7652 C645  30         mov   tmp1,*stack           ; Push tmp1
0036 7654 0649  14         dect  stack
0037 7656 C646  30         mov   tmp2,*stack           ; Push tmp2
0038 7658 0649  14         dect  stack
0039 765A C647  30         mov   tmp3,*stack           ; Push tmp3
0040                       ;------------------------------------------------------
0041                       ; Asserts
0042                       ;------------------------------------------------------
0043 765C C120  34         mov   @parm1,tmp0           ; \ Get string prefix (length-byte)
     765E A006     
0044 7660 D194  26         movb  *tmp0,tmp2            ; /
0045 7662 0986  32         srl   tmp2,8                ; Right align
0046 7664 C1C6  18         mov   tmp2,tmp3             ; Make copy of length-byte for later use
0047               
0048 7666 8806  34         c     tmp2,@parm2           ; String length > requested length?
     7668 A008     
0049 766A 1520  14         jgt   tv.pad.string.panic   ; Yes, crash
0050                       ;------------------------------------------------------
0051                       ; Copy string to buffer
0052                       ;------------------------------------------------------
0053 766C C120  34         mov   @parm1,tmp0           ; Get source address
     766E A006     
0054 7670 C160  34         mov   @parm4,tmp1           ; Get destination address
     7672 A00C     
0055 7674 0586  14         inc   tmp2                  ; Also include length-byte in copy
0056               
0057 7676 0649  14         dect  stack
0058 7678 C647  30         mov   tmp3,*stack           ; Push tmp3 (get overwritten by xpym2m)
0059               
0060 767A 06A0  32         bl    @xpym2m               ; Copy length-prefix string to buffer
     767C 2540     
0061                                                   ; \ i  tmp0 = Source CPU memory address
0062                                                   ; | i  tmp1 = Target CPU memory address
0063                                                   ; / i  tmp2 = Number of bytes to copy
0064               
0065 767E C1F9  30         mov   *stack+,tmp3          ; Pop tmp3
0066                       ;------------------------------------------------------
0067                       ; Set length of new string
0068                       ;------------------------------------------------------
0069 7680 C120  34         mov   @parm2,tmp0           ; Get requested length
     7682 A008     
0070 7684 0A84  32         sla   tmp0,8                ; Left align
0071 7686 C160  34         mov   @parm4,tmp1           ; Get pointer to buffer
     7688 A00C     
0072 768A D544  30         movb  tmp0,*tmp1            ; Set new length of string
0073 768C A147  18         a     tmp3,tmp1             ; \ Skip to end of string
0074 768E 0585  14         inc   tmp1                  ; /
0075                       ;------------------------------------------------------
0076                       ; Prepare for padding string
0077                       ;------------------------------------------------------
0078 7690 C1A0  34         mov   @parm2,tmp2           ; \ Get number of bytes to fill
     7692 A008     
0079 7694 6187  18         s     tmp3,tmp2             ; |
0080 7696 0586  14         inc   tmp2                  ; /
0081               
0082 7698 C120  34         mov   @parm3,tmp0           ; Get byte to padd
     769A A00A     
0083 769C 0A84  32         sla   tmp0,8                ; Left align
0084                       ;------------------------------------------------------
0085                       ; Right-pad string to destination length
0086                       ;------------------------------------------------------
0087               tv.pad.string.loop:
0088 769E DD44  32         movb  tmp0,*tmp1+           ; Pad character
0089 76A0 0606  14         dec   tmp2                  ; Update loop counter
0090 76A2 15FD  14         jgt   tv.pad.string.loop    ; Next character
0091               
0092 76A4 C820  54         mov   @parm4,@outparm1      ; Set pointer to padded string
     76A6 A00C     
     76A8 A018     
0093 76AA 1004  14         jmp   tv.pad.string.exit    ; Exit
0094                       ;-----------------------------------------------------------------------
0095                       ; CPU crash
0096                       ;-----------------------------------------------------------------------
0097               tv.pad.string.panic:
0098 76AC C80B  38         mov   r11,@>ffce            ; \ Save caller address
     76AE FFCE     
0099 76B0 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     76B2 2026     
0100                       ;------------------------------------------------------
0101                       ; Exit
0102                       ;------------------------------------------------------
0103               tv.pad.string.exit:
     **** ****     > POPREGS
0014 76B4 C1F9  30         mov   *stack+,tmp3          ; Pop tmp3
0017 76B6 C1B9  30         mov   *stack+,tmp2          ; Pop tmp2
0020 76B8 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0023 76BA C139  30         mov   *stack+,tmp0          ; Pop tmp0
0025 76BC C2F9  30         mov   *stack+,r11           ; Pop r11
