0313               ***************************************************************
0314               * sams.layout.copy
0315               * Copy SAMS memory layout
0316               ***************************************************************
0317               * bl  @sams.layout.copy
0318               *     data P0
0319               *--------------------------------------------------------------
0320               * P0 = Pointer to 8 words RAM buffer for results
0321               *--------------------------------------------------------------
0322               * OUTPUT
0323               * RAM buffer will have the SAMS page number for each range
0324               * 2000-2fff, 3000-3fff, a000-afff, b000-bfff, ...
0325               *--------------------------------------------------------------
0326               * Register usage
0327               * tmp0, tmp1, tmp2, tmp3
0328               ********|*****|*********************|**************************
0329               sams.layout.copy:
0330 6780 C1FB  30         mov   *r11+,tmp3            ; Get P0
0331               
0332 6782 0649  14         dect  stack
0333 6784 C64B  30         mov   r11,*stack            ; Push return address
0334 6786 0649  14         dect  stack
0335 6788 C644  30         mov   tmp0,*stack           ; Push tmp0
0336 678A 0649  14         dect  stack
0337 678C C645  30         mov   tmp1,*stack           ; Push tmp1
0338 678E 0649  14         dect  stack
0339 6790 C646  30         mov   tmp2,*stack           ; Push tmp2
0340 6792 0649  14         dect  stack
0341 6794 C647  30         mov   tmp3,*stack           ; Push tmp3
0342                       ;------------------------------------------------------
0343                       ; Copy SAMS layout
0344                       ;------------------------------------------------------
0345 6796 0205  20         li    tmp1,sams.layout.copy.data
     6798 26D6     
0346 679A 0206  20         li    tmp2,8                ; Set loop counter
     679C 0008     
0347                       ;------------------------------------------------------
0348                       ; Set SAMS memory pages
0349                       ;------------------------------------------------------
0350               sams.layout.copy.loop:
0351 679E C135  30         mov   *tmp1+,tmp0           ; Get memory address
0352 67A0 06A0  32         bl    @xsams.page.get       ; \ Get SAMS page
     67A2 259E     
0353                                                   ; | i  tmp0   = Memory address
0354                                                   ; / o  @waux1 = SAMS page
0355               
0356 67A4 CDE0  46         mov   @waux1,*tmp3+         ; Copy SAMS page number
     67A6 833C     
0357               
0358 67A8 0606  14         dec   tmp2                  ; Next iteration
0359 67AA 16F9  14         jne   sams.layout.copy.loop ; Loop until done
0360                       ;------------------------------------------------------
0361                       ; Exit
0362                       ;------------------------------------------------------
0363               sams.layout.copy.exit:
0364 67AC C1F9  30         mov   *stack+,tmp3          ; Pop tmp3
0365 67AE C1B9  30         mov   *stack+,tmp2          ; Pop tmp2
0366 67B0 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0367 67B2 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0368 67B4 C2F9  30         mov   *stack+,r11           ; Pop r11
0369 67B6 045B  20         b     *r11                  ; Return to caller
0370               ***************************************************************
0371               * SAMS memory range table
0372               *--------------------------------------------------------------
0373               sams.layout.copy.data:
0374 67B8 2000             data  >2000                 ; >2000-2fff
0375 67BA 3000             data  >3000                 ; >3000-3fff
0376 67BC A000             data  >a000                 ; >a000-afff
0377 67BE B000             data  >b000                 ; >b000-bfff
0378 67C0 C000             data  >c000                 ; >c000-cfff
0379 67C2 D000             data  >d000                 ; >d000-dfff
0380 67C4 E000             data  >e000                 ; >e000-efff
0381 67C6 F000             data  >f000                 ; >f000-ffff
