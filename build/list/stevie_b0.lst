0024 7718 C644  30         mov   tmp0,*stack           ; Push tmp0
0025 771A 0649  14         dect  stack
0026 771C C645  30         mov   tmp1,*stack           ; Push tmp1
0027 771E 0649  14         dect  stack
0028 7720 C646  30         mov   tmp2,*stack           ; Push tmp2
0029                       ;------------------------------------------------------
0030                       ; Get slot entry
0031                       ;------------------------------------------------------
0032 7722 C120  34         mov   @parm1,tmp0           ; Line number in editor buffer
     7724 A006     
0033               
0034 7726 06A0  32         bl    @_idx.samspage.get    ; Get SAMS page with index slot
     7728 3304     
0035                                                   ; \ i  tmp0     = Line number
0036                                                   ; / o  outparm1 = Slot offset in SAMS page
0037               
0038 772A C120  34         mov   @outparm1,tmp0        ; \ Get slot entry
     772C A018     
0039 772E C164  34         mov   @idx.top(tmp0),tmp1   ; /
     7730 B000     
0040               
0041 7732 130C  14         jeq   idx.pointer.get.parm.null
0042                                                   ; Skip if index slot empty
0043                       ;------------------------------------------------------
