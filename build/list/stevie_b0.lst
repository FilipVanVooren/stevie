0046 7734 C185  18         mov   tmp1,tmp2             ; \
0047 7736 0986  32         srl   tmp2,8                ; / Right align SAMS page
0048                       ;------------------------------------------------------
0049                       ; Calculate LSB (pointer address)
0050                       ;------------------------------------------------------
0051 7738 0245  22         andi  tmp1,>00ff            ; Get rid of MSB (SAMS page)
     773A 00FF     
0052 773C 0A45  24         sla   tmp1,4                ; Multiply with 16
0053 773E 0225  22         ai    tmp1,edb.top          ; Add editor buffer base address
     7740 C000     
0054                       ;------------------------------------------------------
0055                       ; Return parameters
0056                       ;------------------------------------------------------
0057               idx.pointer.get.parm:
0058 7742 C805  38         mov   tmp1,@outparm1        ; Index slot -> Pointer
     7744 A018     
0059 7746 C806  38         mov   tmp2,@outparm2        ; Index slot -> SAMS page
     7748 A01A     
0060 774A 1004  14         jmp   idx.pointer.get.exit
0061                       ;------------------------------------------------------
0062                       ; Special handling for "null"-pointer
0063                       ;------------------------------------------------------
0064               idx.pointer.get.parm.null:
0065 774C 04E0  34         clr   @outparm1
     774E A018     
0066 7750 04E0  34         clr   @outparm2
     7752 A01A     
0067                       ;------------------------------------------------------
0068                       ; Exit
0069                       ;------------------------------------------------------
0070               idx.pointer.get.exit:
