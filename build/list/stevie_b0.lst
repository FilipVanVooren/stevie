0014                       ;------------------------------------------------------
0015                       ; Assert 1
0016                       ;------------------------------------------------------
0017 77D2 0286  22         ci    tmp2,2048*5           ; Crash if loop counter value is unrealistic
     77D4 2800     
0018                                                   ; Max. 5 SAMS pages, each with 2048 index
0019                                                   ; entries.
0020               
0021 77D6 1204  14         jle   !                     ; Continue if ok
0022                       ;------------------------------------------------------
0023                       ; Crash and burn
0024                       ;------------------------------------------------------
0025               _idx.entry.insert.reorg.crash:
0026 77D8 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     77DA FFCE     
0027 77DC 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     77DE 2026     
0028                       ;------------------------------------------------------
0029                       ; Reorganize index entries
0030                       ;------------------------------------------------------
0031 77E0 0224  22 !       ai    tmp0,idx.top          ; Add index base to offset
     77E2 B000     
0032 77E4 C144  18         mov   tmp0,tmp1             ; a = current slot
0033 77E6 05C5  14         inct  tmp1                  ; b = current slot + 2
0034 77E8 0586  14         inc   tmp2                  ; One time adjustment for current line
0035                       ;------------------------------------------------------
0036                       ; Assert 2
0037                       ;------------------------------------------------------
0038 77EA C1C6  18         mov   tmp2,tmp3             ; Number of slots to reorganize
0039 77EC 0A17  18         sla   tmp3,1                ; adjust to slot size
0040 77EE 0507  14         neg   tmp3                  ; tmp3 = -tmp3
0041 77F0 A1C4  18         a     tmp0,tmp3             ; tmp3 = tmp3 + tmp0
0042 77F2 0287  22         ci    tmp3,idx.top - 4      ; Address before top of index ?
     77F4 AFFC     
0043 77F6 1504  14         jgt   _idx.entry.insert.reorg.loop
0044                                                   ; No, jump to loop start
0045                       ;------------------------------------------------------
0046                       ; Crash and burn
0047                       ;------------------------------------------------------
0048 77F8 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     77FA FFCE     
0049 77FC 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     77FE 2026     
0050                       ;------------------------------------------------------
0051                       ; Loop backwards from end of index up to insert point
0052                       ;------------------------------------------------------
0053               _idx.entry.insert.reorg.loop:
0054 7800 C554  38         mov   *tmp0,*tmp1           ; Copy a -> b
0055 7802 0644  14         dect  tmp0                  ; Move pointer up
0056 7804 0645  14         dect  tmp1                  ; Move pointer up
0057 7806 0606  14         dec   tmp2                  ; Next index entry
0058 7808 15FB  14         jgt   _idx.entry.insert.reorg.loop
0059                                                   ; Repeat until done
0060                       ;------------------------------------------------------
0061                       ; Clear index entry at insert point
0062                       ;------------------------------------------------------
0063 780A 05C4  14         inct  tmp0                  ; \ Clear index entry for line
0064 780C 04D4  26         clr   *tmp0                 ; / following insert point
0065               
0066 780E 045B  20         b     *r11                  ; Return to caller
