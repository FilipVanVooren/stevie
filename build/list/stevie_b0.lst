0001               * FILE......: timers_tmgr.asm
0002               * Purpose...: Timers / Thread scheduler
0003               
0004               ***************************************************************
0005               * TMGR - X - Start Timers/Thread scheduler
0006               ***************************************************************
0007               *  B @TMGR
0008               *--------------------------------------------------------------
0009               *  REMARKS
0010               *  Timer/Thread scheduler. Normally called from MAIN.
0011               *  This is basically the kernel keeping everything together.
0012               *  Do not forget to set BTIHI to highest slot in use.
0013               *
0014               *  Register usage in TMGR8 - TMGR11
0015               *  TMP0  = Pointer to timer table
0016               *  R10LB = Use as slot counter
0017               *  TMP2  = 2nd word of slot data
0018               *  TMP3  = Address of routine to call
0019               ********|*****|*********************|**************************
0020 6FFA 0300  22 tmgr    limi  0                     ; No interrupt processing
     6FFC 0000     
0021               *--------------------------------------------------------------
0022               * Read VDP status register
0023               *--------------------------------------------------------------
0024 6FFE D360  38 tmgr1   movb  @vdps,r13             ; Save copy of VDP status register in R13
     7000 8802     
0025               *--------------------------------------------------------------
0026               * Latch sprite collision flag
0027               *--------------------------------------------------------------
0028 7002 2360  32         coc   @wbit2,r13            ; C flag on ?
     7004 201C     
0029 7006 1602  14         jne   tmgr1a                ; No, so move on
0030 7008 E0A0  42         soc   @wbit12,config        ; Latch bit 12 in config register
     700A 2008     
0031               *--------------------------------------------------------------
0032               * Interrupt flag
0033               *--------------------------------------------------------------
0034 700C 2360  32 tmgr1a  coc   @wbit0,r13            ; Interupt flag set ?
     700E 2020     
0035 7010 1311  14         jeq   tmgr4                 ; Yes, process slots 0..n
0036               *--------------------------------------------------------------
0037               * Run speech player
0038               *--------------------------------------------------------------
0044               *--------------------------------------------------------------
0045               * Run kernel thread
0046               *--------------------------------------------------------------
0047 7012 20A0  32 tmgr2   coc   @wbit8,config         ; Kernel thread blocked ?
     7014 2010     
0048 7016 1305  14         jeq   tmgr3                 ; Yes, skip to user hook
0049 7018 20A0  32         coc   @wbit9,config         ; Kernel thread enabled ?
     701A 200E     
0050 701C 1602  14         jne   tmgr3                 ; No, skip to user hook
0051 701E 0460  28         b     @kthread              ; Run kernel thread
     7020 2FB6     
0052               *--------------------------------------------------------------
0053               * Run user hook
0054               *--------------------------------------------------------------
0055 7022 20A0  32 tmgr3   coc   @wbit6,config         ; User hook blocked ?
     7024 2014     
0056 7026 13EB  14         jeq   tmgr1
0057 7028 20A0  32         coc   @wbit7,config         ; User hook enabled ?
     702A 2012     
0058 702C 16E8  14         jne   tmgr1
0059 702E C120  38         mov   @wtiusr,tmp0
     7030 832E     
0060 7032 0454  24         b     *tmp0                 ; Run user hook
0061               *--------------------------------------------------------------
0062               * Do internal housekeeping
0063               *--------------------------------------------------------------
0064 7034 40A0  42 tmgr4   szc   @tmdat,config         ; Unblock kernel thread and user hook
     7036 2FB4     
0065 7038 C10A  30         mov   r10,tmp0
0066 703A 0244  30         andi  tmp0,>00ff            ; Clear HI byte
     703C 00FF     
0067 703E 20A0  32         coc   @wbit2,config         ; PAL flag set ?
     7040 201C     
0068 7042 1303  14         jeq   tmgr5
0069 7044 0284  26         ci    tmp0,60               ; 1 second reached ?
     7046 003C     
0070 7048 1002  14         jmp   tmgr6
0071 704A 0284  26 tmgr5   ci    tmp0,50
     704C 0032     
0072 704E 1101  14 tmgr6   jlt   tmgr7                 ; No, continue
0073 7050 1001  14         jmp   tmgr8
0074 7052 058A  22 tmgr7   inc   r10                   ; Increase tick counter
0075               *--------------------------------------------------------------
0076               * Loop over slots
0077               *--------------------------------------------------------------
0078 7054 C120  38 tmgr8   mov   @wtitab,tmp0          ; Pointer to timer table
     7056 832C     
0079 7058 024A  30         andi  r10,>ff00             ; Use R10LB as slot counter. Reset.
     705A FF00     
0080 705C C1D4  38 tmgr9   mov   *tmp0,tmp3            ; Is slot empty ?
0081 705E 1316  14         jeq   tmgr11                ; Yes, get next slot
0082               *--------------------------------------------------------------
0083               *  Check if slot should be executed
0084               *--------------------------------------------------------------
0085 7060 05C4  22         inct  tmp0                  ; Second word of slot data
0086 7062 0594  30         inc   *tmp0                 ; Update tick count in slot
0087 7064 C194  38         mov   *tmp0,tmp2            ; Get second word of slot data
0088 7066 9820  42         cb    @tmp2hb,@tmp2lb       ; Slot target count = Slot internal counter ?
     7068 830C     
     706A 830D     
0089 706C 1608  14         jne   tmgr10                ; No, get next slot
0090 706E 0246  30         andi  tmp2,>ff00            ; Clear internal counter
     7070 FF00     
0091 7072 C506  38         mov   tmp2,*tmp0            ; Update timer table
0092               *--------------------------------------------------------------
0093               *  Run slot, we only need TMP0 to survive
0094               *--------------------------------------------------------------
0095 7074 C804  34         mov   tmp0,@wtitmp          ; Save TMP0
     7076 8330     
0096 7078 0697  32         bl    *tmp3                 ; Call routine in slot
0097 707A C120  38 slotok  mov   @wtitmp,tmp0          ; Restore TMP0
     707C 8330     
0098               *--------------------------------------------------------------
0099               *  Prepare for next slot
0100               *--------------------------------------------------------------
0101 707E 058A  22 tmgr10  inc   r10                   ; Next slot
0102 7080 9820  42         cb    @r10lb,@btihi         ; Last slot done ?
     7082 8315     
     7084 8314     
0103 7086 1504  14         jgt   tmgr12                ; yes, Wait for next VDP interrupt
0104 7088 05C4  22         inct  tmp0                  ; Offset for next slot
0105 708A 10E8  14         jmp   tmgr9                 ; Process next slot
0106 708C 05C4  22 tmgr11  inct  tmp0                  ; Skip 2nd word of slot data
0107 708E 10F7  14         jmp   tmgr10                ; Process next slot
0108 7090 024A  30 tmgr12  andi  r10,>ff00             ; Use R10LB as tick counter. Reset.
     7092 FF00     
0109 7094 10B4  14         jmp   tmgr1
0110 7096 0280     tmdat   data  >0280                 ; Bit 8 (kernel thread) and bit 6 (user hook)
0111               
