0048               ***************************************************************
0049               * Step 1: Setup SAMS banks (inline code because no SP2 yet!)
0050               ********|*****|*********************|**************************
0051               new.stevie:
0052                       aorg  kickstart.code1       ; >6030
0053               
0054 6030 020C  20         li    r12,>1e00             ; SAMS CRU address
     6032 1E00     
0055 6034 1E01  16         sbz   1                     ; Disable SAMS mapper
0056 6036 1D00  16         sbo   0                     ; Enable access to SAMS registers
0057 6038 0200  20         li    r0,>0000              ; \ Page 0 in >2000 - >2fff
     603A 0000     
0058 603C D800  38         movb  r0,@>4004             ; /
     603E 4004     
0059               
0060 6040 0200  20         li    r0,>0100              ; \ Page 1 in >3000 - >3fff
     6042 0100     
0061 6044 D800  38         movb  r0,@>4006             ; /
     6046 4006     
0062               
0063 6048 0200  20         li    r0,>0400              ; \ Page 4 in >a000 - >afff
     604A 0400     
0064 604C D800  38         movb  r0,@>4014             ; /
     604E 4014     
0065               
0066 6050 0200  20         li    r0,>2000              ; \ Page 20 in >b000 - >bfff
     6052 2000     
0067 6054 D800  38         movb  r0,@>4016             ; /
     6056 4016     
0068               
0069 6058 0200  20         li    r0,>4000              ; \ Page 40 in >c000 - >bfff
     605A 4000     
0070 605C D800  38         movb  r0,@>4018             ; /
     605E 4018     
0071               
0072 6060 0200  20         li    r0,>0500              ; \ Page 5 in >d000 - >dfff
     6062 0500     
0073 6064 D800  38         movb  r0,@>401a             ; /
     6066 401A     
0074               
0075 6068 0200  20         li    r0,>0600              ; \ Page 6 in >ec000 - >efff
     606A 0600     
0076 606C D800  38         movb  r0,@>401c             ; /
     606E 401C     
0077               
0078 6070 0200  20         li    r0,>0700              ; \ Page 7 in >f000 - >ffff
     6072 0700     
0079 6074 D800  38         movb  r0,@>401e             ; /
     6076 401E     
0080               
0081 6078 1E00  16         sbz   0                     ; Disable access to SAMS registers
0082 607A 1D01  16         sbo   1                     ; Enable SAMS mapper
0083               
0084               ***************************************************************
0085               * Step 3: Copy resident modules from ROM to RAM >2000 - >3fff
0086               ********|*****|*********************|**************************
0087 607C 0200  20         li    r0,reloc.resident     ; Start of code to relocate
     607E 60E2     
0088 6080 0201  20         li    r1,>2000
     6082 2000     
0089 6084 0202  20         li    r2,512                ; Copy 8K (320 * 16 bytes)
     6086 0200     
0090                       ;------------------------------------------------------
0091                       ; Copy memory to destination
0092                       ; r0 = Source CPU address
0093                       ; r1 = Target CPU address
0094                       ; r2 = Bytes to copy/16
0095                       ;------------------------------------------------------
0096 6088 CC70  46 !       mov   *r0+,*r1+             ; Copy word 1
0097 608A CC70  46         mov   *r0+,*r1+             ; Copy word 2
0098 608C CC70  46         mov   *r0+,*r1+             ; Copy word 3
0099 608E CC70  46         mov   *r0+,*r1+             ; Copy word 4
0100 6090 CC70  46         mov   *r0+,*r1+             ; Copy word 5
0101 6092 CC70  46         mov   *r0+,*r1+             ; Copy word 6
0102 6094 CC70  46         mov   *r0+,*r1+             ; Copy word 7
0103 6096 CC70  46         mov   *r0+,*r1+             ; Copy word 8
0104 6098 0602  14         dec   r2
0105 609A 16F6  14         jne   -!                    ; Loop until done
0106               ***************************************************************
0107               * Step 4: Start SP2 kernel (runs in low MEMEXP)
0108               ********|*****|*********************|**************************
0109 609C 0460  28         b     @runlib               ; \ Start spectra2 library
     609E 3020     
0110                                                   ; | "main" in low MEMEXP is automatically
0111                                                   ; / called by SP2 runlib.
0112                       ;------------------------------------------------------
0113                       ; Assert. Should not get here!
0114                       ;------------------------------------------------------
0115 60A0 0200  20         li    r0,$                  ; Current location
     60A2 60A0     
0116 60A4 C800  38         mov   r0,@>ffce             ; \ Save caller address
     60A6 FFCE     
0117 60A8 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     60AA 2026     
0118               
