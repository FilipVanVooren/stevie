0001               * FILE......: idx.update.asm
0002               * Purpose...: Update index entry
0003               
0004               ***************************************************************
0005               * idx.entry.update
0006               * Update index entry - Each entry corresponds to a line
0007               ***************************************************************
0008               * bl @idx.entry.update
0009               *--------------------------------------------------------------
0010               * INPUT
0011               * @parm1    = Line number in editor buffer
0012               * @parm2    = Pointer to line in editor buffer
0013               * @parm3    = SAMS page
0014               *--------------------------------------------------------------
0015               * OUTPUT
0016               * @outparm1 = Pointer to updated index entry
0017               *--------------------------------------------------------------
0018               * Register usage
0019               * tmp0,tmp1,tmp2
0020               ********|*****|*********************|**************************
0021               idx.entry.update:
0022 76C0 0649  14         dect  stack
0023 76C2 C64B  30         mov   r11,*stack            ; Save return address
0024 76C4 0649  14         dect  stack
0025 76C6 C644  30         mov   tmp0,*stack           ; Push tmp0
0026 76C8 0649  14         dect  stack
0027 76CA C645  30         mov   tmp1,*stack           ; Push tmp1
0028                       ;------------------------------------------------------
0029                       ; Get parameters
0030                       ;------------------------------------------------------
0031 76CC C120  34         mov   @parm1,tmp0           ; Get line number
     76CE A006     
0032 76D0 C160  34         mov   @parm2,tmp1           ; Get pointer
     76D2 A008     
0033 76D4 1312  14         jeq   idx.entry.update.clear
0034                                                   ; Special handling for "null"-pointer
0035                       ;------------------------------------------------------
0036                       ; Calculate LSB value index slot (pointer offset)
0037                       ;------------------------------------------------------
0038 76D6 0245  22         andi  tmp1,>0fff            ; Remove high-nibble from pointer
     76D8 0FFF     
0039 76DA 0945  24         srl   tmp1,4                ; Get offset (divide by 16)
0040                       ;------------------------------------------------------
0041                       ; Calculate MSB value index slot (SAMS page editor buffer)
0042                       ;------------------------------------------------------
0043 76DC 06E0  34         swpb  @parm3
     76DE A00A     
0044 76E0 D160  34         movb  @parm3,tmp1           ; Put SAMS page in MSB
     76E2 A00A     
0045 76E4 06E0  34         swpb  @parm3                ; \ Restore original order again,
     76E6 A00A     
0046                                                   ; / important for messing up caller parm3!
0047                       ;------------------------------------------------------
0048                       ; Update index slot
0049                       ;------------------------------------------------------
0050               idx.entry.update.save:
0051 76E8 06A0  32         bl    @_idx.samspage.get    ; Get SAMS page for index
     76EA 3304     
0052                                                   ; \ i  tmp0     = Line number
0053                                                   ; / o  outparm1 = Slot offset in SAMS page
0054               
0055 76EC C120  34         mov   @outparm1,tmp0        ; \ Update index slot
     76EE A018     
0056 76F0 C905  38         mov   tmp1,@idx.top(tmp0)   ; /
     76F2 B000     
0057 76F4 C804  38         mov   tmp0,@outparm1        ; Pointer to updated index entry
     76F6 A018     
0058 76F8 1008  14         jmp   idx.entry.update.exit
0059                       ;------------------------------------------------------
0060                       ; Special handling for "null"-pointer
0061                       ;------------------------------------------------------
0062               idx.entry.update.clear:
0063 76FA 06A0  32         bl    @_idx.samspage.get    ; Get SAMS page for index
     76FC 3304     
0064                                                   ; \ i  tmp0     = Line number
0065                                                   ; / o  outparm1 = Slot offset in SAMS page
0066               
0067 76FE C120  34         mov   @outparm1,tmp0        ; \ Clear index slot
     7700 A018     
0068 7702 04E4  34         clr   @idx.top(tmp0)        ; /
     7704 B000     
0069 7706 C804  38         mov   tmp0,@outparm1        ; Pointer to updated index entry
     7708 A018     
0070                       ;------------------------------------------------------
0071                       ; Exit
0072                       ;------------------------------------------------------
0073               idx.entry.update.exit:
