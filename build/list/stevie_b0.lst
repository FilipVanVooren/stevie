0084 71FC 04D4  26         clr   *tmp0                 ; Switch to target ROM bank 4K >6000
0085 71FE 0224  22         ai    tmp0,>0800
     7200 0800     
0086 7202 04D4  26         clr   *tmp0                 ; Switch to target RAM bank 4K >7000
0087                       ;------------------------------------------------------
0088                       ; Bankswitch to target bank(s) completed
0089                       ;------------------------------------------------------
0090               rom.farjump.bankswitch.tgt.done:
0091                       ;------------------------------------------------------
