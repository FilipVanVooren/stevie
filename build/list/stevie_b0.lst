0001               * FILE......: cpu_strings.asm
0002               * Purpose...: CPU string manipulation library
0003               
0004               
0005               ***************************************************************
0006               * string.ltrim - Left justify string
0007               ***************************************************************
0008               *  bl   @string.ltrim
0009               *       data p0,p1,p2
0010               *--------------------------------------------------------------
0011               *  P0 = Pointer to length-prefix string
0012               *  P1 = Pointer to RAM work buffer
0013               *  P2 = Fill character
0014               *--------------------------------------------------------------
0015               *  BL   @xstring.ltrim
0016               *
0017               *  TMP0 = Pointer to length-prefix string
0018               *  TMP1 = Pointer to RAM work buffer
0019               *  TMP2 = Fill character
0020               ********|*****|*********************|**************************
0021               string.ltrim:
0022 6BC0 0649  14         dect  stack
0023 6BC2 C64B  30         mov   r11,*stack            ; Save return address
0024 6BC4 0649  14         dect  stack
0025 6BC6 C644  30         mov   tmp0,*stack           ; Push tmp0
0026 6BC8 0649  14         dect  stack
0027 6BCA C645  30         mov   tmp1,*stack           ; Push tmp1
0028 6BCC 0649  14         dect  stack
0029 6BCE C646  30         mov   tmp2,*stack           ; Push tmp2
0030 6BD0 0649  14         dect  stack
0031 6BD2 C647  30         mov   tmp3,*stack           ; Push tmp3
0032                       ;-----------------------------------------------------------------------
0033                       ; Get parameter values
0034                       ;-----------------------------------------------------------------------
0035 6BD4 C13B  30         mov   *r11+,tmp0            ; Pointer to length-prefixed string
0036 6BD6 C17B  30         mov   *r11+,tmp1            ; RAM work buffer
0037 6BD8 C1BB  30         mov   *r11+,tmp2            ; Fill character
0038 6BDA 100A  14         jmp   !
0039                       ;-----------------------------------------------------------------------
0040                       ; Register version
0041                       ;-----------------------------------------------------------------------
0042               xstring.ltrim:
0043 6BDC 0649  14         dect  stack
0044 6BDE C64B  30         mov   r11,*stack            ; Save return address
0045 6BE0 0649  14         dect  stack
0046 6BE2 C644  30         mov   tmp0,*stack           ; Push tmp0
0047 6BE4 0649  14         dect  stack
0048 6BE6 C645  30         mov   tmp1,*stack           ; Push tmp1
0049 6BE8 0649  14         dect  stack
0050 6BEA C646  30         mov   tmp2,*stack           ; Push tmp2
0051 6BEC 0649  14         dect  stack
0052 6BEE C647  30         mov   tmp3,*stack           ; Push tmp3
0053                       ;-----------------------------------------------------------------------
0054                       ; Start
0055                       ;-----------------------------------------------------------------------
0056 6BF0 C1D4  26 !       mov   *tmp0,tmp3
0057 6BF2 06C7  14         swpb  tmp3                  ; LO <-> HI
0058 6BF4 0247  22         andi  tmp3,>00ff            ; Discard HI byte tmp2 (only keep length)
     6BF6 00FF     
0059 6BF8 0A86  32         sla   tmp2,8                ; LO -> HI fill character
0060                       ;-----------------------------------------------------------------------
0061                       ; Scan string from left to right and compare with fill character
0062                       ;-----------------------------------------------------------------------
0063               string.ltrim.scan:
0064 6BFA 9194  26         cb    *tmp0,tmp2            ; Do we have a fill character?
0065 6BFC 1604  14         jne   string.ltrim.move     ; No, now move string left
0066 6BFE 0584  14         inc   tmp0                  ; Next byte
0067 6C00 0607  14         dec   tmp3                  ; Shorten string length
0068 6C02 1301  14         jeq   string.ltrim.move     ; Exit if all characters processed
0069 6C04 10FA  14         jmp   string.ltrim.scan     ; Scan next characer
0070                       ;-----------------------------------------------------------------------
0071                       ; Copy part of string to RAM work buffer (This is the left-justify)
0072                       ;-----------------------------------------------------------------------
0073               string.ltrim.move:
0074 6C06 9194  26         cb    *tmp0,tmp2            ; Do we have a fill character?
0075 6C08 C1C7  18         mov   tmp3,tmp3             ; String length = 0 ?
0076 6C0A 1306  14         jeq   string.ltrim.panic    ; File length assert
0077 6C0C C187  18         mov   tmp3,tmp2
0078 6C0E 06C7  14         swpb  tmp3                  ; HI <-> LO
0079 6C10 DD47  32         movb  tmp3,*tmp1+           ; Set new string length byte in RAM workbuf
0080               
0081 6C12 06A0  32         bl    @xpym2m               ; tmp0 = Memory source address
     6C14 2540     
0082                                                   ; tmp1 = Memory target address
0083                                                   ; tmp2 = Number of bytes to copy
0084 6C16 1004  14         jmp   string.ltrim.exit
0085                       ;-----------------------------------------------------------------------
0086                       ; CPU crash
0087                       ;-----------------------------------------------------------------------
0088               string.ltrim.panic:
0089 6C18 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     6C1A FFCE     
0090 6C1C 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     6C1E 2026     
0091                       ;----------------------------------------------------------------------
0092                       ; Exit
0093                       ;----------------------------------------------------------------------
0094               string.ltrim.exit:
0095 6C20 C1F9  30         mov   *stack+,tmp3          ; Pop tmp3
0096 6C22 C1B9  30         mov   *stack+,tmp2          ; Pop tmp2
0097 6C24 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0098 6C26 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0099 6C28 C2F9  30         mov   *stack+,r11           ; Pop r11
0100 6C2A 045B  20         b     *r11                  ; Return to caller
0101               
