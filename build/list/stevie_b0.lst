0329               * Initialize registers, memory, ...
0330               *--------------------------------------------------------------
0331 7152 04C1  14 runli9  clr   r1
0332 7154 04C2  14         clr   r2
0333 7156 04C3  14         clr   r3
0334 7158 0209  20         li    stack,sp2.stktop      ; Set top of stack (grows downwards!)
     715A A900     
0335 715C 020F  20         li    r15,vdpw              ; Set VDP write address
     715E 8C00     
0337 7160 06A0  32         bl    @mute                 ; Mute sound generators
     7162 28AA     
