0020 7756 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0023 7758 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0025 775A C2F9  30         mov   *stack+,r11           ; Pop r11
0026 775C 045B  20         b     *r11                  ; Return
