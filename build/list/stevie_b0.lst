0001               * FILE......: snd_player.asm
0002               * Purpose...: Sound player support code
0003               
0004               
0005               ***************************************************************
0006               * MUTE - Mute all sound generators
0007               ***************************************************************
0008               *  BL  @MUTE
0009               *  Mute sound generators and clear sound pointer
0010               *
0011               *  BL  @MUTE2
0012               *  Mute sound generators without clearing sound pointer
0013               ********|*****|*********************|**************************
0014 698C 04E0  26 mute    clr   @wsdlst               ; Clear sound pointer
     698E 8334     
0015 6990 40A0  34 mute2   szc   @wbit13,config        ; Turn off/pause sound player
     6992 2006     
0016 6994 0204  20         li    tmp0,muttab
     6996 28C4     
0017 6998 0205  20         li    tmp1,sound            ; Sound generator port >8400
     699A 8400     
0018 699C D574  40         movb  *tmp0+,*tmp1          ; Generator 0
0019 699E D574  40         movb  *tmp0+,*tmp1          ; Generator 1
0020 69A0 D574  40         movb  *tmp0+,*tmp1          ; Generator 2
0021 69A2 D554  38         movb  *tmp0,*tmp1           ; Generator 3
0022 69A4 045B  20         b     *r11
0023 69A6 9FBF     muttab  byte  >9f,>bf,>df,>ff       ; Table for muting all generators
     69A8 DFFF     
0024               
0025               
0026               ***************************************************************
0027               * SDPREP - Prepare for playing sound
0028               ***************************************************************
0029               *  BL   @SDPREP
0030               *  DATA P0,P1
0031               *
0032               *  P0 = Address where tune is stored
0033               *  P1 = Option flags for sound player
0034               *--------------------------------------------------------------
0035               *  REMARKS
0036               *  Use the below equates for P1:
0037               *
0038               *  SDOPT1 => Tune is in CPU memory + loop
0039               *  SDOPT2 => Tune is in CPU memory
0040               *  SDOPT3 => Tune is in VRAM + loop
0041               *  SDOPT4 => Tune is in VRAM
0042               ********|*****|*********************|**************************
0043 69AA C81B  38 sdprep  mov   *r11,@wsdlst          ; Set tune address
     69AC 8334     
0044 69AE C83B  42         mov   *r11+,@wsdtmp         ; Set tune address in temp
     69B0 8336     
0045 69B2 0242  22         andi  config,>fff8          ; Clear bits 13-14-15
     69B4 FFF8     
0046 69B6 E0BB  30         soc   *r11+,config          ; Set options
0047 69B8 D820  46         movb  @hb$01,@r13lb         ; Set initial duration
     69BA 2012     
     69BC 831B     
0048 69BE 045B  20         b     *r11
0049               
0050               ***************************************************************
0051               * SDPLAY - Sound player for tune in VRAM or CPU memory
0052               ***************************************************************
0053               *  BL  @SDPLAY
0054               *--------------------------------------------------------------
0055               *  REMARKS
0056               *  Set config register bit13=0 to pause player.
0057               *  Set config register bit14=1 to repeat (or play next tune).
0058               ********|*****|*********************|**************************
0059 69C0 20A0  32 sdplay  coc   @wbit13,config        ; Play tune ?
     69C2 2006     
0060 69C4 1301  14         jeq   sdpla1                ; Yes, play
0061 69C6 045B  20         b     *r11
0062               *--------------------------------------------------------------
0063               * Initialisation
0064               *--------------------------------------------------------------
0065 69C8 060D  14 sdpla1  dec   r13                   ; duration = duration - 1
0066 69CA 9820  46         cb    @r13lb,@hb$00         ; R13LB == 0 ?
     69CC 831B     
     69CE 2000     
0067 69D0 1301  14         jeq   sdpla3                ; Play next note
0068 69D2 045B  20 sdpla2  b     *r11                  ; Note still busy, exit
0069 69D4 20A0  32 sdpla3  coc   @wbit15,config        ; Play tune from CPU memory ?
     69D6 2002     
0070 69D8 131A  14         jeq   mmplay
0071               *--------------------------------------------------------------
0072               * Play tune from VDP memory
0073               *--------------------------------------------------------------
0074 69DA C120  30 vdplay  mov   @wsdtmp,tmp0          ; Get tune address
     69DC 8336     
0075 69DE 06C4  14         swpb  tmp0
0076 69E0 D804  30         movb  tmp0,@vdpa
     69E2 8C02     
0077 69E4 06C4  14         swpb  tmp0
0078 69E6 D804  30         movb  tmp0,@vdpa
     69E8 8C02     
0079 69EA 04C4  14         clr   tmp0
0080 69EC D120  30         movb  @vdpr,tmp0            ; length = 0 (end of tune) ?
     69EE 8800     
0081 69F0 131E  14         jeq   sdexit                ; Yes. exit
0082 69F2 0984  32 vdpla1  srl   tmp0,8                ; Right justify length byte
0083 69F4 A804  30         a     tmp0,@wsdtmp          ; Adjust for next table entry
     69F6 8336     
0084 69F8 D820  42 vdpla2  movb  @vdpr,@>8400          ; Feed byte to sound generator
     69FA 8800     
     69FC 8400     
0085 69FE 0604  14         dec   tmp0
0086 6A00 16FB  14         jne   vdpla2
0087 6A02 D820  42         movb  @vdpr,@r13lb          ; Set duration counter
     6A04 8800     
     6A06 831B     
0088 6A08 05E0  26 vdpla3  inct  @wsdtmp               ; Adjust for next table entry, honour byte (1) + (n+1)
     6A0A 8336     
0089 6A0C 045B  20         b     *r11
0090               *--------------------------------------------------------------
0091               * Play tune from CPU memory
0092               *--------------------------------------------------------------
0093 6A0E C120  30 mmplay  mov   @wsdtmp,tmp0
     6A10 8336     
0094 6A12 D174  28         movb  *tmp0+,tmp1           ; length = 0 (end of tune) ?
0095 6A14 130C  14         jeq   sdexit                ; Yes, exit
0096 6A16 0985  32 mmpla1  srl   tmp1,8                ; Right justify length byte
0097 6A18 A805  30         a     tmp1,@wsdtmp          ; Adjust for next table entry
     6A1A 8336     
0098 6A1C D834  40 mmpla2  movb  *tmp0+,@>8400         ; Feed byte to sound generator
     6A1E 8400     
0099 6A20 0605  14         dec   tmp1
0100 6A22 16FC  14         jne   mmpla2
0101 6A24 D814  38         movb  *tmp0,@r13lb          ; Set duration counter
     6A26 831B     
0102 6A28 05E0  26         inct  @wsdtmp               ; Adjust for next table entry, honour byte (1) + (n+1)
     6A2A 8336     
0103 6A2C 045B  20         b     *r11
0104               *--------------------------------------------------------------
0105               * Exit. Check if tune must be looped
0106               *--------------------------------------------------------------
0107 6A2E 20A0  32 sdexit  coc   @wbit14,config        ; Loop flag set ?
     6A30 2004     
0108 6A32 1607  14         jne   sdexi2                ; No, exit
0109 6A34 C820  42         mov   @wsdlst,@wsdtmp
     6A36 8334     
     6A38 8336     
0110 6A3A D820  46         movb  @hb$01,@r13lb          ; Set initial duration
     6A3C 2012     
     6A3E 831B     
0111 6A40 045B  20 sdexi1  b     *r11                  ; Exit
0112 6A42 0242  22 sdexi2  andi  config,>fff8          ; Reset music player
     6A44 FFF8     
0113 6A46 045B  20         b     *r11                  ; Exit
