0001               * FILE......: tv.uint16.unpack.asm
0002               * Purpose...: Unpack 16bit unsigned integer to string
0003               
0004               ***************************************************************
0005               * tv.uint16.unpack
0006               * Unpack 16bit unsigned integer to string
0007               ***************************************************************
0008               * bl @tv.uint16.unpack
0009               *--------------------------------------------------------------
0010               * INPUT
0011               * @parm1 = 16bit unsigned integer
0012               *--------------------------------------------------------------
0013               * OUTPUT
0014               * @uint16.unpacked = Length-prefixed string with unpacked uint16
0015               *                    (6 bytes max)
0016               *--------------------------------------------------------------
0017               * Register usage
0018               * tmp0
0019               ***************************************************************
0020               tv.uint16.unpack:
0021 761C 0649  14         dect  stack
0022 761E C64B  30         mov   r11,*stack            ; Save return address
0023 7620 0649  14         dect  stack
0024 7622 C644  30         mov   tmp0,*stack           ; Push tmp0
0025                       ;------------------------------------------------------
0026                       ; Initialize
0027                       ;------------------------------------------------------
0028 7624 06A0  32         bl    @mknum                ; Convert unsigned number to string
     7626 2A56     
0029 7628 A006                   data parm1            ; \ i p0  = Pointer to 16bit unsigned number
0030 762A A100                   data rambuf           ; | i p1  = Pointer to 5 byte string buffer
0031 762C 30                     byte 48               ; | i p2H = Offset for ASCII digit 0
0032 762D   20                   byte 32               ; / i p2L = Char for replacing leading 0's
0033               
0034 762E 0204  20         li    tmp0,uint16.unpacked
     7630 A02C     
0035 7632 04F4  30         clr   *tmp0+                ; Clear string 01
0036 7634 04F4  30         clr   *tmp0+                ; Clear string 23
0037 7636 04F4  30         clr   *tmp0+                ; Clear string 34
0038               
0039 7638 06A0  32         bl    @trimnum              ; Trim unsigned number string
     763A 2AAE     
0040 763C A100                   data rambuf           ; \ i p0  = Pointer to 5 byte string buffer
0041 763E A02C                   data uint16.unpacked  ; | i p1  = Pointer to output buffer
0042 7640 0020                   data 32               ; / i p2  = Padding char to match against
0043                       ;-------------------------------------------------------
0044                       ; Exit
0045                       ;-------------------------------------------------------
0046               tv.uint16.unpack.exit:
     **** ****     > POPREGS
0023 7642 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0025 7644 C2F9  30         mov   *stack+,r11           ; Pop r11
0026 7646 045B  20         b     *r11                  ; Return
