0267               
0268               ***************************************************************
0269               *  RUNLIB - Runtime library initalisation
0270               ***************************************************************
0271               *  B  @RUNLIB
0272               *--------------------------------------------------------------
0273               *  REMARKS
0274               *  if R0 in WS1 equals >4a4a we were called from the system
0275               *  crash handler so we return there after initialisation.
0276               
0277               *  If R1 in WS1 equals >FFFF we return to the TI title screen
0278               *  after clearing scratchpad memory. This has higher priority
0279               *  as crash handler flag R0.
0280               ********|*****|*********************|**************************
0287 7102 04E0  26 runlib  clr   @>8302                ; Reset exit flag (R1 in workspace WS1!)
     7104 8302     
0289               *--------------------------------------------------------------
0290               * Alternative entry point
0291               *--------------------------------------------------------------
0292 7106 0300  22 runli1  limi  0                     ; Turn off interrupts
     7108 0000     
0293 710A 02E0  18         lwpi  ws1                   ; Activate workspace 1
     710C 8300     
0294 710E C0E0  30         mov   @>83c0,r3             ; Get random seed from OS monitor
     7110 83C0     
0295               *--------------------------------------------------------------
0296               * Clear scratch-pad memory from R4 upwards
0297               *--------------------------------------------------------------
0298 7112 0202  20 runli2  li    r2,>8308
     7114 8308     
0299 7116 04F2  30 runli3  clr   *r2+                  ; Clear scratchpad >8306->83FF
0300 7118 0282  22         ci    r2,>8400
     711A 8400     
0301 711C 16FC  14         jne   runli3
0302               *--------------------------------------------------------------
0303               * Exit to TI-99/4A title screen ?
0304               *--------------------------------------------------------------
0305 711E 0281  22 runli3a ci    r1,>ffff              ; Exit flag set ?
     7120 FFFF     
0306 7122 1602  14         jne   runli4                ; No, continue
0307 7124 0420  42         blwp  @0                    ; Yes, bye bye
     7126 0000     
0308               *--------------------------------------------------------------
0309               * Determine if VDP is PAL or NTSC
0310               *--------------------------------------------------------------
0311 7128 C803  30 runli4  mov   r3,@waux1             ; Store random seed
     712A 833C     
0312 712C 04C1  14         clr   r1                    ; Reset counter
0313 712E 0202  20         li    r2,10                 ; We test 10 times
     7130 000A     
0314 7132 C0E0  30 runli5  mov   @vdps,r3
     7134 8802     
0315 7136 20E0  32         coc   @wbit0,r3             ; Interupt flag set ?
     7138 2020     
0316 713A 1302  14         jeq   runli6
0317 713C 0581  14         inc   r1                    ; Increase counter
0318 713E 10F9  14         jmp   runli5
0319 7140 0602  14 runli6  dec   r2                    ; Next test
0320 7142 16F7  14         jne   runli5
0321 7144 0281  22         ci    r1,>1250              ; Max for NTSC reached ?
     7146 1250     
0322 7148 1202  14         jle   runli7                ; No, so it must be NTSC
0323 714A 0262  22         ori   config,palon          ; Yes, it must be PAL, set flag
     714C 201C     
