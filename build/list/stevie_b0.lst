0055 75B2 C1A0  30         mov   @waux1,tmp2           ; Get string length
     75B4 833C     
0056 75B6 131F  14         jeq   tv.uint16.pack.error  ; No input string given
0057 75B8 0286  22         ci    tmp2,5                ; Maximum 5 digits ?
     75BA 0005     
