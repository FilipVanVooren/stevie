0108                       copy  "copy_cpu_cpu.asm"         ; CPU to CPU copy functions
     **** ****     > copy_cpu_cpu.asm
0001               * FILE......: copy_cpu_cpu.asm
0002               * Purpose...: CPU to CPU memory copy support module
0003               
0004               *//////////////////////////////////////////////////////////////
0005               *                       CPU COPY FUNCTIONS
0006               *//////////////////////////////////////////////////////////////
0007               
0008               ***************************************************************
0009               * CPYM2M - Copy CPU memory to CPU memory
0010               ***************************************************************
0011               *  BL   @CPYM2M
0012               *  DATA P0,P1,P2
0013               *--------------------------------------------------------------
0014               *  P0 = Memory source address
0015               *  P1 = Memory target address
0016               *  P2 = Number of bytes to copy
0017               *--------------------------------------------------------------
0018               *  BL @XPYM2M
0019               *
0020               *  TMP0 = Memory source address
0021               *  TMP1 = Memory target address
0022               *  TMP2 = Number of bytes to copy
0023               ********|*****|*********************|**************************
0024 661C C13B  30 cpym2m  mov   *r11+,tmp0            ; Memory source address
0025 661E C17B  30         mov   *r11+,tmp1            ; Memory target address
0026 6620 C1BB  30         mov   *r11+,tmp2            ; Number of bytes to copy
0027               *--------------------------------------------------------------
0028               * Do some checks first
0029               *--------------------------------------------------------------
0030 6622 C186  18 xpym2m  mov   tmp2,tmp2             ; Bytes to copy = 0 ?
0031 6624 1604  14         jne   cpychk                ; No, continue checking
0032               
0033 6626 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     6628 FFCE     
0034 662A 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     662C 2026     
0035               *--------------------------------------------------------------
0036               *    Check: 1 byte copy
0037               *--------------------------------------------------------------
0038 662E 0286  22 cpychk  ci    tmp2,1                ; Bytes to copy = 1 ?
     6630 0001     
0039 6632 1603  14         jne   cpym0                 ; No, continue checking
0040 6634 DD74  42         movb  *tmp0+,*tmp1+         ; Copy byte
0041 6636 04C6  14         clr   tmp2                  ; Reset counter
0042 6638 045B  20         b     *r11                  ; Return to caller
0043               *--------------------------------------------------------------
0044               *    Check: Uneven address handling
0045               *--------------------------------------------------------------
0046 663A 0242  22 cpym0   andi  config,>7fff          ; Clear CONFIG bit 0
     663C 7FFF     
0047 663E C1C4  18         mov   tmp0,tmp3
0048 6640 0247  22         andi  tmp3,1
     6642 0001     
0049 6644 1618  14         jne   cpyodd                ; Odd source address handling
0050 6646 C1C5  18 cpym1   mov   tmp1,tmp3
0051 6648 0247  22         andi  tmp3,1
     664A 0001     
0052 664C 1614  14         jne   cpyodd                ; Odd target address handling
0053               *--------------------------------------------------------------
0054               * 8 bit copy
0055               *--------------------------------------------------------------
0056 664E 20A0  32 cpym2   coc   @wbit0,config         ; CONFIG bit 0 set ?
     6650 2020     
0057 6652 1605  14         jne   cpym3
0058 6654 C820  46         mov   @tmp011,@mcloop       ; Setup byte copy command
     6656 259A     
     6658 8320     
0059 665A 0460  24         b     @mcloop               ; Copy memory and exit
     665C 8320     
0060               *--------------------------------------------------------------
0061               * 16 bit copy
0062               *--------------------------------------------------------------
0063 665E C1C6  18 cpym3   mov   tmp2,tmp3
0064 6660 0247  22         andi  tmp3,1                ; TMP3=1 -> ODD else EVEN
     6662 0001     
0065 6664 1301  14         jeq   cpym4
0066 6666 0606  14         dec   tmp2                  ; Make TMP2 even
0067 6668 CD74  46 cpym4   mov   *tmp0+,*tmp1+
0068 666A 0646  14         dect  tmp2
0069 666C 16FD  14         jne   cpym4
0070               *--------------------------------------------------------------
0071               * Copy last byte if ODD
0072               *--------------------------------------------------------------
0073 666E C1C7  18         mov   tmp3,tmp3
0074 6670 1301  14         jeq   cpymz
0075 6672 D554  38         movb  *tmp0,*tmp1
0076 6674 045B  20 cpymz   b     *r11                  ; Return to caller
0077               *--------------------------------------------------------------
0078               * Handle odd source/target address
0079               *--------------------------------------------------------------
0080 6676 0262  22 cpyodd  ori   config,>8000          ; Set CONFIG bit 0
     6678 8000     
0081 667A 10E9  14         jmp   cpym2
0082 667C DD74     tmp011  data  >dd74                 ; MOVB *TMP0+,*TMP1+
                   < runlib.asm
