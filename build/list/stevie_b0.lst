0156                       copy  "vdp_f18a.asm"             ; VDP F18a low-level functions
     **** ****     > vdp_f18a.asm
0001               * FILE......: vdp_f18a.asm
0002               * Purpose...: VDP F18A Support module
0003               
0004               *//////////////////////////////////////////////////////////////
0005               *                 VDP F18A LOW-LEVEL FUNCTIONS
0006               *//////////////////////////////////////////////////////////////
0007               
0008               ***************************************************************
0009               * f18unl - Unlock F18A VDP
0010               ***************************************************************
0011               *  bl   @f18unl
0012               ********|*****|*********************|**************************
0013 686C C20B  18 f18unl  mov   r11,tmp4              ; Save R11
0014 686E 06A0  32         bl    @putvr                ; Write once
     6870 2332     
0015 6872 391C             data  >391c                 ; VR1/57, value 00011100
0016 6874 06A0  32         bl    @putvr                ; Write twice
     6876 2332     
0017 6878 391C             data  >391c                 ; VR1/57, value 00011100
0018 687A 06A0  32         bl    @putvr
     687C 2332     
0019 687E 01E0             data  >01e0                 ; VR1, value 11100000, a sane setting
0020 6880 0458  20         b     *tmp4                 ; Exit
0021               
0022               
0023               ***************************************************************
0024               * f18lck - Lock F18A VDP
0025               ***************************************************************
0026               *  bl   @f18lck
0027               ********|*****|*********************|**************************
0028 6882 C20B  18 f18lck  mov   r11,tmp4              ; Save R11
0029 6884 06A0  32         bl    @putvr                ; VR1/57, value 00000000
     6886 2332     
0030 6888 3900             data  >3900
0031 688A 0458  20         b     *tmp4                 ; Exit
0032               
0033               
0034               ***************************************************************
0035               * f18idl - Put GPU in F18A VDP in idle mode (stop GPU program)
0036               ***************************************************************
0037               *  bl   @f18idl
0038               *--------------------------------------------------------------
0039               *  REMARKS
0040               *  Expects that the f18a is unlocked when calling this function.
0041               ********|*****|*********************|**************************
0042 688C C20B  18 f18idl  mov   r11,tmp4              ; Save R11
0043 688E 06A0  32         bl    @putvr                ; VR56 >38, value 00000000
     6890 2332     
0044 6892 3800             data  >3800                 ; Reset and load PC (GPU idle!)
0045 6894 0458  20         b     *tmp4                 ; Exit
0046               
0047               
0048               
0049               ***************************************************************
0050               * f18chk - Check if F18A VDP present
0051               ***************************************************************
0052               *  bl   @f18chk
0053               *--------------------------------------------------------------
0054               *  REMARKS
0055               *  Expects that the f18a is unlocked when calling this function.
0056               *  Runs GPU code at VDP >3f00
0057               ********|*****|*********************|**************************
0058 6896 C20B  18 f18chk  mov   r11,tmp4              ; Save R11
0059 6898 06A0  32         bl    @cpym2v
     689A 24E6     
0060 689C 3F00             data  >3f00,f18chk_gpu,8    ; Copy F18A GPU code to VRAM
     689E 27FE     
     68A0 0008     
0061 68A2 06A0  32         bl    @putvr
     68A4 2332     
0062 68A6 363F             data  >363f                 ; Load MSB of GPU PC (>3f) into VR54 (>36)
0063 68A8 06A0  32         bl    @putvr
     68AA 2332     
0064 68AC 3700             data  >3700                 ; Load LSB of GPU PC (>00) into VR55 (>37)
0065                                                   ; GPU code should run now
0066               
0067 68AE 06A0  32         bl    @putvr                ; VR56 >38, value 00000000
     68B0 2332     
0068 68B2 3800             data  >3800                 ; Reset and load PC (GPU idle!)
0069               ***************************************************************
0070               * VDP @>3f00 == 0 ? F18A present : F18a not present
0071               ***************************************************************
0072 68B4 0204  20         li    tmp0,>3f00
     68B6 3F00     
0073 68B8 06A0  32         bl    @vdra                 ; Set VDP read address to >3f00
     68BA 22BA     
0074 68BC D120  30         movb  @vdpr,tmp0            ; Read MSB byte
     68BE 8800     
0075 68C0 0984  32         srl   tmp0,8
0076 68C2 D120  30         movb  @vdpr,tmp0            ; Read LSB byte
     68C4 8800     
0077 68C6 C104  18         mov   tmp0,tmp0             ; For comparing with 0
0078 68C8 1303  14         jeq   f18chk_yes
0079               f18chk_no:
0080 68CA 0242  22         andi  config,>bfff          ; CONFIG Register bit 1=0
     68CC BFFF     
0081 68CE 1002  14         jmp   f18chk_exit
0082               f18chk_yes:
0083 68D0 0262  22         ori   config,>4000          ; CONFIG Register bit 1=1
     68D2 4000     
0084               
0085               f18chk_exit:
0086 68D4 06A0  32         bl    @filv                 ; Clear VDP mem >3f00->3f05
     68D6 228E     
0087 68D8 3F00             data  >3f00,>00,6
     68DA 0000     
     68DC 0006     
0088 68DE 0458  20         b     *tmp4                 ; Exit
0089               ***************************************************************
0090               * GPU code
0091               ********|*****|*********************|**************************
0092               f18chk_gpu
0093 68E0 04E0             data  >04e0                 ; 3f00 \ 04e0  clr @>3f00
0094 68E2 3F00             data  >3f00                 ; 3f02 / 3f00
0095 68E4 0340             data  >0340                 ; 3f04   0340  idle
0096 68E6 10FF             data  >10ff                 ; 3f06   10ff  \ jmp $
0097                                                   ;              | Make classic99 debugger
0098                                                   ;              | happy if break on illegal
0099                                                   ;              / opcode is on.
0100               
0101               ***************************************************************
0102               * f18rst - Reset f18a into standard settings
0103               ***************************************************************
0104               *  bl   @f18rst
0105               *--------------------------------------------------------------
0106               *  REMARKS
0107               *  This is used to leave the F18A mode and revert all settings
0108               *  that could lead to corruption when doing BLWP @0
0109               *
0110               *  Is expected to run while the f18a is unlocked.
0111               *
0112               *  There are some F18a settings that stay on when doing blwp @0
0113               *  and the TI title screen cannot recover from that.
0114               *
0115               *  It is your responsibility to set video mode tables should
0116               *  you want to continue instead of doing blwp @0 after your
0117               *  program cleanup
0118               ********|*****|*********************|**************************
0119 68E8 C20B  18 f18rst  mov   r11,tmp4              ; Save R11
0120                       ;------------------------------------------------------
0121                       ; Reset all F18a VDP registers to power-on defaults
0122                       ;------------------------------------------------------
0123 68EA 06A0  32         bl    @putvr
     68EC 2332     
0124 68EE 3280             data  >3280                 ; F18a VR50 (>32), MSB 8=1
0125               
0126 68F0 06A0  32         bl    @putvr                ; VR1/57, value 00000000
     68F2 2332     
0127 68F4 3900             data  >3900                 ; Lock the F18a
0128 68F6 0458  20         b     *tmp4                 ; Exit
0129               
0130               
0131               
0132               ***************************************************************
0133               * f18fwv - Get F18A Firmware Version
0134               ***************************************************************
0135               *  bl   @f18fwv
0136               *--------------------------------------------------------------
0137               *  REMARKS
0138               *  Successfully tested with F18A v1.8, note that this does not
0139               *  work with F18 v1.3 but you shouldn't be using such old F18A
0140               *  firmware to begin with.
0141               *--------------------------------------------------------------
0142               *  TMP0 High nibble = major version
0143               *  TMP0 Low nibble  = minor version
0144               *
0145               *  Example: >0018     F18a Firmware v1.8
0146               ********|*****|*********************|**************************
0147 68F8 C20B  18 f18fwv  mov   r11,tmp4              ; Save R11
0148 68FA 20A0  32         coc   @wbit1,config         ; CONFIG bit 1 set ?
     68FC 201E     
0149 68FE 1609  14         jne   f18fw1
0150               ***************************************************************
0151               * Read F18A major/minor version
0152               ***************************************************************
0153 6900 C120  30         mov   @vdps,tmp0            ; Clear VDP status register
     6902 8802     
0154 6904 06A0  32         bl    @putvr                ; Write to VR#15 for setting F18A status
     6906 2332     
0155 6908 0F0E             data  >0f0e                 ; register to read (0e=VR#14)
0156 690A 04C4  14         clr   tmp0
0157 690C D120  30         movb  @vdps,tmp0
     690E 8802     
0158 6910 0984  32         srl   tmp0,8
0159 6912 0458  20 f18fw1  b     *tmp4                 ; Exit
                   < runlib.asm
0158               
0160                       copy  "vdp_hchar.asm"            ; VDP hchar functions
     **** ****     > vdp_hchar.asm
0001               * FILE......: vdp_hchar.a99
0002               * Purpose...: VDP hchar module
0003               
0004               ***************************************************************
0005               * Repeat characters horizontally at YX
0006               ***************************************************************
0007               *  BL    @HCHAR
0008               *  DATA  P0,P1
0009               *  ...
0010               *  DATA  EOL                        ; End-of-list
0011               *--------------------------------------------------------------
0012               *  P0HB = Y position
0013               *  P0LB = X position
0014               *  P1HB = Byte to write
0015               *  P1LB = Number of times to repeat
0016               ********|*****|*********************|**************************
0017 6914 C83B  42 hchar   mov   *r11+,@wyx            ; Set YX position
     6916 832A     
0018 6918 D17B  28         movb  *r11+,tmp1
0019 691A 0985  32 hcharx  srl   tmp1,8                ; Byte to write
0020 691C D1BB  28         movb  *r11+,tmp2
0021 691E 0986  32         srl   tmp2,8                ; Repeat count
0022 6920 C1CB  18         mov   r11,tmp3
0023 6922 06A0  32         bl    @yx2pnt               ; Get VDP address into TMP0
     6924 23FA     
0024               *--------------------------------------------------------------
0025               *    Draw line
0026               *--------------------------------------------------------------
0027 6926 020B  20         li    r11,hchar1
     6928 284C     
0028 692A 0460  28         b     @xfilv                ; Draw
     692C 2294     
0029               *--------------------------------------------------------------
0030               *    Do housekeeping
0031               *--------------------------------------------------------------
0032 692E 8817  42 hchar1  c     *tmp3,@w$ffff         ; End-Of-List marker found ?
     6930 2022     
0033 6932 1302  14         jeq   hchar2                ; Yes, exit
0034 6934 C2C7  18         mov   tmp3,r11
0035 6936 10EE  14         jmp   hchar                 ; Next one
0036 6938 05C7  14 hchar2  inct  tmp3
0037 693A 0457  20         b     *tmp3                 ; Exit
                   < runlib.asm
0162               
0164                       copy  "vdp_vchar.asm"            ; VDP vchar functions
     **** ****     > vdp_vchar.asm
0001               * FILE......: vdp_vchar.a99
0002               * Purpose...: VDP vchar module
0003               
0004               ***************************************************************
0005               * Repeat characters vertically at YX
0006               ***************************************************************
0007               *  BL    @VCHAR
0008               *  DATA  P0,P1
0009               *  ...
0010               *  DATA  EOL                        ; End-of-list
0011               *--------------------------------------------------------------
0012               *  P0HB = Y position
0013               *  P0LB = X position
0014               *  P1HB = Byte to write
0015               *  P1LB = Number of times to repeat
0016               ********|*****|*********************|**************************
0017 693C C83B  42 vchar   mov   *r11+,@wyx            ; Set YX position
     693E 832A     
0018 6940 C1CB  18         mov   r11,tmp3              ; Save R11 in TMP3
0019 6942 C220  30 vchar1  mov   @wcolmn,tmp4          ; Get columns per row
     6944 833A     
0020 6946 06A0  32         bl    @yx2pnt               ; Get VDP address into TMP0
     6948 23FA     
0021 694A D177  28         movb  *tmp3+,tmp1           ; Byte to write
0022 694C D1B7  28         movb  *tmp3+,tmp2
0023 694E 0986  32         srl   tmp2,8                ; Repeat count
0024               *--------------------------------------------------------------
0025               *    Setup VDP write address
0026               *--------------------------------------------------------------
0027 6950 06A0  32 vchar2  bl    @vdwa                 ; Setup VDP write address
     6952 22B6     
0028               *--------------------------------------------------------------
0029               *    Dump tile to VDP and do housekeeping
0030               *--------------------------------------------------------------
0031 6954 D7C5  30         movb  tmp1,*r15             ; Dump tile to VDP
0032 6956 A108  18         a     tmp4,tmp0             ; Next row
0033 6958 0606  14         dec   tmp2
0034 695A 16FA  14         jne   vchar2
0035 695C 8817  42         c     *tmp3,@w$ffff         ; End-Of-List marker found ?
     695E 2022     
0036 6960 1303  14         jeq   vchar3                ; Yes, exit
0037 6962 C837  42         mov   *tmp3+,@wyx           ; Save YX position
     6964 832A     
0038 6966 10ED  14         jmp   vchar1                ; Next one
0039 6968 05C7  14 vchar3  inct  tmp3
0040 696A 0457  20         b     *tmp3                 ; Exit
0041               
0042               ***************************************************************
0043               * Repeat characters vertically at YX
0044               ***************************************************************
0045               * TMP0 = YX position
0046               * TMP1 = Byte to write
0047               * TMP2 = Repeat count
0048               ***************************************************************
0049 696C C20B  18 xvchar  mov   r11,tmp4              ; Save return address
0050 696E C804  30         mov   tmp0,@wyx             ; Set cursor position
     6970 832A     
0051 6972 06C5  14         swpb  tmp1                  ; Byte to write into MSB
0052 6974 C1E0  30         mov   @wcolmn,tmp3          ; Get columns per row
     6976 833A     
0053 6978 06A0  32         bl    @yx2pnt               ; Get VDP address into TMP0
     697A 23FA     
0054               *--------------------------------------------------------------
0055               *    Setup VDP write address
0056               *--------------------------------------------------------------
0057 697C 06A0  32 xvcha1  bl    @vdwa                 ; Setup VDP write address
     697E 22B6     
0058               *--------------------------------------------------------------
0059               *    Dump tile to VDP and do housekeeping
0060               *--------------------------------------------------------------
0061 6980 D7C5  30         movb  tmp1,*r15             ; Dump tile to VDP
0062 6982 A120  30         a     @wcolmn,tmp0          ; Next row
     6984 833A     
0063 6986 0606  14         dec   tmp2
0064 6988 16F9  14         jne   xvcha1
0065 698A 0458  20         b     *tmp4                 ; Exit
