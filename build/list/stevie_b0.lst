0218               ***************************************************************
0219               * sams.mapping.off - Disable SAMS mapping mode
0220               ***************************************************************
0221               * bl  @sams.mapping.off
0222               *--------------------------------------------------------------
0223               * OUTPUT
0224               * none
0225               *--------------------------------------------------------------
0226               * Register usage
0227               * r12
0228               ********|*****|*********************|**************************
0229               sams.mapping.off:
0230 6722 0649  14         dect  stack
0231 6724 C64C  30         mov   r12,*stack            ; Push r12
0232 6726 020C  20         li    r12,>1e00             ; SAMS CRU address
     6728 1E00     
0233 672A 1E01  16         sbz   1                     ; Disable SAMS mapper
0234               *--------------------------------------------------------------
0235               * Exit
0236               *--------------------------------------------------------------
0237               sams.mapping.off.exit:
0238 672C C339  30         mov   *stack+,r12           ; Pop r12
0239 672E 045B  20         b     *r11                  ; Return to caller
