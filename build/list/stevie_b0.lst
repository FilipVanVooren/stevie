     **** ****     > copy_cpu_vram.asm
0001               * FILE......: copy_cpu_vram.asm
0002               * Purpose...: CPU memory to VRAM copy support module
0003               
0004               ***************************************************************
0005               * CPYM2V - Copy CPU memory to VRAM
0006               ***************************************************************
0007               *  BL   @CPYM2V
0008               *  DATA P0,P1,P2
0009               *--------------------------------------------------------------
0010               *  P0 = VDP start address
0011               *  P1 = RAM/ROM start address
0012               *  P2 = Number of bytes to copy
0013               *--------------------------------------------------------------
0014               *  BL @XPYM2V
0015               *
0016               *  TMP0 = VDP start address
0017               *  TMP1 = RAM/ROM start address
0018               *  TMP2 = Number of bytes to copy
0019               ********|*****|*********************|**************************
0020 65C8 C13B  30 cpym2v  mov   *r11+,tmp0            ; VDP Start address
0021 65CA C17B  30         mov   *r11+,tmp1            ; RAM/ROM start address
0022 65CC C1BB  30         mov   *r11+,tmp2            ; Bytes to copy
0023               *--------------------------------------------------------------
0024               *    Assert
0025               *--------------------------------------------------------------
0026 65CE C186  18 xpym2v  mov   tmp2,tmp2             ; Bytes to copy = 0 ?
0027 65D0 1604  14         jne   !                     ; No, continue
0028               
0029 65D2 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     65D4 FFCE     
0030 65D6 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     65D8 2026     
0031               *--------------------------------------------------------------
0032               *    Setup VDP write address
0033               *--------------------------------------------------------------
0034 65DA 0264  22 !       ori   tmp0,>4000
     65DC 4000     
0035 65DE 06C4  14         swpb  tmp0
0036 65E0 D804  30         movb  tmp0,@vdpa
     65E2 8C02     
0037 65E4 06C4  14         swpb  tmp0
0038 65E6 D804  30         movb  tmp0,@vdpa
     65E8 8C02     
0039               *--------------------------------------------------------------
0040               *    Copy bytes from CPU memory to VRAM
0041               *--------------------------------------------------------------
0042 65EA 020F  20         li    r15,vdpw              ; Set VDP write address
     65EC 8C00     
0043 65EE C820  46         mov   @tmp008,@mcloop       ; Setup copy command
     65F0 2516     
     65F2 8320     
0044 65F4 0460  24         b     @mcloop               ; Write data to VDP and return
     65F6 8320     
0045               *--------------------------------------------------------------
0046               * Data
0047               *--------------------------------------------------------------
0048 65F8 D7F5     tmp008  data  >d7f5                 ; MOVB *TMP1+,*R15
                   < runlib.asm
