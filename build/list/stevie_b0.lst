0144                       copy  "vdp_yx2px_calc.asm"       ; VDP calculate pixel pos for YX coord
     **** ****     > vdp_yx2px_calc.asm
0001               * FILE......: vdp_yx2px_calc.asm
0002               * Purpose...: Calculate pixel position for YX coordinate
0003               
0004               ***************************************************************
0005               * YX2PX - Get pixel position for cursor YX position
0006               ***************************************************************
0007               *  BL   @YX2PX
0008               *
0009               *  (CONFIG:0 = 1) = Skip sprite adjustment
0010               *--------------------------------------------------------------
0011               *  INPUT
0012               *  @WYX   = Cursor YX position
0013               *--------------------------------------------------------------
0014               *  OUTPUT
0015               *  TMP0HB = Y pixel position
0016               *  TMP0LB = X pixel position
0017               *--------------------------------------------------------------
0018               *  Remarks
0019               *  This subroutine does not support multicolor mode
0020               ********|*****|*********************|**************************
0021 682A C120  30 yx2px   mov   @wyx,tmp0
     682C 832A     
0022 682E C18B  18 yx2pxx  mov   r11,tmp2              ; Save return address
0023 6830 06C4  14         swpb  tmp0                  ; Y<->X
0024 6832 04C5  14         clr   tmp1                  ; Clear before copy
0025 6834 D144  18         movb  tmp0,tmp1             ; Copy X to TMP1
0026               *--------------------------------------------------------------
0027               * X pixel - Special F18a 80 colums treatment
0028               *--------------------------------------------------------------
0029 6836 20A0  32         coc   @wbit1,config         ; f18a present ?
     6838 201E     
0030 683A 1609  14         jne   yx2pxx_normal         ; No, skip 80 cols handling
0031 683C 8820  46         c     @wcolmn,@yx2pxx_c80   ; 80 columns mode enabled ?
     683E 833A     
     6840 2788     
0032 6842 1605  14         jne   yx2pxx_normal         ; No, skip 80 cols handling
0033               
0034 6844 0A15  18         sla   tmp1,1                ; X = X * 2
0035 6846 B144  18         ab    tmp0,tmp1             ; X = X + (original X)
0036 6848 0225  22         ai    tmp1,>0500            ; X = X + 5 (F18a mystery offset)
     684A 0500     
0037 684C 1002  14         jmp   yx2pxx_y_calc
0038               *--------------------------------------------------------------
0039               * X pixel - Normal VDP treatment
0040               *--------------------------------------------------------------
0041               yx2pxx_normal:
0042 684E D144  18         movb  tmp0,tmp1             ; Copy X to TMP1
0043               *--------------------------------------------------------------
0044 6850 0A35  22         sla   tmp1,3                ; X=X*8
0045               *--------------------------------------------------------------
0046               * Calculate Y pixel position
0047               *--------------------------------------------------------------
0048               yx2pxx_y_calc:
0049 6852 0A34  22         sla   tmp0,3                ; Y=Y*8
0050 6854 D105  18         movb  tmp1,tmp0
0051 6856 06C4  14         swpb  tmp0                  ; X<->Y
0052 6858 20A0  32 yx2pi1  coc   @wbit0,config         ; Skip sprite adjustment ?
     685A 2020     
0053 685C 1305  14         jeq   yx2pi3                ; Yes, exit
0054               *--------------------------------------------------------------
0055               * Adjust for Y sprite location
0056               * See VDP Programmers Guide, Section 9.2.1
0057               *--------------------------------------------------------------
0058 685E 7120  34 yx2pi2  sb    @hb$01,tmp0           ; Adjust Y. Top of screen is at >FF
     6860 2012     
0059 6862 9120  34         cb    @hb$d0,tmp0           ; Y position = >D0 ?
     6864 2024     
0060 6866 13FB  14         jeq   yx2pi2                ; Yes, but that's not allowed, adjust
0061 6868 0456  20 yx2pi3  b     *tmp2                 ; Exit
0062               *--------------------------------------------------------------
0063               * Local constants
0064               *--------------------------------------------------------------
0065               yx2pxx_c80:
0066 686A 0050            data   80
0067               
0068               
                   < runlib.asm
