0105               ***************************************************************
0106               * string.getlenc - Get length of C-style string
0107               ***************************************************************
0108               *  bl   @string.getlenc
0109               *       data p0,p1
0110               *--------------------------------------------------------------
0111               *  P0 = Pointer to C-style string
0112               *  P1 = String termination character
0113               *--------------------------------------------------------------
0114               *  bl   @xstring.getlenc
0115               *
0116               *  TMP0 = Pointer to C-style string
0117               *  TMP1 = Termination character
0118               *--------------------------------------------------------------
0119               *  OUTPUT:
0120               *  @waux1 = Length of string
0121               ********|*****|*********************|**************************
0122               string.getlenc:
0123 6C2C 0649  14         dect  stack
0124 6C2E C64B  30         mov   r11,*stack            ; Save return address
0125 6C30 05D9  26         inct  *stack                ; Skip "data P0"
0126 6C32 05D9  26         inct  *stack                ; Skip "data P1"
0127 6C34 0649  14         dect  stack
0128 6C36 C644  30         mov   tmp0,*stack           ; Push tmp0
0129 6C38 0649  14         dect  stack
0130 6C3A C645  30         mov   tmp1,*stack           ; Push tmp1
0131 6C3C 0649  14         dect  stack
0132 6C3E C646  30         mov   tmp2,*stack           ; Push tmp2
0133                       ;-----------------------------------------------------------------------
0134                       ; Get parameter values
0135                       ;-----------------------------------------------------------------------
0136 6C40 C13B  30         mov   *r11+,tmp0            ; Pointer to C-style string
0137 6C42 C17B  30         mov   *r11+,tmp1            ; String termination character
0138 6C44 1008  14         jmp   !
0139                       ;-----------------------------------------------------------------------
0140                       ; Register version
0141                       ;-----------------------------------------------------------------------
0142               xstring.getlenc:
0143 6C46 0649  14         dect  stack
0144 6C48 C64B  30         mov   r11,*stack            ; Save return address
0145 6C4A 0649  14         dect  stack
0146 6C4C C644  30         mov   tmp0,*stack           ; Push tmp0
0147 6C4E 0649  14         dect  stack
0148 6C50 C645  30         mov   tmp1,*stack           ; Push tmp1
0149 6C52 0649  14         dect  stack
0150 6C54 C646  30         mov   tmp2,*stack           ; Push tmp2
0151                       ;-----------------------------------------------------------------------
0152                       ; Start
0153                       ;-----------------------------------------------------------------------
0154 6C56 0A85  32 !       sla   tmp1,8                ; LSB to MSB
0155 6C58 04C6  14         clr   tmp2                  ; Loop counter
0156                       ;-----------------------------------------------------------------------
0157                       ; Scan string for termination character
0158                       ;-----------------------------------------------------------------------
0159               string.getlenc.loop:
0160 6C5A 0586  14         inc   tmp2
0161 6C5C 9174  28         cb    *tmp0+,tmp1           ; Compare character
0162 6C5E 1304  14         jeq   string.getlenc.putlength
0163                       ;-----------------------------------------------------------------------
0164                       ; Assert on string length
0165                       ;-----------------------------------------------------------------------
0166 6C60 0286  22         ci    tmp2,255
     6C62 00FF     
0167 6C64 1505  14         jgt   string.getlenc.panic
0168 6C66 10F9  14         jmp   string.getlenc.loop
0169                       ;-----------------------------------------------------------------------
0170                       ; Return length
0171                       ;-----------------------------------------------------------------------
0172               string.getlenc.putlength:
0173 6C68 0606  14         dec   tmp2                  ; One time adjustment
0174 6C6A C806  30         mov   tmp2,@waux1           ; Store length
     6C6C 833C     
0175 6C6E 1004  14         jmp   string.getlenc.exit   ; Exit
0176                       ;-----------------------------------------------------------------------
0177                       ; CPU crash
0178                       ;-----------------------------------------------------------------------
0179               string.getlenc.panic:
0180 6C70 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     6C72 FFCE     
0181 6C74 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     6C76 2026     
0182                       ;----------------------------------------------------------------------
0183                       ; Exit
0184                       ;----------------------------------------------------------------------
0185               string.getlenc.exit:
0186 6C78 C1B9  30         mov   *stack+,tmp2          ; Pop tmp2
0187 6C7A C179  30         mov   *stack+,tmp1          ; Pop tmp1
0188 6C7C C139  30         mov   *stack+,tmp0          ; Pop tmp0
0189 6C7E C2F9  30         mov   *stack+,r11           ; Pop r11
0190 6C80 045B  20         b     *r11                  ; Return to caller
                   < runlib.asm
