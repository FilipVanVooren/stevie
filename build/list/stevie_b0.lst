     **** ****     > cpu_scrpad_backrest.asm
0001               * FILE......: cpu_scrpad_backrest.asm
0002               * Purpose...: Scratchpad memory backup/restore functions
0003               
0004               *//////////////////////////////////////////////////////////////
0005               *                Scratchpad memory backup/restore
0006               *//////////////////////////////////////////////////////////////
0007               
0008               ***************************************************************
0009               * cpu.scrpad.backup - Backup 256 bytes of scratchpad >8300 to
0010               *                     predefined memory target @cpu.scrpad.tgt
0011               ***************************************************************
0012               *  bl   @cpu.scrpad.backup
0013               *--------------------------------------------------------------
0014               *  Register usage
0015               *  r0-r2, but values restored before exit
0016               *--------------------------------------------------------------
0017               *  Backup 256 bytes of scratchpad memory >8300 to destination
0018               *  @cpu.scrpad.tgt (+ >ff)
0019               *
0020               *  Expects current workspace to be in scratchpad memory.
0021               ********|*****|*********************|**************************
0022               cpu.scrpad.backup:
0023 6C82 C800  38         mov   r0,@cpu.scrpad.tgt    ; Save @>8300 (r0)
     6C84 F000     
0024 6C86 C801  38         mov   r1,@cpu.scrpad.tgt+2  ; Save @>8302 (r1)
     6C88 F002     
0025 6C8A C802  38         mov   r2,@cpu.scrpad.tgt+4  ; Save @>8304 (r2)
     6C8C F004     
0026                       ;------------------------------------------------------
0027                       ; Prepare for copy loop
0028                       ;------------------------------------------------------
0029 6C8E 0200  20         li    r0,>8306              ; Scratchpad source address
     6C90 8306     
0030 6C92 0201  20         li    r1,cpu.scrpad.tgt+6   ; RAM target address
     6C94 F006     
0031 6C96 0202  20         li    r2,62                 ; Loop counter
     6C98 003E     
0032                       ;------------------------------------------------------
0033                       ; Copy memory range >8306 - >83ff
0034                       ;------------------------------------------------------
0035               cpu.scrpad.backup.copy:
0036 6C9A CC70  46         mov   *r0+,*r1+
0037 6C9C CC70  46         mov   *r0+,*r1+
0038 6C9E 0642  14         dect  r2
0039 6CA0 16FC  14         jne   cpu.scrpad.backup.copy
0040 6CA2 C820  50         mov   @>83fe,@cpu.scrpad.tgt + >fe
     6CA4 83FE     
     6CA6 F0FE     
0041                                                   ; Copy last word
0042                       ;------------------------------------------------------
0043                       ; Restore register r0 - r2
0044                       ;------------------------------------------------------
0045 6CA8 C020  34         mov   @cpu.scrpad.tgt,r0    ; Restore r0
     6CAA F000     
0046 6CAC C060  34         mov   @cpu.scrpad.tgt+2,r1  ; Restore r1
     6CAE F002     
0047 6CB0 C0A0  34         mov   @cpu.scrpad.tgt+4,r2  ; Restore r2
     6CB2 F004     
0048                       ;------------------------------------------------------
0049                       ; Exit
0050                       ;------------------------------------------------------
0051               cpu.scrpad.backup.exit:
0052 6CB4 045B  20         b     *r11                  ; Return to caller
0053               
0054               
0055               ***************************************************************
0056               * cpu.scrpad.restore - Restore 256 bytes of scratchpad from
0057               *                      predefined target @cpu.scrpad.tgt
0058               *                      to destination >8300
0059               ***************************************************************
0060               *  bl   @cpu.scrpad.restore
0061               *--------------------------------------------------------------
0062               *  Register usage
0063               *  r0-r1
0064               *--------------------------------------------------------------
0065               *  Restore scratchpad from memory area @cpu.scrpad.tgt (+ >ff).
0066               *  Current workspace may not be in scratchpad >8300 when called.
0067               *
0068               *  Destroys r0,r1
0069               ********|*****|*********************|**************************
0070               cpu.scrpad.restore:
0071                       ;------------------------------------------------------
0072                       ; Prepare for copy loop, WS
0073                       ;------------------------------------------------------
0074 6CB6 0200  20         li    r0,cpu.scrpad.tgt
     6CB8 F000     
0075 6CBA 0201  20         li    r1,>8300
     6CBC 8300     
0076                       ;------------------------------------------------------
0077                       ; Copy 256 bytes from @cpu.scrpad.tgt to >8300
0078                       ;------------------------------------------------------
0079               cpu.scrpad.restore.copy:
0080 6CBE CC70  46         mov   *r0+,*r1+
0081 6CC0 CC70  46         mov   *r0+,*r1+
0082 6CC2 0281  22         ci    r1,>8400
     6CC4 8400     
0083 6CC6 11FB  14         jlt   cpu.scrpad.restore.copy
0084                       ;------------------------------------------------------
0085                       ; Exit
0086                       ;------------------------------------------------------
0087               cpu.scrpad.restore.exit:
0088 6CC8 045B  20         b     *r11                  ; Return to caller
                   < runlib.asm
0233                       copy  "cpu_scrpad_paging.asm"    ; Scratchpad memory paging
     **** ****     > cpu_scrpad_paging.asm
0001               * FILE......: cpu_scrpad_paging.asm
0002               * Purpose...: CPU memory paging functions
0003               
0004               *//////////////////////////////////////////////////////////////
0005               *                     CPU memory paging
0006               *//////////////////////////////////////////////////////////////
0007               
0008               
0009               ***************************************************************
0010               * cpu.scrpad.pgout - Page out 256 bytes of scratchpad at >8300
0011               *                    to CPU memory destination P0 (tmp1)
0012               *                    and replace with 256 bytes of memory from
0013               *                    predefined destination @cpu.scrpad.target
0014               ***************************************************************
0015               *  bl   @cpu.scrpad.pgout
0016               *       DATA p0
0017               *
0018               *  P0 = CPU memory destination
0019               *--------------------------------------------------------------
0020               *  bl   @xcpu.scrpad.pgout
0021               *  tmp1 = CPU memory destination
0022               *--------------------------------------------------------------
0023               *  Register usage
0024               *  tmp3      = Copy of CPU memory destination
0025               *  tmp0-tmp2 = Used as temporary registers
0026               *  @waux1    = Copy of r5 (tmp1)
0027               *--------------------------------------------------------------
0028               *  Remarks
0029               *  Copies 256 bytes from scratchpad to CPU memory destination
0030               *  specified in P0 (tmp1).
0031               *
0032               *  Then switches to the newly copied workspace in P0 (tmp1).
0033               *
0034               *  Finally it copies 256 bytes from @cpu.scrpad.tgt
0035               *  to scratchpad >8300 and activates workspace at >8300
0036               ********|*****|*********************|**************************
0037               cpu.scrpad.pgout:
0038 6CCA C15B  26         mov   *r11,tmp1             ; tmp1 = Memory target address
0039                       ;------------------------------------------------------
0040                       ; Copy registers r0-r7
0041                       ;------------------------------------------------------
0042 6CCC CD40  34         mov   r0,*tmp1+             ; Backup r0
0043 6CCE CD41  34         mov   r1,*tmp1+             ; Backup r1
0044 6CD0 CD42  34         mov   r2,*tmp1+             ; Backup r2
0045 6CD2 CD43  34         mov   r3,*tmp1+             ; Backup r3
0046 6CD4 CD44  34         mov   r4,*tmp1+             ; Backup r4
0047 6CD6 CD45  34         mov   r5,*tmp1+             ; Backup r5 (is tmp1, so is bogus)
0048 6CD8 CD46  34         mov   r6,*tmp1+             ; Backup r6
0049 6CDA CD47  34         mov   r7,*tmp1+             ; Backup r7
0050                       ;------------------------------------------------------
0051                       ; Copy scratchpad memory to destination
0052                       ;------------------------------------------------------
0053               xcpu.scrpad.pgout:
0054 6CDC 0204  20         li    tmp0,>8310            ; tmp0 = Memory source address
     6CDE 8310     
0055                                                   ;        as of register r8
0056 6CE0 0206  20         li    tmp2,15               ; tmp2 = 15 iterations
     6CE2 000F     
0057                       ;------------------------------------------------------
0058                       ; Copy memory
0059                       ;------------------------------------------------------
0060 6CE4 CD74  46 !       mov   *tmp0+,*tmp1+         ; Copy word 1
0061 6CE6 CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 2
0062 6CE8 CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 3
0063 6CEA CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 4
0064 6CEC CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 5
0065 6CEE CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 6
0066 6CF0 CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 7
0067 6CF2 CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 8
0068 6CF4 0606  14         dec   tmp2
0069 6CF6 16F6  14         jne   -!                    ; Loop until done
0070                       ;------------------------------------------------------
0071                       ; Switch to newly copied workspace
0072                       ;------------------------------------------------------
0073 6CF8 C37B  30         mov   *r11+,r13             ; R13=WP   (pop tmp1 from stack)
0074 6CFA 020E  20         li    r14,cpu.scrpad.pgout.after.rtwp
     6CFC 2C20     
0075                                                   ; R14=PC
0076 6CFE 04CF  14         clr   r15                   ; R15=STATUS
0077                       ;------------------------------------------------------
0078                       ; If we get here, WS was copied to specified
0079                       ; destination.  Also contents of r13,r14,r15
0080                       ; are about to be overwritten by rtwp instruction.
0081                       ;------------------------------------------------------
0082 6D00 0380  18         rtwp                        ; Activate copied workspace
0083                                                   ; in non-scratchpad memory!
0084               
0085               cpu.scrpad.pgout.after.rtwp:
0086 6D02 0460  28         b     @cpu.scrpad.restore   ; Restore scratchpad memory
     6D04 2BD4     
0087                                                   ; from @cpu.scrpad.tgt to @>8300
0088                                                   ; and switch workspace to >8300.
0089                       ;------------------------------------------------------
0090                       ; Exit
0091                       ;------------------------------------------------------
0092               cpu.scrpad.pgout.exit:
0093 6D06 045B  20         b     *r11                  ; Return to caller
0094               
0095               
0096               ***************************************************************
0097               * cpu.scrpad.pgin - Page in 256 bytes of scratchpad memory
0098               *                   at >8300 from CPU memory specified in
0099               *                   p0 (tmp0)
0100               ***************************************************************
0101               *  bl   @cpu.scrpad.pgin
0102               *       DATA p0
0103               *
0104               *  P0 = CPU memory source
0105               *--------------------------------------------------------------
0106               *  bl   @memx.scrpad.pgin
0107               *  TMP0 = CPU memory source
0108               *--------------------------------------------------------------
0109               *  Register usage
0110               *  tmp0-tmp2 = Used as temporary registers
0111               *--------------------------------------------------------------
0112               *  Remarks
0113               *  Copies 256 bytes from CPU memory source to scratchpad >8300
0114               *  and activates workspace in scratchpad >8300
0115               *
0116               *  It's expected that the workspace is outside scratchpad >8300
0117               *  when calling this function.
0118               ********|*****|*********************|**************************
0119               cpu.scrpad.pgin:
0120 6D08 C13B  30         mov   *r11+,tmp0            ; tmp0 = Memory source address
0121                       ;------------------------------------------------------
0122                       ; Copy scratchpad memory to destination
0123                       ;------------------------------------------------------
0124               xcpu.scrpad.pgin:
0125 6D0A 0205  20         li    tmp1,>8300            ; tmp1 = Memory destination address
     6D0C 8300     
0126 6D0E 0206  20         li    tmp2,16               ; tmp2 = 256/16
     6D10 0010     
0127                       ;------------------------------------------------------
0128                       ; Copy memory
0129                       ;------------------------------------------------------
0130 6D12 CD74  46 !       mov   *tmp0+,*tmp1+         ; Copy word 1
0131 6D14 CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 2
0132 6D16 CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 3
0133 6D18 CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 4
0134 6D1A CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 5
0135 6D1C CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 6
0136 6D1E CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 7
0137 6D20 CD74  46         mov   *tmp0+,*tmp1+         ; Copy word 8
0138 6D22 0606  14         dec   tmp2
0139 6D24 16F6  14         jne   -!                    ; Loop until done
0140                       ;------------------------------------------------------
0141                       ; Switch workspace to scratchpad memory
0142                       ;------------------------------------------------------
0143 6D26 02E0  18         lwpi  >8300                 ; Activate copied workspace
     6D28 8300     
0144                       ;------------------------------------------------------
0145                       ; Exit
0146                       ;------------------------------------------------------
0147               cpu.scrpad.pgin.exit:
0148 6D2A 045B  20         b     *r11                  ; Return to caller
                   < runlib.asm
0235               
0237                       copy  "fio.equ"                  ; File I/O equates
     **** ****     > fio.equ
0001               * FILE......: fio.equ
0002               * Purpose...: Equates for file I/O operations
0003               
0004               ***************************************************************
0005               * File IO operations - Byte 0 in PAB
0006               ************************************@**************************
0007      0000     io.op.open       equ >00            ; OPEN
0008      0001     io.op.close      equ >01            ; CLOSE
0009      0002     io.op.read       equ >02            ; READ
0010      0003     io.op.write      equ >03            ; WRITE
0011      0004     io.op.rewind     equ >04            ; RESTORE/REWIND
0012      0005     io.op.load       equ >05            ; LOAD
0013      0006     io.op.save       equ >06            ; SAVE
0014      0007     io.op.delete     equ >07            ; DELETE
0015      0008     io.op.scratch    equ >08            ; SCRATCH
0016      0009     io.op.status     equ >09            ; STATUS
0017               ***************************************************************
0018               * File & data type - Byte 1 in PAB (Bit 0-4)
0019               ***************************************************************
0020               * Bit position: 4  3  21  0
0021               *               |  |  ||   \
0022               *               |  |  ||    File type
0023               *               |  |  ||    0 = INTERNAL
0024               *               |  |  ||    1 = FIXED
0025               *               |  |  \\
0026               *               |  |   File operation
0027               *               |  |   00 - UPDATE
0028               *               |  |   01 - OUTPUT
0029               *               |  |   10 - INPUT
0030               *               |  |   11 - APPEND
0031               *               |  |
0032               *               |  \
0033               *               |   Data type
0034               *               |   0 = DISPLAY
0035               *               |   1 = INTERNAL
0036               *               |
0037               *               \
0038               *                Record type
0039               *                0 = FIXED
0040               *                1 = VARIABLE
0041               ***************************************************************
0042               ; Bit position           43210
0043               ************************************|**************************
0044      0000     io.seq.upd.dis.fix  equ :00000      ; 00
0045      0001     io.rel.upd.dis.fix  equ :00001      ; 01
0046      0003     io.rel.out.dis.fix  equ :00011      ; 02
0047      0002     io.seq.out.dis.fix  equ :00010      ; 03
0048      0004     io.seq.inp.dis.fix  equ :00100      ; 04
0049      0005     io.rel.inp.dis.fix  equ :00101      ; 05
0050      0006     io.seq.app.dis.fix  equ :00110      ; 06
0051      0007     io.rel.app.dis.fix  equ :00111      ; 07
0052      0008     io.seq.upd.int.fix  equ :01000      ; 08
0053      0009     io.rel.upd.int.fix  equ :01001      ; 09
0054      000A     io.seq.out.int.fix  equ :01010      ; 0A
0055      000B     io.rel.out.int.fix  equ :01011      ; 0B
0056      000C     io.seq.inp.int.fix  equ :01100      ; 0C
0057      000D     io.rel.inp.int.fix  equ :01101      ; 0D
0058      000E     io.seq.app.int.fix  equ :01110      ; 0E
0059      000F     io.rel.app.int.fix  equ :01111      ; 0F
0060      0010     io.seq.upd.dis.var  equ :10000      ; 10
0061      0011     io.rel.upd.dis.var  equ :10001      ; 11
0062      0012     io.seq.out.dis.var  equ :10010      ; 12
0063      0013     io.rel.out.dis.var  equ :10011      ; 13
0064      0014     io.seq.inp.dis.var  equ :10100      ; 14
0065      0015     io.rel.inp.dis.var  equ :10101      ; 15
0066      0016     io.seq.app.dis.var  equ :10110      ; 16
0067      0017     io.rel.app.dis.var  equ :10111      ; 17
0068      0018     io.seq.upd.int.var  equ :11000      ; 18
0069      0019     io.rel.upd.int.var  equ :11001      ; 19
0070      001A     io.seq.out.int.var  equ :11010      ; 1A
0071      001B     io.rel.out.int.var  equ :11011      ; 1B
0072      001C     io.seq.inp.int.var  equ :11100      ; 1C
0073      001D     io.rel.inp.int.var  equ :11101      ; 1D
0074      001E     io.seq.app.int.var  equ :11110      ; 1E
0075      001F     io.rel.app.int.var  equ :11111      ; 1F
0076               ***************************************************************
0077               * File error codes - Byte 1 in PAB (Bits 5-7)
0078               ************************************|**************************
0079      0000     io.err.no_error_occured             equ 0
0080                       ; Error code 0 with condition bit reset, indicates that
0081                       ; no error has occured
0082               
0083      0000     io.err.bad_device_name              equ 0
0084                       ; Device indicated not in system
0085                       ; Error code 0 with condition bit set, indicates a
0086                       ; device not present in system
0087               
0088      0001     io.err.device_write_prottected      equ 1
0089                       ; Device is write protected
0090               
0091      0002     io.err.bad_open_attribute           equ 2
0092                       ; One or more of the OPEN attributes are illegal or do
0093                       ; not match the file's actual characteristics.
0094                       ; This could be:
0095                       ;   * File type
0096                       ;   * Record length
0097                       ;   * I/O mode
0098                       ;   * File organization
0099               
0100      0003     io.err.illegal_operation            equ 3
0101                       ; Either an issued I/O command was not supported, or a
0102                       ; conflict with the OPEN mode has occured
0103               
0104      0004     io.err.out_of_table_buffer_space    equ 4
0105                       ; The amount of space left on the device is insufficient
0106                       ; for the requested operation
0107               
0108      0005     io.err.eof                          equ 5
0109                       ; Attempt to read past end of file.
0110                       ; This error may also be given for non-existing records
0111                       ; in a relative record file
0112               
0113      0006     io.err.device_error                 equ 6
0114                       ; Covers all hard device errors, such as parity and
0115                       ; bad medium errors
0116               
0117      0007     io.err.file_error                   equ 7
0118                       ; Covers all file-related error like: program/data
0119                       ; file mismatch, non-existing file opened for input mode, etc.
                   < runlib.asm
0238                       copy  "fio_dsrlnk.asm"           ; DSRLNK for peripheral communication
     **** ****     > fio_dsrlnk.asm
0001               * FILE......: fio_dsrlnk.asm
0002               * Purpose...: Custom DSRLNK implementation
0003               
0004               *//////////////////////////////////////////////////////////////
0005               *                          DSRLNK
0006               *//////////////////////////////////////////////////////////////
0007               
0008               
0009               ***************************************************************
0010               * dsrlnk - DSRLNK for file I/O in DSR space >1000 - >1F00
0011               ***************************************************************
0012               *  blwp @dsrlnk
0013               *  data p0
0014               *--------------------------------------------------------------
0015               *  Input:
0016               *  P0     = 8 or 10 (a)
0017               *  @>8356 = Pointer to VDP PAB file descriptor length (PAB+9)
0018               *--------------------------------------------------------------
0019               *  Output:
0020               *  r0 LSB = Bits 13-15 from VDP PAB byte 1, right aligned
0021               *--------------------------------------------------------------
0022               *  Remarks:
0023               *
0024               *  You need to specify following equates in main program
0025               *
0026               *  dsrlnk.dsrlws      equ >????     ; Address of dsrlnk workspace
0027               *  dsrlnk.namsto      equ >????     ; 8-byte RAM buffer for storing device name
0028               *
0029               *  Scratchpad memory usage
0030               *  >8322            Parameter (>08) or (>0A) passed to dsrlnk
0031               *  >8356            Pointer to PAB
0032               *  >83D0            CRU address of current device
0033               *  >83D2            DSR entry address
0034               *  >83e0 - >83ff    GPL / DSRLNK workspace
0035               *
0036               *  Credits
0037               *  Originally appeared in Miller Graphics The Smart Programmer.
0038               *  This version based on version of Paolo Bagnaresi.
0039               *
0040               *  The following memory address can be used to directly jump
0041               *  into the DSR in consequtive calls without having to
0042               *  scan the PEB cards again:
0043               *
0044               *  dsrlnk.namsto  -  8-byte RAM buf for holding device name
0045               *  dsrlnk.savcru  -  CRU address of device in prev. DSR call
0046               *  dsrlnk.savent  -  DSR entry addr of prev. DSR call
0047               *  dsrlnk.savpab  -  Pointer to Device or Subprogram in PAB
0048               *  dsrlnk.savver  -  Version used in prev. DSR call
0049               *  dsrlnk.savlen  -  Length of DSR name of prev. DSR call (in MSB)
0050               *  dsrlnk.flgptr  -  Pointer to VDP PAB byte 1 (flag byte)
0051               
0052               *--------------------------------------------------------------
0053      A40A     dsrlnk.dstype equ   dsrlnk.dsrlws + 10
0054                                                   ; dstype is address of R5 of DSRLNK ws.
0055               ********|*****|*********************|**************************
0056 6D2C A400     dsrlnk  data  dsrlnk.dsrlws         ; dsrlnk workspace
0057 6D2E 2C4E             data  dsrlnk.init           ; Entry point
0058                       ;------------------------------------------------------
0059                       ; DSRLNK entry point
0060                       ;------------------------------------------------------
0061               dsrlnk.init:
0062 6D30 C17E  30         mov   *r14+,r5              ; Get pgm type for link
0063 6D32 C805  38         mov   r5,@dsrlnk.sav8a      ; Save data following blwp @dsrlnk (8 or >a)
     6D34 A428     
0064 6D36 53E0  34         szcb  @hb$20,r15            ; Reset equal bit in status register
     6D38 201C     
0065 6D3A C020  30         mov   @>8356,r0             ; Get pointer to PAB+9 in VDP
     6D3C 8356     
0066 6D3E C240  18         mov   r0,r9                 ; Save pointer
0067                       ;------------------------------------------------------
0068                       ; Fetch file descriptor length from PAB
0069                       ;------------------------------------------------------
0070 6D40 0229  22         ai    r9,>fff8              ; Adjust r9 to addr PAB byte 1
     6D42 FFF8     
0071                                                   ; FLAG byte->(pabaddr+9)-8
0072 6D44 C809  38         mov   r9,@dsrlnk.flgptr     ; Save pointer to PAB byte 1
     6D46 A434     
0073                       ;---------------------------; Inline VSBR start
0074 6D48 06C0  14         swpb  r0                    ;
0075 6D4A D800  30         movb  r0,@vdpa              ; Send low byte
     6D4C 8C02     
0076 6D4E 06C0  14         swpb  r0                    ;
0077 6D50 D800  30         movb  r0,@vdpa              ; Send high byte
     6D52 8C02     
0078 6D54 D0E0  30         movb  @vdpr,r3              ; Read byte from VDP RAM
     6D56 8800     
0079                       ;---------------------------; Inline VSBR end
0080 6D58 0983  32         srl   r3,8                  ; Move to low byte
0081               
0082                       ;------------------------------------------------------
0083                       ; Fetch file descriptor device name from PAB
0084                       ;------------------------------------------------------
0085 6D5A 0704  14         seto  r4                    ; Init counter
0086 6D5C 0202  20         li    r2,dsrlnk.namsto      ; Point to 8-byte CPU buffer
     6D5E A420     
0087 6D60 0580  14 !       inc   r0                    ; Point to next char of name
0088 6D62 0584  14         inc   r4                    ; Increment char counter
0089 6D64 0284  22         ci    r4,>0007              ; Check if length more than 7 chars
     6D66 0007     
0090 6D68 1573  14         jgt   dsrlnk.error.devicename_invalid
0091                                                   ; Yes, error
0092 6D6A 80C4  18         c     r4,r3                 ; End of name?
0093 6D6C 130C  14         jeq   dsrlnk.device_name.get_length
0094                                                   ; Yes
0095               
0096                       ;---------------------------; Inline VSBR start
0097 6D6E 06C0  14         swpb  r0                    ;
0098 6D70 D800  30         movb  r0,@vdpa              ; Send low byte
     6D72 8C02     
0099 6D74 06C0  14         swpb  r0                    ;
0100 6D76 D800  30         movb  r0,@vdpa              ; Send high byte
     6D78 8C02     
0101 6D7A D060  30         movb  @vdpr,r1              ; Read byte from VDP RAM
     6D7C 8800     
0102                       ;---------------------------; Inline VSBR end
0103               
0104                       ;------------------------------------------------------
0105                       ; Look for end of device name, for example "DSK1."
0106                       ;------------------------------------------------------
0107 6D7E DC81  32         movb  r1,*r2+               ; Move into buffer
0108 6D80 9801  34         cb    r1,@dsrlnk.period     ; Is character a '.'
     6D82 2DBA     
0109 6D84 16ED  14         jne   -!                    ; No, loop next char
0110                       ;------------------------------------------------------
0111                       ; Determine device name length
0112                       ;------------------------------------------------------
0113               dsrlnk.device_name.get_length:
0114 6D86 C104  18         mov   r4,r4                 ; Check if length = 0
0115 6D88 1363  14         jeq   dsrlnk.error.devicename_invalid
0116                                                   ; Yes, error
0117 6D8A 04E0  26         clr   @>83d0
     6D8C 83D0     
0118 6D8E C804  30         mov   r4,@>8354             ; Save name length for search (length
     6D90 8354     
0119                                                   ; goes to >8355 but overwrites >8354!)
0120 6D92 C804  38         mov   r4,@dsrlnk.savlen     ; Save name length for nextr dsrlnk call
     6D94 A432     
0121               
0122 6D96 0584  14         inc   r4                    ; Adjust for dot
0123 6D98 A804  30         a     r4,@>8356             ; Point to position after name
     6D9A 8356     
0124 6D9C C820  50         mov   @>8356,@dsrlnk.savpab ; Save pointer for next dsrlnk call
     6D9E 8356     
     6DA0 A42E     
0125                       ;------------------------------------------------------
0126                       ; Prepare for DSR scan >1000 - >1f00
0127                       ;------------------------------------------------------
0128               dsrlnk.dsrscan.start:
0129 6DA2 02E0  18         lwpi  >83e0                 ; Use GPL WS
     6DA4 83E0     
0130 6DA6 04C1  14         clr   r1                    ; Version found of dsr
0131 6DA8 020C  20         li    r12,>0f00             ; Init cru address
     6DAA 0F00     
0132                       ;------------------------------------------------------
0133                       ; Turn off ROM on current card
0134                       ;------------------------------------------------------
0135               dsrlnk.dsrscan.cardoff:
0136 6DAC C30C  18         mov   r12,r12               ; Anything to turn off?
0137 6DAE 1301  14         jeq   dsrlnk.dsrscan.cardloop
0138                                                   ; No, loop over cards
0139 6DB0 1E00  16         sbz   0                     ; Yes, turn off
0140                       ;------------------------------------------------------
0141                       ; Loop over cards and look if DSR present
0142                       ;------------------------------------------------------
0143               dsrlnk.dsrscan.cardloop:
0144 6DB2 022C  22         ai    r12,>0100             ; Next ROM to turn on
     6DB4 0100     
0145 6DB6 04E0  26         clr   @>83d0                ; Clear in case we are done
     6DB8 83D0     
0146 6DBA 028C  22         ci    r12,>2000             ; Card scan complete? (>1000 to >1F00)
     6DBC 2000     
0147 6DBE 1346  14         jeq   dsrlnk.error.nodsr_found
0148                                                   ; Yes, no matching DSR found
0149 6DC0 C80C  30         mov   r12,@>83d0            ; Save address of next cru
     6DC2 83D0     
0150                       ;------------------------------------------------------
0151                       ; Look at card ROM (@>4000 eq 'AA' ?)
0152                       ;------------------------------------------------------
0153 6DC4 1D00  16         sbo   0                     ; Turn on ROM
0154 6DC6 0202  20         li    r2,>4000              ; Start at beginning of ROM
     6DC8 4000     
0155 6DCA 9812  42         cb    *r2,@dsrlnk.$aa00     ; Check for a valid DSR header
     6DCC 2DB6     
0156 6DCE 16EE  14         jne   dsrlnk.dsrscan.cardoff
0157                                                   ; No ROM found on card
0158                       ;------------------------------------------------------
0159                       ; Valid DSR ROM found. Now loop over chain/subprograms
0160                       ;------------------------------------------------------
0161                       ; dstype is the address of R5 of the DSRLNK workspace,
0162                       ; which is where 8 for a DSR or 10 (>A) for a subprogram
0163                       ; is stored before the DSR ROM is searched.
0164                       ;------------------------------------------------------
0165 6DD0 A0A0  34         a     @dsrlnk.dstype,r2     ; Goto first pointer (byte 8 or 10)
     6DD2 A40A     
0166 6DD4 1003  14         jmp   dsrlnk.dsrscan.getentry
0167                       ;------------------------------------------------------
0168                       ; Next DSR entry
0169                       ;------------------------------------------------------
0170               dsrlnk.dsrscan.nextentry:
0171 6DD6 C0A0  30         mov   @>83d2,r2             ; Offset 0 > Fetch link to next DSR or
     6DD8 83D2     
0172                                                   ; subprogram
0173               
0174 6DDA 1D00  16         sbo   0                     ; Turn ROM back on
0175                       ;------------------------------------------------------
0176                       ; Get DSR entry
0177                       ;------------------------------------------------------
0178               dsrlnk.dsrscan.getentry:
0179 6DDC C092  26         mov   *r2,r2                ; Is address a zero? (end of chain?)
0180 6DDE 13E6  14         jeq   dsrlnk.dsrscan.cardoff
0181                                                   ; Yes, no more DSRs or programs to check
0182 6DE0 C802  30         mov   r2,@>83d2             ; Offset 0 > Store link to next DSR or
     6DE2 83D2     
0183                                                   ; subprogram
0184               
0185 6DE4 05C2  14         inct  r2                    ; Offset 2 > Has call address of current
0186                                                   ; DSR/subprogram code
0187               
0188 6DE6 C272  30         mov   *r2+,r9               ; Store call address in r9. Move r2 to
0189                                                   ; offset 4 (DSR/subprogram name)
0190                       ;------------------------------------------------------
0191                       ; Check file descriptor in DSR
0192                       ;------------------------------------------------------
0193 6DE8 04C5  14         clr   r5                    ; Remove any old stuff
0194 6DEA D160  30         movb  @>8355,r5             ; Get length as counter
     6DEC 8355     
0195 6DEE 1309  14         jeq   dsrlnk.dsrscan.call_dsr
0196                                                   ; If zero, do not further check, call DSR
0197                                                   ; program
0198               
0199 6DF0 9C85  28         cb    r5,*r2+               ; See if length matches
0200 6DF2 16F1  14         jne   dsrlnk.dsrscan.nextentry
0201                                                   ; No, length does not match.
0202                                                   ; Go process next DSR entry
0203               
0204 6DF4 0985  32         srl   r5,8                  ; Yes, move to low byte
0205 6DF6 0206  20         li    r6,dsrlnk.namsto      ; Point to 8-byte CPU buffer
     6DF8 A420     
0206 6DFA 9CB6  38 !       cb    *r6+,*r2+             ; Compare byte in CPU buffer with byte in
0207                                                   ; DSR ROM
0208 6DFC 16EC  14         jne   dsrlnk.dsrscan.nextentry
0209                                                   ; Try next DSR entry if no match
0210 6DFE 0605  14         dec   r5                    ; Update loop counter
0211 6E00 16FC  14         jne   -!                    ; Loop until full length checked
0212                       ;------------------------------------------------------
0213                       ; Call DSR program in card/device
0214                       ;------------------------------------------------------
0215               dsrlnk.dsrscan.call_dsr:
0216 6E02 0581  14         inc   r1                    ; Next version found
0217 6E04 C80C  38         mov   r12,@dsrlnk.savcru    ; Save CRU address
     6E06 A42A     
0218 6E08 C809  38         mov   r9,@dsrlnk.savent     ; Save DSR entry address
     6E0A A42C     
0219 6E0C C801  38         mov   r1,@dsrlnk.savver     ; Save DSR Version number
     6E0E A430     
0220               
0221 6E10 020D  20         li    r13,>9800             ; Set GROM base to >9800 to prevent
     6E12 9800     
0222                                                   ; lockup of TI Disk Controller DSR.
0223               
0224 6E14 020F  20         li    r15,>8C02             ; Set VDP port address, needed to prevent
     6E16 8C02     
0225                                                   ; lockup of TI Disk Controller DSR.
0226               
0227 6E18 0699  24         bl    *r9                   ; Execute DSR
0228                       ;
0229                       ; Depending on IO result the DSR in card ROM does RET
0230                       ; or (INCT R11 + RET), meaning either (1) or (2) get executed.
0231                       ;
0232 6E1A 10DD  14         jmp   dsrlnk.dsrscan.nextentry
0233                                                   ; (1) error return
0234 6E1C 1E00  16         sbz   0                     ; (2) turn off card/device if good return
0235 6E1E 02E0  18         lwpi  dsrlnk.dsrlws         ; (2) restore workspace
     6E20 A400     
0236 6E22 C009  30         mov   r9,r0                 ; Point to flag byte (PAB+1) in VDP PAB
0237                       ;------------------------------------------------------
0238                       ; Returned from DSR
0239                       ;------------------------------------------------------
0240               dsrlnk.dsrscan.return_dsr:
0241 6E24 C060  42         mov   @dsrlnk.sav8a,r1      ; get back data following blwp @dsrlnk
     6E26 A428     
0242                                                   ; (8 or >a)
0243 6E28 0281  26         ci    r1,8                  ; was it 8?
     6E2A 0008     
0244 6E2C 1303  14         jeq   dsrlnk.dsrscan.dsr.8  ; yes, jump: normal dsrlnk
0245 6E2E D060  38         movb  @>8350,r1             ; no, we have a data >a.
     6E30 8350     
0246                                                   ; Get error byte from @>8350
0247 6E32 1008  14         jmp   dsrlnk.dsrscan.dsr.a  ; go and return error byte to the caller
0248               
0249                       ;------------------------------------------------------
0250                       ; Read VDP PAB byte 1 after DSR call completed (status)
0251                       ;------------------------------------------------------
0252               dsrlnk.dsrscan.dsr.8:
0253                       ;---------------------------; Inline VSBR start
0254 6E34 06C0  22         swpb  r0                    ;
0255 6E36 D800  34         movb  r0,@vdpa              ; send low byte
     6E38 8C02     
0256 6E3A 06C0  22         swpb  r0                    ;
0257 6E3C D800  34         movb  r0,@vdpa              ; send high byte
     6E3E 8C02     
0258 6E40 D060  38         movb  @vdpr,r1              ; read byte from VDP ram
     6E42 8800     
0259                       ;---------------------------; Inline VSBR end
0260               
0261                       ;------------------------------------------------------
0262                       ; Return DSR error to caller
0263                       ;------------------------------------------------------
0264               dsrlnk.dsrscan.dsr.a:
0265 6E44 09D1  50         srl   r1,13                 ; just keep error bits
0266 6E46 1605  14         jne   dsrlnk.error.io_error
0267                                                   ; handle IO error
0268 6E48 0380  30         rtwp                        ; Return from DSR workspace to caller
0269                                                   ; workspace
0270               
0271                       ;------------------------------------------------------
0272                       ; IO-error handler
0273                       ;------------------------------------------------------
0274               dsrlnk.error.nodsr_found_off:
0275 6E4A 1E00  20         sbz   >00                   ; Turn card off, nomatter what
0276               dsrlnk.error.nodsr_found:
0277 6E4C 02E0  18         lwpi  dsrlnk.dsrlws         ; No DSR found, restore workspace
     6E4E A400     
0278               dsrlnk.error.devicename_invalid:
0279 6E50 04C1  22         clr   r1                    ; clear flag for error 0 = bad device name
0280               dsrlnk.error.io_error:
0281 6E52 06C1  22         swpb  r1                    ; put error in hi byte
0282 6E54 D741  38         movb  r1,*r13               ; store error flags in callers r0
0283 6E56 F3E0  42         socb  @hb$20,r15            ; \ Set equal bit in copy of status register
     6E58 201C     
0284                                                   ; / to indicate error
0285 6E5A 0380  30         rtwp                        ; Return from DSR workspace to caller
0286                                                   ; workspace
0287               
0288               
0289               ***************************************************************
0290               * dsrln.reuse - Reuse previous DSRLNK call for improved speed
0291               ***************************************************************
0292               *  blwp @dsrlnk.reuse
0293               *--------------------------------------------------------------
0294               *  Input:
0295               *  @>8356         = Pointer to VDP PAB file descriptor length byte (PAB+9)
0296               *  @dsrlnk.savcru = CRU address of device in previous DSR call
0297               *  @dsrlnk.savent = DSR entry address of previous DSR call
0298               *  @dsrlnk.savver = Version used in previous DSR call
0299               *  @dsrlnk.pabptr = Pointer to PAB in VDP memory, set in previous DSR call
0300               *--------------------------------------------------------------
0301               *  Output:
0302               *  r0 LSB = Bits 13-15 from VDP PAB byte 1, right aligned
0303               *--------------------------------------------------------------
0304               *  Remarks:
0305               *   Call the same DSR entry again without having to scan through
0306               *   all devices again.
0307               *
0308               *   Expects dsrlnk.savver, @dsrlnk.savent, @dsrlnk.savcru to be
0309               *   set by previous DSRLNK call.
0310               ********|*****|*********************|**************************
0311               dsrlnk.reuse:
0312 6E5C A400             data  dsrlnk.dsrlws         ; dsrlnk workspace
0313 6E5E 2D7E             data  dsrlnk.reuse.init     ; entry point
0314                       ;------------------------------------------------------
0315                       ; DSRLNK entry point
0316                       ;------------------------------------------------------
0317               dsrlnk.reuse.init:
0318 6E60 02E0  18         lwpi  >83e0                 ; Use GPL WS
     6E62 83E0     
0319               
0320 6E64 53E0  34         szcb  @hb$20,r15            ; reset equal bit in status register
     6E66 201C     
0321                       ;------------------------------------------------------
0322                       ; Restore dsrlnk variables of previous DSR call
0323                       ;------------------------------------------------------
0324 6E68 020B  20         li    r11,dsrlnk.savcru     ; Get pointer to last used CRU
     6E6A A42A     
0325 6E6C C33B  30         mov   *r11+,r12             ; Get CRU address         < @dsrlnk.savcru
0326 6E6E C27B  30         mov   *r11+,r9              ; Get DSR entry address   < @dsrlnk.savent
0327 6E70 C83B  42         mov   *r11+,@>8356          ; \ Get pointer to Device name or
     6E72 8356     
0328                                                   ; / or subprogram in PAB  < @dsrlnk.savpab
0329 6E74 C07B  30         mov   *r11+,R1              ; Get DSR Version number  < @dsrlnk.savver
0330 6E76 C81B  38         mov   *r11,@>8354           ; Get device name length  < @dsrlnk.savlen
     6E78 8354     
0331                       ;------------------------------------------------------
0332                       ; Call DSR program in card/device
0333                       ;------------------------------------------------------
0334 6E7A 020F  20         li    r15,>8C02             ; Set VDP port address, needed to prevent
     6E7C 8C02     
0335                                                   ; lockup of TI Disk Controller DSR.
0336               
0337 6E7E 1D00  16         sbo   >00                   ; Open card/device ROM
0338               
0339 6E80 9820  50         cb    @>4000,@dsrlnk.$aa00  ; Valid identifier found?
     6E82 4000     
     6E84 2DB6     
0340 6E86 16E2  14         jne   dsrlnk.error.nodsr_found
0341                                                   ; No, error code 0 = Bad Device name
0342                                                   ; The above jump may happen only in case of
0343                                                   ; either card hardware malfunction or if
0344                                                   ; there are 2 cards opened at the same time.
0345               
0346 6E88 0699  24         bl    *r9                   ; Execute DSR
0347                       ;
0348                       ; Depending on IO result the DSR in card ROM does RET
0349                       ; or (INCT R11 + RET), meaning either (1) or (2) get executed.
0350                       ;
0351 6E8A 10DF  14         jmp   dsrlnk.error.nodsr_found_off
0352                                                   ; (1) error return
0353 6E8C 1E00  16         sbz   >00                   ; (2) turn off card ROM if good return
0354                       ;------------------------------------------------------
0355                       ; Now check if any DSR error occured
0356                       ;------------------------------------------------------
0357 6E8E 02E0  18         lwpi  dsrlnk.dsrlws         ; Restore workspace
     6E90 A400     
0358 6E92 C020  42         mov   @dsrlnk.flgptr,r0     ; Get pointer to VDP PAB byte 1
     6E94 A434     
0359               
0360 6E96 10C6  14         jmp   dsrlnk.dsrscan.return_dsr
0361                                                   ; Rest is the same as with normal DSRLNK
0362               
0363               
