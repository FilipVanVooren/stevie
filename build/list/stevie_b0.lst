0204                       copy  "cpu_numsupport.asm"       ; CPU unsigned numbers support
     **** ****     > cpu_numsupport.asm
0001               * FILE......: cpu_numsupport.asm
0002               * Purpose...: CPU create, display numbers module
0003               
0004               ***************************************************************
0005               * MKNUM - Convert unsigned number to string
0006               ***************************************************************
0007               *  BL   @MKNUM
0008               *  DATA P0,P1,P2
0009               *
0010               *  P0   = Pointer to 16 bit unsigned number
0011               *  P1   = Pointer to 5 byte string buffer
0012               *  P2HB = Offset for ASCII digit
0013               *  P2LB = Character for replacing leading 0's
0014               *
0015               *  (CONFIG:0 = 1) = Display number at cursor YX
0016               *-------------------------------------------------------------
0017               *  Destroys registers tmp0-tmp4
0018               ********|*****|*********************|**************************
0019 6B38 0207  20 mknum   li    tmp3,5                ; Digit counter
     6B3A 0005     
0020 6B3C C17B  30         mov   *r11+,tmp1            ; \ Get 16 bit unsigned number
0021 6B3E C155  26         mov   *tmp1,tmp1            ; /
0022 6B40 C23B  30         mov   *r11+,tmp4            ; Pointer to string buffer
0023 6B42 0228  22         ai    tmp4,4                ; Get end of buffer
     6B44 0004     
0024 6B46 0206  20         li    tmp2,10               ; Divide by 10 to isolate last digit
     6B48 000A     
0025               *--------------------------------------------------------------
0026               *  Do string conversion
0027               *--------------------------------------------------------------
0028 6B4A 04C4  14 mknum1  clr   tmp0                  ; Clear the high word of the dividend
0029 6B4C 3D06 128         div   tmp2,tmp0             ; (TMP0:TMP1) / 10 (TMP2)
0030 6B4E 06C5  14         swpb  tmp1                  ; Move to high-byte for writing to buffer
0031 6B50 B15B  26         ab    *r11,tmp1             ; Add offset for ASCII digit
0032 6B52 D605  30         movb  tmp1,*tmp4            ; Write remainder to string buffer
0033 6B54 C144  18         mov   tmp0,tmp1             ; Move integer result into R4 for next digit
0034 6B56 0608  14         dec   tmp4                  ; Adjust string pointer for next digit
0035 6B58 0607  14         dec   tmp3                  ; Decrease counter
0036 6B5A 16F7  14         jne   mknum1                ; Do next digit
0037               *--------------------------------------------------------------
0038               *  Replace leading 0's with fill character
0039               *--------------------------------------------------------------
0040 6B5C 0207  20         li    tmp3,4                ; Check first 4 digits
     6B5E 0004     
0041 6B60 0588  14         inc   tmp4                  ; Too far, back to buffer start
0042 6B62 C11B  26         mov   *r11,tmp0
0043 6B64 0A84  32         sla   tmp0,8                ; Only keep fill character in HB
0044 6B66 96D8  34 mknum2  cb    *tmp4,*r11            ; Digit = 0 ?
0045 6B68 1305  14         jeq   mknum4                ; Yes, replace with fill character
0046 6B6A 05CB  14 mknum3  inct  r11
0047 6B6C 20A0  32         coc   @wbit0,config         ; Check if 'display' bit is set
     6B6E 2020     
0048 6B70 1305  14         jeq   mknum5                ; Yes, so show at current YX position
0049 6B72 045B  20         b     *r11                  ; Exit
0050 6B74 DE04  32 mknum4  movb  tmp0,*tmp4+           ; Replace leading 0 with fill character
0051 6B76 0607  14         dec   tmp3                  ; 4th digit processed ?
0052 6B78 13F8  14         jeq   mknum3                ; Yes, exit
0053 6B7A 10F5  14         jmp   mknum2                ; No, next one
0054               *--------------------------------------------------------------
0055               *  Display integer on screen at current YX position
0056               *--------------------------------------------------------------
0057 6B7C 0242  22 mknum5  andi  config,>7fff          ; Reset bit 0
     6B7E 7FFF     
0058 6B80 C10B  18         mov   r11,tmp0
0059 6B82 0224  22         ai    tmp0,-4
     6B84 FFFC     
0060 6B86 C154  26         mov   *tmp0,tmp1            ; Get buffer address
0061 6B88 0206  20         li    tmp2,>0500            ; String length = 5
     6B8A 0500     
0062 6B8C 0460  28         b     @xutstr               ; Display string
     6B8E 2422     
