0001               * FILE......: idx_delete.asm
0002               * Purpose...: Delete index entry
0003               
0004               ***************************************************************
0005               * _idx.entry.delete.reorg
0006               * Reorganize index slot entries
0007               ***************************************************************
0008               * bl @_idx.entry.delete.reorg
0009               *--------------------------------------------------------------
0010               *  Remarks
0011               *  Private, only to be called from idx_entry_delete
0012               ********|*****|*********************|**************************
0013               _idx.entry.delete.reorg:
0014                       ;------------------------------------------------------
0015                       ; Reorganize index entries
0016                       ;------------------------------------------------------
0017 775E 0224  22         ai    tmp0,idx.top          ; Add index base to offset
     7760 B000     
0018 7762 C144  18         mov   tmp0,tmp1             ; a = current slot
0019 7764 05C5  14         inct  tmp1                  ; b = current slot + 2
0020                       ;------------------------------------------------------
0021                       ; Loop forward until end of index
0022                       ;------------------------------------------------------
0023               _idx.entry.delete.reorg.loop:
0024 7766 CD35  46         mov   *tmp1+,*tmp0+         ; Copy b -> a
0025 7768 0606  14         dec   tmp2                  ; tmp2--
0026 776A 16FD  14         jne   _idx.entry.delete.reorg.loop
0027                                                   ; Loop unless completed
0028 776C 045B  20         b     *r11                  ; Return to caller
0029               
