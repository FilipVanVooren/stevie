0067               ***************************************************************
0068               * trimnum - Trim unsigned number string
0069               ***************************************************************
0070               *  bl   @trimnum
0071               *  data p0,p1,p2
0072               *--------------------------------------------------------------
0073               *  p0   = Pointer to 5 byte string buffer (no length byte!)
0074               *  p1   = Pointer to output variable
0075               *  p2   = Padding character to match against
0076               *--------------------------------------------------------------
0077               *  Copy unsigned number string into a length-padded, left
0078               *  justified string for display with putstr, putat, ...
0079               *
0080               *  The new string starts at index 5 in buffer, overwriting
0081               *  anything that is located there !
0082               *
0083               *               01234|56789A
0084               *  Before...:   XXXXX          length
0085               *  After....:   XXXXY|zY       z=1
0086               *               XXXYY|zYY      z=2
0087               *               XXYYY|zYYY     z=3
0088               *               XYYYY|zYYYY    z=4
0089               *               YYYYY|zYYYYY   z=5
0090               *--------------------------------------------------------------
0091               *  Destroys registers tmp0-tmp3
0092               ********|*****|*********************|**************************
0093               trimnum:
0094 6B90 C13B  30         mov   *r11+,tmp0            ; Get pointer to input string
0095 6B92 C17B  30         mov   *r11+,tmp1            ; Get pointer to output string
0096 6B94 C1BB  30         mov   *r11+,tmp2            ; Get padding character
0097 6B96 06C6  14         swpb  tmp2                  ; LO <-> HI
0098 6B98 0207  20         li    tmp3,5                ; Set counter
     6B9A 0005     
0099                       ;------------------------------------------------------
0100                       ; Scan for padding character from left to right
0101                       ;------------------------------------------------------:
0102               trimnum_scan:
0103 6B9C 9194  26         cb    *tmp0,tmp2            ; Matches padding character ?
0104 6B9E 1604  14         jne   trimnum_setlen        ; No, exit loop
0105 6BA0 0584  14         inc   tmp0                  ; Next character
0106 6BA2 0607  14         dec   tmp3                  ; Last digit reached ?
0107 6BA4 1301  14         jeq   trimnum_setlen        ; yes, exit loop
0108 6BA6 10FA  14         jmp   trimnum_scan
0109                       ;------------------------------------------------------
0110                       ; Scan completed, set length byte new string
0111                       ;------------------------------------------------------
0112               trimnum_setlen:
0113 6BA8 06C7  14         swpb  tmp3                  ; LO <-> HI
0114 6BAA DD47  32         movb  tmp3,*tmp1+           ; Update string-length in work buffer
0115 6BAC 06C7  14         swpb  tmp3                  ; LO <-> HI
0116                       ;------------------------------------------------------
0117                       ; Start filling new string
0118                       ;------------------------------------------------------
0119               trimnum_fill:
0120 6BAE DD74  42         movb  *tmp0+,*tmp1+         ; Copy character
0121 6BB0 0607  14         dec   tmp3                  ; Last character ?
0122 6BB2 16FD  14         jne   trimnum_fill          ; Not yet, repeat
0123 6BB4 045B  20         b     *r11                  ; Return
0124               
0125               
0126               
