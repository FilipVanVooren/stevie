0001               * FILE......: basic_cpu_vdp.asm
0002               * Purpose...: Basic CPU & VDP functions used by other modules
0003               
0004               *//////////////////////////////////////////////////////////////
0005               *       Support Machine Code for copy & fill functions
0006               *//////////////////////////////////////////////////////////////
0007               
0008               *--------------------------------------------------------------
0009               * ; Machine code for tight loop.
0010               * ; The MOV operation at MCLOOP must be injected by the calling routine.
0011               *--------------------------------------------------------------
0012               *       DATA  >????                 ; \ mcloop  mov   ...
0013 62F2 0606     mccode  data  >0606                 ; |         dec   r6 (tmp2)
0014 62F4 16FD             data  >16fd                 ; |         jne   mcloop
0015 62F6 045B             data  >045b                 ; /         b     *r11
0016               *--------------------------------------------------------------
0017               * ; Machine code for reading from the speech synthesizer
0018               * ; The SRC instruction takes 12 uS for execution in scratchpad RAM.
0019               * ; Is required for the 12 uS delay. It destroys R5.
0020               *--------------------------------------------------------------
0021 62F8 D114     spcode  data  >d114                 ; \         movb  *r4,r4 (tmp0)
0022 62FA 0BC5             data  >0bc5                 ; /         src   r5,12  (tmp1)
0023                       even
0024               
0025               
0026               ***************************************************************
0027               * loadmc - Load machine code into scratchpad  >8322 - >8328
0028               ***************************************************************
0029               *  bl  @loadmc
0030               *--------------------------------------------------------------
0031               *  REMARKS
0032               *  Machine instruction in location @>8320 will be set by
0033               *  SP2 copy/fill routine that is called later on.
0034               ********|*****|*********************|**************************
0035               loadmc:
0036 62FC 0201  20         li    r1,mccode             ; Machinecode to patch
     62FE 2210     
0037 6300 0202  20         li    r2,mcloop+2           ; Scratch-pad reserved for machine code
     6302 8322     
0038 6304 CCB1  46         mov   *r1+,*r2+             ; Copy 1st instruction
0039 6306 CCB1  46         mov   *r1+,*r2+             ; Copy 2nd instruction
0040 6308 CCB1  46         mov   *r1+,*r2+             ; Copy 3rd instruction
0041 630A 045B  20         b     *r11                  ; Return to caller
0042               
0043               
0044               *//////////////////////////////////////////////////////////////
0045               *                    STACK SUPPORT FUNCTIONS
0046               *//////////////////////////////////////////////////////////////
0047               
0048               ***************************************************************
0049               * POPR. - Pop registers & return to caller
0050               ***************************************************************
0051               *  B  @POPRG.
0052               *--------------------------------------------------------------
0053               *  REMARKS
0054               *  R11 must be at stack bottom
0055               ********|*****|*********************|**************************
0056 630C C0F9  30 popr3   mov   *stack+,r3
0057 630E C0B9  30 popr2   mov   *stack+,r2
0058 6310 C079  30 popr1   mov   *stack+,r1
0059 6312 C039  30 popr0   mov   *stack+,r0
0060 6314 C2F9  30 poprt   mov   *stack+,r11
0061 6316 045B  20         b     *r11
0062               
0063               
0064               
0065               *//////////////////////////////////////////////////////////////
0066               *                   MEMORY FILL FUNCTIONS
0067               *//////////////////////////////////////////////////////////////
0068               
0069               ***************************************************************
0070               * FILM - Fill CPU memory with byte
0071               ***************************************************************
0072               *  bl   @film
0073               *  data P0,P1,P2
0074               *--------------------------------------------------------------
0075               *  P0 = Memory start address
0076               *  P1 = Byte to fill
0077               *  P2 = Number of bytes to fill
0078               *--------------------------------------------------------------
0079               *  bl   @xfilm
0080               *
0081               *  TMP0 = Memory start address
0082               *  TMP1 = Byte to fill
0083               *  TMP2 = Number of bytes to fill
0084               ********|*****|*********************|**************************
0085 6318 C13B  30 film    mov   *r11+,tmp0            ; Memory start
0086 631A C17B  30         mov   *r11+,tmp1            ; Byte to fill
0087 631C C1BB  30         mov   *r11+,tmp2            ; Repeat count
0088               *--------------------------------------------------------------
0089               * Assert
0090               *--------------------------------------------------------------
0091 631E C1C6  18 xfilm   mov   tmp2,tmp3             ; Bytes to fill = 0 ?
0092 6320 1604  14         jne   filchk                ; No, continue checking
0093               
0094 6322 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     6324 FFCE     
0095 6326 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     6328 2026     
0096               *--------------------------------------------------------------
0097               *       Check: 1 byte fill
0098               *--------------------------------------------------------------
0099 632A D820  42 filchk  movb  @tmp1lb,@tmp1hb       ; Duplicate value
     632C 830B     
     632E 830A     
0100               
0101 6330 0286  22         ci    tmp2,1                ; Bytes to fill = 1 ?
     6332 0001     
0102 6334 1602  14         jne   filchk2
0103 6336 DD05  32         movb  tmp1,*tmp0+
0104 6338 045B  20         b     *r11                  ; Exit
0105               *--------------------------------------------------------------
0106               *       Check: 2 byte fill
0107               *--------------------------------------------------------------
0108 633A 0286  22 filchk2 ci    tmp2,2                ; Byte to fill = 2 ?
     633C 0002     
0109 633E 1603  14         jne   filchk3
0110 6340 DD05  32         movb  tmp1,*tmp0+           ; Deal with possible uneven start address
0111 6342 DD05  32         movb  tmp1,*tmp0+
0112 6344 045B  20         b     *r11                  ; Exit
0113               *--------------------------------------------------------------
0114               *       Check: Handle uneven start address
0115               *--------------------------------------------------------------
0116 6346 C1C4  18 filchk3 mov   tmp0,tmp3
0117 6348 0247  22         andi  tmp3,1                ; TMP3=1 -> ODD else EVEN
     634A 0001     
0118 634C 1305  14         jeq   fil16b
0119 634E DD05  32         movb  tmp1,*tmp0+           ; Copy 1st byte
0120 6350 0606  14         dec   tmp2
0121 6352 0286  22         ci    tmp2,2                ; Do we only have 1 word left?
     6354 0002     
0122 6356 13F1  14         jeq   filchk2               ; Yes, copy word and exit
0123               *--------------------------------------------------------------
0124               *       Fill memory with 16 bit words
0125               *--------------------------------------------------------------
0126 6358 C1C6  18 fil16b  mov   tmp2,tmp3
0127 635A 0247  22         andi  tmp3,1                ; TMP3=1 -> ODD else EVEN
     635C 0001     
0128 635E 1301  14         jeq   dofill
0129 6360 0606  14         dec   tmp2                  ; Make TMP2 even
0130 6362 CD05  34 dofill  mov   tmp1,*tmp0+
0131 6364 0646  14         dect  tmp2
0132 6366 16FD  14         jne   dofill
0133               *--------------------------------------------------------------
0134               * Fill last byte if ODD
0135               *--------------------------------------------------------------
0136 6368 C1C7  18         mov   tmp3,tmp3
0137 636A 1301  14         jeq   fil.exit
0138 636C DD05  32         movb  tmp1,*tmp0+
0139               fil.exit:
0140 636E 045B  20         b     *r11
0141               
0142               
0143               ***************************************************************
0144               * FILV - Fill VRAM with byte
0145               ***************************************************************
0146               *  BL   @FILV
0147               *  DATA P0,P1,P2
0148               *--------------------------------------------------------------
0149               *  P0 = VDP start address
0150               *  P1 = Byte to fill
0151               *  P2 = Number of bytes to fill
0152               *--------------------------------------------------------------
0153               *  BL   @XFILV
0154               *
0155               *  TMP0 = VDP start address
0156               *  TMP1 = Byte to fill
0157               *  TMP2 = Number of bytes to fill
0158               ********|*****|*********************|**************************
0159 6370 C13B  30 filv    mov   *r11+,tmp0            ; Memory start
0160 6372 C17B  30         mov   *r11+,tmp1            ; Byte to fill
0161 6374 C1BB  30         mov   *r11+,tmp2            ; Repeat count
0162               *--------------------------------------------------------------
0163               *    Setup VDP write address
0164               *--------------------------------------------------------------
0165 6376 0264  22 xfilv   ori   tmp0,>4000
     6378 4000     
0166 637A 06C4  14         swpb  tmp0
0167 637C D804  30         movb  tmp0,@vdpa
     637E 8C02     
0168 6380 06C4  14         swpb  tmp0
0169 6382 D804  30         movb  tmp0,@vdpa
     6384 8C02     
0170               *--------------------------------------------------------------
0171               *    Fill bytes in VDP memory
0172               *--------------------------------------------------------------
0173 6386 020F  20         li    r15,vdpw              ; Set VDP write address
     6388 8C00     
0174 638A 06C5  14         swpb  tmp1
0175 638C C820  46         mov   @filzz,@mcloop        ; Setup move command
     638E 22B4     
     6390 8320     
0176 6392 0460  24         b     @mcloop               ; Write data to VDP
     6394 8320     
0177               *--------------------------------------------------------------
0181 6396 D7C5     filzz   data  >d7c5                 ; MOVB TMP1,*R15
0183               
0184               
0185               
0186               *//////////////////////////////////////////////////////////////
0187               *                  VDP LOW LEVEL FUNCTIONS
0188               *//////////////////////////////////////////////////////////////
0189               
0190               ***************************************************************
0191               * VDWA / VDRA - Setup VDP write or read address
0192               ***************************************************************
0193               *  BL   @VDWA
0194               *
0195               *  TMP0 = VDP destination address for write
0196               *--------------------------------------------------------------
0197               *  BL   @VDRA
0198               *
0199               *  TMP0 = VDP source address for read
0200               ********|*****|*********************|**************************
0201 6398 0264  22 vdwa    ori   tmp0,>4000            ; Prepare VDP address for write
     639A 4000     
0202 639C 06C4  14 vdra    swpb  tmp0
0203 639E D804  30         movb  tmp0,@vdpa
     63A0 8C02     
0204 63A2 06C4  14         swpb  tmp0
0205 63A4 D804  30         movb  tmp0,@vdpa            ; Set VDP address
     63A6 8C02     
0206 63A8 045B  20         b     *r11                  ; Exit
0207               
0208               ***************************************************************
0209               * VPUTB - VDP put single byte
0210               ***************************************************************
0211               *  BL @VPUTB
0212               *  DATA P0,P1
0213               *--------------------------------------------------------------
0214               *  P0 = VDP target address
0215               *  P1 = Byte to write
0216               ********|*****|*********************|**************************
0217 63AA C13B  30 vputb   mov   *r11+,tmp0            ; Get VDP target address
0218 63AC C17B  30         mov   *r11+,tmp1            ; Get byte to write
0219               *--------------------------------------------------------------
0220               * Set VDP write address
0221               *--------------------------------------------------------------
0222 63AE 0264  22 xvputb  ori   tmp0,>4000            ; Prepare VDP address for write
     63B0 4000     
0223 63B2 06C4  14         swpb  tmp0                  ; \
0224 63B4 D804  30         movb  tmp0,@vdpa            ; | Set VDP write address
     63B6 8C02     
0225 63B8 06C4  14         swpb  tmp0                  ; | inlined @vdwa call
0226 63BA D804  30         movb  tmp0,@vdpa            ; /
     63BC 8C02     
0227               *--------------------------------------------------------------
0228               * Write byte
0229               *--------------------------------------------------------------
0230 63BE 06C5  14         swpb  tmp1                  ; LSB to MSB
0231 63C0 D7C5  30         movb  tmp1,*r15             ; Write byte
0232 63C2 045B  20         b     *r11                  ; Exit
0233               
0234               
0235               ***************************************************************
0236               * VGETB - VDP get single byte
0237               ***************************************************************
0238               *  bl   @vgetb
0239               *  data p0
0240               *--------------------------------------------------------------
0241               *  P0 = VDP source address
0242               *--------------------------------------------------------------
0243               *  bl   @xvgetb
0244               *
0245               *  tmp0 = VDP source address
0246               *--------------------------------------------------------------
0247               *  Output:
0248               *  tmp0 MSB = >00
0249               *  tmp0 LSB = VDP byte read
0250               ********|*****|*********************|**************************
0251 63C4 C13B  30 vgetb   mov   *r11+,tmp0            ; Get VDP source address
0252               *--------------------------------------------------------------
0253               * Set VDP read address
0254               *--------------------------------------------------------------
0255 63C6 06C4  14 xvgetb  swpb  tmp0                  ; \
0256 63C8 D804  30         movb  tmp0,@vdpa            ; | Set VDP read address
     63CA 8C02     
0257 63CC 06C4  14         swpb  tmp0                  ; | inlined @vdra call
0258 63CE D804  30         movb  tmp0,@vdpa            ; /
     63D0 8C02     
0259               *--------------------------------------------------------------
0260               * Read byte
0261               *--------------------------------------------------------------
0262 63D2 D120  30         movb  @vdpr,tmp0            ; Read byte
     63D4 8800     
0263 63D6 0984  32         srl   tmp0,8                ; Right align
0264 63D8 045B  20         b     *r11                  ; Exit
0265               
0266               
0267               ***************************************************************
0268               * VIDTAB - Dump videomode table
0269               ***************************************************************
0270               *  BL   @VIDTAB
0271               *  DATA P0
0272               *--------------------------------------------------------------
0273               *  P0 = Address of video mode table
0274               *--------------------------------------------------------------
0275               *  BL   @XIDTAB
0276               *
0277               *  TMP0 = Address of video mode table
0278               *--------------------------------------------------------------
0279               *  Remarks
0280               *  TMP1 = MSB is the VDP target register
0281               *         LSB is the value to write
0282               ********|*****|*********************|**************************
0283 63DA C13B  30 vidtab  mov   *r11+,tmp0            ; Get video mode table
0284 63DC C394  26 xidtab  mov   *tmp0,r14             ; Store copy of VDP#0 and #1 in RAM
0285               *--------------------------------------------------------------
0286               * Calculate PNT base address
0287               *--------------------------------------------------------------
0288 63DE C144  18         mov   tmp0,tmp1
0289 63E0 05C5  14         inct  tmp1
0290 63E2 D155  26         movb  *tmp1,tmp1            ; Get value for VDP#2
0291 63E4 0245  22         andi  tmp1,>ff00            ; Only keep MSB
     63E6 FF00     
0292 63E8 0A25  20         sla   tmp1,2                ; TMP1 *= 400
0293 63EA C805  30         mov   tmp1,@wbase           ; Store calculated base
     63EC 8328     
0294               *--------------------------------------------------------------
0295               * Dump VDP shadow registers
0296               *--------------------------------------------------------------
0297 63EE 0205  20         li    tmp1,>8000            ; Start with VDP register 0
     63F0 8000     
0298 63F2 0206  20         li    tmp2,8
     63F4 0008     
0299 63F6 D834  40 vidta1  movb  *tmp0+,@tmp1lb        ; Write value to VDP register
     63F8 830B     
0300 63FA 06C5  14         swpb  tmp1
0301 63FC D805  30         movb  tmp1,@vdpa
     63FE 8C02     
0302 6400 06C5  14         swpb  tmp1
0303 6402 D805  30         movb  tmp1,@vdpa
     6404 8C02     
0304 6406 0225  22         ai    tmp1,>0100
     6408 0100     
0305 640A 0606  14         dec   tmp2
0306 640C 16F4  14         jne   vidta1                ; Next register
0307 640E C814  38         mov   *tmp0,@wcolmn         ; Store # of columns per row
     6410 833A     
0308 6412 045B  20         b     *r11
0309               
0310               
0311               ***************************************************************
0312               * PUTVR  - Put single VDP register
0313               ***************************************************************
0314               *  BL   @PUTVR
0315               *  DATA P0
0316               *--------------------------------------------------------------
0317               *  P0 = MSB is the VDP target register
0318               *       LSB is the value to write
0319               *--------------------------------------------------------------
0320               *  BL   @PUTVRX
0321               *
0322               *  TMP0 = MSB is the VDP target register
0323               *         LSB is the value to write
0324               ********|*****|*********************|**************************
0325 6414 C13B  30 putvr   mov   *r11+,tmp0
0326 6416 0264  22 putvrx  ori   tmp0,>8000
     6418 8000     
0327 641A 06C4  14         swpb  tmp0
0328 641C D804  30         movb  tmp0,@vdpa
     641E 8C02     
0329 6420 06C4  14         swpb  tmp0
0330 6422 D804  30         movb  tmp0,@vdpa
     6424 8C02     
0331 6426 045B  20         b     *r11
0332               
0333               
0334               ***************************************************************
0335               * PUTV01  - Put VDP registers #0 and #1
0336               ***************************************************************
0337               *  BL   @PUTV01
0338               ********|*****|*********************|**************************
0339 6428 C20B  18 putv01  mov   r11,tmp4              ; Save R11
0340 642A C10E  18         mov   r14,tmp0
0341 642C 0984  32         srl   tmp0,8
0342 642E 06A0  32         bl    @putvrx               ; Write VR#0
     6430 2334     
0343 6432 0204  20         li    tmp0,>0100
     6434 0100     
0344 6436 D820  42         movb  @r14lb,@tmp0lb
     6438 831D     
     643A 8309     
0345 643C 06A0  32         bl    @putvrx               ; Write VR#1
     643E 2334     
0346 6440 0458  20         b     *tmp4                 ; Exit
0347               
0348               
0349               ***************************************************************
0350               * LDFNT - Load TI-99/4A font from GROM into VDP
0351               ***************************************************************
0352               *  BL   @LDFNT
0353               *  DATA P0,P1
0354               *--------------------------------------------------------------
0355               *  P0 = VDP Target address
0356               *  P1 = Font options
0357               *--------------------------------------------------------------
0358               * Uses registers tmp0-tmp4
0359               ********|*****|*********************|**************************
0360 6442 C20B  18 ldfnt   mov   r11,tmp4              ; Save R11
0361 6444 05CB  14         inct  r11                   ; Get 2nd parameter (font options)
0362 6446 C11B  26         mov   *r11,tmp0             ; Get P0
0363 6448 0242  22         andi  config,>7fff          ; CONFIG register bit 0=0
     644A 7FFF     
0364 644C 2120  32         coc   @wbit0,tmp0
     644E 2020     
0365 6450 1604  14         jne   ldfnt1
0366 6452 0262  22         ori   config,>8000          ; CONFIG register bit 0=1
     6454 8000     
0367 6456 0244  22         andi  tmp0,>7fff            ; Parameter value bit 0=0
     6458 7FFF     
0368               *--------------------------------------------------------------
0369               * Read font table address from GROM into tmp1
0370               *--------------------------------------------------------------
0371 645A C124  34 ldfnt1  mov   @tmp006(tmp0),tmp0    ; Load GROM index address into tmp0
     645C 23E2     
0372 645E D804  38         movb  tmp0,@grmwa           ; Setup GROM source byte 1 for reading
     6460 9C02     
0373 6462 06C4  14         swpb  tmp0
0374 6464 D804  38         movb  tmp0,@grmwa           ; Setup GROM source byte 2 for reading
     6466 9C02     
0375 6468 D160  34         movb  @grmrd,tmp1           ; Read font table address byte 1
     646A 9800     
0376 646C 06C5  14         swpb  tmp1
0377 646E D160  34         movb  @grmrd,tmp1           ; Read font table address byte 2
     6470 9800     
0378 6472 06C5  14         swpb  tmp1
0379               *--------------------------------------------------------------
0380               * Setup GROM source address from tmp1
0381               *--------------------------------------------------------------
0382 6474 D805  38         movb  tmp1,@grmwa
     6476 9C02     
0383 6478 06C5  14         swpb  tmp1
0384 647A D805  38         movb  tmp1,@grmwa           ; Setup GROM address for reading
     647C 9C02     
0385               *--------------------------------------------------------------
0386               * Setup VDP target address
0387               *--------------------------------------------------------------
0388 647E C118  26         mov   *tmp4,tmp0            ; Get P1 (VDP destination)
0389 6480 06A0  32         bl    @vdwa                 ; Setup VDP destination address
     6482 22B6     
0390 6484 05C8  14         inct  tmp4                  ; R11=R11+2
0391 6486 C158  26         mov   *tmp4,tmp1            ; Get font options into TMP1
0392 6488 0245  22         andi  tmp1,>7fff            ; Parameter value bit 0=0
     648A 7FFF     
0393 648C C1A5  34         mov   @tmp006+2(tmp1),tmp2  ; Get number of patterns to copy
     648E 23E4     
0394 6490 C165  34         mov   @tmp006+4(tmp1),tmp1  ; 7 or 8 byte pattern ?
     6492 23E6     
0395               *--------------------------------------------------------------
0396               * Copy from GROM to VRAM
0397               *--------------------------------------------------------------
0398 6494 0B15  18 ldfnt2  src   tmp1,1                ; Carry set ?
0399 6496 1812  14         joc   ldfnt4                ; Yes, go insert a >00
0400 6498 D120  34         movb  @grmrd,tmp0
     649A 9800     
0401               *--------------------------------------------------------------
0402               *   Make font fat
0403               *--------------------------------------------------------------
0404 649C 20A0  32         coc   @wbit0,config         ; Fat flag set ?
     649E 2020     
0405 64A0 1603  14         jne   ldfnt3                ; No, so skip
0406 64A2 D1C4  18         movb  tmp0,tmp3
0407 64A4 0917  18         srl   tmp3,1
0408 64A6 E107  18         soc   tmp3,tmp0
0409               *--------------------------------------------------------------
0410               *   Dump byte to VDP and do housekeeping
0411               *--------------------------------------------------------------
0412 64A8 D804  30 ldfnt3  movb  tmp0,@vdpw            ; Dump byte to VRAM
     64AA 8C00     
0413 64AC 0606  14         dec   tmp2
0414 64AE 16F2  14         jne   ldfnt2
0415 64B0 05C8  14         inct  tmp4                  ; R11=R11+2
0416 64B2 020F  20         li    r15,vdpw              ; Set VDP write address
     64B4 8C00     
0417 64B6 0242  22         andi  config,>7fff          ; CONFIG register bit 0=0
     64B8 7FFF     
0418 64BA 0458  20         b     *tmp4                 ; Exit
0419 64BC D820  46 ldfnt4  movb  @hb$00,@vdpw          ; Insert byte >00 into VRAM
     64BE 2000     
     64C0 8C00     
0420 64C2 10E8  14         jmp   ldfnt2
0421               *--------------------------------------------------------------
0422               * Fonts pointer table
0423               *--------------------------------------------------------------
0424 64C4 004C     tmp006  data  >004c,64*8,>0000      ; Pointer to TI title screen font
     64C6 0200     
     64C8 0000     
0425 64CA 004E             data  >004e,64*7,>0101      ; Pointer to upper case font
     64CC 01C0     
     64CE 0101     
0426 64D0 004E             data  >004e,96*7,>0101      ; Pointer to upper & lower case font
     64D2 02A0     
     64D4 0101     
0427 64D6 0050             data  >0050,32*7,>0101      ; Pointer to lower case font
     64D8 00E0     
     64DA 0101     
0428               
0429               
0430               
0431               ***************************************************************
0432               * YX2PNT - Get VDP PNT address for current YX cursor position
0433               ***************************************************************
0434               *  BL   @YX2PNT
0435               *--------------------------------------------------------------
0436               *  INPUT
0437               *  @WYX = Cursor YX position
0438               *--------------------------------------------------------------
0439               *  OUTPUT
0440               *  TMP0 = VDP address for entry in Pattern Name Table
0441               *--------------------------------------------------------------
0442               *  Register usage
0443               *  TMP0, R14, R15
0444               ********|*****|*********************|**************************
0445 64DC C10E  18 yx2pnt  mov   r14,tmp0              ; Save VDP#0 & VDP#1
0446 64DE C3A0  30         mov   @wyx,r14              ; Get YX
     64E0 832A     
0447 64E2 098E  32         srl   r14,8                 ; Right justify (remove X)
0448 64E4 3BA0  70         mpy   @wcolmn,r14           ; pos = Y * (columns per row)
     64E6 833A     
0449               *--------------------------------------------------------------
0450               * Do rest of calculation with R15 (16 bit part is there)
0451               * Re-use R14
0452               *--------------------------------------------------------------
0453 64E8 C3A0  30         mov   @wyx,r14              ; Get YX
     64EA 832A     
0454 64EC 024E  22         andi  r14,>00ff             ; Remove Y
     64EE 00FF     
0455 64F0 A3CE  18         a     r14,r15               ; pos = pos + X
0456 64F2 A3E0  30         a     @wbase,r15            ; pos = pos + (PNT base address)
     64F4 8328     
0457               *--------------------------------------------------------------
0458               * Clean up before exit
0459               *--------------------------------------------------------------
0460 64F6 C384  18         mov   tmp0,r14              ; Restore VDP#0 & VDP#1
0461 64F8 C10F  18         mov   r15,tmp0              ; Return pos in TMP0
0462 64FA 020F  20         li    r15,vdpw              ; VDP write address
     64FC 8C00     
0463 64FE 045B  20         b     *r11
0464               
0465               
0466               
0467               ***************************************************************
0468               * Put length-byte prefixed string at current YX
0469               ***************************************************************
0470               *  BL   @PUTSTR
0471               *  DATA P0
0472               *
0473               *  P0 = Pointer to string
0474               *--------------------------------------------------------------
0475               *  REMARKS
0476               *  First byte of string must contain length
0477               *--------------------------------------------------------------
0478               *  Register usage
0479               *  tmp1, tmp2, tmp3
0480               ********|*****|*********************|**************************
0481 6500 C17B  30 putstr  mov   *r11+,tmp1
0482 6502 D1B5  28 xutst0  movb  *tmp1+,tmp2           ; Get length byte
0483 6504 C1CB  18 xutstr  mov   r11,tmp3
0484 6506 06A0  32         bl    @yx2pnt               ; Get VDP destination address
     6508 23FA     
0485 650A C2C7  18         mov   tmp3,r11
0486 650C 0986  32         srl   tmp2,8                ; Right justify length byte
0487               *--------------------------------------------------------------
0488               * Put string
0489               *--------------------------------------------------------------
0490 650E C186  18         mov   tmp2,tmp2             ; Length = 0 ?
0491 6510 1305  14         jeq   !                     ; Yes, crash and burn
0492               
0493 6512 0286  22         ci    tmp2,255              ; Length > 255 ?
     6514 00FF     
0494 6516 1502  14         jgt   !                     ; Yes, crash and burn
0495               
0496 6518 0460  28         b     @xpym2v               ; Display string
     651A 24EC     
0497               *--------------------------------------------------------------
0498               * Crash handler
0499               *--------------------------------------------------------------
0500 651C C80B  38 !       mov   r11,@>ffce            ; \ Save caller address
     651E FFCE     
0501 6520 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     6522 2026     
0502               
0503               
0504               
0505               ***************************************************************
0506               * Put length-byte prefixed string at YX
0507               ***************************************************************
0508               *  BL   @PUTAT
0509               *  DATA P0,P1
0510               *
0511               *  P0 = YX position
0512               *  P1 = Pointer to string
0513               *--------------------------------------------------------------
0514               *  REMARKS
0515               *  First byte of string must contain length
0516               ********|*****|*********************|**************************
0517 6524 C83B  42 putat   mov   *r11+,@wyx            ; Set YX position
     6526 832A     
0518 6528 0460  28         b     @putstr
     652A 241E     
0519               
0520               ***************************************************************
0521               * putlst
0522               * Loop over string list and display in columns
0523               ***************************************************************
0524               * bl  @putlst
0525               *--------------------------------------------------------------
0526               * INPUT
0527               * @wyx = Cursor position
0528               * tmp0 = Cutover row and column offset for next column.
0529               *        Set to >0000 for single-column list
0530               * tmp1 = Pointer to first length-prefixed string in list
0531               * tmp2 = Number of strings to display
0532               * tmp3 = String padding length
0533               *--------------------------------------------------------------
0534               * OUTPUT
0535               * @waux1 = Pointer to next entry in list after display.
0536               *          Only set if tmp2 < entries in list
0537               *--------------------------------------------------------------
0538               * Register usage
0539               * r0 (!), tmp0, tmp1, tmp2, tmp3, tmp4
0540               *
0541               * Memory usage
0542               * r0     = Counter used in padding
0543               * r1     = Backup YX used in padding
0544               * @waux1 = Backup string padding length
0545               ********|*****|*********************|**************************
0546               putlst:
0547 652C 0649  14         dect  stack
0548 652E C64B  30         mov   r11,*stack            ; Save return address
0549                       ;------------------------------------------------------
0550                       ; Prepare
0551                       ;------------------------------------------------------
0552 6530 C807  30 	mov   tmp3,@waux1           ; Backup string padding length
     6532 833C     
0553 6534 C220  30         mov   @wyx,tmp4             ; Backup @wyx position
     6536 832A     
0554                       ;------------------------------------------------------
0555                       ; Dump strings to VDP
0556                       ;------------------------------------------------------
0557               putlst.loop:
0558 6538 D1D5  26         movb  *tmp1,tmp3            ; Get string length byte
0559 653A 0987  32         srl   tmp3,8                ; Right align
0560 653C 1343  14         jeq   putlst.exit           ; Exit early if 0-byte string length
0561                       ;------------------------------------------------------
0562                       ; Display string
0563                       ;------------------------------------------------------
0564 653E 0649  14         dect  stack
0565 6540 C644  30         mov   tmp0,*stack           ; Push tmp0
0566 6542 0649  14         dect  stack
0567 6544 C645  30         mov   tmp1,*stack           ; Push tmp1
0568 6546 0649  14         dect  stack
0569 6548 C646  30         mov   tmp2,*stack           ; Push tmp2
0570 654A 0649  14         dect  stack
0571 654C C647  30         mov   tmp3,*stack           ; Push tmp3
0572 654E 0649  14         dect  stack
0573 6550 C648  30         mov   tmp4,*stack           ; Push tmp4
0574               
0575 6552 06A0  32         bl    @xutst0               ; Display string
     6554 2420     
0576                                                   ; \ i  tmp1 = Pointer to string
0577                                                   ; / i  @wyx = Cursor position at
0578               
0579 6556 C239  30         mov   *stack+,tmp4          ; Pop tmp4
0580 6558 C1F9  30         mov   *stack+,tmp3          ; Pop tmp3
0581 655A C1B9  30         mov   *stack+,tmp2          ; Pop tmp2
0582 655C C179  30         mov   *stack+,tmp1          ; Pop tmp1
0583 655E C139  30         mov   *stack+,tmp0          ; Pop tmp0
0584                       ;------------------------------------------------------
0585                       ; Pad string?
0586                       ;------------------------------------------------------
0587 6560 0760  30         abs   @waux1                ; Padding length set?
     6562 833C     
0588 6564 131C  14         jeq   putlst.nextcol        ; No, skip padding
0589               
0590 6566 81E0  30         c     @waux1,tmp3           ; Padding length < string length?
     6568 833C     
0591 656A 1319  14         jeq   putlst.nextcol        ; Yes, skip padding
0592                       ;------------------------------------------------------
0593                       ; Pad string
0594                       ;------------------------------------------------------
0595 656C C060  30         mov   @wyx,r1               ; Backup YX
     656E 832A     
0596 6570 A807  30         a     tmp3,@wyx             ; Add string length
     6572 832A     
0597 6574 C020  30         mov   @waux1,r0             ; Set counter
     6576 833C     
0598               
0599               putlst.loop.pad:
0600 6578 0649  14         dect  stack
0601 657A C644  30         mov   tmp0,*stack           ; Push tmp0
0602 657C 0649  14         dect  stack
0603 657E C645  30         mov   tmp1,*stack           ; Push tmp1
0604               
0605 6580 06A0  32         bl    @yx2pnt               ; Get VDP destination address (tmp0)
     6582 23FA     
0606               
0607 6584 0205  20         li    tmp1,32
     6586 0020     
0608 6588 06A0  32         bl    @xvputb               ; Write byte to VDP
     658A 22CC     
0609                                                   ; \ i  tmp0 = VDP destination address
0610                                                   ; / i  tmp1 = Byte to write in LSB
0611               
0612 658C C179  30         mov   *stack+,tmp1          ; Pop tmp1
0613 658E C139  30         mov   *stack+,tmp0          ; Pop tmp0
0614               
0615 6590 05A0  26         inc   @wyx                  ; X=X+1
     6592 832A     
0616 6594 0600  14         dec   r0
0617 6596 81C0  18         c     r0,tmp3
0618 6598 15EF  14         jgt   putlst.loop.pad
0619               
0620 659A C801  30         mov   r1,@wyx               ; Restore YX
     659C 832A     
0621                       ;------------------------------------------------------
0622                       ; Next column?
0623                       ;------------------------------------------------------
0624               putlst.nextcol:
0625 659E C104  18         mov   tmp0,tmp0             ; \ Single column list?
0626 65A0 1309  14         jeq   !                     ; / Yes, skip next column handling
0627               
0628 65A2 9120  30         cb    @wyx,tmp0             ; Cutover row reached?
     65A4 832A     
0629 65A6 1106  14         jlt   !                     ; Not yet, move down
0630               
0631 65A8 D808  30         movb  tmp4,@wyx             ; Restore Y-position
     65AA 832A     
0632 65AC B820  42         ab    @tmp0lb,@wyx+1        ; Add column offset
     65AE 8309     
     65B0 832B     
0633               
0634 65B2 1002  14         jmp   putlst.next           ; Next iteration
0635 65B4 06A0  32 !       bl    @down                 ; Move cursor down
     65B6 272C     
0636                       ;------------------------------------------------------
0637                       ; Prepare for next iteration
0638                       ;------------------------------------------------------
0639               putlst.next:
0640 65B8 A147  18         a     tmp3,tmp1             ; Add string length to pointer
0641 65BA 0585  14         inc   tmp1                  ; Consider length byte
0642 65BC 0606  14         dec   tmp2
0643 65BE 15BC  14         jgt   putlst.loop           ; Display next entry in list
0644 65C0 C805  30         mov   tmp1,@waux1           ; Save pointer to next entry in list
     65C2 833C     
0645                       ;------------------------------------------------------
0646                       ; Exit
0647                       ;------------------------------------------------------
0648               putlst.exit:
0649 65C4 C2F9  30         mov   *stack+,r11           ; Pop r11
0650 65C6 045B  20         b     *r11                  ; Return
                   < runlib.asm
