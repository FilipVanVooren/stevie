0200                       copy  "cpu_hexsupport.asm"       ; CPU hex numbers support
     **** ****     > cpu_hexsupport.asm
0001               * FILE......: cpu_hexsupport.asm
0002               * Purpose...: CPU create, display hex numbers module
0003               
0004               ***************************************************************
0005               * mkhex - Convert hex word to string
0006               ***************************************************************
0007               *  bl   @mkhex
0008               *       data P0,P1,P2
0009               *--------------------------------------------------------------
0010               *  P0 = Pointer to 16 bit word
0011               *  P1 = Pointer to string buffer
0012               *  P2 = Offset for ASCII digit
0013               *       MSB determines offset for chars A-F
0014               *       LSB determines offset for chars 0-9
0015               *  (CONFIG#0 = 1) = Display number at cursor YX
0016               *--------------------------------------------------------------
0017               *  Memory usage:
0018               *  tmp0, tmp1, tmp2, tmp3, tmp4
0019               *  waux1, waux2, waux3
0020               *--------------------------------------------------------------
0021               *  Memory variables waux1-waux3 are used as temporary variables
0022               ********|*****|*********************|**************************
0023 6AAA C13B  30 mkhex   mov   *r11+,tmp0            ; P0: Address of word
0024 6AAC C83B  42         mov   *r11+,@waux3          ; P1: Pointer to string buffer
     6AAE 8340     
0025 6AB0 04E0  26         clr   @waux1
     6AB2 833C     
0026 6AB4 04E0  26         clr   @waux2
     6AB6 833E     
0027 6AB8 0207  20         li    tmp3,waux1            ; We store results in WAUX1 and WAUX2
     6ABA 833C     
0028 6ABC C114  26         mov   *tmp0,tmp0            ; Get word
0029               *--------------------------------------------------------------
0030               *    Convert nibbles to bytes (is in wrong order)
0031               *--------------------------------------------------------------
0032 6ABE 0205  20         li    tmp1,4                ; 4 nibbles
     6AC0 0004     
0033 6AC2 C184  18 mkhex1  mov   tmp0,tmp2             ; Make work copy
0034 6AC4 0246  22         andi  tmp2,>000f            ; Only keep LSN
     6AC6 000F     
0035                       ;------------------------------------------------------
0036                       ; Determine offset for ASCII char
0037                       ;------------------------------------------------------
0038 6AC8 0286  22         ci    tmp2,>000a
     6ACA 000A     
0039 6ACC 1105  14         jlt   mkhex1.digit09
0040                       ;------------------------------------------------------
0041                       ; Add ASCII offset for digits A-F
0042                       ;------------------------------------------------------
0043               mkhex1.digitaf:
0044 6ACE C21B  26         mov   *r11,tmp4
0045 6AD0 0988  32         srl   tmp4,8                ; Right justify
0046 6AD2 0228  22         ai    tmp4,-10              ; Adjust offset for 'A-F'
     6AD4 FFF6     
0047 6AD6 1003  14         jmp   mkhex2
0048               
0049               mkhex1.digit09:
0050                       ;------------------------------------------------------
0051                       ; Add ASCII offset for digits 0-9
0052                       ;------------------------------------------------------
0053 6AD8 C21B  26         mov   *r11,tmp4
0054 6ADA 0248  22         andi  tmp4,>00ff            ; Only keep LSB
     6ADC 00FF     
0055               
0056 6ADE A188  18 mkhex2  a     tmp4,tmp2             ; Add ASCII-offset
0057 6AE0 06C6  14         swpb  tmp2
0058 6AE2 DDC6  32         movb  tmp2,*tmp3+           ; Save byte
0059 6AE4 0944  24         srl   tmp0,4                ; Next nibble
0060 6AE6 0605  14         dec   tmp1
0061 6AE8 16EC  14         jne   mkhex1                ; Repeat until all nibbles processed
0062 6AEA 0242  22         andi  config,>bfff          ; Reset bit 1 in config register
     6AEC BFFF     
0063               *--------------------------------------------------------------
0064               *    Build first 2 bytes in correct order
0065               *--------------------------------------------------------------
0066 6AEE C160  30         mov   @waux3,tmp1           ; Get pointer
     6AF0 8340     
0067 6AF2 04D5  26         clr   *tmp1                 ; Set length byte to 0
0068 6AF4 0585  14         inc   tmp1                  ; Next byte, not word!
0069 6AF6 C120  30         mov   @waux2,tmp0
     6AF8 833E     
0070 6AFA 06C4  14         swpb  tmp0
0071 6AFC DD44  32         movb  tmp0,*tmp1+
0072 6AFE 06C4  14         swpb  tmp0
0073 6B00 DD44  32         movb  tmp0,*tmp1+
0074               *--------------------------------------------------------------
0075               *    Set length byte
0076               *--------------------------------------------------------------
0077 6B02 C120  30         mov   @waux3,tmp0           ; Get start of string buffer
     6B04 8340     
0078 6B06 D520  46         movb  @hb$04,*tmp0          ; Set lengh byte to 4
     6B08 2016     
0079 6B0A 05CB  14         inct  r11                   ; Skip Parameter P2
0080               *--------------------------------------------------------------
0081               *    Build last 2 bytes in correct order
0082               *--------------------------------------------------------------
0083 6B0C C120  30         mov   @waux1,tmp0
     6B0E 833C     
0084 6B10 06C4  14         swpb  tmp0
0085 6B12 DD44  32         movb  tmp0,*tmp1+
0086 6B14 06C4  14         swpb  tmp0
0087 6B16 DD44  32         movb  tmp0,*tmp1+
0088               *--------------------------------------------------------------
0089               *    Display hex number ?
0090               *--------------------------------------------------------------
0091 6B18 20A0  32         coc   @wbit0,config         ; Check if 'display' bit is set
     6B1A 2020     
0092 6B1C 1301  14         jeq   mkhex3                ; Yes, so show at current YX position
0093 6B1E 045B  20         b     *r11                  ; Exit
0094               *--------------------------------------------------------------
0095               *  Display hex number on screen at current YX position
0096               *--------------------------------------------------------------
0097 6B20 0242  22 mkhex3  andi  config,>7fff          ; Reset bit 0
     6B22 7FFF     
0098 6B24 C160  30         mov   @waux3,tmp1           ; Get Pointer to string
     6B26 8340     
0099 6B28 0460  28         b     @xutst0               ; Display string
     6B2A 2420     
0100 6B2C 0610     prefix  data  >0610                 ; Length byte + blank
0101               
0102               
0103               
0104               ***************************************************************
0105               * puthex - Put 16 bit word on screen
0106               ***************************************************************
0107               *  bl   @mkhex
0108               *       data P0,P1,P2,P3
0109               *--------------------------------------------------------------
0110               *  P0 = YX position
0111               *  P1 = Pointer to 16 bit word
0112               *  P2 = Pointer to string buffer
0113               *  P3 = Offset for ASCII digit
0114               *       MSB determines offset for chars A-F
0115               *       LSB determines offset for chars 0-9
0116               *--------------------------------------------------------------
0117               *  Memory usage:
0118               *  tmp0, tmp1, tmp2, tmp3
0119               *  waux1, waux2, waux3
0120               ********|*****|*********************|**************************
0121 6B2E C83B  42 puthex  mov   *r11+,@wyx            ; Set cursor
     6B30 832A     
0122 6B32 0262  22         ori   config,>8000          ; CONFIG register bit 0=1
     6B34 8000     
0123 6B36 10B9  14         jmp   mkhex                 ; Convert number and display
0124               
                   < runlib.asm
