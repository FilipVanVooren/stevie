0245               ***************************************************************
0246               * sams.layout
0247               * Setup SAMS memory banks
0248               ***************************************************************
0249               * bl  @sams.layout
0250               *     data P0
0251               *--------------------------------------------------------------
0252               * INPUT
0253               * P0 = Pointer to SAMS page layout table
0254               *--------------------------------------------------------------
0255               * bl  @xsams.layout
0256               *
0257               * tmp0 = Pointer to SAMS page layout table
0258               *--------------------------------------------------------------
0259               * OUTPUT
0260               * none
0261               *--------------------------------------------------------------
0262               * Register usage
0263               * tmp0, r12
0264               ********|*****|*********************|**************************
0265               sams.layout:
0266 6730 C13B  30         mov   *r11+,tmp0            ; Get P0
0267               xsams.layout:
0268 6732 0649  14         dect  stack
0269 6734 C64B  30         mov   r11,*stack            ; Save return address
0270 6736 0649  14         dect  stack
0271 6738 C644  30         mov   tmp0,*stack           ; Save tmp0
0272 673A 0649  14         dect  stack
0273 673C C64C  30         mov   r12,*stack            ; Save r12
0274                       ;------------------------------------------------------
0275                       ; Set SAMS registers
0276                       ;------------------------------------------------------
0277 673E 020C  20         li    r12,>1e00             ; SAMS CRU address
     6740 1E00     
0278 6742 1D00  16         sbo   0                     ; Enable access to SAMS registers
0279               
0280 6744 C834  50         mov  *tmp0+,@>4004          ; Set page for >2000 - >2fff
     6746 4004     
0281 6748 C834  50         mov  *tmp0+,@>4006          ; Set page for >3000 - >3fff
     674A 4006     
0282 674C C834  50         mov  *tmp0+,@>4014          ; Set page for >a000 - >afff
     674E 4014     
0283 6750 C834  50         mov  *tmp0+,@>4016          ; Set page for >b000 - >bfff
     6752 4016     
0284 6754 C834  50         mov  *tmp0+,@>4018          ; Set page for >c000 - >cfff
     6756 4018     
0285 6758 C834  50         mov  *tmp0+,@>401a          ; Set page for >d000 - >dfff
     675A 401A     
0286 675C C834  50         mov  *tmp0+,@>401c          ; Set page for >e000 - >efff
     675E 401C     
0287 6760 C834  50         mov  *tmp0+,@>401e          ; Set page for >f000 - >ffff
     6762 401E     
0288               
0289 6764 1E00  16         sbz   0                     ; Disable access to SAMS registers
0290 6766 1D01  16         sbo   1                     ; Enable SAMS mapper
0291                       ;------------------------------------------------------
0292                       ; Exit
0293                       ;------------------------------------------------------
0294               sams.layout.exit:
0295 6768 C339  30         mov   *stack+,r12           ; Pop r12
0296 676A C139  30         mov   *stack+,tmp0          ; Pop tmp0
0297 676C C2F9  30         mov   *stack+,r11           ; Pop r11
0298 676E 045B  20         b     *r11                  ; Return to caller
