0003               
0004               ***************************************************************
0005               * Task - Update cursor shape (blink)
0006               ********|*****|*********************|**************************
0007               task.vdp.cursor:
0008 79A0 0649  14         dect  stack
0009 79A2 C64B  30         mov   r11,*stack            ; Save return address
0010                       ;------------------------------------------------------
0011                       ; Set cursor shape
0012                       ;------------------------------------------------------
0013 79A4 06A0  32         bl    @rom.farjump          ; \ Trampoline jump to bank
     79A6 30D8     
0014 79A8 600C                   data bank6.rom        ; | i  p0 = bank address
0015 79AA 7F78                   data vec.5            ; | i  p1 = Vector with target address
0016 79AC 6002                   data bankid           ; / i  p2 = Source ROM bank for return
0017                       ;------------------------------------------------------
0018                       ; Exit
0019                       ;------------------------------------------------------
0020               task.vdp.cursor.exit:
0021 79AE C2F9  30         mov   *stack+,r11           ; Pop r11
0022 79B0 0460  28         b     @slotok               ; Exit task
     79B2 2F98     
                   < ram.resident.asm
0048                       copy  "task.oneshot.asm"            ; Run "one shot" task
