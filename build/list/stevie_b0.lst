0024 7922 0649  14         dect  stack
0025 7924 C645  30         mov   tmp1,*stack           ; Push tmp1
0026                       ;------------------------------------------------------
0027                       ; 1a. Check if highest SAMS page needs to be increased
0028                       ;------------------------------------------------------
0029               edb.hipage.alloc.check_setpage:
0030 7926 C120  34         mov   @edb.next_free.ptr,tmp0
     7928 A508     
0031                                                   ;--------------------------
0032                                                   ; Check for page overflow
0033                                                   ;--------------------------
0034 792A 0244  22         andi  tmp0,>0fff            ; Get rid of highest nibble
     792C 0FFF     
0035 792E 0224  22         ai    tmp0,82               ; Assume line of 80 chars (+2 bytes prefix)
     7930 0052     
0036 7932 0284  22         ci    tmp0,>1000 - 16       ; 4K boundary reached?
     7934 0FF0     
0037 7936 1105  14         jlt   edb.hipage.alloc.setpage
0038                                                   ; Not yet, don't increase SAMS page
0039                       ;------------------------------------------------------
0040                       ; 1b. Increase highest SAMS page (copy-on-write!)
0041                       ;------------------------------------------------------
0042 7938 05A0  34         inc   @edb.sams.hipage      ; Set highest SAMS page
     793A A51C     
0043 793C C820  54         mov   @edb.top.ptr,@edb.next_free.ptr
     793E A500     
     7940 A508     
0044                                                   ; Start at top of SAMS page again
0045                       ;------------------------------------------------------
0046                       ; 1c. Switch to SAMS page and exit
0047                       ;------------------------------------------------------
0048               edb.hipage.alloc.setpage:
0049 7942 C120  34         mov   @edb.sams.hipage,tmp0
     7944 A51C     
0050 7946 C160  34         mov   @edb.top.ptr,tmp1
     7948 A500     
0051 794A 06A0  32         bl    @xsams.page.set       ; Set SAMS page
     794C 25D6     
0052                                                   ; \ i  tmp0 = SAMS page number
0053                                                   ; / i  tmp1 = Memory address
0054               
0055 794E 1004  14         jmp   edb.hipage.alloc.exit
0056                       ;------------------------------------------------------
