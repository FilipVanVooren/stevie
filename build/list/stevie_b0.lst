     7206 FFFF     
0095 7208 1602  14         jne   !
0096 720A C160  34         mov   @trmpvector,tmp1
     720C A034     
0097                       ;------------------------------------------------------
0098                       ; Deref value in vector
0099                       ;------------------------------------------------------
0100 720E C115  26 !       mov   *tmp1,tmp0            ; Deref value in vector address
0101 7210 1301  14         jeq   rom.farjump.bankswitch.failed1
0102                                                   ; Crash if null-pointer in vector
0103               
0104 7212 1004  14         jmp   rom.farjump.bankswitch.call
0105                                                   ; Call function in target bank
0106                       ;------------------------------------------------------
0107                       ; Assert 1 failed before bank-switch
0108                       ;------------------------------------------------------
0109               rom.farjump.bankswitch.failed1:
0110 7214 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     7216 FFCE     
0111 7218 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     721A 2026     
0112                       ;------------------------------------------------------
0113                       ; Call function in target bank
0114                       ;------------------------------------------------------
0115               rom.farjump.bankswitch.call:
0116 721C 0694  24         bl    *tmp0                 ; Call function
0117                       ;------------------------------------------------------
0118                       ; Bankswitch back to source bank
0119                       ;------------------------------------------------------
0120               rom.farjump.return:
0121 721E C120  34         mov   @tv.fj.stackpnt,tmp0  ; Get farjump stack pointer
     7220 A22E     
0122 7222 C154  26         mov   *tmp0,tmp1            ; Get bank write address of caller
0123 7224 1319  14         jeq   rom.farjump.bankswitch.failed2
0124                                                   ; Crash if null-pointer in address
0125               
0126 7226 04F4  30         clr   *tmp0+                ; Remove bank write address from
0127                                                   ; farjump stack
0128               
0129 7228 C2D4  26         mov   *tmp0,r11             ; Get return addr of caller for return
0130               
0131 722A 04F4  30         clr   *tmp0+                ; Remove return address of caller from
0132                                                   ; farjump stack
0133               
0134                       ;------------------------------------------------------
0135                       ; Assert on memory source address in cartridge space
0136                       ;------------------------------------------------------
0137               rom.farjump.assert.cart:
0138 722C 028B  22         ci    r11,>6000
     722E 6000     
0139 7230 1104  14         jlt   rom.farjump.assert.lowmem
0140 7232 028B  22         ci    r11,>7fff
     7234 7FFF     
0141 7236 1510  14         jgt   rom.farjump.bankswitch.failed2
0142 7238 1006  14         jmp   !
0143                       ;------------------------------------------------------
0144                       ; Assert on memory source address in low memory expansion
0145                       ;------------------------------------------------------
0146               rom.farjump.assert.lowmem:
0147 723A 028B  22         ci    r11,>2000
     723C 2000     
0148 723E 110C  14         jlt   rom.farjump.bankswitch.failed2
0149 7240 028B  22         ci    r11,>3fff
     7242 3FFF     
0150 7244 1509  14         jgt   rom.farjump.bankswitch.failed2
0151                       ;------------------------------------------------------
0152                       ; Update farjump return stack pointer
0153                       ;------------------------------------------------------
0154 7246 C804  38 !       mov   tmp0,@tv.fj.stackpnt  ; Update farjump return stack pointer
     7248 A22E     
