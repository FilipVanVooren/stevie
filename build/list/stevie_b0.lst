0366 6E98 AA00     dsrlnk.$aa00      data   >aa00      ; Used for identifying DSR header
0367 6E9A 0008     dsrlnk.$0008      data   >0008      ; 8 is the data that usually follows
0368                                                   ; a @blwp @dsrlnk
0369 6E9C 2E       dsrlnk.period     text  '.'         ; For finding end of device name
