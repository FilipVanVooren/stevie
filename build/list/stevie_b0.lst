0003               
0004               ***************************************************************
0005               * Task - One-shot
0006               ***************************************************************
0007               
0008               task.oneshot:
0009 79B4 C120  34         mov   @tv.task.oneshot,tmp0  ; Get pointer to one-shot task
     79B6 A22C     
0010 79B8 1301  14         jeq   task.oneshot.exit
0011               
0012 79BA 0694  24         bl    *tmp0                  ; Execute one-shot task
0013                       ;------------------------------------------------------
0014                       ; Exit
0015                       ;------------------------------------------------------
0016               task.oneshot.exit:
0017 79BC 0460  28         b     @slotok                ; Exit task
     79BE 2F98     
