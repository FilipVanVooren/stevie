0193                       copy  "keyb_rkscan.asm"          ; Use ROM#0 OS monitor KSCAN
     **** ****     > keyb_rkscan.asm
0001               * FILE......: keyb_rkscan.asm
0002               * Purpose...: Full (real) keyboard support module
0003               
0004               *//////////////////////////////////////////////////////////////
0005               *                     KEYBOARD FUNCTIONS
0006               *//////////////////////////////////////////////////////////////
0007               
0008               ***************************************************************
0009               * RKSCAN - Scan keyboard using ROM#0 OS monitor KSCAN
0010               ***************************************************************
0011               *  BL @RKSCAN
0012               *--------------------------------------------------------------
0013               * Register usage
0014               * none
0015               *--------------------------------------------------------------
0016               * Scratchpad usage by console KSCAN:
0017               *
0018               * >8373  I/O:    LSB of GPL subroutine stack pointer 80 = (>8380)
0019               * >8374  Input:  keyboard scan mode (default=0)
0020               * >8375  Output: ASCII code detected by keyboard scan
0021               * >8376  Output: Joystick Y-status by keyboard scan
0022               * >8377  Output: Joystick X-status by keyboard scan
0023               * >837c  Output: GPL status byte (>20 if key pressed)
0024               * >838a  I/O:    GPL substack
0025               * >838c  I/O:    GPL substack
0026               * >83c6  I/O:    ISRWS R3 Keyboard state and debounce info
0027               * >83c8  I/O:    ISRWS R4 Keyboard state and debounce info
0028               * >83ca  I/O:    ISRWS R5 Keyboard state and debounce info
0029               * >83d4  I/O:    ISRWS R10 Contents of VDP register 01
0030               * >83d6  I/O:    ISRWS R11 Screen timeout counter, blanks when 0000
0031               * >83d8  I/O:    ISRWS R12 (Backup return address old R11 in GPLWS)
0032               * >83f8  output: GPLWS R12 (CRU base address for key scan)
0033               * >83fa  output: GPLWS R13 (GROM/GRAM read data port 9800)
0034               * >83fe  I/O:    GPLWS R15 (VDP write address port 8c02)
0035               ********|*****|*********************|**************************
0036               rkscan:
0037 6A48 0649  14         dect  stack
0038 6A4A C64B  30         mov   r11,*stack            ; Push return address
0039 6A4C 0649  14         dect  stack
0040 6A4E C644  30         mov   tmp0,*stack           ; Push tmp0
0041                       ;------------------------------------------------------
0042                       ; (1) Check for alpha lock
0043                       ;------------------------------------------------------
0044 6A50 40A0  34         szc   @wbit10,config        ; Reset CONFIG register bit 10=0
     6A52 200C     
0045                                                   ; (alpha lock off)
0046               
0047                       ; See CRU interface and keyboard sections for details
0048                       ; http://www.nouspikel.com/ti99/titechpages.htm
0049               
0050 6A54 04CC  14         clr   r12                   ; Set base address (to bit 0) so
0051                                                   ; following offsets correspond
0052               
0053 6A56 1E15  16         sbz   21                    ; \ Set bit 21 (PIN 5 attached to alpha
0054                                                   ; / lock column) to 0.
0055               
0056 6A58 0BEC  44         src   r12,14                ; Burn some time (r12=0 no problem shifting)
0057               
0058 6A5A 1F07  16         tb    7                     ; \ Copy CRU bit 7 into EQ bit
0059                                                   ; | That is CRU INT7*/P15 pin (keyboard row
0060                                                   ; | with keys FCTN, 2,3,4,5,1,
0061                                                   ; / [joy1-up,joy2-up, Alpha Lock])
0062               
0063 6A5C 1302  14         jeq   !                     ; No, alpha lock is off
0064               
0065 6A5E E0A0  34         soc   @wbit10,config        ; \ Yes, alpha lock is on.
     6A60 200C     
0066                                                   ; / Set CONFIG register bit 10=1
0067               
0068 6A62 1D15  16 !       sbo   21                    ; \ Reset bit 21 (Pin 5 attached to alpha
0069                                                   ; / lock column) to 1.
0070                       ;------------------------------------------------------
0071                       ; (2) Prepare for OS monitor kscan
0072                       ;------------------------------------------------------
0073 6A64 C820  46         mov   @scrpad.83c6,@>83c6   ; Required for lowercase support
     6A66 29C2     
     6A68 83C6     
0074 6A6A C820  46         mov   @scrpad.83fa,@>83fa   ; Load GPLWS R13
     6A6C 29C4     
     6A6E 83FA     
0075 6A70 C820  46         mov   @scrpad.83fe,@>83fe   ; Load GPLWS R15
     6A72 29C6     
     6A74 83FE     
0076               
0077 6A76 04C4  14         clr   tmp0                  ; \ Keyboard mode in MSB
0078                                                   ; / 00=Scan all of keyboard
0079               
0080 6A78 D804  30         movb  tmp0,@>8374           ; Set keyboard mode at @>8374
     6A7A 8374     
0081                                                   ; (scan entire keyboard)
0082               
0083 6A7C 02E0  18         lwpi  >83e0                 ; Activate GPL workspace
     6A7E 83E0     
0084               
0085 6A80 06A0  28         bl    @kscan                ; Call KSCAN
     6A82 000E     
0086 6A84 02E0  18         lwpi  ws1                   ; Activate user workspace
     6A86 8300     
0087                       ;------------------------------------------------------
0088                       ; (3) Check if key pressed
0089                       ;------------------------------------------------------
0090 6A88 D120  30         movb  @>837c,tmp0           ; Get flag
     6A8A 837C     
0091 6A8C 0A34  22         sla   tmp0,3                ; Flag value is >20
0092 6A8E 1707  14         jnc   rkscan.exit           ; No key pressed, exit early
0093                       ;------------------------------------------------------
0094                       ; (4) Key detected, store in memory
0095                       ;------------------------------------------------------
0096 6A90 D120  30         movb  @>8375,tmp0           ; \ Key pressed is at @>8375
     6A92 8375     
0097 6A94 0984  32         srl   tmp0,8                ; / Move to LSB
0099 6A96 C804  38         mov   tmp0,@rom0_kscan_out  ; Store ASCII value in user location
     6A98 A028     
0103 6A9A E0A0  34         soc   @wbit11,config        ; Set ANYKEY flag in CONFIG register
     6A9C 200A     
0104                       ;------------------------------------------------------
0105                       ; Exit
0106                       ;------------------------------------------------------
0107               rkscan.exit:
0108 6A9E C139  30         mov   *stack+,tmp0          ; Pop tmp0
0109 6AA0 C2F9  30         mov   *stack+,r11           ; Pop r11
0110 6AA2 045B  20         b     *r11                  ; Return to caller
0111               
0112               
0113 6AA4 0200     scrpad.83c6   data >0200            ; Required for KSCAN to support lowercase
0114 6AA6 9800     scrpad.83fa   data >9800
0115               
0116               ; Dummy value for GPLWS R15 (instead of VDP write address port 8c02)
0117               ; We do not want console KSCAN to fiddle with VDP registers while Stevie
0118               ; is running
0119               
0120 6AA8 83A0     scrpad.83fe   data >83a0            ; 8c02
                   < runlib.asm
