2987               
2988               * GROM addresses >0000 - >1FFF
2989      02B2     SCAN   EQU >02B2  ; >000E is an indirect that just consumes time
2990      04B2     CHKCLR EQU >04B2  ; uses R12 only
2991               
2992               * CPU scratchpad RAM >8300 - >83FF
2993      8300     BASWP  EQU >8300      ; workspace for BASIC interpretter
2994      8320     CURLIN EQU BASWP+32   ; Save pointer into current line pointer table entry when reading each line (for skipping false IFs)
2995      8322     LINTOP EQU CURLIN+2   ; Pointer to end of line pointers in low memory (word where -1 is found)
2996      8324     MEMTOP EQU LINTOP+2   ; Pointer to end of line strings in high memory (above this usable for strings)
2997      8326     CURSOR EQU MEMTOP+2   ; Cursor position in VDP RAM
2998      8328     RAND1  EQU CURSOR+2   ; Random number
2999      832A     RAND2  EQU RAND1+2    ; Used to generate random number
3000      832C     CHRGET EQU RAND2+2    ; CHRGET routine (for speed)
3001      000C     CHRSIZ EQU INIT-INITAT  ; number of bytes in CHRGET routine
3002      8338     TEMPF1 EQU CHRGET+CHRSIZ  ; fast temp #1 (used in CHROUT and CHKEND and TOKEND and SLOAD/SSAVE)
3003      833A     TEMPF2 EQU TEMPF1+2   ; fast temp #2 (used in CHROUT and TOKARG and SLOAD/SSAVE)
3004      833C     TEMPF3 EQU TEMPF2+2   ; fast temp #3 (used in CHROUT and TOKIZE and SLOAD/SSAVE)
3005      833E     TEMPF4 EQU TEMPF3+2   ; fast temp #4 (used in TOKIZE and SLIST and LSOPT)
3006      8340     TEMPF5 EQU TEMPF4+2   ; fast temp #5 (used in SLIST)
3007      8342     ENDLIN EQU TEMPF5+2   ; End of line flag for SPRINT
3008      8343     NXTPAD EQU ENDLIN+1   ; next scratchpad address (for adding more high speed storage locations)
3009               * 43-53 available (8.5 words/17 bytes)
3010      8374     KEYDEV EQU >8374      ; keyboard device to check (byte)
3011      8375     KEYKEY EQU >8375      ; key pressed (byte)
3012      837C     GPLSTS EQU >837C      ; keyboard and DSR status (byte)
3013               * 80-BF GPL stack not available because of SCAN
3014      83E0     GPLWS  EQU >83E0      ; GPL workspace registers
3015               
3016               * Low expansion RAM >2000 - >3FFF
3017      0100     STKSIZ EQU >0100      ; size of BASIC stack
3018      0006     GSBSIZ EQU 6          ; size of a GOSUB entry on the stack
3019      000C     FORSIZ EQU 12         ; size of a FOR entry on the stack
3020      0100     LINSIZ EQU >0100      ; size of line input buffer
3021      02E0     VDPSIZ EQU >02E0      ; Size of screen minus 1 line (768-32)
3022      2000     STACK  EQU >2000      ; BASIC stack for FOR/NEXT and GOSUB/RETURN statements
3023      2100     LINBUF EQU STACK+STKSIZ  ; Line input buffer (overlap middle of VDPBUF)
3024      2200     VDPBUF EQU LINBUF+LINSIZ  ; Room to save screen minus 1 line, also used for tokenization of input line
3025                      EVEN           ; any workspace register set must be aligned
3026      24E0     SYSWS  EQU VDPBUF+VDPSIZ  ; workspace for SYS statement
3027      2500     VARS   EQU SYSWS+32   ; 26 words for variables A-Z
3028      2534     SCROLL EQU VARS+52    ; indicator that last CHROUT resulted in screen scrolling (0=no, -1=yes)
3029      2535     OPENED EQU SCROLL+1   ; indicator that a file is open (0=no, -1=yes)
3030                      EVEN           ; any workspace register set must be aligned
3031      2536     UTILWS EQU OPENED+1   ; workspace for utility routines (only for KSCAN, DSRLNK)
3032      2556     DSRWRK EQU UTILWS+32  ; DSR workspace array (80 bytes)
3033      001A     PABSIZ EQU 26         ; size of PAB
3034      25A6     CPUPAB EQU DSRWRK+80  ; File handle assembly point for LOAD/SAVE in CPU RAM
3035      25A8     PABADR EQU CPUPAB+2   ; Buffer address in VDP RAM for LOAD/SAVE
3036      25AC     PABLEN EQU CPUPAB+6   ; Data length for LOAD/SAVE
3037      25AF     PABFNL EQU CPUPAB+9   ; Filename length
3038      25B0     PABNAM EQU CPUPAB+10  ; Filename
3039      373E     VDPPAB EQU 14142      ; Actual file handle for LOAD/SAVE in VDP RAM
3040      3758     FILBUF EQU VDPPAB+PABSIZ  ; File buffer for LOAD/SAVE in VDP RAM (just below floppy drive controller reserved space)
3041      25C0     NXTLBL EQU CPUPAB+PABSIZ  ; Placeholder for next available address in low memory
3042      0006     LTESIZ EQU 6          ; Line table entry size (6 bytes/3 words)
3043      25C0     LINBOT EQU >25C0      ; Equate to start of line pointers in low memory
3044               * Line pointer table entry = WORD line number (-1 is end), WORD pointer (next free byte at end), WORD length (0 at end)
3045               * Starting at >25C0 leaves room for 1120 lines
3046               
3047               * High expansion RAM >A000 - >FFFF
3048      A000     TXTBOT EQU >A000      ; Equate to start of lines in high memory
3049               
3050               * Hardware bridge register addresses
3051      8C02     VDPWA  EQU >8C02      ; VDP RAM write address
3052      8800     VDPRD  EQU >8800      ; VDP RAM read data
3053      8C00     VDPWD  EQU >8C00      ; VDP RAM write data
3054      8802     VDPSTA EQU >8802      ; VDP RAM status
3055      83D4     SHDWR1 EQU >83D4      ; VDP register 1 shadow (always update)
3056      8400     SOUND  EQU >8400      ; Sound chip register bridge address
3057               * GROM registers
3058      9C02     GRMWA  EQU >9C02      ; GROM/GRAM write address
3059      9802     GRMRA  EQU >9802      ; GROM/GRAM read address
3060      9800     GRMRD  EQU >9800      ; GROM/GRAM read data
3061      9C00     GRMWD  EQU >9C00      ; GROM/GRAM write data
3062               * Utility constants
3063      8354     DSRSIZ EQU >8354      ; Name length
3064      8356     DSRNAM EQU >8356      ; DSR address
3065      83D0     CRULST EQU >83D0      ; CRU list
3066      83D2     SAVADD EQU >83D2      ; Save address
3067      2540     DSRWS5 EQU UTILWS+10  ; DSR register 5
3068      2537     DSRWS0 EQU UTILWS+1   ; DSR register 0 low byte
3069      0000     DSROPN EQU >0000      ; OPEN
3070      0100     DSRCLS EQU >0100      ; CLOSE
3071      0200     DSRRD  EQU >0200      ; READ
3072      0300     DSRWR  EQU >0300      ; WRITE
3073               
3074               * character codes/joystick
3075      0200     CCLEAR EQU >0200      ; clear (FN+4) [break]
3076      0800     CLEFT  EQU >0800      ; left arrow [delete]
3077      0900     CRIGHT EQU >0900      ; right arrow [tab]
3078      0D00     CENTER EQU >0D00      ; enter
3079      2000     CSPACE EQU >2000      ; space
3080      7F00     CCURSR EQU >7F00      ; cursor
3081               *JOYB   EQU >0100      ; joystick button
3082               *JOYL   EQU >0200      ; joystick left
3083               *JOYR   EQU >0400      ; joystick right
3084               *JOYD   EQU >0800      ; joystick down
3085               *JOYU   EQU >1000      ; joystick up
