0299               * start EXECUTION --------------------------------------
0300 61D6 028E  22 GETSTT CI R14,TSYS*>0100
     61D8 7100     
0301 61DA 1A1B  14        JL GETSTE          ; 00-70: unassigned (error)
0302 61DC 028E  22        CI R14,TDEC*>0100
     61DE E600     
0303 61E0 1A03  14        JL GETST1
0304 61E2 020B  20        LI R11,SDECRE      ; E6-FF -> E6: decrement
     61E4 7022     
0305 61E6 1014  14        JMP DOSTMT
0306 61E8 028E  22 GETST1 CI R14,TINC*>0100
     61EA CC00     
0307 61EC 1A03  14        JL GETST2
0308 61EE 020B  20        LI R11,SINCRE      ; CC-E5 -> CC: increment
     61F0 701A     
0309 61F2 100E  14        JMP DOSTMT
0310 61F4 028E  22 GETST2 CI R14,TLET*>0100
     61F6 B100     
0311 61F8 1A03  14        JL GETST3
0312 61FA 020B  20        LI R11,SLET        ; B2-CB -> B2: let
     61FC 6E66     
0313 61FE 1008  14        JMP DOSTMT
0314               *      fall through       ; 71-B1: literal statements
0315               * look up statement address from table
0316 6200 020F  20 GETST3 LI R15,TSYS*>0100
     6202 7100     
0317 6204 C30E  18        MOV R14,R12        ; never operate on R14 since the low byte must remain 00 at all times
0318 6206 730F  18        SB R15,R12         ; R14=R14-R15 (current token minus first token)
0319 6208 06CC  14        SWPB R12           ; put result in lower byte
0320 620A A30C  18        A R12,R12          ; double result (2 bytes per table entry)
0321 620C C2EC  34        MOV @STABLE(R12),R11  ; R11=*(STABLE+2*R12) (address of statement is R12th word in statement table)
     620E 6000     
0322 6210 045B  20 DOSTMT B *R11             ; all statements will branch to NXTSTT at the end so no need for BL
0323 6212 0460  28 GETSTE B @SYNERR
     6214 74FC     
0324               * all statements branch here
0325 6216 06A0  28 NXTSTT BL @CHKCLR         ; check if CLEAR/FN4/break key is pressed
     6218 04B2     
0326 621A 1606  14        JNE NXTST0
0327 621C 0203  20        LI R3,BREAK        ; CLEAR/FN4/break key pressed
     621E 79EC     
0328 6220 06A0  32        BL @PRTNEG
     6222 791C     
0329 6224 0460  28        B @NXTCMD
     6226 6266     
0330 6228 06A0  32 NXTST0 BL @CHKEND         ; check if EOS/EOL (GETVC includes implicit CHRGET)
     622A 7646     
0331 622C 13F2  14        JEQ GETSTE         ; if 0/not at end marker then syntax error
0332 622E 028E  22        CI R14,':'*>0100
     6230 3A00     
0333 6232 1603  14        JNE NXTST1
0334 6234 06A0  28        BL @CHRGET         ; advance past colon
     6236 832C     
0335 6238 10CE  14        JMP GETSTT
0336               * if not colon then must be null for end of line
0337 623A C2A0  30 NXTST1 MOV @CURLIN,R10    ; R10 points to current line table entry's line number location
     623C 8320     
0338 623E 880A  30        C R10,@LINTOP
     6240 8322     
0339 6242 1304  14        JEQ NXTST2         ; if already at top, don't update
0340 6244 022A  22        AI R10,LTESIZ      ; move to start of next entry
     6246 0006     
0341 6248 C80A  30        MOV R10,@CURLIN
     624A 8320     
0342 624C 05CA  14 NXTST2 INCT R10           ; R10 points to current line table entry's pointer location
0343 624E C29A  26        MOV *R10,R10       ; update TXTPTR to new line pointer value
0344 6250 060A  14        DEC R10            ; backup for CHRGET
0345 6252 06A0  28        BL @CHRGET         ; preload character for GETSTT (skipping leading spaces)
     6254 832C     
0346 6256 8820  42        C @CURLIN,@LINTOP  ; see if program ended
     6258 8320     
     625A 8322     
0347 625C 16BC  14        JNE GETSTT         ; if not (current <> top) then get next statement
0348 625E 0203  20 NXTRDY LI R3,READY
     6260 79F2     
0349 6262 06A0  32        BL @PRTNEG         ; print READY message
     6264 791C     
0350 6266 06A0  32 NXTCMD BL @LINGET         ; wait for something to be typed
     6268 765C     
0351 626A 04CE  14        CLR R14
0352 626C DA4E  38        MOVB R14,@LINBUF(R9)  ; insert null at end of input
     626E 2100     
0353 6270 0201  20        LI R1,CENTER
     6272 0D00     
0354 6274 06A0  32        BL @CHROUT         ; print blank line
     6276 770E     
0355 6278 C249  18        MOV R9,R9          ; set flags based on input length
0356 627A 13F5  14        JEQ NXTCMD         ; wait for something to be typed
0357               * fall through to tokenize an input line
0358               * 1. default line number -1, process line number if present (stash in TEMPF4 until done)
0359               * 2. process statement
0360               * 3. process other text until : or null, if : then 2, if null then done
0361 627C 070C  14 TOKIZE SETO R12           ; default line number is -1
0362 627E 020A  20        LI R10,LINBUF-1    ; work on line input buffer
     6280 20FF     
0363 6282 06A0  28        BL @CHRGET         ; advance to first non-space character
     6284 832C     
0364 6286 C14A  18        MOV R10,R5
0365 6288 06A0  32        BL @ATOI           ; get the number if present
     628A 7876     
0366               * must set R9 after ATOI since ATOI clobbers them
