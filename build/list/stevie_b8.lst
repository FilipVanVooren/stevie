2591 788A 0281  22        CI R1,'-'*>0100
     788C 2D00     
2592 788E 1602  14        JNE ATOI1    ; if not minus treat as digit
2593 7890 0546  14        INV R6       ; use R6 as negative flag (when negative)
2594 7892 D075  28        MOVB *R5+,R1
2595 7894 C081  18 ATOI1  MOV R1,R2
2596 7896 1113  14        JLT ATOI5    ; two jumps for last character is faster than two not taken jumps for the rest
2597 7898 9101  18 ATOI4  CB R1,R4
2598 789A 1A0C  14        JL ATOI2     ; character <'0' then end of number
2599 789C 90C1  18        CB R1,R3
2600 789E 1B0A  14        JH ATOI2     ; character >'9' then end of number
2601 78A0 7044  18        SB R4,R1     ; character = character - '0'
2602 78A2 06C1  14        SWPB R1      ; digit is character byte
2603 78A4 3A00  58        MPY R0,R8    ; value = value  ; 10
2604 78A6 C209  18        MOV R9,R8
