2508               * DSKIN reads a byte from the file buffer, if buffer empty reads next record before returning byte
2509               * if PAB error on record read then return EOF indicator to caller
2510               * caller must do first record read and set buffer pointer to after header
2511               * R0,1,2 used by VMBR, R3=file length (reserved), R4=buffer pointer, R5=buffer remaining, R6=read length
2512               * R7=CPU address (input), R8=length (input), R9=EOF (output)
2513 77D8 C30B  18 DSKIN  MOV R11,R12    ; protect return address from calls to VMBR/VSBR
2514 77DA C188  18 DSKIN1 MOV R8,R6      ; write_len = length
2515 77DC 8148  18        C R8,R5
2516 77DE 1202  14        JLE DSKIN2
2517 77E0 C185  18        MOV R5,R6      ; if length > buff_left then read_len = buff_left
2518 77E2 0709  14        SETO R9        ; return end of file reached
2519 77E4 C004  18 DSKIN2 MOV R4,R0      ; VDP address = buff_ptr
2520 77E6 C047  18        MOV R7,R1      ; CPU address = address
2521 77E8 C086  18        MOV R6,R2      ; copy length = read_len
2522 77EA 06A0  32        BL @VMBR       ; move from VDP to CPU
     77EC 7B12     
2523 77EE A1C6  18        A R6,R7        ; address += read_len
2524 77F0 6206  18        S R6,R8        ; length -= read_len
2525 77F2 A106  18        A R6,R4        ; buff_ptr += read_len
2526 77F4 6146  18        S R6,R5        ; buff_left -= read_len
2527 77F6 160F  14        JNE DSKIN3     ; if buff_left <> 0 skip
2528 77F8 04E0  26        CLR @GPLSTS    ; always clear status before calling DSRLNK
     77FA 837C     
2529 77FC 0420  50        BLWP @DSRLNK   ; read next record
     77FE 7ADC     
2530 7800 0200  20        LI R0,VDPPAB+1
     7802 373F     
