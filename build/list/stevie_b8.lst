2636 78EC 3D03 128        DIV R3,R4     ; R4=digit, R5=remainder (new value next iteration)
2637 78EE 2984  18        XOR R4,R6     ; set EQ flag and adjust leading 0 flag at the same time
2638 78F0 1304  14        JEQ ITOA3     ; if 0 skip output
2639 78F2 06C4  14        SWPB R4
