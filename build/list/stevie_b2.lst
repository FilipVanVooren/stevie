0001               * FILE......: timers_kthread.asm
0002               * Purpose...: Timers / User hooks
0003               
0004               
0005               ***************************************************************
0006               * MKHOOK - Allocate user hook
0007               ***************************************************************
0008               *  BL    @MKHOOK
0009               *  DATA  P0
0010               *--------------------------------------------------------------
0011               *  P0 = Address of user hook
0012               *--------------------------------------------------------------
0013               *  REMARKS
0014               *  The user hook gets executed after the kernel thread.
0015               *  The user hook must always exit with "B @HOOKOK"
0016               ********|*****|*********************|**************************
0017 2FCC C83B  50 mkhook  mov   *r11+,@wtiusr         ; Set user hook address
     2FCE 832E     
0018 2FD0 E0A0  42         soc   @wbit7,config         ; Enable user hook
     2FD2 2012     
0019 2FD4 045B  24 mkhoo1  b     *r11                  ; Return
0020      2F1C     hookok  equ   tmgr1                 ; Exit point for user hook
0021               
0022               
0023               ***************************************************************
0024               * CLHOOK - Clear user hook
0025               ***************************************************************
0026               *  BL    @CLHOOK
0027               ********|*****|*********************|**************************
0028 2FD6 04E0  26 clhook  clr   @wtiusr               ; Unset user hook address
     2FD8 832E     
0029 2FDA 0242  30         andi  config,>feff          ; Disable user hook (bit 7=0)
     2FDC FEFF     
0030 2FDE 045B  24         b     *r11                  ; Return
