0343 73AA 0985  32         srl   tmp1,8                ; MSB to LSB
0344               
0345 73AC D1B4  28         movb  *tmp0+,tmp2           ; Get float mantissa byte
0346 73AE 0986  32         srl   tmp2,8                ; MSB to LSB
0347                       ;------------------------------------------------------
0348                       ; Turn radix 100 floating point into hex number
0349                       ;------------------------------------------------------
0350 73B0 0225  22         ai    tmp1,-64              ; Subtract radix 100 exponent bias >40
     73B2 FFC0     
