0038 371A C1C6  18         mov   tmp2,tmp3             ; Number of slots to reorganize
0039 371C 0A17  18         sla   tmp3,1                ; adjust to slot size
0040 371E 0507  14         neg   tmp3                  ; tmp3 = -tmp3
0041 3720 A1C4  18         a     tmp0,tmp3             ; tmp3 = tmp3 + tmp0
0042 3722 0287  22         ci    tmp3,idx.top - 4      ; Address before top of index ?
     3724 AFFC     
0043 3726 1504  14         jgt   _idx.entry.insert.reorg.loop
0044                                                   ; No, jump to loop start
0045                       ;------------------------------------------------------
0046                       ; Crash and burn
0047                       ;------------------------------------------------------
