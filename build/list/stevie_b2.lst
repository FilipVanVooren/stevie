     **** ****     > idx.asm
0001               * FILE......: idx.asm
0002               * Purpose...: Index management
0003               
0004               ***************************************************************
0005               *  Size of index page is 4K and allows indexing of 2048 lines
0006               *  per page.
0007               *
0008               *  Each index slot (word) has the format:
0009               *    +-----+-----+
0010               *    | MSB | LSB |
0011               *    +-----|-----+   LSB = Pointer offset 00-ff.
0012               *
0013               *  MSB = SAMS Page 40-ff
0014               *        Allows addressing of up to 256 4K SAMS pages (1024 KB)
0015               *
0016               *  LSB = Pointer offset in range 00-ff
0017               *
0018               *        To calculate pointer to line in Editor buffer:
0019               *        Pointer address = edb.top + (LSB * 16)
0020               *
0021               *        Note that the editor buffer itself resides in own 4K memory range
0022               *        starting at edb.top
0023               *
0024               *        All support routines must assure that length-prefixed string in
0025               *        Editor buffer always start on a 16 byte boundary for being
0026               *        accessible via index.
0027               *
0028               *
0029               * The index starts at SAMS page >20 and can allocate up to page >3f
0030               * for a total of 32 pages (128 K). With that up to 65536 lines of text
0031               * can be addressed.
0032               ***************************************************************
0033               
0034               
0035               ***************************************************************
0036               * idx.init
0037               * Initialize index
0038               ***************************************************************
0039               * bl @idx.init
0040               *--------------------------------------------------------------
0041               * INPUT
0042               * none
0043               *--------------------------------------------------------------
0044               * OUTPUT
0045               * none
0046               *--------------------------------------------------------------
0047               * Register usage
0048               * tmp0
0049               ********|*****|*********************|**************************
0050               idx.init:
0051                       .pushregs 0                 ; Push return address and registers on stack
     **** ****     > PUSHREGS
0001 325C 0229  22         ai    stack,-(0 * 2 + 4)   ; Make room on stack for registers
     325E FFFC     
0015 3260 CE44  34         mov   tmp0,*stack+          ; Push tmp0
0017 3262 C64B  30         mov   r11,*stack            ; Push return address
0018 3264 0229  22         ai    stack,-(0 * 2 + 2)   ; Set stack pointer back to original position
     3266 FFFE     
                   < idx.asm
0052                       ;------------------------------------------------------
0053                       ; Initialize
0054                       ;------------------------------------------------------
0055 3268 0204  20         li    tmp0,idx.top
     326A B000     
0056 326C C804  38         mov   tmp0,@edb.index.ptr   ; Set pointer to index in editor structure
     326E A502     
0057               
0058 3270 C120  34         mov   @tv.sams.b000,tmp0
     3272 A206     
0059 3274 C804  38         mov   tmp0,@idx.sams.page   ; Set current SAMS page
     3276 A600     
0060 3278 C804  38         mov   tmp0,@idx.sams.lopage ; Set 1st SAMS page
     327A A602     
0061                       ;------------------------------------------------------
0062                       ; Clear all index pages
0063                       ;------------------------------------------------------
0064 327C 0224  22         ai    tmp0,4                ; \ Let's clear all index pages
     327E 0004     
0065 3280 C804  38         mov   tmp0,@idx.sams.hipage ; /
     3282 A604     
0066               
0067 3284 06A0  32         bl    @_idx.sams.mapcolumn.on
     3286 32A2     
0068                                                   ; Index in continuous memory region
0069               
0070 3288 06A0  32         bl    @film
     328A 2236     
0071 328C B000                   data idx.top,>00,idx.size * 5
     328E 0000     
     3290 5000     
0072                                                   ; Clear index
0073               
0074 3292 06A0  32         bl    @_idx.sams.mapcolumn.off
     3294 32D6     
0075                                                   ; Restore memory window layout
0076               
0077 3296 C820  54         mov   @idx.sams.lopage,@idx.sams.hipage
     3298 A602     
     329A A604     
0078                                                   ; Reset last SAMS page
0079                       ;------------------------------------------------------
0080                       ; Exit
0081                       ;------------------------------------------------------
0082               idx.init.exit:
0083                       .popregs 0                  ; Pop registers and return to caller
     **** ****     > POPREGS
0014 329C C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 329E C2F9  30         mov   *stack+,r11           ; Pop r11
0017 32A0 045B  20         b     *r11                  ; Return
                   < idx.asm
