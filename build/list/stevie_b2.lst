0176               ***************************************************************
0177               * _idx.samspage.get
0178               * Get SAMS page for index
0179               ***************************************************************
0180               * bl @_idx.samspage.get
0181               *--------------------------------------------------------------
0182               * INPUT
0183               * tmp0 = Line number
0184               *--------------------------------------------------------------
0185               * OUTPUT
0186               * @outparm1 = Offset for index entry in index SAMS page
0187               *--------------------------------------------------------------
0188               * Register usage
0189               * tmp0,tmp1,tmp2
0190               *--------------------------------------------------------------
0191               *  Remarks
0192               *  Private, only to be called from inside idx module.
0193               *  Activates SAMS page containing required index slot entry.
0194               ********|*****|*********************|**************************
0195               _idx.samspage.get:
0196 3310 0649  14         dect  stack
0197 3312 C64B  30         mov   r11,*stack            ; Save return address
0198 3314 0649  14         dect  stack
0199 3316 C644  30         mov   tmp0,*stack           ; Push tmp0
0200 3318 0649  14         dect  stack
0201 331A C645  30         mov   tmp1,*stack           ; Push tmp1
0202 331C 0649  14         dect  stack
0203 331E C646  30         mov   tmp2,*stack           ; Push tmp2
0204                       ;------------------------------------------------------
0205                       ; Determine SAMS index page
0206                       ;------------------------------------------------------
0207 3320 C184  18         mov   tmp0,tmp2             ; Line number
0208 3322 04C5  14         clr   tmp1                  ; MSW (tmp1) = 0 / LSW (tmp2) = Line number
0209 3324 0204  20         li    tmp0,2048             ; Index entries in 4K SAMS page
     3326 0800     
0210               
0211 3328 3D44 128         div   tmp0,tmp1             ; \ Divide 32 bit value by 2048
0212                                                   ; | tmp1 = quotient  (SAMS page offset)
0213                                                   ; / tmp2 = remainder
