     **** ****     > rom.farjump.asm
0001               * FILE......: rom.farjump.asm
0002               * Purpose...: Trampoline to routine in other ROM bank
0003               
0004               ***************************************************************
0005               * rom.farjump - Jump to routine in specified bank
0006               ***************************************************************
0007               *  bl   @rom.farjump
0008               *       data p0,p1,p2
0009               *--------------------------------------------------------------
0010               *  p0 = Write address of target ROM bank
0011               *  p1 = Vector address with target address to jump to
0012               *  p2 = Write address of source ROM bank
0013               *--------------------------------------------------------------
0014               *  bl   @xrom.farjump
0015               *
0016               *  tmp0 = Write address of target ROM bank
0017               *  tmp1 = Vector address with target address to jump to
0018               *  tmp2 = Write address of source ROM bank
0019               *--------------------------------------------------------------
0020               * Register usage
0021               * tmp0,tmp1,tmp2,tmp3
0022               *--------------------------------------------------------------
0023               *  Remarks
0024               *  r11 gets pushed/popped from farjump stack, not from normal
0025               *  value stack.
0026               ********|*****|*********************|**************************
0027               rom.farjump:
0028                       ;***********************************************************************
0029                       ; Attention!
0030                       ; r11 is not pushed to value stack!
0031                       ;***********************************************************************
0032 30D8 0649  14         dect  stack
0033 30DA C644  30         mov   tmp0,*stack           ; Push tmp0
0034 30DC 0649  14         dect  stack
0035 30DE C645  30         mov   tmp1,*stack           ; Push tmp1
0036 30E0 0649  14         dect  stack
0037 30E2 C646  30         mov   tmp2,*stack           ; Push tmp2
0038 30E4 0649  14         dect  stack
0039 30E6 C647  30         mov   tmp3,*stack           ; Push tmp3
0040                       ;------------------------------------------------------
0041                       ; Parameters
0042                       ;------------------------------------------------------
0043 30E8 C13B  30         mov   *r11+,tmp0            ; P0
0044 30EA C17B  30         mov   *r11+,tmp1            ; P1
0045 30EC C1BB  30         mov   *r11+,tmp2            ; P2
0046 30EE 1008  14         jmp   xrom.farjump.push_return
0047                       ;------------------------------------------------------
0048                       ; Push registers to value stack (but not r11!)
0049                       ;------------------------------------------------------
0050               xrom.farjump:
0051 30F0 0649  14         dect  stack
0052 30F2 C644  30         mov   tmp0,*stack           ; Push tmp0
0053 30F4 0649  14         dect  stack
0054 30F6 C645  30         mov   tmp1,*stack           ; Push tmp1
0055 30F8 0649  14         dect  stack
0056 30FA C646  30         mov   tmp2,*stack           ; Push tmp2
0057 30FC 0649  14         dect  stack
0058 30FE C647  30         mov   tmp3,*stack           ; Push tmp3
0059                       ;------------------------------------------------------
0060                       ; Push to farjump return stack
0061                       ;------------------------------------------------------
0062               xrom.farjump.push_return:
0063 3100 0284  22         ci    tmp0,>6000            ; Invalid bank write address?
     3102 6000     
0064 3104 1116  14         jlt   rom.farjump.bankswitch.failed1
0065                                                   ; Crash if bogus value in bank write address
0066               
0067 3106 C1E0  34         mov   @tv.fj.stackpnt,tmp3  ; Get farjump stack pointer
     3108 A22E     
0068 310A 0647  14         dect  tmp3
0069 310C C5CB  30         mov   r11,*tmp3             ; Push return address to farjump stack
0070 310E 0647  14         dect  tmp3
0071 3110 C5C6  30         mov   tmp2,*tmp3            ; Push source ROM bank to farjump stack
0072 3112 C807  38         mov   tmp3,@tv.fj.stackpnt  ; Set farjump stack pointer
     3114 A22E     
0073               
0077                       ;------------------------------------------------------
0078                       ; Bankswitch to target 8K ROM bank
0079                       ;------------------------------------------------------
0080               rom.farjump.bankswitch.target.rom8k:
0081 3116 04D4  26         clr   *tmp0                 ; Switch to target ROM bank 8K >6000
0082 3118 1004  14         jmp   rom.farjump.bankswitch.tgt.done
0083                       ;------------------------------------------------------
0084                       ; Bankswitch to target 4K ROM / 4K RAM banks (FG99 advanced mode)
0085                       ;------------------------------------------------------
0086               rom.farjump.bankswitch.tgt.advfg99:
0087 311A 04D4  26         clr   *tmp0                 ; Switch to target ROM bank 4K >6000
0088 311C 0224  22         ai    tmp0,>0800
     311E 0800     
0089 3120 04D4  26         clr   *tmp0                 ; Switch to target RAM bank 4K >7000
0090                       ;------------------------------------------------------
0091                       ; Bankswitch to target bank(s) completed
0092                       ;------------------------------------------------------
0093               rom.farjump.bankswitch.tgt.done:
0094                       ;------------------------------------------------------
0095                       ; Deref vector from @trmpvector if >ffff
0096                       ;------------------------------------------------------
0097 3122 0285  22         ci    tmp1,>ffff
     3124 FFFF     
0098 3126 1602  14         jne   !
0099 3128 C160  34         mov   @trmpvector,tmp1
     312A A034     
0100                       ;------------------------------------------------------
0101                       ; Deref value in vector
0102                       ;------------------------------------------------------
0103 312C C115  26 !       mov   *tmp1,tmp0            ; Deref value in vector address
0104 312E 1301  14         jeq   rom.farjump.bankswitch.failed1
0105                                                   ; Crash if null-pointer in vector
0106               
0107 3130 1004  14         jmp   rom.farjump.bankswitch.call
0108                                                   ; Call function in target bank
0109                       ;------------------------------------------------------
0110                       ; Assert 1 failed before bank-switch
0111                       ;------------------------------------------------------
0112               rom.farjump.bankswitch.failed1:
0113 3132 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     3134 FFCE     
0114 3136 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     3138 2026     
0115                       ;------------------------------------------------------
0116                       ; Call function in target bank
0117                       ;------------------------------------------------------
0118               rom.farjump.bankswitch.call:
0119 313A 0694  24         bl    *tmp0                 ; Call function
0120                       ;------------------------------------------------------
0121                       ; Bankswitch back to source bank
0122                       ;------------------------------------------------------
0123               rom.farjump.return:
0124 313C C120  34         mov   @tv.fj.stackpnt,tmp0  ; Get farjump stack pointer
     313E A22E     
0125 3140 C154  26         mov   *tmp0,tmp1            ; Get bank write address of caller
0126 3142 1319  14         jeq   rom.farjump.bankswitch.failed2
0127                                                   ; Crash if null-pointer in address
0128               
0129 3144 04F4  30         clr   *tmp0+                ; Remove bank write address from
0130                                                   ; farjump stack
0131               
0132 3146 C2D4  26         mov   *tmp0,r11             ; Get return addr of caller for return
0133               
0134 3148 04F4  30         clr   *tmp0+                ; Remove return address of caller from
0135                                                   ; farjump stack
0136               
0137                       ;------------------------------------------------------
0138                       ; Assert on memory source address in cartridge space
0139                       ;------------------------------------------------------
0140               rom.farjump.assert.cart:
0141 314A 028B  22         ci    r11,>6000
     314C 6000     
0142 314E 1104  14         jlt   rom.farjump.assert.lowmem
0143 3150 028B  22         ci    r11,>7fff
     3152 7FFF     
0144 3154 1510  14         jgt   rom.farjump.bankswitch.failed2
0145 3156 1006  14         jmp   !
0146                       ;------------------------------------------------------
0147                       ; Assert on memory source address in low memory expansion
0148                       ;------------------------------------------------------
0149               rom.farjump.assert.lowmem:
0150 3158 028B  22         ci    r11,>2000
     315A 2000     
0151 315C 110C  14         jlt   rom.farjump.bankswitch.failed2
