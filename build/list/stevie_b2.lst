0107 32B2 C120  34         mov   @idx.sams.lopage,tmp0 ; Get lowest index page
     32B4 A602     
0108 32B6 0205  20         li    tmp1,idx.top
     32B8 B000     
0109 32BA 0206  20         li    tmp2,5                ; Set loop counter. all pages of index
     32BC 0005     
0110                       ;-------------------------------------------------------
0111                       ; Loop over banks
0112                       ;-------------------------------------------------------
0113 32BE 06A0  32 !       bl    @xsams.page.set       ; Set SAMS page
     32C0 25D6     
0114                                                   ; \ i  tmp0  = SAMS page number
0115                                                   ; / i  tmp1  = Memory address
0116               
0117 32C2 0584  14         inc   tmp0                  ; Next SAMS index page
0118 32C4 0225  22         ai    tmp1,>1000            ; Next memory region
     32C6 1000     
0119 32C8 0606  14         dec   tmp2                  ; Update loop counter
0120 32CA 15F9  14         jgt   -!                    ; Next iteration
0121               *--------------------------------------------------------------
0122               * Exit
0123               *--------------------------------------------------------------
