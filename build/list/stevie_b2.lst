0159                       ;-------------------------------------------------------
0160 32F6 C137  30 !       mov   *tmp3+,tmp0           ; Get SAMS page
0161               
0162 32F8 06A0  32         bl    @xsams.page.set       ; Set SAMS page
     32FA 25D6     
0163                                                   ; \ i  tmp0  = SAMS page number
0164                                                   ; / i  tmp1  = Memory address
0165               
0166 32FC 0225  22         ai    tmp1,>1000            ; Next memory region
     32FE 1000     
