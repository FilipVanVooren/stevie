0055 3732 0644  14         dect  tmp0                  ; Move pointer up
0056 3734 0645  14         dect  tmp1                  ; Move pointer up
0057 3736 0606  14         dec   tmp2                  ; Next index entry
0058 3738 15FB  14         jgt   _idx.entry.insert.reorg.loop
0059                                                   ; Repeat until done
0060                       ;------------------------------------------------------
