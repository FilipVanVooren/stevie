0027                                                   ; All checks passed, continue
0028                                                   ;--------------------------
0029                                                   ; Assert failed
0030                                                   ;--------------------------
0031 37AA C80B  38         mov   r11,@>ffce            ; \ Save caller address
     37AC FFCE     
0032 37AE 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     37B0 2026     
