0195 72EA 0986  32         srl   tmp2,8                ; MSB to LSB
0196                       ;------------------------------------------------------
0197                       ; Turn radix 100 floating point into hex number
0198                       ;------------------------------------------------------
0199 72EC 0225  22         ai    tmp1,-64              ; Subtract radix 100 exponent bias >40
     72EE FFC0     
0200 72F0 1502  14         jgt   fm.dir.callback2.volsize.radix100.part1
0201                                                   ; Handle 1st byte if exponent > 1
0202               
0203 72F2 C146  18         mov   tmp2,tmp1             ; No multiplication needed
0204 72F4 1009  14         jmp   fm.dir.callback2.volsize.store
0205                       ;------------------------------------------------------
