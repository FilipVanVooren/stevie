0100 375C C1E0  34         mov   @parm2,tmp3
     375E A014     
0101 3760 0287  22         ci    tmp3,2048
     3762 0800     
0102 3764 110A  14         jlt   idx.entry.insert.reorg.simple
0103                                                   ; Do simple reorg only if single
0104                                                   ; SAMS index page, otherwise complex reorg.
