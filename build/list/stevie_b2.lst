0047                       copy  "task.vdp.cursor.asm"         ; Set cursor shape in VDP (blink)
     **** ****     > task.vdp.cursor.asm
0001               * FILE......: task.vdp.cursor.asm
0002               * Purpose...: VDP cursor shape
0003               
0004               ***************************************************************
0005               * Task - Update cursor shape (blink)
0006               ********|*****|*********************|**************************
0007               task.vdp.cursor:
0008 38D8 0649  14         dect  stack
0009 38DA C64B  30         mov   r11,*stack            ; Save return address
0010                       ;------------------------------------------------------
0011                       ; Set cursor shape
0012                       ;------------------------------------------------------
0013 38DC 06A0  32         bl    @rom.farjump          ; \ Trampoline jump to bank
     38DE 30D8     
0014 38E0 600C                   data bank6.rom        ; | i  p0 = bank address
0015 38E2 7F78                   data vec.5            ; | i  p1 = Vector with target address
0016 38E4 6004                   data bankid           ; / i  p2 = Source ROM bank for return
0017                       ;------------------------------------------------------
0018                       ; Exit
0019                       ;------------------------------------------------------
0020               task.vdp.cursor.exit:
0021 38E6 C2F9  30         mov   *stack+,r11           ; Pop r11
0022 38E8 0460  28         b     @slotok               ; Exit task
     38EA 2F98     
                   < ram.resident.asm
0048                       copy  "task.oneshot.asm"            ; Run "one shot" task
     **** ****     > task.oneshot.asm
0001               * FILE......: task.oneshot.asm
0002               * Purpose...: Trigger one-shot task
0003               
0004               ***************************************************************
0005               * Task - One-shot
0006               ***************************************************************
0007               
0008               task.oneshot:
0009 38EC 0649  14         dect  stack
0010 38EE C644  30         mov   tmp0,*stack            ; Push tmp0
0011 38F0 C120  34         mov   @tv.task.oneshot,tmp0  ; Get pointer to one-shot task
     38F2 A22C     
0012 38F4 1301  14         jeq   task.oneshot.exit
0013 38F6 0694  24         bl    *tmp0                  ; Execute one-shot task
0014                       ;------------------------------------------------------
0015                       ; Exit
0016                       ;------------------------------------------------------
0017               task.oneshot.exit:
0018 38F8 C139  30         mov   *stack+,tmp0           ; Pop tmp0
0019 38FA 0460  28         b     @slotok                ; Exit task
     38FC 2F98     
                   < ram.resident.asm
