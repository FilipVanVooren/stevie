     600A 228E     
0022 600C 37E0                   data >37e0            ; | p0  = Start address
0023 600E 0000                   data 00               ; | p1  = Byte to fill
0024 6010 0820                   data 2080             ; / p2  = Number of bytes to fill
0025               
0026 6012 06A0  32         bl    @cpym2v               ; \ Copy CPU memory to VDP memory
     6014 24E6     
0027 6016 37D8                   data >37d8            ; | p0 = VDP target address
0028 6018 6034                   data file.vmem.37d8   ; | p1 = CPU source address
0029 601A 0006                   data 6                ; / p2 = Number of bytes to copy
0030               
0031 601C 06A0  32         bl    @cpym2v               ; \ Copy CPU memory to VDP memory
     601E 24E6     
0032 6020 3EE6                   data >3ee6            ; | p0 = VDP target address
0033 6022 603C                   data file.vmem.part1  ; | p1 = CPU source address
0034 6024 0006                   data 6                ; / p2 = Number of bytes to copy
0035               
0036 6026 06A0  32         bl    @cpym2v               ; \ Copy CPU memory to VDP memory
     6028 24E6     
0037 602A 3F06                   data >3f06            ; | p0 = VDP target address
0038 602C 6042                   data file.vmem.part2  ; | p1 = CPU source address
0039 602E 0002                   data 2                ; / p2 = Number of bytes to copy
