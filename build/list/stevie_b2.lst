0085               
0086               ***************************************************************
0087               * bl @_idx.sams.mapcolumn.on
0088               *--------------------------------------------------------------
0089               * Register usage
0090               * tmp0,tmp1,tmp2
0091               *--------------------------------------------------------------
0092               *  Remarks
0093               *  Private, only to be called from inside idx module
0094               ********|*****|*********************|**************************
0095               _idx.sams.mapcolumn.on:
0096 32A2 0649  14         dect  stack
0097 32A4 C64B  30         mov   r11,*stack            ; Push return address
0098 32A6 0649  14         dect  stack
0099 32A8 C644  30         mov   tmp0,*stack           ; Push tmp0
0100 32AA 0649  14         dect  stack
0101 32AC C645  30         mov   tmp1,*stack           ; Push tmp1
0102 32AE 0649  14         dect  stack
0103 32B0 C646  30         mov   tmp2,*stack           ; Push tmp2
