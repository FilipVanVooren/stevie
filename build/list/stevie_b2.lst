0009 3746 CE46  34         mov   tmp2,*stack+          ; Push tmp2
0012 3748 CE45  34         mov   tmp1,*stack+          ; Push tmp1
0015 374A CE44  34         mov   tmp0,*stack+          ; Push tmp0
