0099 60E8 0284  22         ci    tmp0,>6000            ; Insane address ?
     60EA 6000     
0100 60EC 110D  14         jlt   fh.file.read.mem.crsh ; Yes, crash!
0101 60EE 0284  22         ci    tmp0,>7fff            ; Insane address ?
