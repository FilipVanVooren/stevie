0133                       ; Copy PAB header to VDP
0134                       ;------------------------------------------------------
0135               fh.file.read.mem.pabheader:
0136 611C 0204  20         li    tmp0,fh.vpab          ; VDP destination
     611E 2580     
0137 6120 C160  34         mov   @fh.pabtpl.ptr,tmp1   ; PAB header source address
     6122 A466     
0138 6124 0206  20         li    tmp2,9                ; 9 bytes to copy
     6126 0009     
0139               
0140 6128 06A0  32         bl    @xpym2v               ; Copy CPU memory to VDP memory
     612A 24EC     
0141                                                   ; \ i  tmp0 = VDP destination
0142                                                   ; | i  tmp1 = CPU source
0143                                                   ; / i  tmp2 = Number of bytes to copy
0144                       ;------------------------------------------------------
0145                       ; Append file descriptor to PAB header in VDP
0146                       ;------------------------------------------------------
0147 612C 0204  20         li    tmp0,fh.vpab + 9      ; VDP destination
     612E 2589     
0148 6130 C160  34         mov   @fh.fname.ptr,tmp1    ; Get pointer to file descriptor
     6132 A444     
0149 6134 D195  26         movb  *tmp1,tmp2            ; Get file descriptor length
0150 6136 0986  32         srl   tmp2,8                ; Right justify
0151 6138 0586  14         inc   tmp2                  ; Include length byte as well
0152               
0153 613A 06A0  32         bl    @xpym2v               ; Copy CPU memory to VDP memory
     613C 24EC     
0154                                                   ; \ i  tmp0 = VDP destination
0155                                                   ; | i  tmp1 = CPU source
0156                                                   ; / i  tmp2 = Number of bytes to copy
