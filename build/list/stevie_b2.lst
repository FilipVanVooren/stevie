     77EE FFF6     
0006 77F0 CE47  34         mov   tmp3,*stack+          ; Push tmp3
0009 77F2 CE46  34         mov   tmp2,*stack+          ; Push tmp2
0012 77F4 CE45  34         mov   tmp1,*stack+          ; Push tmp1
0015 77F6 CE44  34         mov   tmp0,*stack+          ; Push tmp0
0017 77F8 C64B  30         mov   r11,*stack            ; Push return address
0018 77FA 0229  22         ai    stack,-(3 * 2 + 2)   ; Set stack pointer back to original position
     77FC FFF8     
                   < fm.browse.updir.asm
0022                       ;------------------------------------------------------
0023                       ; Get device name/path
0024                       ;------------------------------------------------------
0025 77FE 04E0  34         clr   @outparm1             ; Clear success flag
     7800 A018     
0026 7802 D120  34         movb  @tv.devpath,tmp0      ; Get length current device name/path
     7804 A294     
0027 7806 0984  32         srl   tmp0,8                ; MSB to LSB
0028 7808 C144  18         mov   tmp0,tmp1             ; Save length
0029 780A 0225  22         ai    tmp1,tv.devpath       ; Point to last character
     780C A294     
0030 780E C184  18         mov   tmp0,tmp2             ; Set counter
0031 7810 04C7  14         clr   tmp3                  ; Clear dot count
0032 7812 0204  20         li    tmp0,>2e00            ; Dot '.' character in MSB
     7814 2E00     
0033                       ;------------------------------------------------------
0034                       ; Count dots in device path
0035                       ;------------------------------------------------------
0036               fm.browse.updir.loop1:
0037 7816 9115  26         cb    *tmp1,tmp0            ; Is it a dot?
0038 7818 1606  14         jne   fm.browse.updir.loop1.cont
0039                                                   ; No match, continue loop
0040 781A 0587  14         inc   tmp3                  ; Match. Increment dot count
0041 781C 0287  22         ci    tmp3,2                ; 2nd dot encountered?
     781E 0002     
0042 7820 1602  14         jne   fm.browse.updir.loop1.cont
0043                                                   ; No. Continue loop
0044 7822 C805  38         mov   tmp1,@cat.var1        ; Yes. Save position of 2nd dot
     7824 E286     
0045               fm.browse.updir.loop1.cont:
0046 7826 0605  14         dec   tmp1                  ; Move to previous character
0047 7828 0606  14         dec   tmp2                  ; Decrement counter
0048 782A 15F5  14         jgt   fm.browse.updir.loop1 ; Previous character
0049                       ;------------------------------------------------------
0050                       ; Exit early if at root or not subdirectory on device
0051                       ;------------------------------------------------------
0052 782C 0287  22         ci    tmp3,2                ; More than one dot?
     782E 0002     
0053 7830 1115  14         jlt   fm.browse.updir.exit  ; No. Exit early
0054                       ;------------------------------------------------------
0055                       ; Remove last part of device name/path
0056                       ;------------------------------------------------------
0057 7832 C160  34         mov   @cat.var1,tmp1        ; Get position of 2nd dot
     7834 E286     
0058 7836 0225  22         ai    tmp1,-tv.devpath      ; Calculate length of device name/path
     7838 5D6C     
0059 783A C805  38         mov   tmp1,@cat.var2        ; Backup length of device name/path
     783C E288     
0060 783E 0A85  32         sla   tmp1,8                ; LSB to MSB
0061 7840 D805  38         movb  tmp1,@tv.devpath      ; Set new length
     7842 A294     
