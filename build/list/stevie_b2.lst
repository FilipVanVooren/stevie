0067 784C 0584  14         inc   tmp0                  ; Skip 2nd dot
0068 784E 04C5  14         clr   tmp1                  ; Fill with nulls
0069 7850 0206  20         li    tmp2,80
     7852 0050     
0070 7854 61A0  34         s     @cat.var2,tmp2        ; Limit to 80 characters
     7856 E288     
0071               
0072 7858 06A0  32         bl    @xfilm                ; \ Fill memory
     785A 223C     
