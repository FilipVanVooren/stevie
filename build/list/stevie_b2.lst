0001               * FILE......: tv.uint16.pack.asm
0002               * Purpose...: Pack string to 16bit unsigned integer
0003               
0004               ***************************************************************
0005               * tv.uint16.pack
0006               * Pack (number) string to 16bit unsigned integer
0007               ***************************************************************
0008               * bl @tv.uint16.pack
0009               *--------------------------------------------------------------
0010               * INPUT
0011               * @parm1 = Pointer to input string (no length-byte prefix!)
0012               *--------------------------------------------------------------
0013               * OUTPUT
0014               * @outparm1 = 16bit unsigned integer
0015               * @outparm2 = 0 conversion ok, >FFFF invalid input
0016               *--------------------------------------------------------------
0017               * REMARK
0018               * None
0019               *--------------------------------------------------------------
0020               * Register usage
0021               * tmp0,tmp1,tmp2,tmp3,r0,r1
0022               ***************************************************************
0023               tv.uint16.pack:
0024                       .pushregs 3                 ; Push return address and registers on stack
     **** ****     > PUSHREGS
0001 34B4 0229  22         ai    stack,-(3 * 2 + 4)   ; Make room on stack for registers
     34B6 FFF6     
0006 34B8 CE47  34         mov   tmp3,*stack+          ; Push tmp3
0009 34BA CE46  34         mov   tmp2,*stack+          ; Push tmp2
0012 34BC CE45  34         mov   tmp1,*stack+          ; Push tmp1
0015 34BE CE44  34         mov   tmp0,*stack+          ; Push tmp0
0017 34C0 C64B  30         mov   r11,*stack            ; Push return address
0018 34C2 0229  22         ai    stack,-(3 * 2 + 2)   ; Set stack pointer back to original position
     34C4 FFF8     
                   < tv.uint16.pack.asm
0025 34C6 0649  14         dect  stack
0026 34C8 C640  30         mov   r0,*stack             ; Push r0
0027 34CA 0649  14         dect  stack
0028 34CC C641  30         mov   r1,*stack             ; Push r1
0029                       ;------------------------------------------------------
0030                       ; Initialisation
0031                       ;------------------------------------------------------
0032 34CE C120  34         mov   @parm1,tmp0           ; Pointer to input string
     34D0 A016     
0033 34D2 04C5  14         clr   tmp1                  ; Termination character >00
0034 34D4 04E0  34         clr   @outparm1             ; Reset output parameters
     34D6 A018     
0035 34D8 04E0  34         clr   @outparm2             ; Reset output parameters
     34DA A01A     
0036                       ;------------------------------------------------------
0037                       ; Get string length
0038                       ;------------------------------------------------------
0039 34DC 06A0  32         bl    @xstring.getlenc      ; Get length of C-style string
     34DE 2B64     
0040                                                   ; \ i  tmp0   = Pointer to C-style string
0041                                                   ; | i  tmp1   = Termination character
0042                                                   ; / o  @waux1 = Length of string
0043                       ;------------------------------------------------------
0044                       ; Assert
0045                       ;------------------------------------------------------
0046 34E0 C1A0  30         mov   @waux1,tmp2           ; Get string length
     34E2 833C     
0047 34E4 131F  14         jeq   tv.uint16.pack.error  ; No input string given
0048 34E6 0286  22         ci    tmp2,5                ; Maximum 5 digits ?
     34E8 0005     
0049 34EA 151C  14         jgt   tv.uint16.pack.error  ; Input string too long
0050                       ;------------------------------------------------------
0051                       ; Prepare register values
0052                       ;------------------------------------------------------
0053 34EC C120  34         mov   @parm1,tmp0           ; Pointer to input string
     34EE A016     
0054               
0055 34F0 A186  18         a     tmp2,tmp2             ; \ Starting offset in tv.uint16.mpy
0056 34F2 0226  22         ai    tmp2,-10              ; |    10 - (tmp2 * 2)
     34F4 FFF6     
0057 34F6 0746  18         abs   tmp2                  ; /
0058               
0059 34F8 04C7  14         clr   tmp3                  ; Clear final uint16
0060                       ;------------------------------------------------------
0061                       ; Get character
0062                       ;------------------------------------------------------
0063               tv.uint16.pack.loop:
0064 34FA D174  28         movb  *tmp0+,tmp1           ; Get character
0065 34FC 0985  32         srl   tmp1,8                ; MSB to LSB
0066                       ;------------------------------------------------------
0067                       ; Character is ASCII 0 or blank (ASCII 32) ?
0068                       ;------------------------------------------------------
0069 34FE 1318  14         jeq   tv.uint16.pack.exit   ; End of string reached
0070 3500 0285  22         ci    tmp1,32               ; Blank ?
     3502 0020     
0071 3504 1315  14         jeq   tv.uint16.pack.exit   ; End of string reached
0072                       ;------------------------------------------------------
0073                       ; Character in range 0..9 ?
0074                       ;------------------------------------------------------
0075 3506 0225  22         ai    tmp1,-48              ; Remove ASCII offset
     3508 FFD0     
0076 350A 110C  14         jlt   tv.uint16.pack.error  ; Invalid character, exit
0077 350C 0285  22         ci    tmp1,9
     350E 0009     
0078 3510 1509  14         jgt   tv.uint16.pack.error  ; Invalid character, exit
0079                       ;------------------------------------------------------
0080                       ; Get base 10 multiplier for digit
0081                       ;------------------------------------------------------
0082 3512 C026  34         mov   @tv.uint16.mpy(tmp2),r0
     3514 3540     
0083                       ;------------------------------------------------------
0084                       ; Convert number to decimal 10 (final result in tmp3)
0085                       ;------------------------------------------------------
0086 3516 3805  58         mpy   tmp1,r0               ; Multiply digit with r0, 32bit result is
0087                                                   ; in r0 and r1. We need r1 (LSW)
0088 3518 A1C1  18         a     r1,tmp3               ; Add base10 value to final uint16
0089                       ;------------------------------------------------------
0090                       ; Prepare for next digit
0091                       ;------------------------------------------------------
0092 351A 05C6  14         inct  tmp2                  ; Update loop counter
0093 351C 0286  22         ci    tmp2,8                ; Last digit done?
     351E 0008     
0094 3520 12EC  14         jle   tv.uint16.pack.loop   ; Next iteration
0095 3522 1004  14         jmp   tv.uint16.pack.done   ; Done packing uint16, exit
0096                       ;------------------------------------------------------
0097                       ; Invalid character, stop packing and exit
0098                       ;------------------------------------------------------
0099               tv.uint16.pack.error:
0100 3524 04E0  34         clr   @outparm1             ; Empty uint16
     3526 A018     
0101 3528 0720  34         seto  @outparm2             ; Invalid input string
     352A A01A     
0102                       ;-------------------------------------------------------
0103                       ; Save final uint16
0104                       ;-------------------------------------------------------
0105               tv.uint16.pack.done:
0106 352C C807  38         mov   tmp3,@outparm1
     352E A018     
0107                       ;-------------------------------------------------------
0108                       ; Exit
0109                       ;-------------------------------------------------------
0110               tv.uint16.pack.exit:
0111 3530 C079  30         mov   *stack+,r1            ; Pop r1
0112 3532 C039  30         mov   *stack+,r0            ; Pop r0
0113                       .popregs 3                  ; Pop registers and return to caller
     **** ****     > POPREGS
0005 3534 C1F9  30         mov   *stack+,tmp3          ; Pop tmp3
0008 3536 C1B9  30         mov   *stack+,tmp2          ; Pop tmp2
0011 3538 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 353A C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 353C C2F9  30         mov   *stack+,r11           ; Pop r11
0017 353E 045B  20         b     *r11                  ; Return
