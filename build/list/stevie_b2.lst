0211 72FC C187  18         mov   tmp3,tmp2             ; / Move LSW to MSW
0212 72FE 0605  14         dec   tmp1                  ; Decrement exponent
0213 7300 15FA  14         jgt   fm.dir.callback2.volsize.radix100.part1
0214                                                   ; Next iteration if exponent > 0
