0133                                                   ; / o  outparm1 = Slot offset in SAMS page
0134               
0135 3782 C120  34         mov   @outparm1,tmp0        ; Index offset
     3784 A018     
0136               
0137 3786 06A0  32         bl    @_idx.entry.insert.reorg
     3788 3702     
