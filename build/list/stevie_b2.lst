0003               
0004               
0005               ***************************************************************
0006               * KTHREAD - The kernel thread
0007               *--------------------------------------------------------------
0008               *  REMARKS
0009               *  You should not call the kernel thread manually.
0010               *  Instead control it via the CONFIG register.
0011               *
0012               *  The kernel thread is responsible for running the sound
0013               *  player and doing keyboard scan.
0014               ********|*****|*********************|**************************
0015 2FB6 E0A0  42 kthread soc   @wbit8,config         ; Block kernel thread
     2FB8 2010     
0016               *--------------------------------------------------------------
0017               * Run sound player
0018               *--------------------------------------------------------------
0022 2FBA 20A0  38         coc   @wbit13,config        ; Sound player on ?
     2FBC 2006     
0023 2FBE 1602  14         jne   kthread_kb
0024 2FC0 06A0  36         bl    @sdpla1               ; Run sound player
     2FC2 28E6     
0026               *--------------------------------------------------------------
0027               * Scan virtual keyboard
0028               *--------------------------------------------------------------
0029               kthread_kb
0031               *       <<skipped>>
0035               *--------------------------------------------------------------
0036               * Scan real keyboard
0037               *--------------------------------------------------------------
0042 2FC4 06A0  36         bl    @rkscan               ; Scan full keyboard with ROM#0 KSCAN
     2FC6 2966     
0047               *--------------------------------------------------------------
0048               kthread_exit
0049 2FC8 0460  28         b     @tmgr3                ; Exit
     2FCA 2F40     
