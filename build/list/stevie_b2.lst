0290               ***************************************************************
0291               * _file.record.fop - File operation
0292               ***************************************************************
0293               * Called internally via JMP/B by file operations
0294               *--------------------------------------------------------------
0295               *  Input:
0296               *  r0   = Address of PAB in VDP RAM
0297               *  r1   = File type/mode
0298               *  tmp1 = File operation opcode
0299               *
0300               *  @fh.offsetopcode = >00  Data buffer in VDP RAM
0301               *  @fh.offsetopcode = >40  Data buffer in CPU RAM
0302               *--------------------------------------------------------------
0303               *  Output:
0304               *  tmp0     = Copy of VDP PAB byte 1 after operation
0305               *  tmp1 LSB = Copy of VDP PAB byte 5 after operation
0306               *  tmp2 LSB = Copy of status register after operation
0307               *--------------------------------------------------------------
0308               *  Register usage:
0309               *  r0, r1, tmp0, tmp1, tmp2
0310               *--------------------------------------------------------------
0311               *  Remarks
0312               *  Private, only to be called from inside fio_level3 module
0313               *  via jump or branch instruction.
0314               *
0315               *  Uses @waux1 for backup/restore of memory word @>8322
0316               ********|*****|*********************|**************************
0317               _file.record.fop:
0318                       ;------------------------------------------------------
0319                       ; Write to PAB required?
0320                       ;------------------------------------------------------
0321 2E82 C800  42         mov   r0,@fh.pab.ptr        ; Backup of pointer to current VDP PAB
     2E84 A436     
0322                       ;------------------------------------------------------
0323                       ; Set file opcode in VDP PAB
0324                       ;------------------------------------------------------
0325 2E86 C100  30         mov   r0,tmp0               ; VDP write address (PAB byte 0)
0326               
0327 2E88 A160  42         a     @fh.offsetopcode,tmp1 ; Inject offset for file I/O opcode
     2E8A A44E     
0328                                                   ; >00 = Data buffer in VDP RAM
0329                                                   ; >40 = Data buffer in CPU RAM
0330               
0331 2E8C 06A0  36         bl    @xvputb               ; Write file I/O opcode to VDP
     2E8E 22CC     
0332                                                   ; \ i  tmp0 = VDP target address
0333                                                   ; / i  tmp1 = Byte to write
0334                       ;------------------------------------------------------
0335                       ; Set file type/mode in VDP PAB
0336                       ;------------------------------------------------------
0337 2E90 C100  30         mov   r0,tmp0               ; VDP write address (PAB byte 0)
0338 2E92 0584  22         inc   tmp0                  ; Next byte in PAB
0339 2E94 C160  42         mov   @fh.filetype,tmp1     ; Get file type/mode
     2E96 A44C     
0340               
0341 2E98 06A0  36         bl    @xvputb               ; Write file type/mode to VDP
     2E9A 22CC     
0342                                                   ; \ i  tmp0 = VDP target address
0343                                                   ; / i  tmp1 = Byte to write
0344                       ;------------------------------------------------------
0345                       ; Prepare for DSRLNK
0346                       ;------------------------------------------------------
0347 2E9C 0220  30 !       ai    r0,9                  ; Move to file descriptor length
     2E9E 0009     
0348 2EA0 C800  34         mov   r0,@>8356             ; Pass file descriptor to DSRLNK
     2EA2 8356     
0349               *--------------------------------------------------------------
0350               * Call DSRLINK for doing file operation
0351               *--------------------------------------------------------------
0352 2EA4 C820  42         mov   @>8322,@waux1         ; Save word at @>8322
     2EA6 8322     
     2EA8 833C     
0353               
0354 2EAA C120  42         mov   @dsrlnk.savcru,tmp0   ; Call optimized or standard version?
     2EAC A42A     
0355 2EAE 1504  14         jgt   _file.record.fop.optimized
0356                                                   ; Optimized version
0357               
0358                       ;------------------------------------------------------
0359                       ; First IO call. Call standard DSRLNK
0360                       ;------------------------------------------------------
0361 2EB0 0420  62         blwp  @dsrlnk               ; Call DSRLNK
     2EB2 2C4A     
0362 2EB4 0008                   data >8               ; \ i  p0 = >8 (DSR)
0363                                                   ; / o  r0 = Copy of VDP PAB byte 1
0364 2EB6 1002  14         jmp  _file.record.fop.pab   ; Return PAB to caller
0365               
0366                       ;------------------------------------------------------
0367                       ; Recurring IO call. Call optimized DSRLNK
0368                       ;------------------------------------------------------
0369               _file.record.fop.optimized:
0370 2EB8 0420  62         blwp  @dsrlnk.reuse         ; Call DSRLNK
     2EBA 2D7A     
0371               
0372               *--------------------------------------------------------------
0373               * Return PAB details to caller
0374               *--------------------------------------------------------------
0375               _file.record.fop.pab:
0376 2EBC 02C6  12         stst  tmp2                  ; Store status register contents in tmp2
0377                                                   ; Upon DSRLNK return status register EQ bit
0378                                                   ; 1 = No file error
0379                                                   ; 0 = File error occured
0380               
0381 2EBE C820  42         mov   @waux1,@>8322         ; Restore word at @>8322
     2EC0 833C     
     2EC2 8322     
0382               *--------------------------------------------------------------
0383               * Get PAB byte 5 from VDP ram into tmp1 (character count)
0384               *--------------------------------------------------------------
0385 2EC4 C120  42         mov   @fh.pab.ptr,tmp0      ; Get VDP address of current PAB
     2EC6 A436     
0386 2EC8 0224  30         ai    tmp0,5                ; Get address of VDP PAB byte 5
     2ECA 0005     
0387 2ECC 06A0  36         bl    @xvgetb               ; VDP read PAB status byte into tmp0
     2ECE 22E4     
0388 2ED0 C144  30         mov   tmp0,tmp1             ; Move to destination
0389               *--------------------------------------------------------------
0390               * Get PAB byte 1 from VDP ram into tmp0 (status)
0391               *--------------------------------------------------------------
0392 2ED2 C100  30         mov   r0,tmp0               ; VDP PAB byte 1 (status)
0393                                                   ; as returned by DSRLNK
0394               *--------------------------------------------------------------
0395               * Exit
0396               *--------------------------------------------------------------
0397               ; If an error occured during the IO operation, then the
0398               ; equal bit in the saved status register (=tmp2) is set to 1.
0399               ;
0400               ; Upon return from this IO call you should basically test with:
0401               ;       coc   @wbit2,tmp2           ; Equal bit set?
0402               ;       jeq   my_file_io_handler    ; Yes, IO error occured
0403               ;
0404               ; Then look for further details in the copy of VDP PAB byte 1
0405               ; in register tmp0, bits 13-15
0406               ;
0407               ;       srl   tmp0,8                ; Right align (only for DSR type >8
0408               ;                                   ; calls, skip for type >A subprograms!)
0409               ;       ci    tmp0,io.err.<code>    ; Check for error pattern
0410               ;       jeq   my_error_handler
0411               *--------------------------------------------------------------
0412               _file.record.fop.exit:
0413 2ED4 C2F9  46         mov   *stack+,r11           ; Pop R11
0414 2ED6 045B  24         b     *r11                  ; Return to caller
                   < runlib.asm
