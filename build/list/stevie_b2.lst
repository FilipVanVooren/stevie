0011 32CE C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 32D0 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 32D2 C2F9  30         mov   *stack+,r11           ; Pop r11
0017 32D4 045B  20         b     *r11                  ; Return
                   < idx.asm
