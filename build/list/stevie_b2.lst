     **** ****     > edb.hipage.alloc.asm
0001               * FILE......: edb.hipage.alloc.asm
0002               * Purpose...: Editor buffer utilities
0003               
0004               
0005               ***************************************************************
0006               * edb.hipage.alloc
0007               * Check and increase highest SAMS page of editor buffer
0008               ***************************************************************
0009               *  bl   @edb.hipage.alloc
0010               *--------------------------------------------------------------
0011               * INPUT
0012               * @edb.next_free.ptr = Pointer to next free line
0013               *--------------------------------------------------------------
0014               * OUTPUT
0015               *--------------------------------------------------------------
0016               * Register usage
0017               * tmp0,tmp1
0018               ********|*****|*********************|**************************
0019               edb.hipage.alloc:
0020                       .pushregs 1                 ; Push return address and registers on stack
     **** ****     > PUSHREGS
0001 3850 0229  22         ai    stack,-(1 * 2 + 4)   ; Make room on stack for registers
     3852 FFFA     
0012 3854 CE45  34         mov   tmp1,*stack+          ; Push tmp1
0015 3856 CE44  34         mov   tmp0,*stack+          ; Push tmp0
0017 3858 C64B  30         mov   r11,*stack            ; Push return address
0018 385A 0229  22         ai    stack,-(1 * 2 + 2)   ; Set stack pointer back to original position
     385C FFFC     
                   < edb.hipage.alloc.asm
0021                       ;------------------------------------------------------
0022                       ; 1a. Check if highest SAMS page needs to be increased
0023                       ;------------------------------------------------------
0024               edb.hipage.alloc.check_setpage:
0025 385E C120  34         mov   @edb.next_free.ptr,tmp0
     3860 A508     
0026                                                   ;--------------------------
0027                                                   ; Check for page overflow
0028                                                   ;--------------------------
0029 3862 0244  22         andi  tmp0,>0fff            ; Get rid of highest nibble
     3864 0FFF     
0030 3866 0224  22         ai    tmp0,82               ; Assume line of 80 chars (+2 bytes prefix)
     3868 0052     
0031 386A 0284  22         ci    tmp0,>1000 - 16       ; 4K boundary reached?
     386C 0FF0     
0032 386E 1105  14         jlt   edb.hipage.alloc.setpage
0033                                                   ; Not yet, don't increase SAMS page
0034                       ;------------------------------------------------------
0035                       ; 1b. Increase highest SAMS page (copy-on-write!)
0036                       ;------------------------------------------------------
0037 3870 05A0  34         inc   @edb.sams.hipage      ; Set highest SAMS page
     3872 A51C     
0038 3874 C820  54         mov   @edb.top.ptr,@edb.next_free.ptr
     3876 A500     
     3878 A508     
0039                                                   ; Start at top of SAMS page again
0040                       ;------------------------------------------------------
0041                       ; 1c. Switch to SAMS page and exit
0042                       ;------------------------------------------------------
0043               edb.hipage.alloc.setpage:
0044 387A C120  34         mov   @edb.sams.hipage,tmp0
     387C A51C     
0045 387E C160  34         mov   @edb.top.ptr,tmp1
     3880 A500     
0046 3882 06A0  32         bl    @xsams.page.set       ; Set SAMS page
     3884 25D6     
0047                                                   ; \ i  tmp0 = SAMS page number
0048                                                   ; / i  tmp1 = Memory address
0049               
0050 3886 1004  14         jmp   edb.hipage.alloc.exit
0051                       ;------------------------------------------------------
0052                       ; Check failed, crash CPU!
0053                       ;------------------------------------------------------
0054               edb.hipage.alloc.crash:
0055 3888 C80B  38         mov   r11,@>ffce            ; \ Save caller address
     388A FFCE     
0056 388C 06A0  32         bl    @cpu.crash            ; / Crash and halt system
     388E 2026     
0057                       ;------------------------------------------------------
0058                       ; Exit
0059                       ;------------------------------------------------------
0060               edb.hipage.alloc.exit:
0061                       .popregs 1                  ; Pop registers and return to caller
     **** ****     > POPREGS
0011 3890 C179  30         mov   *stack+,tmp1          ; Pop tmp1
0014 3892 C139  30         mov   *stack+,tmp0          ; Pop tmp0
0016 3894 C2F9  30         mov   *stack+,r11           ; Pop r11
0017 3896 045B  20         b     *r11                  ; Return
