0001               * FILE......: data.pab.tpl.asm
0002               * Purpose...: PAB templates for accessing files
0003               
0004               
0005               ***************************************************************
0006               * PAB for accessing catalog file
0007               ********|*****|*********************|**************************
0008                       even                        ; Must always start on even address!!
0009               fh.file.pab.header.cat:
0010 7D2A 00               byte  io.op.open            ;  0    - OPEN
0011 7D2B   0D             byte  io.rel.inp.int.fix    ;  1    - INPUT, RELATIVE, INTERNAL, FIXED
0012 7D2C 2620             data  fh.vrecbuf            ;  2-3  - Record buffer in VDP memory
0013 7D2E 26               byte  38                    ;  4    - Record length (unset, DSR control)
0014 7D2F   00             byte  00                    ;  5    - Character count
0015 7D30 0000             data  >0000                 ;  6-7  - Seek record (only for fixed recs)
0016 7D32 00               byte  >00                   ;  8    - Screen offset (cassette DSR only)
0017                       ;------------------------------------------------------
0018                       ; Filename descriptor part (variable length)
0019                       ;------------------------------------------------------
0020                       ; byte  12                  ;  9    - File descriptor length
0021                       ; text 'DSK3.XBEADOC'       ; 10-.. - File descriptor
0022                                                   ;         (Device + '.' + File name)
0023               
0024               ***************************************************************
0025               * PAB for accessing DV80 file
0026               ********|*****|*********************|**************************
0027                       even                        ; Must always start on even address!!
0028               fh.file.pab.header:
0029 7D34 00               byte  io.op.open            ;  0    - OPEN
0030 7D35   14             byte  io.seq.inp.dis.var    ;  1    - INPUT, VARIABLE, DISPLAY
0031 7D36 2620             data  fh.vrecbuf            ;  2-3  - Record buffer in VDP memory
0032 7D38 50               byte  80                    ;  4    - Record length (80 chars max)
0033 7D39   00             byte  00                    ;  5    - Character count
0034 7D3A 0000             data  >0000                 ;  6-7  - Seek record (only for fixed recs)
0035 7D3C 00               byte  >00                   ;  8    - Screen offset (cassette DSR only)
0036                       ;------------------------------------------------------
0037                       ; File descriptor part (variable length)
0038                       ;------------------------------------------------------
0039                       ; byte  64                  ;  9    - File descriptor length
0040                       ; text 'DSK3.XBEADOC'       ; 10-.. - File descriptor
0041                                                   ;         (Device + '.' + File name)
0042               
0043               ***************************************************************
0044               * PAB for accessing clock file
0045               ********|*****|*********************|**************************
0046                       even                        ; Must always start on even address!!
0047               fh.file.pab.clock:
0048 7D3E 00               byte  io.op.open            ;  0    - OPEN
0049 7D3F   14             byte  io.seq.inp.dis.var    ;  1    - INPUT, VARIABLE, DISPLAY
0050 7D40 2620             data  fh.vrecbuf            ;  2-3  - Record buffer in VDP memory
0051 7D42 00               byte  0                     ;  4    - Record length (let it figure out)
0052 7D43   00             byte  00                    ;  5    - Character count
0053 7D44 0000             data  >0000                 ;  6-7  - Seek record (only for fixed recs)
0054 7D46 00               byte  >00                   ;  8    - Screen offset (cassette DSR only)
0055                       ;------------------------------------------------------
0056                       ; File descriptor part (variable length)
0057                       ;------------------------------------------------------
0058                       ; byte  64                  ;  9    - File descriptor length
0059                       ; text 'DSK3.XBEADOC'       ; 10-.. - File descriptor
0060                                                   ;         (Device + '.' + File name)
0061               
0062               ***************************************************************
0063               * PAB for loading binary image
0064               ********|*****|*********************|**************************
0065                       even                        ; Must always start on even address!!
0066               fh.file.pab.header.binimage:
0067 7D48 05               byte  io.op.load            ;  0    - LOAD BINARY
0068 7D49   00             byte  00                    ;  1    - Not used
0069 7D4A 2000             data  fh.filebuf            ;  2-3  - Buffer location in VDP memory
0070 7D4C 0000             data  >0000                 ;  4-5  - Not used in load operation
0071 7D4E 2006             data  8198                  ;  6-7  - Maximum number of bytes to load
0072 7D50 00               byte  00                    ;  8    - Not used
0073                       ;------------------------------------------------------
0074                       ; File descriptor part (variable length)
0075                       ;------------------------------------------------------
0076                       ; byte  64                  ;  9    - File descriptor length
0077                       ; text 'DSK3.XBEADOC'       ; 10-.. - File descriptor
0078                                                   ;         (Device + '.' + File name)
0079               
0080               ***************************************************************
0081               * PAB for deleting file
0082               ********|*****|*********************|**************************
0083                       even                        ; Must always start on even address!!
0084               fh.file.pab.header.delete:
0085 7D52 07               byte  io.op.delete          ;  0    - DELETE
0086 7D53   00             byte  00                    ;  1    - Not used
0087 7D54 2000             data  fh.filebuf            ;  2-3  - Buffer location in VDP memory
0088 7D56 0000             data  >0000                 ;  4-5  - Not used
0089 7D58 0000             data  0                     ;  6-7  - Not used
0090 7D5A 00               byte  0                     ;  8    - Not used
0091                       ;------------------------------------------------------
0092                       ; File descriptor part (variable length)
0093                       ;------------------------------------------------------
0094                       ; byte  64                  ;  9    - File descriptor length
0095                       ; text 'DSK3.XBEADOC'       ; 10-.. - File descriptor
0096                                                   ;         (Device + '.' + File name)
